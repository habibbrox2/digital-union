# ============================================
# Complete Environment Configuration File
# ============================================
# Copy this file to .env and update with your actual values
# This file contains ALL application configuration
# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name
DB_CHARSET=utf8mb4

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_ENV=production
APP_DEBUG=true
APP_URL=https://yourdomain.com
APP_NAME="lgDhaka"
APP_LOCALE=bn_BD
APP_TIMEZONE=Asia/Dhaka
DEPLOY_TOKEN=your_deploy_token
# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_TIMEOUT=1800
SESSION_COOKIE_NAME=PHPSESSID
SESSION_COOKIE_PATH=/
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ============================================
# CSRF PROTECTION
# ============================================
CSRF_TOKEN_TIMEOUT=3600
CSRF_VALIDATION_ENABLED=true

# ============================================
# SMTP EMAIL CONFIGURATION
# ============================================

# Email sending driver: 'smtp', 'gmail', 'sendmail'
MAIL_DRIVER=smtp

# SMTP Host (for sending emails)
SMTP_HOST=smtp.gmail.com

# SMTP Port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP Encryption: 'tls' or 'ssl'
SMTP_ENCRYPTION=tls

# SMTP Username (usually your email address)
SMTP_USERNAME=your_email@example.com

# SMTP Password (for Gmail, use App Password from https://myaccount.google.com/apppasswords)
SMTP_PASSWORD=your_email_password

# From Address (should match SMTP_USERNAME or be a valid sender)
MAIL_FROM_ADDRESS=your_email@example.com

# From Name (display name for sender)
MAIL_FROM_NAME="lgDhaka"

# ============================================
# EMAIL FEATURE FLAGS
# ============================================

# Send welcome email on registration
SEND_WELCOME_EMAIL=true

# Send email verification (requires email_verifications table)
SEND_EMAIL_VERIFICATION=false

# Send password change alert
SEND_PASSWORD_CHANGE_ALERT=true

# Send failed login alert (after 3+ attempts)
SEND_FAILED_LOGIN_ALERT=true

# Send new device login alert
SEND_LOGIN_ALERT=false

# ============================================
# EMAIL TOKEN EXPIRY TIMES (in seconds)
# ============================================

# Password reset token expiry time
PASSWORD_RESET_EXPIRY=3600

# Email verification token expiry time
EMAIL_VERIFICATION_EXPIRY=86400

# ============================================
# EMAIL LOGGING CONFIGURATION
# ============================================

# Enable email logging
EMAIL_LOG_ENABLED=true

# Email log directory
EMAIL_LOG_DIR=storage/logs/email

# Email debug mode (log detailed SMTP info)
EMAIL_DEBUG=false

# ============================================
# EMAIL RETRY CONFIGURATION
# ============================================

# Maximum retry attempts for failed emails
EMAIL_MAX_RETRIES=3

# Delay between retry attempts (in seconds)
EMAIL_RETRY_DELAY=300

# ============================================
# SECURITY SETTINGS
# ============================================

# Password hashing algorithm
PASSWORD_ALGORITHM=bcrypt

# Password hashing cost (4-31, higher = slower but more secure)
PASSWORD_HASH_COST=10

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=info

# Log location
LOG_DIR=storage/logs

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Maximum file upload size (in bytes)
MAX_UPLOAD_SIZE=10485760

# Allowed file extensions
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# Upload directory
UPLOAD_DIR=public/uploads

# ============================================
# CACHE CONFIGURATION
# ============================================

# Cache driver: file, array, redis
CACHE_DRIVER=file

# Cache TTL (in seconds)
CACHE_TTL=3600

# ============================================
# AUTHENTICATION SETTINGS
# ============================================

# Failed login attempt limit (before lockout)
LOGIN_ATTEMPT_LIMIT=5

# Failed login lockout duration (in seconds)
LOGIN_LOCKOUT_DURATION=900

# Session activity timeout (in seconds)
ACTIVITY_TIMEOUT=1800

# ============================================
# RATE LIMITING
# ============================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Request limit per minute
RATE_LIMIT_REQUESTS=60

# Rate limit window (in seconds)
RATE_LIMIT_WINDOW=60

# ============================================
# PDF & IMAGE GENERATION
# ============================================

# PDF generation driver: mpdf, tcpdf
PDF_DRIVER=mpdf

# PDF page size
PDF_PAGE_SIZE=A4

# PDF orientation: P (portrait), L (landscape)
PDF_ORIENTATION=P

# Barcode format: CODE128, CODE39, EAN13, etc.
BARCODE_FORMAT=CODE128

# QR code size
QR_CODE_SIZE=256

# ============================================
# LOCALIZATION SETTINGS
# ============================================

# Default language
DEFAULT_LANGUAGE=bn

# Supported languages (comma-separated)
SUPPORTED_LANGUAGES=bn,en

# ============================================
# GOOGLE RECAPTCHA (Optional)
# ============================================

# Enable reCAPTCHA
RECAPTCHA_ENABLED=false

# reCAPTCHA site key
RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# reCAPTCHA secret key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ============================================
# EXTERNAL API INTEGRATION (Optional)
# ============================================

# SMS Gateway API Key
SMS_API_KEY=your_sms_api_key

# SMS Gateway URL
SMS_GATEWAY_URL=https://api.sms-provider.com/send

# Twilio Account SID
TWILIO_ACCOUNT_SID=your_twilio_account_sid

# Twilio Auth Token
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ============================================
# BACKUP & MAINTENANCE
# ============================================

# Enable automatic backups
BACKUP_ENABLED=true

# Backup frequency: daily, weekly, monthly
BACKUP_FREQUENCY=daily

# Backup retention (days)
BACKUP_RETENTION=30

# ============================================
# DEVELOPMENT & DEBUGGING
# ============================================

# Show errors on screen (disable in production)
DISPLAY_ERRORS=true

# Error reporting level
ERROR_REPORTING=32767

# Enable query debugging
DEBUG_QUERIES=false

# Enable template debugging
DEBUG_TEMPLATES=false

# ============================================
# NOTES
# ============================================

# For Gmail SMTP:
# 1. Go to myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to myaccount.google.com/apppasswords
# 4. Select "Mail" and "Windows Computer"
# 5. Copy the 16-character password (remove spaces)
# 6. Set SMTP_PASSWORD to the 16-character password
# 7. Set SMTP_USERNAME to your Gmail address

# For SendGrid:
# 1. Create account at sendgrid.com
# 2. Go to Settings > API Keys
# 3. Create new API key
# 4. Set MAIL_DRIVER=sendgrid
# 5. Set SENDGRID_API_KEY to your API key

# For Custom SMTP:
# 1. Contact your hosting provider for SMTP details
# 2. Update SMTP_HOST, SMTP_PORT, SMTP_USERNAME, SMTP_PASSWORD
# 3. Test connection: php test_email.php

# DO NOT commit this file to version control
# Add .env to .gitignore

# ============================================
# ENCRYPTION CONFIGURATION
# ============================================

ENCRYPTION_KEY=your_encryption_key_here_base64_encoded
ENCRYPTION_METHOD=AES-256-CBC
{% extends 'layout.twig' %}

{% block title %}পারমিশন ব্যবস্থাপনা{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
{% include 'components/rbac_ui.twig' %}
<div class="container-fluid py-4">

    <div class="rbac-header">
        <div>
            <h4><i class="bi bi-key-fill text-primary me-2"></i>পারমিশন ব্যবস্থাপনা</h4>
            <div class="subtitle">ভূমিকাভিত্তিক অনুমতি পরিচালনা করুন</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="/permissions/add" class="btn btn-success rbac-btn shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> নতুন অনুমতি
            </a>
            <a href="/roles" class="btn btn-info rbac-btn">
                <i class="bi bi-people me-1"></i> ভূমিকা
            </a>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="rbac-card rbac-stat p-3 d-flex align-items-center gap-3">
                <div class="rbac-stat-icon rbac-badge-primary"><i class="bi bi-key"></i></div>
                <div>
                    <div class="text-muted small">মোট অনুমতি</div>
                    <div class="fs-4 fw-bold mb-0">{{ permissions|length }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rbac-card rbac-stat p-3 d-flex align-items-center gap-3">
                <div class="rbac-stat-icon rbac-badge-info"><i class="bi bi-box"></i></div>
                <div>
                    <div class="text-muted small">মডিউল</div>
                    <div class="fs-4 fw-bold mb-0">{{ modules|length }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rbac-card rbac-stat p-3 d-flex align-items-center gap-3">
                <div class="rbac-stat-icon rbac-badge-warning"><i class="bi bi-link-45deg"></i></div>
                <div>
                    <div class="text-muted small">অনুমতি নির্ধারণ</div>
                    <a href="/permissions/assign" class="fw-bold text-decoration-none">যান →</a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rbac-card rbac-stat p-3 d-flex align-items-center gap-3">
                <div class="rbac-stat-icon rbac-badge-success"><i class="bi bi-sliders"></i></div>
                <div>
                    <div class="text-muted small">উন্নত ব্যবস্থাপনা</div>
                    <a href="/manage-permissions" class="fw-bold text-decoration-none">যান →</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Permissions by module -->
    <div class="row">
        <div class="col-lg-12">
            {% if modules|length > 0 %}
                {% for module in modules %}
                    {% set perms = permissionsByModule[module] | default([]) %}
                    <div class="rbac-card mb-4">
                        <div class="d-flex align-items-center justify-content-between p-3 border-bottom">
                            <h5 class="mb-0 fw-bold">
                                <i class="bi bi-box text-secondary me-2"></i>{{ module|upper }}
                            </h5>
                            <span class="badge rounded-pill rbac-badge-primary">{{ perms|length }}টি অনুমতি</span>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 rbac-table">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 22%">অনুমতির নাম</th>
                                        <th style="width: 40%">বিবরণ</th>
                                        <th style="width: 15%; text-align: center;">তৈরি</th>
                                        <th style="width: 23%; text-align: center;">পদক্ষেপ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for perm in perms %}
                                        <tr>
                                            <td><strong class="text-primary">{{ perm.name }}</strong></td>
                                            <td><small class="text-muted">{{ perm.description | default('(বিবরণ নেই)', true) }}</small></td>
                                            <td class="text-center"><small class="text-muted">{{ perm.created_at | date('d-m-Y') }}</small></td>
                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <a href="/permissions/{{ perm.id }}/edit" class="btn btn-warning" title="সম্পাদনা" data-bs-toggle="tooltip">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <a href="/permissions/{{ perm.id }}/delete" class="btn btn-danger" title="মুছুন" data-bs-toggle="tooltip">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div class="rbac-card">
                    <div class="text-center py-5">
                        <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                        <h4 class="text-muted">কোনো অনুমতি পাওয়া যায়নি</h4>
                        <p class="text-muted mb-3">শুরু করতে প্রথম অনুমতিটি তৈরি করুন</p>
                        <a href="/permissions/add" class="btn btn-primary rbac-btn">
                            <i class="bi bi-plus-lg me-1"></i> নতুন অনুমতি
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
            new bootstrap.Tooltip(el);
        });
    }
});
</script>
{% endblock %}

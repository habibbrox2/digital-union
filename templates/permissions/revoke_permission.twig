{% extends "layout.twig" %}

{% block title %}পারমিশন প্রত্যাহার{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
{% include 'components/rbac_ui.twig' %}
<div class="container-fluid py-4">
    <div class="rbac-header">
        <div>
            <h4><i class="bi bi-ban text-danger me-2"></i>পারমিশন প্রত্যাহার</h4>
            <div class="subtitle">একটি ভূমিকা থেকে অনুমতি সম্পূর্ণভাবে সরিয়ে ফেলুন</div>
        </div>
        <a href="/permissions/assign" class="btn btn-outline-secondary rbac-btn">
            <i class="bi bi-arrow-left me-1"></i> অনুমতি নির্ধারণে ফিরুন
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="rbac-danger-card shadow-sm">
                <div class="card-header d-flex align-items-center p-3"
                     style="border-radius:16px 16px 0 0; background:#e74c3c; color:#fff;">
                    <i class="bi bi-exclamation-triangle me-2 fs-5"></i>
                    <h5 class="mb-0">নিশ্চিত করুন</h5>
                </div>

                <div class="p-4">
                    <div class="mb-4">
                        <div class="text-muted small text-uppercase fw-bold mb-2">ভূমিকা (Role)</div>
                        <div class="rbac-badge">
                            <i class="bi bi-person-shield me-2"></i>
                            <span class="fw-semibold">{{ role.role_name }}</span>
                        </div>
                        {% if role.description %}<small class="text-muted d-block mt-2">{{ role.description }}</small>{% endif %}
                    </div>

                    <div class="mb-4">
                        <div class="text-muted small text-uppercase fw-bold mb-2">প্রত্যাহার করার পারমিশন</div>
                        <div class="rbac-perm-card">
                            <div class="d-flex align-items-start">
                                <div class="rbac-perm-icon"><i class="bi bi-key"></i></div>
                                <div>
                                    <h6 class="mb-1 fw-semibold">{{ permission.name }}</h6>
                                    <p class="mb-0 text-muted small">{{ permission.description }}</p>
                                    <div class="mt-2"><span class="badge rounded-pill rbac-badge-light">{{ permission.module }}</span></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        <span><strong>সতর্কতা!</strong> এই কাজটি ফিরানো যাবে না। এই ভূমিকা বর্তমানে এই অনুমতি হারাবে।</span>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-danger rbac-btn" onclick="confirmRevoke()">
                            <i class="bi bi-trash3 me-1"></i> নিশ্চিত - প্রত্যাহার করুন
                        </button>
                        <a href="/permissions/assign" class="btn btn-outline-secondary rbac-btn">
                            <i class="bi bi-x-circle me-1"></i> বাতিল করুন
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<form id="revokeForm" action="/permissions/revoke/{{ role.role_id }}/{{ permission.id }}" method="POST" style="display: none;">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
</form>

<style>
.rbac-badge {
    display: inline-flex; align-items: center;
    background: #e8f4f8; color: #0c5460;
    padding: 0.6rem 1rem; border-radius: 12px; font-weight: 500;
    border-left: 4px solid #0c5460;
}
.rbac-perm-card {
    background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 12px; padding: 1rem;
}
.rbac-perm-icon {
    display: flex; align-items: center; justify-content: center;
    width: 46px; height: 46px; background: #008B8B; color: #fff;
    border-radius: 12px; margin-right: 0.9rem; flex-shrink: 0; font-size: 1.25rem;
}
.spin { animation: rbac-spin 1s linear infinite; }
@keyframes rbac-spin { from { transform: rotate(0); } to { transform: rotate(360deg); } }
</style>

<script>
function confirmRevoke() {
    const permissionName = '{{ permission.name }}';
    const roleName = '{{ role.role_name }}';
    Swal.fire({
        title: 'নিশ্চিত করুন',
        html: `<p>আপনি কি নিশ্চিত যে আপনি <strong>${roleName}</strong> থেকে <strong>${permissionName}</strong> প্রত্যাহার করতে চান?</p>
               <p style="color:#e74c3c;font-weight:500;margin-top:1rem;">এই কাজটি ফিরানো যাবে না।</p>`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#e74c3c',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'প্রত্যাহার করুন',
        cancelButtonText: 'বাতিল করুন',
        allowOutsideClick: false,
        allowEscapeKey: false
    }).then((result) => {
        if (result.isConfirmed) document.getElementById('revokeForm').submit();
    });
}
</script>
{% endblock %}

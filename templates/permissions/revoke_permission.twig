<script>
function confirmRevoke() {
    const permissionName = '{{ permission.name }}';
    const roleName = '{{ role.role_name }}';

    Swal.fire({
        title: '{{ "নিশ্চিত করুন"|trans }}',
        html: `<p>আপনি কি নিশ্চিত যে আপনি <strong>${roleName}</strong> থেকে <strong>${permissionName}</strong> প্রত্যাহার করতে চান?</p>
               <p style="color: #e74c3c; font-weight: 500; margin-top: 1rem;">এই ক্রিয়াটি পূর্বাবাস যোগ্য নয়।</p>`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#e74c3c',
        cancelButtonColor: '#6c757d',
        confirmButtonText: '{{ "প্রত্যাহার করুন"|trans }}',
        cancelButtonText: '{{ "বাতিল করুন"|trans }}',
        allowOutsideClick: false,
        allowEscapeKey: false
    }).then((result) => {
        if (result.isConfirmed) {
            // Submit the form
            document.getElementById('revokeForm').submit();
        }
    });
}

// Show confirmation on page load
document.addEventListener('DOMContentLoaded', function() {
    Swal.fire({
        title: '{{ "আপনি কি নিশ্চিত?"|trans }}',
        html: `<p>আপনি এই পারমিশন প্রত্যাহার করতে চলেছেন।</p>`,
        icon: 'question',
        confirmButtonColor: '#667eea',
        confirmButtonText: '{{ "বুঝেছি"|trans }}'
    });
});
</script>

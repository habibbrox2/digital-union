{% extends "layout.twig" %}

{% block content %}
<div class="container my-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-lg-8 mx-auto">
            <div class="page-header-gradient">
                <div class="page-header-content">
                    <h1 class="page-header-title">{{ 'পারমিশন প্রত্যাহার করুন'|trans }}</h1>
                    <p class="page-header-subtitle">{{ 'অনুমতি সম্পূর্ণভাবে সরিয়ে ফেলুন'|trans }}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Confirmation Card -->
            <div class="card shadow-lg border-0 mb-4 revoke-card">
                <div class="card-header revoke-header">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-exclamation-triangle me-2" style="color: #f39c12;"></i>
                        <h5 class="mb-0">{{ 'নিশ্চিত করুন'|trans }}</h5>
                    </div>
                </div>

                <div class="card-body p-4">
                    <!-- Role Information -->
                    <div class="mb-4">
                        <h6 class="text-muted mb-2">{{ 'ভূমিকা (Role)'|trans }}</h6>
                        <div class="role-badge">
                            <i class="fas fa-user-shield me-2"></i>
                            <span class="role-name">{{ role.role_name }}</span>
                        </div>
                        {% if role.description %}
                            <small class="text-muted d-block mt-2">{{ role.description }}</small>
                        {% endif %}
                    </div>

                    <!-- Permission Information -->
                    <div class="mb-4">
                        <h6 class="text-muted mb-2">{{ 'প্রত্যাহার করার পারমিশন'|trans }}</h6>
                        <div class="permission-card">
                            <div class="d-flex align-items-start">
                                <div class="permission-icon">
                                    <i class="fas fa-key"></i>
                                </div>
                                <div class="permission-details">
                                    <h6 class="mb-1 permission-name">{{ permission.name }}</h6>
                                    <p class="mb-0 text-muted permission-description">{{ permission.description }}</p>
                                    <div class="mt-2">
                                        <span class="badge bg-secondary">{{ permission.module }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Warning Message -->
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>{{ 'সতর্কতা!'|trans }}</strong> {{ 'এই ক্রিয়াটি আপস্পন্ন হতে পারে না। এই ভূমিকা বর্তমানে এই অনুমতি হারাবে।'|trans }}
                    </div>
                </div>

                <div class="card-footer bg-transparent border-top-0 p-4">
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-lg btn-danger" onclick="confirmRevoke()">
                            <i class="fas fa-trash-alt me-2"></i>
                            {{ 'নিশ্চিত - প্রত্যাহার করুন'|trans }}
                        </button>
                        <a href="/permissions/assign" class="btn btn-lg btn-secondary">
                            <i class="fas fa-times me-2"></i>
                            {{ 'বাতিল করুন'|trans }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Revoke Form (Hidden) -->
<form id="revokeForm" action="/permissions/revoke/{{ role.role_id }}/{{ permission.id }}" method="POST" style="display: none;">
    @csrf
</form>

<style>

{% extends "layout.twig" %}

{% block title %}Manage Permissions{% endblock %}

{% block header_title %}Manage Permissions for {{ currentUser.role_name|default('') }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-11">

            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-primary text-white d-flex flex-column flex-md-row justify-content-between align-items-center">
                    <h3 class="card-title mb-2 mb-md-0">{{ header_title }}</h3>
                    {% if isSuperadmin %}
                        <form method="get" id="unionSelectForm" class="form-inline">
                            <label for="union_id" class="mr-2 font-weight-bold text-white">Select Union:</label>
                            <select name="union_id" id="union_id" class="form-control form-control-sm" onchange="document.getElementById('unionSelectForm').submit();">
                                {% for union in allUnions %}
                                    <option value="{{ union.union_id }}" {% if union.union_id == unionId %}selected{% endif %}>
                                        {{ union.union_name_en }} ({{ union.union_name_bn }})
                                    </option>
                                {% endfor %}
                            </select>
                        </form>
                    {% elseif currentUser.union_name %}
                        <span class="font-italic text-white">Permissions for: {{ currentUser.union_name }}</span>
                    {% endif %}
                </div>

                <div class="card-body">

                    {% if message %}
                        <div class="alert alert-{{ status == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
                            <strong><i class="fas fa-{{ status == 'success' ? 'check-circle' : 'exclamation-triangle' }} mr-2"></i>{{ status|capitalize }}!</strong> {{ message }}
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    {% endif %}

                    <form action="/manage-permissions" method="post" novalidate>
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                        {# ===== Role-based Permissions ===== #}
                        <h4 class="mb-3 text-primary font-weight-bold border-bottom pb-2">Role Based Permissions</h4>
                        {% if not isSuperadmin %}
                            <div class="alert alert-info rounded-pill">
                                <i class="fas fa-info-circle mr-2"></i>
                                You have readonly access to Role Based Permissions. Only Superadmins can make changes.
                            </div>
                        {% endif %}

                        <div class="table-responsive mb-5 shadow-sm rounded">
                            <table class="table table-striped table-hover table-bordered mb-0 text-center align-middle">
                                {% set adminRoles = [
                                    'admin', 'superadmin', 'administrator', 'root', 'system admin',
                                    'master admin', 'god mode', 'chief admin', 'global admin', 'platform admin'
                                ] %}
                                <thead class="thead-light">
                                    <tr>
                                        <th class="text-left">Permission</th>
                                        {% for role in roles %}
                                            {% if role.role_name|lower not in adminRoles %}
                                                <th>{{ role.role_name|replace({'_': ' '})|title }}</th>
                                            {% endif %}
                                        {% endfor %}
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for permission in permissions %}
                                        <tr>
                                            <td class="text-left font-weight-medium">{{ permission.name|replace({'_': ' '})|title }}</td>
                                            {% for role in roles %}
                                                {% if role.role_name|lower not in adminRoles %}
                                                    <td>
                                                        <input
                                                            type="checkbox"
                                                            name="role_permissions[{{ role.role_id }}][]"
                                                            value="{{ permission.permission_id }}"
                                                            id="role_perm_{{ role.role_id }}_{{ permission.permission_id }}"
                                                            class="form-check-input position-relative"
                                                            {% if assigned_role_permissions[role.role_id] is defined 
                                                                and assigned_role_permissions[role.role_id][permission.permission_id] is defined %}
                                                                checked
                                                            {% endif %}
                                                            {% if not isSuperadmin %}
                                                                disabled
                                                            {% endif %}
                                                        >
                                                    </td>
                                                {% endif %}
                                            {% endfor %}
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        {# ===== Note about Role-Based System ===== #}
                        <div class="alert alert-info rounded mt-5 border-left border-primary" style="border-left-width: 4px !important;">
                            <i class="fas fa-lightbulb mr-2 text-primary"></i>
                            <strong>Role-Based System Only:</strong> User permissions are managed through roles. To change a user's permissions, 
                            assign them to the appropriate role in the <a href="/roles" class="alert-link font-weight-bold">Roles Management</a> section.
                        </div>

                        {# Save button #}
                        <div class="card-footer d-flex justify-content-end mt-4 border-0 bg-transparent p-0">
                            <button type="submit" class="btn btn-primary btn-lg"
                                {% if not isSuperadmin %}
                                    disabled
                                {% endif %}
                            >
                                <i class="fas fa-save mr-2"></i> Save Changes
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}

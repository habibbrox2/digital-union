{% extends 'layout.twig' %}

{% block title %}নতুন পারমিশন যোগ করুন{% endblock %}
{% block header_title %}{{ header_title|default('নতুন পারমিশন') }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
{% include 'components/rbac_ui.twig' %}
<div class="container-fluid py-4">
    <div class="rbac-header">
        <div>
            <h4><i class="bi bi-key text-primary me-2"></i>নতুন পারমিশন</h4>
            <div class="subtitle">সিস্টেমে একটি নতুন অনুমতি যোগ করুন</div>
        </div>
        <a href="/permissions" class="btn btn-outline-secondary rbac-btn">
            <i class="bi bi-arrow-left me-1"></i> তালিকায় ফিরুন
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="rbac-card p-4">
                <form method="post" action="/permissions/add" id="permissionForm" novalidate>
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />

                    <div class="mb-3">
                        <label for="module" class="form-label fw-semibold small text-secondary">মডিউল <span class="text-danger">*</span></label>
                        <input class="form-control form-control-lg rbac-input"
                               list="module-options"
                               id="module"
                               name="module"
                               placeholder="যেমন: roles, users, reports"
                               value="{{ form_data.module|default('') }}"
                               autocomplete="off"
                               required />
                        <datalist id="module-options">
                            {% for m in modules %}<option value="{{ m|e }}">{{ m|upper }}</option>{% endfor %}
                            <option value="general">general</option>
                            <option value="admin">admin</option>
                            <option value="reports">reports</option>
                            <option value="users">users</option>
                        </datalist>
                        <div class="invalid-feedback">মডিউলের নাম দিন।</div>
                        <small class="text-muted">অনুমতিগুলো গোছানোর জন্য মডিউল (যেমন 'roles', 'users')</small>
                    </div>

                    <div class="mb-3">
                        <label for="name" class="form-label fw-semibold small text-secondary">অনুমতির নাম <span class="text-danger">*</span></label>
                        <input class="form-control form-control-lg rbac-input"
                               id="name"
                               name="name"
                               required
                               minlength="2"
                               placeholder="যেমন: view_dashboard, edit_users"
                               maxlength="191"
                               value="{{ form_data.name|default('') }}" />
                        <div class="invalid-feedback">অনুমতির নাম দিন (কমপক্ষে ২ অক্ষর)।</div>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted">কোডে ব্যবহৃত ইউনিক কী (আন্ডারস্কোর ব্যবহার করুন)</small>
                            <small class="text-muted char-counter" data-target="name">0/191</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label fw-semibold small text-secondary">বিবরণ</label>
                        <textarea class="form-control rbac-input"
                                  id="description"
                                  name="description"
                                  rows="4"
                                  placeholder="এই অনুমতি কী করতে দেয় তার সংক্ষিপ্ত বিবরণ"
                                  maxlength="1000">{{ form_data.description|default('') }}</textarea>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted">ঐচ্ছিক: অ্যাডমিনদের বুঝতে সাহায্য করে</small>
                            <small class="text-muted char-counter" data-target="description">0/1000</small>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button class="btn btn-primary rbac-btn shadow-sm" type="submit">
                            <i class="bi bi-check2-circle me-1"></i> পারমিশন তৈরি করুন
                        </button>
                        <a href="/permissions" class="btn btn-outline-secondary rbac-btn">
                            <i class="bi bi-x-circle me-1"></i> বাতিল
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="rbac-card p-4">
                <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-info-circle text-info"></i> সহায়িকা
                </h6>
                <ul class="list-unstyled mb-0 small rbac-summary">
                    <li><span class="label">মডিউল</span><span>অনুমতির গ্রুপ</span></li>
                    <li><span class="label">নাম</span><span>কোডে ব্যবহৃত কী</span></li>
                    <li><span class="label">বিবরণ</span><span>মানুষের বোঝার জন্য</span></li>
                </ul>
                <div class="alert alert-light border mt-3 mb-0 small">
                    <i class="bi bi-lightbulb text-warning me-1"></i>
                    স্পেসের বদলে স্বয়ংক্রিয়ভাবে আন্ডারস্কোর (_) বসবে।
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('permissionForm');
    if (!form) return;
    document.querySelectorAll('.char-counter').forEach(function (counter) {
        const el = document.getElementById(counter.dataset.target);
        if (!el) return;
        const update = () => counter.textContent = `${el.value.length}/${el.maxLength}`;
        el.addEventListener('input', update);
        update();
    });
    const nameInput = document.getElementById('name');
    if (nameInput) {
        nameInput.addEventListener('input', function () {
            const pos = this.selectionStart;
            const cleaned = this.value.replace(/\s+/g, '_');
            if (cleaned !== this.value) {
                this.value = cleaned;
                this.setSelectionRange(pos, pos);
            }
        });
    }
    form.addEventListener('submit', function (e) {
        if (!form.checkValidity()) {
            e.preventDefault();
            e.stopPropagation();
            form.classList.add('was-validated');
        }
    });
});
</script>
{% endblock %}

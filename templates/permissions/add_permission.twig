{% extends 'layout.twig' %}

{% block title %}Add Permission{% endblock %}
{% block header_title %}{{ header_title|default('Add Permission') }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container mt-4">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0"><i class="fas fa-key"></i> Create New Permission</h4>
        </div>
        <div class="card-body">
          <form method="post" action="/permissions/add">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />

            <div class="mb-3">
              <label for="module" class="form-label fw-bold">Module <span class="text-danger">*</span></label>
              <select class="form-control form-control-lg" id="module" name="module" required>
                <option value="">-- Select or Enter Module --</option>
                {% for m in modules %}
                  <option value="{{ m|e }}">{{ m|upper }}</option>
                {% endfor %}
                <option value="general">general</option>
                <option value="admin">admin</option>
                <option value="reports">reports</option>
                <option value="users">users</option>
              </select>
              <small class="form-text text-muted d-block mt-2">
                <i class="fas fa-info-circle"></i>
                Namespace for organizing permissions (e.g., 'roles', 'users', 'reports')
              </small>
            </div>

            <div class="mb-3">
              <label for="name" class="form-label fw-bold">Permission Name <span class="text-danger">*</span></label>
              <input class="form-control form-control-lg" 
                     id="name" 
                     name="name" 
                     required 
                     placeholder="e.g., view_dashboard, edit_users"
                     maxlength="191" />
              <small class="form-text text-muted d-block mt-2">
                <i class="fas fa-info-circle"></i>
                Unique key used in code (use underscores, no spaces)
              </small>
            </div>

            <div class="mb-3">
              <label for="description" class="form-label fw-bold">Description</label>
              <textarea class="form-control" 
                        id="description" 
                        name="description" 
                        rows="4" 
                        placeholder="Brief description of what this permission allows"
                        maxlength="1000"></textarea>
              <small class="form-text text-muted d-block mt-2">
                <i class="fas fa-info-circle"></i>
                Optional: helps admins identify the permission's purpose
              </small>
            </div>

            <div class="d-flex gap-2 mt-4">
              <button class="btn btn-primary btn-lg" type="submit">
                <i class="fas fa-plus"></i> Create Permission
              </button>
              <a href="/permissions" class="btn btn-secondary btn-lg">
                <i class="fas fa-times"></i> Cancel
              </a>
            </div>
          </form>

        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
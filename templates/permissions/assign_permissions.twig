{% extends "layout.twig" %}

{% block title %}অনুমতি নির্ধারণ{% endblock %}
{% block header_title %}ভূমিকায় অনুমতি নির্ধারণ করুন{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
{% include 'components/rbac_ui.twig' %}

<div class="container-fluid py-4">
    <div class="rbac-header">
        <div>
            <h4><i class="bi bi-link-45deg text-primary me-2"></i>অনুমতি ব্যবস্থাপনা</h4>
            <div class="subtitle">প্রতিটি ভূমিকার জন্য অনুমতি নির্ধারণ ও পরিচালনা করুন</div>
        </div>
        <span class="badge rounded-pill rbac-badge-info fs-6 px-3 py-2">
            <i class="bi bi-people me-1"></i>{{ roles|length }}টি ভূমিকা
        </span>
    </div>

    {% if roles|length > 0 %}
        <div class="row g-4">
            {% for role in roles %}
                <div class="col-12 col-lg-6">
                    <div class="rbac-card rbac-role-card h-100 overflow-hidden">
                        <!-- Card header -->
                        <div class="card-header d-flex align-items-center gap-2 p-3"
                             style="background: linear-gradient(135deg, #008B8B 0%, #007A7A 100%); color:#fff;">
                            <div class="role-icon" style="background: rgba(255,255,255,0.2); color:#fff;">
                                {% if role.role_id == 1 %}
                                    <i class="bi bi-person-fill-gear"></i>
                                {% elseif role.role_id == 2 %}
                                    <i class="bi bi-shield-lock"></i>
                                {% elseif role.role_id == 3 %}
                                    <i class="bi bi-person-badge"></i>
                                {% else %}
                                    <i class="bi bi-person"></i>
                                {% endif %}
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="mb-0 fw-bold">{{ role.role_name|replace({'_':' '})|title }}</h5>
                                {% if role.description %}<small class="rbac-role-meta opacity-75">{{ role.description }}</small>{% endif %}
                            </div>
                            <span class="badge bg-light text-dark fw-bold">আইডি: {{ role.role_id }}</span>
                        </div>

                        <!-- Card body -->
                        <div class="card-body p-0 d-flex flex-column">
                            <form class="role-permissions-form d-flex flex-column h-100" data-role-id="{{ role.role_id }}">
                                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                                <div class="px-3 pt-3 flex-grow-1">
                                    {% set rolePerms = assigned_role_permissions[role.role_id]|default({}) %}
                                    {% set permsByModule = {} %}
                                    {% for permission in permissions %}
                                        {% set module = permission.module %}
                                        {% if not permsByModule[module] %}
                                            {% set permsByModule = permsByModule|merge({(module): []}) %}
                                        {% endif %}
                                        {% set permsByModule = permsByModule|merge({(module): permsByModule[module]|merge([permission])}) %}
                                    {% endfor %}

                                    {% for module, perms in permsByModule %}
                                        <div class="mb-3">
                                            <div class="text-uppercase fw-bold text-secondary small mb-2">
                                                <i class="bi bi-folder2-open me-1"></i>{{ module|title }}
                                            </div>
                                            {% for permission in perms %}
                                                <div class="rbac-perm-row d-flex align-items-start justify-content-between">
                                                    <div class="form-check d-flex align-items-start gap-2 m-0">
                                                        <input class="form-check-input rbac-perm-check"
                                                               type="checkbox"
                                                               id="role_{{ role.role_id }}_perm_{{ permission.id }}"
                                                               name="role_permissions[]"
                                                               value="{{ permission.id }}"
                                                               {% if rolePerms[permission.id]|default(false) %}checked{% endif %}>
                                                        <label class="form-check-label" for="role_{{ role.role_id }}_perm_{{ permission.id }}">
                                                            <span class="fw-medium">{{ permission.name }}</span>
                                                            {% if permission.description %}
                                                                <small class="d-block text-muted">{{ permission.description }}</small>
                                                            {% endif %}
                                                        </label>
                                                    </div>
                                                    <a href="/permissions/revoke/{{ role.role_id }}/{{ permission.id }}"
                                                       class="btn btn-sm btn-outline-danger ms-2"
                                                       title="প্রত্যাহার">
                                                        <i class="bi bi-ban"></i>
                                                    </a>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% endfor %}
                                </div>

                                <div class="p-3 border-top bg-light mt-3">
                                    <div class="d-flex gap-2">
                                        <button type="submit" class="btn btn-success flex-grow-1 fw-bold rounded-2">
                                            <i class="bi bi-check2-circle me-1"></i>সংরক্ষণ করুন
                                        </button>
                                        <button type="reset" class="btn btn-outline-secondary rounded-2">
                                            <i class="bi bi-arrow-counterclockwise me-1"></i>রিসেট
                                        </button>
                                    </div>
                                    <small class="text-muted d-block mt-2">
                                        <i class="bi bi-info-circle me-1"></i>
                                        নির্বাচিত: <span class="permission-count fw-bold">0</span>
                                    </small>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-warning d-flex align-items-center shadow-sm rounded-3" role="alert">
            <i class="bi bi-exclamation-triangle text-warning me-3 fs-5"></i>
            <div>
                <strong>কোনো ভূমিকা পাওয়া যায়নি।</strong>
                <p class="mb-0 text-muted">অনুমতি নির্ধারণের জন্য কমপক্ষে একটি ভূমিকা প্রয়োজন।</p>
            </div>
        </div>
    {% endif %}
</div>

{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const SweetAlertUtil = {
        success: (title, message) => Swal.fire({ icon: 'success', title: title, text: message, confirmButtonColor: '#28a745' }),
        error: (title, message) => Swal.fire({ icon: 'error', title: title, text: message, confirmButtonColor: '#dc3545' }),
        toast: (message, icon = 'success') => Swal.fire({ toast: true, position: 'top-end', icon: icon, title: message, timer: 3000, timerProgressBar: true, showConfirmButton: false })
    };

    function updatePermissionCount(form) {
        const count = form.querySelectorAll('.rbac-perm-check:checked').length;
        const countSpan = form.querySelector('.permission-count');
        if (countSpan) countSpan.textContent = count;
    }

    document.querySelectorAll('.role-permissions-form').forEach(form => {
        updatePermissionCount(form);
        form.querySelectorAll('.rbac-perm-check').forEach(cb => {
            cb.addEventListener('change', () => updatePermissionCount(form));
        });

        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            const roleId = form.dataset.roleId;
            const formData = new FormData(form);
            const submitBtn = form.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-arrow-repeat spin me-1"></i>প্রক্রিয়াকরণ...';

            try {
                const response = await fetch(`/permissions/assign/${roleId}`, {
                    method: 'POST',
                    headers: { 'X-CSRF-TOKEN': formData.get('csrf_token') },
                    body: formData
                });
                const result = await response.json();
                if (result.success) {
                    SweetAlertUtil.toast('অনুমতি সফলভাবে সংরক্ষিত হয়েছে!', 'success');
                } else {
                    SweetAlertUtil.error('ত্রুটি', result.message || 'অনুমতি সংরক্ষণ করতে ব্যর্থ হয়েছে');
                }
            } catch (error) {
                SweetAlertUtil.error('ত্রুটি', 'কোনো কিছু ভুল হয়েছে, পুনরায় চেষ্টা করুন');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="bi bi-check2-circle me-1"></i>সংরক্ষণ করুন';
            }
        });

        form.querySelector('button[type="reset"]').addEventListener('click', function() {
            setTimeout(() => updatePermissionCount(form), 0);
        });
    });
});
</script>
{% endblock %}

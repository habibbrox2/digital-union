{% extends 'layout.twig' %}

{% block title %}পারমিশন মুছুন - নিশ্চিতকরণ{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
{% include 'components/rbac_ui.twig' %}
<div class="container-fluid py-4">
    <div class="rbac-header">
        <div>
            <h4><i class="bi bi-trash3 text-danger me-2"></i>পারমিশন মুছুন</h4>
            <div class="subtitle">এই কাজটি ফিরানো যাবে না</div>
        </div>
        <a href="/permissions" class="btn btn-outline-secondary rbac-btn">
            <i class="bi bi-arrow-left me-1"></i> তালিকায় ফিরুন
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-7">
            <div class="rbac-danger-card shadow-sm">
                <div class="alert alert-warning d-flex align-items-center rounded-top m-0" style="border-radius:16px 16px 0 0;">
                    <i class="bi bi-exclamation-triangle-fill fs-4 me-2"></i>
                    <span><strong>সতর্কতা!</strong> এই কাজটি ফিরানো যাবে না।</span>
                </div>

                <div class="p-4">
                    <div class="text-muted small text-uppercase fw-bold mb-2">মোছার জন্য পারমিশন</div>
                    <ul class="list-group list-group-flush border rounded mb-4">
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">আইডি</span>
                            <span class="badge rounded-pill rbac-badge-secondary">{{ permission.id }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">নাম</span>
                            <span class="fw-semibold">{{ permission.name|e }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">মডিউল</span>
                            <span class="badge rounded-pill rbac-badge-info">{{ permission.module|e }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">বিবরণ</span>
                            <span>{{ permission.description|e }}</span>
                        </li>
                    </ul>

                    <div class="alert alert-light border mb-4">
                        <i class="bi bi-info-circle me-2"></i>
                        মুছে ফেললে এই অনুমতিটি সব ভূমিকা থেকে সরিয়ে নেওয়া হবে।
                    </div>

                    <form method="post" action="/permissions/{{ permission.id }}/delete">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />
                        <div class="d-flex gap-2">
                            <button class="btn btn-danger rbac-btn" type="submit">
                                <i class="bi bi-trash3 me-1"></i> হ্যাঁ, মুছুন
                            </button>
                            <a href="/permissions" class="btn btn-outline-secondary rbac-btn">
                                <i class="bi bi-x-circle me-1"></i> বাতিল
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

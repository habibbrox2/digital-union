{% extends 'layout.twig' %}

{% block title %}Delete Permission - Confirmation{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container mt-4">
  <div class="row">
    <div class="col-md-6 offset-md-3">
      <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">
          <h4 class="mb-0"><i class="fas fa-trash"></i> Delete Permission - Confirm</h4>
        </div>
        <div class="card-body">
          <div class="alert alert-warning mb-4">
            <i class="fas fa-exclamation-triangle"></i> <strong>WARNING:</strong> This action cannot be undone!
          </div>

          <div class="mb-4">
            <p class="fw-bold">Permission to delete:</p>
            <ul class="list-unstyled ps-3">
              <li class="mb-2"><strong>ID:</strong> <span class="badge bg-secondary">{{ permission.id }}</span></li>
              <li class="mb-2"><strong>Name:</strong> {{ permission.name|e }}</li>
              <li class="mb-2"><strong>Module:</strong> <span class="badge bg-info">{{ permission.module|e }}</span></li>
              <li class="mb-2"><strong>Description:</strong> {{ permission.description|e }}</li>
            </ul>
          </div>

          <p class="text-muted mb-4">
            <i class="fas fa-info-circle"></i>
            Are you sure you want to delete this permission? It will be removed from all role assignments.
          </p>

          <form method="post" action="/permissions/{{ permission.id }}/delete">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />
            
            <div class="d-flex gap-2">
              <button class="btn btn-danger btn-lg" type="submit">
                <i class="fas fa-trash"></i> Yes, Delete Permission
              </button>
              <a href="/permissions" class="btn btn-secondary btn-lg">
                <i class="fas fa-arrow-left"></i> Cancel
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
{% extends 'layout.twig' %}

{% block title %}Permissions Management - RBAC System{% endblock %}
{% block header_title %}{{ header_title|default('Permissions Management') }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container-fluid">
  <!-- Page Header -->
  <div class="page-header mb-4 mt-4">
    <div class="row align-items-center">
      <div class="col-md-6">
        <h1 class="page-title mb-0">
          <i class="fas fa-key"></i> Permissions Management
        </h1>
        <p class="text-muted small mt-2">Manage role-based permissions</p>
      </div>
      <div class="col-md-6 text-end">
        <a href="/permissions/add" class="btn btn-success btn-lg">
          <i class="fas fa-plus"></i> Add Permission
        </a>
        <a href="/roles" class="btn btn-info btn-lg">
          <i class="fas fa-user-shield"></i> Manage Roles
        </a>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="row mb-4">
    <div class="col-md-6">
      <div class="card stat-card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="stat-icon bg-primary">
              <i class="fas fa-key"></i>
            </div>
            <div class="stat-content">
              <h6 class="mb-0 text-muted">Total Permissions</h6>
              <h3 class="mb-0">{{ permissions|length }}</h3>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card stat-card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="stat-icon bg-info">
              <i class="fas fa-cube"></i>
            </div>
            <div class="stat-content">
              <h6 class="mb-0 text-muted">Modules</h6>
              <h3 class="mb-0">{{ modules|length }}</h3>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Permissions by Module -->
  <div class="row">
    <div class="col-lg-12">
      {% if modules|length > 0 %}
        {% for module in modules %}
          {% set perms = permissionsByModule[module] | default([]) %}
          <div class="card shadow-sm mb-4 border-0">
            <div class="card-header bg-light border-bottom">
              <div class="d-flex align-items-center justify-content-between">
                <h5 class="mb-0">
                  <i class="fas fa-cube"></i> {{ module|upper }}
                </h5>
                <span class="badge bg-primary">{{ perms|length }} permissions</span>
              </div>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0">
                  <thead class="table-light">
                    <tr>
                      <th style="width: 20%"><i class="fas fa-tag"></i> Permission Name</th>
                      <th style="width: 40%"><i class="fas fa-comment"></i> Description</th>
                      <th style="width: 15%; text-align: center"><i class="fas fa-calendar"></i> Created</th>
                      <th style="width: 25%; text-align: center"><i class="fas fa-cog"></i> Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for perm in perms %}
                      <tr>
                        <td class="align-middle">
                          <strong class="text-primary">{{ perm.name }}</strong>
                        </td>
                        <td class="align-middle">
                          <small class="text-muted">
                            {{ perm.description | default('(no description)', true) }}
                          </small>
                        </td>
                        <td class="align-middle text-center">
                          <small class="text-muted">
                            {{ perm.created_at | date('M d, Y') }}
                          </small>
                        </td>
                        <td class="align-middle text-center">
                          <a href="/permissions/{{ perm.id }}/edit" class="btn btn-sm btn-info" title="Edit">
                            <i class="fas fa-edit"></i>
                          </a>
                          <a href="/permissions/{{ perm.id }}/delete" class="btn btn-sm btn-danger" title="Delete">
                            <i class="fas fa-trash"></i>
                          </a>
                        </td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="card shadow-sm border-0">
          <div class="card-body text-center py-5">
            <i class="fas fa-inbox text-muted" style="font-size: 3rem;"></i>
            <h4 class="mt-3 text-muted">No Permissions Found</h4>
            <p class="text-muted mb-3">Create your first permission to get started</p>
            <a href="/permissions/add" class="btn btn-primary btn-lg">
              <i class="fas fa-plus"></i> Add Permission
            </a>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
.page-header {
  border-bottom: 2px solid #f0f0f0;
  padding-bottom: 1.5rem;
}

.page-title {
  font-size: 2rem;
  font-weight: 600;
  color: #333;
}

.stat-card {
  transition: transform 0.2s;
}

.stat-card:hover {
  transform: translateY(-5px);
}

.stat-icon {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  color: white;
  margin-right: 15px;
}

.bg-primary { background-color: #0d6efd !important; }
.bg-info { background-color: #0dcaf0 !important; }
</style>
{% endblock %}

{% extends "layout.twig" %}
{% block title %}{{ 'নতুন ব্যবহারকারী যোগ করুন' }}{% endblock %}
{% block header_title %}{{ header_title|default('নতুন ব্যবহারকারী যোগ করুন') }}{% endblock %}
{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container-fluid px-0">
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-2">
        <div>
            <h4 class="mb-0 fw-bold" style="color: #1e293b;">
                <i class="bi bi-person-plus me-2 text-primary"></i>নতুন ব্যবহারকারী
            </h4>
            <small class="text-muted">নতুন ব্যবহারকারী তৈরি করে দল ও ইউনিয়ন অ্যাক্সেস দিন</small>
        </div>
        <a href="/users" class="btn btn-outline-secondary rounded-pill px-3">
            <i class="bi bi-arrow-left me-1"></i> তালিকায় ফিরুন
        </a>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="section-card p-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-person-lines-fill text-primary"></i> ব্যবহারকারীর তথ্য
                </h5>
                <form method="POST" enctype="multipart/form-data" id="addUserForm" novalidate>
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <div class="row">
                        <div class="col-12 mb-3">
                            <label class="form-label fw-semibold small text-secondary">প্রোফাইল ছবি</label>
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:80px;height:80px;">
                                    <i class="bi bi-person fs-1 text-secondary"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <input type="file" class="form-control input-enhanced" name="profile_picture" accept="image/*">
                                    <small class="text-muted">JPG, PNG বা GIF (সর্বোচ্চ 5MB)</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ব্যবহারকারীনাম <span class="text-danger">*</span></label>
                            <input type="text" class="form-control input-enhanced" name="username" required value="" placeholder="unique_username" minlength="3" maxlength="50" pattern="^[a-zA-Z0-9_]+$">
                            <small class="text-muted">৩-৫০ অক্ষর (শুধুমাত্র ইংরেজি অক্ষর, সংখ্যা ও আন্ডারস্কোর)</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ইমেইল <span class="text-danger">*</span></label>
                            <input type="email" class="form-control input-enhanced" name="email" required value="" placeholder="user@example.com">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">নাম (বাংলা) <span class="text-danger">*</span></label>
                            <input type="text" class="form-control input-enhanced" name="name_bn" required value="" placeholder="উদা: আব্দুল করিম" maxlength="100">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">নাম (ইংরেজি) <span class="text-danger">*</span></label>
                            <input type="text" class="form-control input-enhanced" name="name_en" required value="" placeholder="Ex: Abdul Karim" maxlength="100">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ফোন নম্বর</label>
                            <div class="input-group input-group-enhanced">
                                <span class="input-group-text bg-light">+88</span>
                                <input type="tel" class="form-control" name="phone_number" value="" placeholder="017XXXXXXXX" pattern="01[3-9][0-9]{8}">
                            </div>
                            <small class="text-muted">১১ ডিজিটের সঠিক মোবাইল নম্বর</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ভূমিকা <span class="text-danger">*</span></label>
                            <select class="form-select input-enhanced" name="role_id" id="roleSelect" required>
                                <option value="">নির্বাচন করুন</option>
                                {% for role in roles %}
                                    {% if role.id > 1 %}
                                <option value="{{ role.id }}">{{ role.name_bn }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">পাসওয়ার্ড <span class="text-danger">*</span></label>
                            <div class="input-group input-group-enhanced">
                                <input type="password" class="form-control" name="password" id="password" required minlength="8" placeholder="••••••••" autocomplete="new-password">
                                <button class="btn btn-outline-secondary toggle-password" type="button"><i class="bi bi-eye"></i></button>
                            </div>
                            <small class="text-muted">কমপক্ষে ৮ অক্ষর</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">পাসওয়ার্ড নিশ্চিত করুন <span class="text-danger">*</span></label>
                            <input type="password" class="form-control input-enhanced" name="confirm_password" id="confirmPassword" required minlength="8" placeholder="••••••••" autocomplete="new-password">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ইউনিয়ন</label>
                            <select class="form-select input-enhanced" name="union_id" id="unionSelect">
                                <option value="">কোন ইউনিয়ন নেই</option>
                                {% for union in unions %}
                                <option value="{{ union.union_id }}">{{ union.union_name_bn }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6 mb-3" id="wardField" style="display:none;">
                            <label class="form-label fw-semibold small text-secondary">ওয়ার্ড নং <span class="text-danger" id="wardRequired">*</span></label>
                            <select class="form-select input-enhanced" name="ward_no" id="wardSelect">
                                <option value="">ওয়ার্ড নির্বাচন করুন</option>
                                {% for i in 1..9 %}
                                <option value="{{ i }}">{{ i }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ঠিকানা</label>
                            <textarea class="form-control input-enhanced" name="address" rows="2" maxlength="500" placeholder="বিস্তারিত ঠিকানা লিখুন..."></textarea>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold small text-secondary">অবস্থা</label>
                            <select class="form-select input-enhanced" name="is_active">
                                <option value="1" selected>সক্রিয়</option>
                                <option value="0">নিষ্ক্রিয়</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ভাষা পছন্দ</label>
                            <select class="form-select input-enhanced" name="language">
                                <option value="bn" selected>বাংলা</option>
                                <option value="en">ইংরেজি</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold small text-secondary">সময় অঞ্চল</label>
                            <select class="form-select input-enhanced" name="timezone">
                                <option value="Asia/Dhaka" selected>Asia/Dhaka (UTC+6)</option>
                                <option value="Asia/Kolkata">Asia/Kolkata (UTC+5:30)</option>
                                <option value="UTC">UTC</option>
                            </select>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-semibold small text-secondary">বিজ্ঞপ্তি সেটিংস</label>
                            <div class="d-flex gap-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="email_notifications" id="emailNotif" value="1" checked>
                                    <label class="form-check-label" for="emailNotif">ইমেইল বিজ্ঞপ্তি</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="sms_notifications" id="smsNotif" value="1" checked>
                                    <label class="form-check-label" for="smsNotif">এসএমএস বিজ্ঞপ্তি</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="bi bi-check2-circle me-1"></i> ব্যবহারকারী তৈরি করুন</button>
                        <a href="/users" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-x-circle me-1"></i> বাতিল</a>
                    </div>
                </form>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="section-card p-4">
                <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i class="bi bi-info-circle text-info"></i> নির্দেশিকা</h6>
                <ul class="list-unstyled mb-0 small">
                    <li class="d-flex gap-2 py-2 border-bottom">
                        <i class="bi bi-check-circle text-success flex-shrink-0 mt-1"></i>
                        <span>ব্যবহারকারীর নাম শুধুমাত্র ইংরেজি অক্ষর, সংখ্যা ও আন্ডারস্কোর হতে পারে</span>
                    </li>
                    <li class="d-flex gap-2 py-2 border-bottom">
                        <i class="bi bi-check-circle text-success flex-shrink-0 mt-1"></i>
                        <span>পাসওয়ার্ড কমপক্ষে ৮ অক্ষরের হতে হবে</span>
                    </li>
                    <li class="d-flex gap-2 py-2 border-bottom">
                        <i class="bi bi-check-circle text-success flex-shrink-0 mt-1"></i>
                        <span>সদস্য ভূমিকা নির্বাচন করলে ওয়ার্ড নং বাধ্যতামূলক</span>
                    </li>
                    <li class="d-flex gap-2 py-2">
                        <i class="bi bi-check-circle text-success flex-shrink-0 mt-1"></i>
                        <span>নতুন ব্যবহারকারী তৈরি হলে স্বয়ংক্রিয়ভাবে ইমেইল বিজ্ঞপ্তি পাঠানো হবে</span>
                    </li>
                </ul>
            </div>
            <div class="section-card p-4 mt-3">
                <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i class="bi bi-shield-check text-warning"></i> পারমিশন নোট</h6>
                <p class="small text-muted mb-0">
                    শুধুমাত্র সচিব বা তার উপরের স্তরের ব্যবহারকারীরা নতুন ব্যবহারকারী তৈরি করতে পারবেন। আপনি নিজের চেয়ে উচ্চতর ভূমিকা নির্ধারণ করতে পারবেন না।
                </p>
            </div>
        </div>
    </div>
</div>
<style>
.section-card{background:#fff;border-radius:16px;box-shadow:0 2px 8px rgba(0,0,0,0.04);border:1px solid rgba(0,0,0,0.06);}
.input-enhanced{border:1px solid #ced4da;transition:border-color 0.2s ease,box-shadow 0.2s ease;}
.input-enhanced:focus{border-color:#008B8B;box-shadow:0 0 0 0.2rem rgba(0,139,139,0.15),0 0 12px rgba(0,139,139,0.08);}
.input-group-enhanced:focus-within{border-color:#008B8B;box-shadow:0 0 0 0.2rem rgba(0,139,139,0.15);border-radius:6px;}
.input-group-enhanced .form-control:focus{box-shadow:none;border-color:#ced4da;}
.toggle-password{transition:all 0.2s ease;}
.toggle-password:hover{background:#f0f0f0;}
</style>
<script>
document.addEventListener('DOMContentLoaded',function(){
    var roleSelect=document.getElementById('roleSelect'),wardField=document.getElementById('wardField'),wardSelect=document.getElementById('wardSelect'),wardRequired=document.getElementById('wardRequired'),addUserForm=document.getElementById('addUserForm');
    document.querySelectorAll('.toggle-password').forEach(function(btn){
        btn.addEventListener('click',function(){
            var input=this.parentElement.querySelector('input'),icon=this.querySelector('i');
            if(input.type==='password'){input.type='text';icon.classList.replace('bi-eye','bi-eye-slash');}
            else{input.type='password';icon.classList.replace('bi-eye-slash','bi-eye');}
        });
    });
    function toggleWardField(){
        if(roleSelect.value=='4'){wardField.style.display='block';wardSelect.required=true;wardRequired.style.display='inline';}
        else{wardField.style.display='none';wardSelect.required=false;wardSelect.value='';wardRequired.style.display='none';}
    }
    roleSelect.addEventListener('change',toggleWardField);
    addUserForm.addEventListener('submit',async function(e){
        e.preventDefault();
        var submitter=e.submitter,originalHtml=submitter.innerHTML;
        submitter.disabled=true;submitter.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span> তৈরি করা হচ্ছে...';
        var password=document.getElementById('password').value,confirmPassword=document.getElementById('confirmPassword').value;
        if(password!==confirmPassword){Swal.fire({icon:'error',title:'ত্রুটি',text:'পাসওয়ার্ড মিলছে না',confirmButtonText:'ঠিক আছে'});submitter.disabled=false;submitter.innerHTML=originalHtml;return;}
        if(password.length<8){Swal.fire({icon:'error',title:'ত্রুটি',text:'পাসওয়ার্ড কমপক্ষে ৮ অক্ষর',confirmButtonText:'ঠিক আছে'});submitter.disabled=false;submitter.innerHTML=originalHtml;return;}
        if(roleSelect.value=='4'&&!wardSelect.value){Swal.fire({icon:'error',title:'ত্রুটি',text:'সদস্য ভূমিকার জন্য ওয়ার্ড নং বাধ্যতামূলক',confirmButtonText:'ঠিক আছে'});wardSelect.focus();submitter.disabled=false;submitter.innerHTML=originalHtml;return;}
        var formData=new FormData(addUserForm);
        try{
            var response=await fetch('/users/add',{method:'POST',body:formData,headers:{'X-Requested-With':'XMLHttpRequest'}});
            var result=await response.json();
            if(response.ok&&result.success){
                Swal.fire({icon:'success',title:'সফল!',text:'নতুন ব্যবহারকারী তৈরি হয়েছে',confirmButtonText:'ঠিক আছে',timer:2000}).then(function(){window.location.href=result.redirect||'/users';});
            }else{
                Swal.fire({icon:'error',title:result.alert?.title||'ত্রুটি!',text:result.alert?.message||'তৈরি করতে ব্যর্থ হয়েছে',confirmButtonText:'ঠিক আছে'});
            }
        }catch(error){
            console.error(error);Swal.fire({icon:'error',title:'ত্রুটি!',text:'সার্ভার সংযোগ ব্যর্থ',confirmButtonText:'ঠিক আছে'});
        }finally{submitter.disabled=false;submitter.innerHTML=originalHtml;}
    });
});
</script>
{% endblock %}

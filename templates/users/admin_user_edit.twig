{% extends "layout.twig" %}
{% block title %}{{ 'ব্যবহারকারী সম্পাদনা' }}{% endblock %}
{% block header_title %}{{ header_title|default('ব্যবহারকারী সম্পাদনা') }}{% endblock %}
{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container-fluid px-0">
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-2">
        <div>
            <h4 class="mb-0 fw-bold" style="color: #1e293b;">
                <i class="bi bi-pencil-square me-2 text-warning"></i>ব্যবহারকারী সম্পাদনা
            </h4>
            <small class="text-muted">{{ profileData.username }} (ID: {{ profileData.user_id }})</small>
        </div>
        <a href="/users" class="btn btn-outline-secondary rounded-pill px-3">
            <i class="bi bi-arrow-left me-1"></i> তালিকায় ফিরুন
        </a>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="section-card p-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-person-lines-fill text-primary"></i> ব্যবহারকারীর তথ্য
                </h5>
                <form method="POST" enctype="multipart/form-data" id="editUserForm" novalidate>
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <div class="row">
                        <div class="col-12 mb-3">
                            <label class="form-label fw-semibold small text-secondary">প্রোফাইল ছবি</label>
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:80px;height:80px;">
                                    {% if profileData.profile_picture_url %}
                                    <img src="{{ profileData.profile_picture_url }}" class="rounded-circle w-100 h-100" style="object-fit:cover;">
                                    {% else %}
                                    <i class="bi bi-person fs-1 text-secondary"></i>
                                    {% endif %}
                                </div>
                                <div class="flex-grow-1">
                                    <input type="file" class="form-control input-enhanced" name="profile_picture" accept="image/*">
                                    <small class="text-muted">JPG, PNG বা GIF (সর্বোচ্চ 5MB)</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ব্যবহারকারীনাম <span class="text-danger">*</span></label>
                            <input type="text" class="form-control input-enhanced" name="username" required value="{{ profileData.username }}" placeholder="unique_username" minlength="3" maxlength="50" pattern="^[a-zA-Z0-9_]+$">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ইমেইল <span class="text-danger">*</span></label>
                            <div class="input-group input-group-enhanced">
                                <input type="email" class="form-control" name="email" required value="{{ profileData.email }}" placeholder="user@example.com">
                                {% if profileData.email_verified_at %}
                                <span class="input-group-text bg-success text-white small"><i class="bi bi-check-circle me-1"></i>যাচাইকৃত</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">নাম (বাংলা) <span class="text-danger">*</span></label>
                            <input type="text" class="form-control input-enhanced" name="name_bn" required value="{{ profileData.name_bn }}" placeholder="উদা: আব্দুল করিম" maxlength="100">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">নাম (ইংরেজি)</label>
                            <input type="text" class="form-control input-enhanced" name="name_en" value="{{ profileData.name_en }}" placeholder="Ex: Abdul Karim" maxlength="100">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ফোন নম্বর</label>
                            <div class="input-group input-group-enhanced">
                                <span class="input-group-text bg-light">+88</span>
                                <input type="tel" class="form-control" name="phone_number" value="{{ profileData.phone_number }}" placeholder="017XXXXXXXX" pattern="01[3-9][0-9]{8}">
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ভূমিকা <span class="text-danger">*</span></label>
                            <select class="form-select input-enhanced" name="role_id" id="roleSelect" required>
                                <option value="">নির্বাচন করুন</option>
                                {% for role in roles %}
                                    {% if role.id > 1 %}
                                <option value="{{ role.id }}" {% if profileData.role_id == role.id %}selected{% endif %}>{{ role.name_bn }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ইউনিয়ন</label>
                            <select class="form-select input-enhanced" name="union_id" id="unionSelect">
                                <option value="">কোন ইউনিয়ন নেই</option>
                                {% for union in unions %}
                                <option value="{{ union.union_id }}" {% if profileData.union_id == union.union_id %}selected{% endif %}>{{ union.union_name_bn }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6 mb-3" id="wardField" style="display:{% if profileData.role_id == 4 %}block{% else %}none{% endif %};">
                            <label class="form-label fw-semibold small text-secondary">ওয়ার্ড নং <span class="text-danger" id="wardRequired" {% if profileData.role_id != 4 %}style="display:none"{% endif %}>*</span></label>
                            <select class="form-select input-enhanced" name="ward_no" id="wardSelect">
                                <option value="">ওয়ার্ড নির্বাচন করুন</option>
                                {% for i in 1..9 %}
                                <option value="{{ i }}" {% if (profileData.ward_no ?: 0) == i %}selected{% endif %}>{{ i }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">নতুন পাসওয়ার্ড</label>
                            <div class="input-group input-group-enhanced">
                                <input type="password" class="form-control" name="password" id="password" placeholder="ফাঁকা রাখলে অপরিবর্তিত থাকবে" minlength="8" autocomplete="new-password">
                                <button class="btn btn-outline-secondary toggle-password" type="button"><i class="bi bi-eye"></i></button>
                            </div>
                            <small class="text-muted">শুধুমাত্র পরিবর্তন করতে চাইলে পূরণ করুন (কমপক্ষে ৮ অক্ষর)</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small text-secondary">পাসওয়ার্ড নিশ্চিত করুন</label>
                            <input type="password" class="form-control input-enhanced" name="confirm_password" id="confirmPassword" placeholder="ফাঁকা রাখলে অপরিবর্তিত থাকবে" minlength="8" autocomplete="new-password">
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ঠিকানা</label>
                            <textarea class="form-control input-enhanced" name="address" rows="2" maxlength="500" placeholder="বিস্তারিত ঠিকানা লিখুন...">{{ profileData.address }}</textarea>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold small text-secondary">অবস্থা</label>
                            <select class="form-select input-enhanced" name="status">
                                <option value="active" {% if profileData.status == 'active' %}selected{% endif %}>সক্রিয়</option>
                                <option value="inactive" {% if profileData.status == 'inactive' %}selected{% endif %}>নিষ্ক্রিয়</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold small text-secondary">ভাষা পছন্দ</label>
                            <select class="form-select input-enhanced" name="language_preference">
                                <option value="bn" {% if profileData.language_preference == 'bn' %}selected{% endif %}>বাংলা</option>
                                <option value="en" {% if profileData.language_preference == 'en' %}selected{% endif %}>ইংরেজি</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold small text-secondary">সময় অঞ্চল</label>
                            <select class="form-select input-enhanced" name="timezone">
                                <option value="Asia/Dhaka" {% if profileData.timezone == 'Asia/Dhaka' %}selected{% endif %}>Asia/Dhaka (UTC+6)</option>
                                <option value="Asia/Kolkata" {% if profileData.timezone == 'Asia/Kolkata' %}selected{% endif %}>Asia/Kolkata (UTC+5:30)</option>
                                <option value="UTC" {% if profileData.timezone == 'UTC' %}selected{% endif %}>UTC</option>
                            </select>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-semibold small text-secondary">বিজ্ঞপ্তি সেটিংস</label>
                            <div class="d-flex gap-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="is_email_notifications_enabled" id="emailNotif" value="1" {% if profileData.is_email_notifications_enabled %}checked{% endif %}>
                                    <label class="form-check-label" for="emailNotif">ইমেইল বিজ্ঞপ্তি</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="is_sms_notifications_enabled" id="smsNotif" value="1" {% if profileData.is_sms_notifications_enabled %}checked{% endif %}>
                                    <label class="form-check-label" for="smsNotif">এসএমএস বিজ্ঞপ্তি</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="bi bi-check2-circle me-1"></i> সংরক্ষণ করুন</button>
                        <a href="/users/{{ profileData.user_id }}" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-x-circle me-1"></i> বাতিল</a>
                    </div>
                </form>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="section-card p-4">
                <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i class="bi bi-info-circle text-info"></i> ব্যবহারকারী সংক্ষিপ্ত বিবরণ</h6>
                <ul class="list-unstyled mb-0 small">
                    <li class="d-flex justify-content-between py-2 border-bottom"><span class="text-muted">আইডি:</span><span class="fw-medium">#{{ profileData.user_id }}</span></li>
                    <li class="d-flex justify-content-between py-2 border-bottom"><span class="text-muted">নাম:</span><span class="fw-medium">{{ profileData.name_bn }}</span></li>
                    <li class="d-flex justify-content-between py-2 border-bottom"><span class="text-muted">ভূমিকা:</span><span class="fw-medium">{{ profileData.role_name }}</span></li>
                    {% if profileData.union_name_bn %}
                    <li class="d-flex justify-content-between py-2 border-bottom"><span class="text-muted">ইউনিয়ন:</span><span class="fw-medium">{{ profileData.union_name_bn }}</span></li>
                    {% endif %}
                    <li class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">অবস্থা:</span>
                        {% if profileData.status == 'active' %}<span class="badge bg-success rounded-pill">সক্রিয়</span>{% else %}<span class="badge bg-danger rounded-pill">নিষ্ক্রিয়</span>{% endif %}
                    </li>
                    <li class="d-flex justify-content-between py-2"><span class="text-muted">যোগদান:</span><span class="fw-medium">{{ profileData.created_at|date('d-m-Y') }}</span></li>
                </ul>
            </div>
            <div class="section-card p-4 mt-3">
                <h6 class="fw-bold mb-3 d-flex align-items-center gap-2"><i class="bi bi-lightning-charge text-warning"></i> দ্রুত কাজ</h6>
                <div class="d-grid gap-2">
                    <a href="/users/{{ profileData.user_id }}" class="btn btn-outline-info rounded-pill"><i class="bi bi-eye me-1"></i> প্রোফাইল দেখুন</a>
                    {% if profileData.status == 'inactive' %}
                    <button type="button" class="btn btn-success rounded-pill" id="reactivateBtn"><i class="bi bi-arrow-repeat me-1"></i> পুনরায় সক্রিয় করুন</button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
<style>
.section-card{background:#fff;border-radius:16px;box-shadow:0 2px 8px rgba(0,0,0,0.04);border:1px solid rgba(0,0,0,0.06);}
.input-enhanced{border:1px solid #ced4da;transition:border-color 0.2s ease,box-shadow 0.2s ease;}
.input-enhanced:focus{border-color:#008B8B;box-shadow:0 0 0 0.2rem rgba(0,139,139,0.15),0 0 12px rgba(0,139,139,0.08);}
.input-group-enhanced:focus-within{border-color:#008B8B;box-shadow:0 0 0 0.2rem rgba(0,139,139,0.15);border-radius:6px;}
.input-group-enhanced .form-control:focus{box-shadow:none;border-color:#ced4da;}
.toggle-password{transition:all 0.2s ease;}
.toggle-password:hover{background:#f0f0f0;}
</style>
<script>
document.addEventListener('DOMContentLoaded',function(){
    var roleSelect=document.getElementById('roleSelect'),wardField=document.getElementById('wardField'),wardSelect=document.getElementById('wardSelect'),wardRequired=document.getElementById('wardRequired'),editUserForm=document.getElementById('editUserForm');
    document.querySelectorAll('.toggle-password').forEach(function(btn){
        btn.addEventListener('click',function(){
            var input=this.parentElement.querySelector('input'),icon=this.querySelector('i');
            if(input.type==='password'){input.type='text';icon.classList.replace('bi-eye','bi-eye-slash');}
            else{input.type='password';icon.classList.replace('bi-eye-slash','bi-eye');}
        });
    });
    function toggleWardField(){
        if(roleSelect.value=='4'){wardField.style.display='block';wardSelect.required=true;wardRequired.style.display='inline';}
        else{wardField.style.display='none';wardSelect.required=false;wardSelect.value='';wardRequired.style.display='none';}
    }
    roleSelect.addEventListener('change',toggleWardField);
    var reactivateBtn=document.getElementById('reactivateBtn');
    if(reactivateBtn){
        reactivateBtn.addEventListener('click',async function(){
            var result=await Swal.fire({title:'পুনরায় সক্রিয় করবেন?',text:'এই ব্যবহারকারী আবার লগইন করতে পারবে',icon:'question',showCancelButton:true,confirmButtonColor:'#28a745',confirmButtonText:'হ্যাঁ, সক্রিয় করুন!',cancelButtonText:'বাতিল'});
            if(!result.isConfirmed)return;
            var btn=this;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span> প্রক্রিয়াধীন...';
            try{
                var fd=new FormData();fd.append('csrf_token','{{ csrf_token }}');var response=await fetch('/users/{{ profileData.user_id }}/toggle-status',{method:'POST',body:fd,headers:{'X-Requested-With':'XMLHttpRequest'}});
                var data=await response.json();
                if(response.ok&&data.success){Swal.fire({icon:'success',title:'সফল!',text:'ব্যবহারকারী পুনরায় সক্রিয় করা হয়েছে',confirmButtonText:'ঠিক আছে',timer:2000}).then(function(){window.location.reload();});}
                else{Swal.fire({icon:'error',title:'ত্রুটি!',text:data.alert?.message||'সক্রিয় করতে ব্যর্থ',confirmButtonText:'ঠিক আছে'});btn.disabled=false;btn.innerHTML='<i class="bi bi-arrow-repeat me-1"></i> পুনরায় সক্রিয় করুন';}
            }catch(error){console.error(error);Swal.fire({icon:'error',title:'ত্রুটি!',text:'সার্ভার সংযোগ ব্যর্থ',confirmButtonText:'ঠিক আছে'});btn.disabled=false;btn.innerHTML='<i class="bi bi-arrow-repeat me-1"></i> পুনরায় সক্রিয় করুন';}
        });
    }

    editUserForm.addEventListener('submit',async function(e){
        e.preventDefault();
        var submitter=e.submitter,originalHtml=submitter.innerHTML;
        submitter.disabled=true;submitter.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span> সংরক্ষণ করা হচ্ছে...';
        var password=document.getElementById('password').value,confirmPassword=document.getElementById('confirmPassword').value;
        if(password||confirmPassword){
            if(password!==confirmPassword){Swal.fire({icon:'error',title:'ত্রুটি',text:'পাসওয়ার্ড মিলছে না',confirmButtonText:'ঠিক আছে'});submitter.disabled=false;submitter.innerHTML=originalHtml;return;}
            if(password.length<8){Swal.fire({icon:'error',title:'ত্রুটি',text:'পাসওয়ার্ড কমপক্ষে ৮ অক্ষর',confirmButtonText:'ঠিক আছে'});submitter.disabled=false;submitter.innerHTML=originalHtml;return;}
        }
        if(roleSelect.value=='4'&&!wardSelect.value){Swal.fire({icon:'error',title:'ত্রুটি',text:'সদস্য ভূমিকার জন্য ওয়ার্ড নং বাধ্যতামূলক',confirmButtonText:'ঠিক আছে'});wardSelect.focus();submitter.disabled=false;submitter.innerHTML=originalHtml;return;}
        var formData=new FormData(editUserForm);
        try{
            var response=await fetch('/users/{{ profileData.user_id }}/edit',{method:'POST',body:formData,headers:{'X-Requested-With':'XMLHttpRequest'}});
            var result=await response.json();
            if(response.ok&&result.success){
                Swal.fire({icon:'success',title:'সফল!',text:result.alert?.message||'ব্যবহারকারী আপডেট হয়েছে',confirmButtonText:'ঠিক আছে',timer:2000}).then(function(){window.location.href=result.redirect||'/users/{{ profileData.user_id }}';});
            }else{
                Swal.fire({icon:'error',title:result.alert?.title||'ত্রুটি!',text:result.alert?.message||'আপডেট ব্যর্থ',confirmButtonText:'ঠিক আছে'});
            }
        }catch(error){
            console.error(error);Swal.fire({icon:'error',title:'ত্রুটি!',text:'সার্ভার সংযোগ ব্যর্থ',confirmButtonText:'ঠিক আছে'});
        }finally{submitter.disabled=false;submitter.innerHTML=originalHtml;}
    });
});
</script>
{% endblock %}

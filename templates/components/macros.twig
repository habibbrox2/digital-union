{# components/macros.twig #}

{% macro display_info_block(data) %}
    <div class="info-grid">
    {% for label, value in data %}
        <div class="info-item">
            <span class="info-label">{{ label }}</span>
            <span class="info-value">{{ value is not empty ? value : 'N/A' }}</span>
        </div>
    {% endfor %}
    </div>
{% endmacro %}

{% macro display_status_badge(status) %}
    {% set badge_class = {
        'Approved': 'bg-success',
        'approved': 'bg-success',
        'Pending': 'bg-warning text-dark',
        'pending': 'bg-warning text-dark',
        'Rejected': 'bg-danger',
        'rejected': 'bg-danger',
        'on_hold': 'bg-secondary',
        'On_Hold': 'bg-secondary'
    } %}
    {% set icons = {
        'Approved': 'bi-check-circle-fill',
        'approved': 'bi-check-circle-fill',
        'Pending': 'bi-clock-fill',
        'pending': 'bi-clock-fill',
        'Rejected': 'bi-x-circle-fill',
        'rejected': 'bi-x-circle-fill',
        'on_hold': 'bi-pause-circle-fill',
        'On_Hold': 'bi-pause-circle-fill'
    } %}
    {% set icon = icons[status] | default('bi-info-circle-fill') %}
    {% set badge = badge_class[status] | default('bg-info') %}
    <span class="badge {{ badge }} rounded-pill px-3">
        <i class="bi {{ icon }} me-1"></i> {{ status }}
    </span>
{% endmacro %}

{% macro display_documents_table(documents) %}
    {% if documents is empty %}
        <div class="text-center py-4">
            <i class="bi bi-file-earmark-x fs-1 text-muted"></i>
            <p class="text-muted fst-italic mt-2">কোনো ডকুমেন্ট আপলোড করা হয়নি।</p>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover align-middle table-enhanced">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Document Name</th>
                        <th class="text-center">Download</th>
                    </tr>
                </thead>
                <tbody>
                    {% for doc_path in documents %}
                        <tr>
                            <td>{{ loop.index }}</td>
                            <td>{{ doc_path | split('/') | last }}</td>
                            <td class="text-center">
                                <a href="{{ doc_path }}" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye me-1"></i> View
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endmacro %}

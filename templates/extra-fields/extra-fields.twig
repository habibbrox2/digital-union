{% extends "layout.twig" %}

{% block title %}অতিরিক্ত ফিল্ড{% endblock %}
{% block header_title %}অতিরিক্ত ফিল্ড ব্যবস্থাপনা{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}

<div class="container py-4">
    <!-- Page Header -->
    <div class="page-header-bar mb-4">
        <div>
            <h2 class="page-header-title mb-1">{{ header_title }}</h2>
            <p class="page-header-subtitle mb-0">সার্টিফিকেট অনুযায়ী অতিরিক্ত ফিল্ড যোগ, সম্পাদনা ও সংরক্ষণ করুন।</p>
        </div>
        <span class="badge-page"><i class="fas fa-sliders me-1"></i> এক্সট্রা ফিল্ড</span>
    </div>

    <div class="section-card">
        <!-- Certificate Type Selection -->
        <div class="row align-items-end g-3 mb-4">
            <div class="col-12 col-md-6">
                <label for="certificate_type" class="form-label fw-semibold">সার্টিফিকেটের ধরণ</label>
                <select class="form-select input-enhanced" id="certificate_type">
                    <option value="">সার্টিফিকেটের ধরণ নির্বাচন করুন</option>
                </select>
            </div>
            <div class="col-12 col-md-6 text-md-end">
                <button class="btn btn-primary" id="add_field_btn">
                    <i class="fa-solid fa-plus me-1"></i> নতুন ফিল্ড যোগ করুন
                </button>
            </div>
        </div>

        <!-- Extra Fields Table -->
        <div class="alert alert-info-soft d-flex align-items-start gap-2 mb-3" role="note">
            <i class="fas fa-circle-info mt-1"></i>
            <div>
                <strong>নতুন ফিল্ড যোগ করতে:</strong> প্রথমে উপর থেকে সঠিক সার্টিফিকেটের ধরণ নির্বাচন করুন, তারপর <em>“নতুন ফিল্ড যোগ করুন”</em> বাটনে ক্লিক করুন।
                <ul class="mb-0 mt-1 ps-3">
                    <li><strong>ফিল্ড আইডি:</strong> ইংরেজিতে ছোট অক্ষর ও আন্ডারস্কোর ব্যবহার করুন (যেমন: <code>father_name</code>)।</li>
                    <li><strong>ধরণ:</strong> ড্রপডাউন হলে <strong>অপশন (JSON)</strong> এ <code>["A","B"]</code> আকারে মান লিখুন।</li>
                    <li><strong>এরপর সাজান:</strong> কোন ফিল্ডের পরে এটি দেখাতে চান, তার আইডি দিন (ফাঁকা রাখলে শেষে যুক্ত হবে)।</li>
                </ul>
                শেষে <strong>সংরক্ষণ করুন</strong> বাটনে ক্লিক করতে ভুলবেন না।
            </div>
        </div>

        <div class="table-responsive mb-3">
            <table class="table table-hover table-enhanced align-middle text-center extra-fields-table" id="extra_fields_table">
                <thead>
                    <tr>
                        <th>ফিল্ড আইডি</th>
                        <th>লেবেল (BN)</th>
                        <th>লেবেল (EN)</th>
                        <th>ধরণ</th>
                        <th>সংখ্যা</th>
                        <th>এরপর সাজান</th>
                        <th>অপশন (JSON)</th>
                        <th>অ্যাকশন</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
            <div id="tableEmpty" class="table-empty d-none">
                <i class="fas fa-table"></i>
                <p class="mb-0">এই সার্টিফিকেটের জন্য কোনো ফিল্ড নেই। উপরের বাটনে ক্লিক করে নতুন ফিল্ড যোগ করুন।</p>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 justify-content-end">
            <button class="btn btn-success" id="save_fields_btn">
                <i class="fa-solid fa-floppy-disk me-1"></i> সংরক্ষণ করুন
            </button>
        </div>
    </div>
</div>

<!-- Hidden template row -->
<table style="display:none;">
    <tbody>
        <tr id="field_row_template">
            <td><input type="text" class="form-control form-control-sm field_id" placeholder="যেমন: father_name"></td>
            <td><input type="text" class="form-control form-control-sm label_bn"></td>
            <td><input type="text" class="form-control form-control-sm label_en"></td>
            <td>
                <select class="form-select form-select-sm type input-enhanced">
                    <option value="text">টেক্সট</option>
                    <option value="textarea">টেক্সট এরিয়া</option>
                    <option value="select">ড্রপডাউন</option>
                    <option value="date">তারিখ</option>
                    <option value="label">লেবেল</option>
                </select>
            </td>
            <td><input type="number" class="form-control form-control-sm count" value="1" min="1"></td>
            <td><input type="text" class="form-control form-control-sm order_after" placeholder="যেমন: name"></td>
            <td><input type="text" class="form-control form-control-sm options" placeholder='["A","B"]'></td>
            <td><button class="btn btn-outline-danger btn-sm remove_field_btn" title="সরান"><i class="fa-solid fa-trash"></i></button></td>
        </tr>
    </tbody>
</table>

<script>
function escapeHtml(str) {
    return $('<div>').text(str ?? '').html();
}

document.addEventListener('DOMContentLoaded', function() {
    const certificateSelect = document.getElementById('certificate_type');
    const tableBody = document.querySelector('#extra_fields_table tbody');
    const templateRow = document.querySelector('#field_row_template');
    const emptyState = document.getElementById('tableEmpty');

    function toggleEmpty() {
        emptyState.classList.toggle('d-none', tableBody.children.length > 0);
    }

    // Fetch certificate types
    fetch('/api/certificate-types')
        .then(res => res.json())
        .then(data => {
            if(data.status === 'success') {
                data.data.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c.slug;
                    opt.textContent = c.name_bn;
                    certificateSelect.appendChild(opt);
                });
            }
        });

    // Load fields on certificate type change
    certificateSelect.addEventListener('change', function(){
        const certType = this.value;
        tableBody.innerHTML = '';
        if(!certType) { toggleEmpty(); return; }

        fetch(`/api/extra-fields?certificate_type=${encodeURIComponent(certType)}`)
            .then(res => res.json())
            .then(data => {
                if(data.status === 'success') {
                    data.data.forEach(f => {
                        const newRow = templateRow.cloneNode(true);
                        newRow.removeAttribute('id');
                        newRow.style.display = '';
                        newRow.querySelector('.field_id').value = f.field_id || '';
                        newRow.querySelector('.label_bn').value = f.label_bn || '';
                        newRow.querySelector('.label_en').value = f.label_en || '';
                        newRow.querySelector('.type').value = f.type || 'text';
                        newRow.querySelector('.count').value = f.count || 1;
                        newRow.querySelector('.order_after').value = f.order_after || '';
                        newRow.querySelector('.options').value = f.options || '';
                        newRow.querySelector('.remove_field_btn').addEventListener('click', () => { newRow.remove(); toggleEmpty(); });
                        tableBody.appendChild(newRow);
                    });
                    toggleEmpty();
                }
            });
    });

    // Add new field
    document.getElementById('add_field_btn').addEventListener('click', () => {
        const newRow = templateRow.cloneNode(true);
        newRow.removeAttribute('id');
        newRow.style.display = '';
        newRow.querySelector('.remove_field_btn').addEventListener('click', () => { newRow.remove(); toggleEmpty(); });
        tableBody.appendChild(newRow);
        toggleEmpty();
    });

    // Save fields
    document.getElementById('save_fields_btn').addEventListener('click', () => {
        const certType = certificateSelect.value;
        if(!certType) return Swal.fire('ত্রুটি', 'অনুগ্রহ করে একটি সার্টিফিকেটের ধরণ নির্বাচন করুন।', 'error');

        const fields = Array.from(tableBody.querySelectorAll('tr')).map(r => ({
            field_id: r.querySelector('.field_id').value,
            label_bn: r.querySelector('.label_bn').value,
            label_en: r.querySelector('.label_en').value,
            type: r.querySelector('.type').value,
            count: parseInt(r.querySelector('.count').value) || 1,
            order_after: r.querySelector('.order_after').value,
            options: r.querySelector('.options').value
        }));

        const btn = document.getElementById('save_fields_btn');
        btn.disabled = true;
        fetch('/api/extra-fields', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({certificate_type: certType, fields})
        })
        .then(res => res.json())
        .then(data => Swal.fire('সফল', escapeHtml(data.message || 'সংরক্ষিত হয়েছে'), 'success'))
        .catch(err => Swal.fire('ত্রুটি', 'ফিল্ড সংরক্ষণ করা যায়নি', 'error'))
        .finally(() => { btn.disabled = false; });
    });

    toggleEmpty();
});
</script>

{% endblock %}

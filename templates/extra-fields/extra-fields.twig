{% extends "layout.twig" %}

{% block title %}Extra Fields{% endblock %}
{% block header_title %}Extra Fields Management{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
{% if not is_logged_in %}
    {% set redirect = "<script>window.location.href='/#';</script>" %}
    {{ redirect|raw }}
{% endif %}

<div class="container mt-5">
    <div class="card shadow-sm rounded-3 p-4">
        <h1 class="text-center mb-4">Extra Fields Management</h1>

        <!-- Certificate Type Selection -->
        <div class="mb-4">
            <label for="certificate_type" class="form-label fw-semibold">Certificate Type</label>
            <select class="form-select form-select-md mb-3" id="certificate_type">
                <option value="">Select Certificate Type</option>
            </select>
        </div>

        <!-- Extra Fields Table -->
        <div class="table-responsive mb-3">
            <table class="table table-striped table-hover table-bordered align-middle text-center" id="extra_fields_table">
                <thead class="table-light">
                    <tr>
                        <th>Field ID</th>
                        <th>Label (BN)</th>
                        <th>Label (EN)</th>
                        <th>Type</th>
                        <th>Count</th>
                        <th>Order After</th>
                        <th>Options (JSON)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <div class="d-flex flex-wrap gap-2 justify-content-center">
            <button class="btn btn-sm btn-primary d-flex align-items-center gap-1" id="add_field_btn">
                <i class="fa-solid fa-plus"></i> Add
            </button>
            <button class="btn btn-sm btn-success d-flex align-items-center gap-1" id="save_fields_btn">
                <i class="fa-solid fa-floppy-disk"></i> Save
            </button>
        </div>
    </div>
</div>

<!-- Hidden template row -->
<table style="display:none;">
    <tbody>
        <tr id="field_row_template">
            <td><input type="text" class="form-control form-control-sm field_id"></td>
            <td><input type="text" class="form-control form-control-sm label_bn"></td>
            <td><input type="text" class="form-control form-control-sm label_en"></td>
            <td>
                <select class="form-select form-select-sm type">
                    <option value="text">Text</option>
                    <option value="textarea">Textarea</option>
                    <option value="select">Select</option>
                    <option value="date">Date</option>
                    <option value="label">Label</option>
                </select>
            </td>
            <td><input type="number" class="form-control form-control-sm count" value="1"></td>
            <td><input type="text" class="form-control form-control-sm order_after"></td>
            <td><input type="text" class="form-control form-control-sm options" placeholder='JSON Array'></td>
            <td><button class="btn btn-danger btn-sm remove_field_btn"><i class="fa-solid fa-trash"></i></button></td>
        </tr>
    </tbody>
</table>

<style>
/* ---------------- Modern Responsive Styles ---------------- */
.card {
    background-color: #fff;
    border-radius: 12px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    padding: 1.5rem;
    transition: all 0.2s;
}
.card:hover {
    box-shadow: 0 8px 22px rgba(0,0,0,0.12);
}

/* Hide default arrow for select elements */
select.form-select, select.form-select-sm {
    -webkit-appearance: none; 
    -moz-appearance: none;    
    appearance: none;         
    background-image: none;   
    padding-right: 0.75rem;  
    text-align: center;
    cursor: pointer;
}

/* Hide number input spinners */
input[type=number]::-webkit-inner-spin-button, 
input[type=number]::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
}
input[type=number] {
    -moz-appearance: textfield; 
}

table th, table td {
    vertical-align: middle;
    font-size: 0.875rem;
}
table td input, table td select {
    font-size: 0.85rem;
    padding: 0.3rem 0.5rem;
    border-radius: 5px;
}
table td button {
    padding: 0.25rem;
}

/* Buttons small + icon + hover */
.btn {
    font-weight: 500;
    border-radius: 6px;
    min-width: 70px;
    transition: all 0.2s;
}
.btn-sm {
    padding: 0.35rem 0.6rem;
    font-size: 0.8rem;
}
.btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 3px 6px rgba(0,0,0,0.12);
}
.btn i {
    font-size: 0.9rem;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .table-responsive { overflow-x: auto; }
    table th, table td { font-size: 0.75rem; padding: 0.25rem; }
    .form-control-sm, .form-select-sm { font-size: 0.75rem; padding: 0.25rem 0.35rem; }
    .btn { font-size: 0.75rem; padding: 0.25rem 0.35rem; min-width: 60px; }
    .btn i { font-size: 0.75rem; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const certificateSelect = document.getElementById('certificate_type');
    const tableBody = document.querySelector('#extra_fields_table tbody');
    const templateRow = document.querySelector('#field_row_template');

    // Fetch certificate types
    fetch('/api/certificate-types')
        .then(res => res.json())
        .then(data => {
            if(data.status === 'success') {
                data.data.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c.slug;
                    opt.textContent = c.name_bn;
                    certificateSelect.appendChild(opt);
                });
            }
        });

    // Load fields on certificate type change
    certificateSelect.addEventListener('change', function(){
        const certType = this.value;
        tableBody.innerHTML = '';
        if(!certType) return;

        fetch(`/api/extra-fields?certificate_type=${certType}`)
            .then(res => res.json())
            .then(data => {
                if(data.status === 'success') {
                    data.data.forEach(f => {
                        const newRow = templateRow.cloneNode(true);
                        newRow.removeAttribute('id');
                        newRow.style.display = '';
                        newRow.querySelector('.field_id').value = f.field_id || '';
                        newRow.querySelector('.label_bn').value = f.label_bn || '';
                        newRow.querySelector('.label_en').value = f.label_en || '';
                        newRow.querySelector('.type').value = f.type || 'text';
                        newRow.querySelector('.count').value = f.count || 1;
                        newRow.querySelector('.order_after').value = f.order_after || '';
                        newRow.querySelector('.options').value = f.options || '';
                        newRow.querySelector('.remove_field_btn').addEventListener('click', () => newRow.remove());
                        tableBody.appendChild(newRow);
                    });
                }
            });
    });

    // Add new field
    document.getElementById('add_field_btn').addEventListener('click', () => {
        const newRow = templateRow.cloneNode(true);
        newRow.removeAttribute('id');
        newRow.style.display = '';
        newRow.querySelector('.remove_field_btn').addEventListener('click', () => newRow.remove());
        tableBody.appendChild(newRow);
    });

    // Save fields
    document.getElementById('save_fields_btn').addEventListener('click', () => {
        const certType = certificateSelect.value;
        if(!certType) return alert('Please select a certificate type.');

        const fields = Array.from(tableBody.querySelectorAll('tr')).map(r => ({
            field_id: r.querySelector('.field_id').value,
            label_bn: r.querySelector('.label_bn').value,
            label_en: r.querySelector('.label_en').value,
            type: r.querySelector('.type').value,
            count: parseInt(r.querySelector('.count').value) || 1,
            order_after: r.querySelector('.order_after').value,
            options: r.querySelector('.options').value
        }));

        fetch('/api/extra-fields', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({certificate_type: certType, fields})
        })
        .then(res => res.json())
        .then(data => alert(data.message))
        .catch(err => console.error(err));
    });
});
</script>

{% endblock %}

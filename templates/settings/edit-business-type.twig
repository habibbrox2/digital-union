{% extends 'layout.twig' %}

{% block title %}ব্যবসার ধরণ সম্পাদনা করুন{% endblock %}
{% block header_title %}{{ header_title|default('ব্যবসার ধরণ সম্পাদনা করুন') }}{% endblock %}

{% block content %}
{% if not is_logged_in %}
    {% set redirect = "<script>window.location.href='/#';</script>" %}
    {{ redirect|raw }}
{% endif %}

<div class="container-fluid px-0">
    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h3 class="mb-1 fw-bold" style="font-size: 1.5rem; color: #1e293b;">{{ header_title }}</h3>
            <p class="text-muted mb-0" style="font-size: 0.9rem;">
                <i class="bi bi-pencil-square me-1"></i>
                ব্যবসার ধরণ সম্পাদনা করুন
                {% if not is_superadmin and user_union_id %}
                    <span class="mx-2">&bull;</span>
                    <span class="badge bg-info bg-opacity-10 text-info-emphasis px-3 py-1 rounded-pill">
                        <i class="bi bi-pin-map me-1"></i> নিজ ইউনিয়ন
                    </span>
                {% endif %}
            </p>
        </div>
        <a href="/settings/business-types" class="btn btn-outline-secondary rounded-pill px-3">
            <i class="bi bi-arrow-left me-1"></i> ফিরে যান
        </a>
    </div>

    {% if status %}
        <div class="alert alert-{{ status == 'success' ? 'success' : 'danger' }} modern-alert d-flex align-items-center gap-2 mb-4" role="alert">
            <i class="bi bi-{{ status == 'success' ? 'check-circle-fill' : 'exclamation-triangle-fill' }} fs-5"></i>
            <span>{{ message }}</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endif %}

    <!-- Edit Form Section Card -->
    <div class="section-card">
        <div class="d-flex align-items-center gap-2 mb-4">
            <div class="section-header-icon">
                <i class="bi bi-pencil-square"></i>
            </div>
            <h5 class="section-title mb-0">
                <i class="bi bi-pencil-square text-primary me-2"></i>
                ব্যবসার ধরণ সম্পাদনা করুন
            </h5>
        </div>

        <form method="POST">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="id" value="{{ businessType.id }}">

            <!-- Union Badge (read-only reference) -->
            {% if businessType.union_id > 0 %}
            <div class="mb-4">
                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">
                    <i class="bi bi-pin-map me-1"></i>
                    {% if businessType.union_name_bn %}
                        {{ businessType.union_name_bn }}
                    {% else %}
                        ইউনিয়ন #{{ businessType.union_id }}
                    {% endif %}
                </span>
            </div>
            {% endif %}

            <div class="row g-3">
                <div class="col-md-6">
                    <label for="business_name_bn" class="form-label fw-semibold small text-secondary">ব্যবসার নাম (বাংলা) <span class="text-danger">*</span></label>
                    <input type="text" id="business_name_bn" name="business_name_bn" class="form-control input-enhanced" value="{{ businessType.business_name_bn }}" placeholder="যেমন: মুদির দোকান" required>
                </div>
                <div class="col-md-6">
                    <label for="business_name_en" class="form-label fw-semibold small text-secondary">ব্যবসার নাম (ইংরেজি) <span class="text-danger">*</span></label>
                    <input type="text" id="business_name_en" name="business_name_en" class="form-control input-enhanced" value="{{ businessType.business_name_en }}" placeholder="e.g. Departmental Store" required>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-4">
                    <label for="license_fee" class="form-label fw-semibold small text-secondary">লাইসেন্স ফি <span class="text-danger">*</span></label>
                    <div class="input-group input-enhanced">
                        <span class="input-group-text bg-light border-0">৳</span>
                        <input type="number" step="0.01" id="license_fee" name="license_fee" class="form-control border-start-0" value="{{ businessType.license_fee }}" placeholder="৫০০" required min="0">
                    </div>
                </div>
                <div class="col-md-4">
                    <label for="vat_amount" class="form-label fw-semibold small text-secondary">ভ্যাট পরিমাণ <span class="text-danger">*</span></label>
                    <div class="input-group input-enhanced">
                        <span class="input-group-text bg-light border-0">৳</span>
                        <input type="number" step="0.01" id="vat_amount" name="vat_amount" class="form-control border-start-0" value="{{ businessType.vat_amount }}" placeholder="৭৫" required min="0">
                    </div>
                </div>
                <div class="col-md-4">
                    <label for="occupation_tax" class="form-label fw-semibold small text-secondary">পেশা কর <span class="text-danger">*</span></label>
                    <div class="input-group input-enhanced">
                        <span class="input-group-text bg-light border-0">৳</span>
                        <input type="number" step="0.01" id="occupation_tax" name="occupation_tax" class="form-control border-start-0" value="{{ businessType.occupation_tax }}" placeholder="২০০" required min="0">
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-4">
                    <label for="income_tax" class="form-label fw-semibold small text-secondary">আয়কর/উৎসে কর</label>
                    <div class="input-group input-enhanced">
                        <span class="input-group-text bg-light border-0">৳</span>
                        <input type="number" step="0.01" id="income_tax" name="income_tax" class="form-control border-start-0" value="{{ businessType.income_tax }}" placeholder="০" min="0">
                    </div>
                </div>
                <div class="col-md-4">
                    <label for="signboard_tax" class="form-label fw-semibold small text-secondary">সাইনবোর্ড কর</label>
                    <div class="input-group input-enhanced">
                        <span class="input-group-text bg-light border-0">৳</span>
                        <input type="number" step="0.01" id="signboard_tax" name="signboard_tax" class="form-control border-start-0" value="{{ businessType.signboard_tax }}" placeholder="০" min="0">
                    </div>
                </div>
                <div class="col-md-4">
                    <label for="surcharge" class="form-label fw-semibold small text-secondary">সারচার্জ</label>
                    <div class="input-group input-enhanced">
                        <span class="input-group-text bg-light border-0">৳</span>
                        <input type="number" step="0.01" id="surcharge" name="surcharge" class="form-control border-start-0" value="{{ businessType.surcharge }}" placeholder="০" min="0">
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-check-circle me-1"></i> আপডেট করুন
                </button>
                <a href="{{ previous_url }}" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-x-circle me-1"></i> বাতিল
                </a>
            </div>
        </form>
    </div>
</div>

<style>
/* Re-use same input group focus styling from listing page */
.input-group.input-enhanced .form-control {
    border-left: none;
}
.input-group.input-enhanced .form-control:focus {
    border-color: #ced4da;
    box-shadow: none;
}
.input-group.input-enhanced:focus-within {
    border-color: var(--primary);
    box-shadow: 0 0 0 0.2rem rgba(0,139,139,0.15), 0 0 12px rgba(0,139,139,0.08);
    border-radius: 6px;
}
.input-group.input-enhanced:focus-within .input-group-text,
.input-group.input-enhanced:focus-within .form-control {
    border-color: var(--primary) !important;
}
@media (max-width: 768px) {
    .section-card { padding: 1rem !important; }
}
</style>
{% endblock %}
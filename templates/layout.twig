<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf_token" content="{{ csrf_token }}">
       <title>
        {% block title %}
            {{ title is defined and title ? title ~ ' - ক্যাশলেস ইউপি অ্যাপ' : 'ক্যাশলেস ইউপি অ্যাপ' }}
        {% endblock %}
    </title>
    <link rel="shortcut icon" href="{{ url }}/assets/favicon.ico" type="image/x-icon" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ url }}/assets/css/vs-datepicker.css?t={{ "now"|date("Hi") }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Custom Styles -->
    <link rel="stylesheet" href="{{ url }}/assets/styles.css?t={{ "now"|date("Hi") }}">
    <link rel="stylesheet" href="{{ url }}/assets/navbar.css?t={{ "now"|date("Hi") }}">
    {% block styles %}{% endblock %}

    <style>
        :root{
            --primary: #4f46e5;
            --primary-600: #4338ca;
            --muted: #6c757d;
            --bg: #f8f9fa;
            --card-radius: .75rem;
            --accent: #00c6ff;
        }
        body{ font-family: 'Roboto', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial; background:var(--bg); color:#212529 }
        .card{ border-radius:var(--card-radius); }
        .badge{ font-weight:600 }
        .header-logo{ max-height:48px }
        .profile-pic{ width:48px; height:48px; border-radius:50%; object-fit:cover }
        .top-button{ position:fixed; right:18px; bottom:18px; background:var(--primary); color:#fff; border:none; padding:10px 12px; border-radius:999px; box-shadow:0 8px 24px rgba(79,70,229,0.18); }
        .custom-footer{ background:linear-gradient(90deg,var(--primary),var(--primary-600)); padding:18px 0 }
        .profile-header{ background: linear-gradient(135deg,#0d6efd,#6610f2); }
        @media (max-width:768px){ .profile-header{ padding:2rem 1rem } }
    </style>



    <!-- jQuery & Plugins -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SweetAlert Util (make available early so components can use it) -->
    <script src="{{ url }}/assets/js/sweetalertUtil.js?t={{ "now"|date("Hiss") }}"></script>




</head>

<body>
    {% include 'components/sweetAlert.twig' %}
    
    <div class="wrapper">
        {% if is_logged_in %}
        {% include 'partials/sidebar.twig' %}
        <div class="main-content">
            <header>
                <div class="rtl-animation">
                    <p>{% if auth_user.union_name_bn %} {{ auth_user.union_name_bn }} এর {% endif %}স্মার্ট ইউনিয়ন পরিষদ পোর্টাল এ আপনাকে স্বাগতম</p>
                </div>
                <span class="sidebar-toggle" id="sidebar"><i class="fas fa-bars"></i></span>
            </header>

        {% if show_breadcrumbs and breadcrumbs|length > 0 %}
        <nav class="breadcrumb-nav" aria-label="breadcrumb">
            <div class="breadcrumb-container">
                <ol class="breadcrumb">
                    {% for breadcrumb in breadcrumbs %}
                        <li class="breadcrumb-item {% if breadcrumb.is_active %}active{% endif %}" 
                            {% if breadcrumb.is_active %}aria-current="page"{% endif %}>
                            {% if breadcrumb.url is defined and not breadcrumb.is_active %}
                                <a href="{{ breadcrumb.url }}" class="breadcrumb-link">
                                    {% if breadcrumb.icon %}<i class="{{ breadcrumb.icon }}"></i>{% endif %}
                                    <span>{{ breadcrumb.name }}</span>
                                </a>
                            {% else %}
                                {% if breadcrumb.icon %}<i class="{{ breadcrumb.icon }}"></i>{% endif %}
                                <span>{{ breadcrumb.name }}</span>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ol>
            </div>
        </nav>
        {% endif %}


        {% else %}
        <div class="main-container">
            <header>

                        <div class="row align-items-center">
                            <!-- Logo -->
                            <div class="col-md-4 col-sm-4 text-center">
                                <a href="https://lgdhaka.co">
                                    <img class="header-logo" src="https://lgdhaka.co/assets/images/dijital union logo.png" alt="Logo">
                                </a>
                            </div>

                            <!-- Title -->
                            <div class="col-md-4 col-sm-4 text-center">
                                <h3 class="header-title">স্মার্ট ইউপি, ঢাকা</h3>
                            </div>

                            <!-- User Profile Section -->
                            <div class="col-md-4 col-sm-4 text-center">
                                {% if auth_user %}
                                    <div class="user-profile d-inline-flex align-items-center">
                                        <img class="user-avatar" src="{{ auth_user.profile_image_url ?: '/assets/images/default-avatar.png' }}" alt="Profile" />
                                        <div class="user-info">
                                            <span class="user-name">{{ auth_user.name_bn ?: auth_user.name_en }}</span>
                                            <div class="user-links">
                                                <a href="/dashboard">ড্যাশবোর্ড</a> |
                                                <a href="/logout">লগআউট</a>
                                            </div>
                                        </div>
                                    </div>
                                {% else %}
                                    <a href="/login" class="btn btn-primary">লগইন</a>
                                {% endif %}
                            </div>
                        </div>

            </header>





        {% endif %}

        <!-- Shared content area -->
        <div class="content-body">
            {% block content %}
            <div id="csrfMessage"></div>
            {% endblock %}
        </div>

        <footer class="custom-footer text-white mt-5 pt-4 pb-2">
          <div class="container text-center">
            <p class="mb-1">&copy; 2024 Smart Union Parishad. All Rights Reserved.</p>
            
            <div class="footer-icons">
              <a href="#" class="text-white me-3" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
              <a href="#" class="text-white me-3" aria-label="Twitter"><i class="bi bi-twitter"></i></a>
              <a href="#" class="text-white me-3" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
              <a href="#" class="text-white" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
            </div>
          </div>
        </footer>



        <!-- Scroll to top -->
        <button id="topBtn" class="top-button">
            <i class="fas fa-arrow-up"></i>
        </button>

    </div>












    <script src="{{ url }}/assets/script.js?t={{ "now"|date("Hiss") }}"></script>
    <script src="{{ url }}/assets/js/csrf.js?t={{ "now"|date("Hiss") }}"></script>
    <script src="{{ url }}/assets/js/banglaValidation.js?t={{ "now"|date("Hiss") }}"></script>
    <script src="{{ url }}/assets/js/vs-datepicker.js?t={{ "now"|date("Hiss") }}"></script>
    <script src="{{ url }}/assets/js/permissions.js?t={{ "now"|date("Hiss") }}"></script>
    <!-- Debug: Enable form debugging by uncommenting below -->
    <!-- <script src="{{ url }}/assets/js/form-debug.js?t={{ "now"|date("Hiss") }}"></script> -->
    {% block scripts %} {% endblock %}
    

</body>

</html>

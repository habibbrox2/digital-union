{% extends "layout.twig" %}

{% block title %}{{ page_title }} - ডাটাবেস মাইগ্রেশন{% endblock %}
{% block header_title %}{{ page_title }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container-fluid px-0">

    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-2">
        <div>
            <h4 class="mb-0 fw-bold" style="color: #1e293b;">
                <i class="bi bi-database-gear me-2 text-primary"></i>{{ page_title }}
            </h4>
            <small class="text-muted">Safely execute SQL migrations with backup and rollback capabilities</small>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-success rounded-pill px-3 shadow-sm" onclick="showExportModal()">
                <i class="bi bi-download me-1"></i> Export DB
            </button>
            <button type="button" class="btn btn-outline-primary rounded-pill px-3" onclick="showBackupsList()">
                <i class="bi bi-clock-history me-1"></i> View Backups
            </button>
        </div>
    </div>

    <!-- Database Statistics -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="section-card p-3 text-center">
                <h3 class="text-primary mb-0 fw-bold">{{ db_stats.tables ?? '-' }}</h3>
                <small class="text-muted">Tables</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="section-card p-3 text-center">
                <h3 class="text-info mb-0 fw-bold">{{ db_stats.size ?? '-' }} MB</h3>
                <small class="text-muted">Database Size</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="section-card p-3 text-center">
                <h3 class="text-success mb-0 fw-bold">{{ db_stats.backups ?? '-' }}</h3>
                <small class="text-muted">Backups</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="section-card p-3 text-center">
                <h3 class="text-warning mb-0 fw-bold">{{ db_stats.last_backup ?? '-' }}</h3>
                <small class="text-muted">Last Backup</small>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-7">
            <!-- Upload SQL File -->
            <div class="section-card p-4 mb-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-cloud-upload text-primary"></i> Upload SQL File
                </h5>
                <form id="uploadForm" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-secondary">Select SQL File</label>
                        <div class="input-group input-group-enhanced">
                            <input type="file" class="form-control" id="sqlFile" name="sql_file" accept=".sql" required>
                            <button class="btn btn-outline-secondary" type="button" id="browseBtn">
                                <i class="bi bi-folder2-open"></i> Browse
                            </button>
                        </div>
                        <small class="text-muted">Only .sql files are supported</small>
                    </div>

                    <!-- Preview Section -->
                    <div id="previewSection" style="display: none;">
                        <hr>

                        <!-- File Info -->
                        <div class="alert alert-info alert-dismissible d-flex flex-column gap-1 p-3 mb-3" role="alert" style="position: relative;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-info-circle fs-5"></i>
                                <h6 class="mb-0 fw-bold">File Information</h6>
                            </div>
                            <div class="row small mt-1">
                                <div class="col-6">
                                    <span class="text-muted">File:</span> <span id="previewFileName" class="fw-semibold"></span><br>
                                    <span class="text-muted">Size:</span> <span id="previewFileSize" class="fw-semibold"></span>
                                </div>
                                <div class="col-6">
                                    <span class="text-muted">Total Queries:</span>
                                    <span id="previewTotalQueries" class="badge bg-info rounded-pill ms-1"></span>
                                </div>
                            </div>
                            <button type="button" class="btn-close position-absolute top-0 end-0 mt-2 me-2" data-bs-dismiss="alert"></button>
                        </div>

                        <!-- Query Statistics -->
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div class="section-card p-2 text-center">
                                    <h4 class="text-success mb-0 fw-bold">
                                        <i class="bi bi-check-circle-fill"></i>
                                        <span id="safeCount">0</span>
                                    </h4>
                                    <small class="text-muted">Safe Queries</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="section-card p-2 text-center">
                                    <h4 class="text-warning mb-0 fw-bold">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                        <span id="dangerousCount">0</span>
                                    </h4>
                                    <small class="text-muted">Dangerous Queries</small>
                                </div>
                            </div>
                        </div>

                        <!-- Dangerous Queries Table -->
                        <div id="dangerousTableSection" style="display: none;">
                            <h6 class="text-warning fw-bold mt-3 mb-2">
                                <i class="bi bi-shield-fill-exclamation"></i> Dangerous Operations (Will be backed up)
                            </h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Type</th>
                                            <th>Table</th>
                                            <th>Query Preview</th>
                                        </tr>
                                    </thead>
                                    <tbody id="dangerousQueriesBody"></tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Safe Queries Preview -->
                        <div id="safeTableSection" style="display: none;">
                            <h6 class="text-success fw-bold mt-3 mb-2">
                                <i class="bi bi-database-check"></i> Safe Queries (First 5)
                            </h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Query Preview</th>
                                        </tr>
                                    </thead>
                                    <tbody id="safeQueriesBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm" id="uploadBtn">
                            <i class="bi bi-cloud-upload me-1"></i> Upload & Preview
                        </button>
                        <button type="reset" class="btn btn-outline-secondary rounded-pill px-4" id="resetBtn">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
                        </button>
                    </div>
                </form>
            </div>

            <!-- Quick Import -->
            <div class="section-card p-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-lightning-charge text-info"></i> Quick Import
                </h5>
                <p class="small text-muted">Upload and execute an SQL file directly — skips the preview step. Use with caution!</p>
                <form id="quickImportForm" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <div class="input-group input-group-enhanced">
                        <input type="file" class="form-control" id="quickImportFile" name="sql_file" accept=".sql" required>
                        <button class="btn btn-info text-white" type="submit" id="quickImportBtn" style="border-radius: 0 50px 50px 0;">
                            <i class="bi bi-upload me-1"></i> Import & Execute
                        </button>
                    </div>
                    <small class="text-muted mt-1 d-block">Imports .sql files directly without preview. Backups are not automatically created.</small>
                </form>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-5">
            <!-- Recent Backups -->
            <div class="section-card p-4 mb-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-archive text-success"></i> Recent Backups
                </h5>
                <div id="backupsList">
                    <p class="text-muted text-center py-3 mb-0">
                        <i class="bi bi-arrow-repeat bi-spin"></i> Loading backups...
                    </p>
                </div>
            </div>

            <!-- Safety Tips -->
            <div class="section-card p-4 mb-4" style="border-left: 4px solid #0dcaf0;">
                <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-lightbulb text-info"></i> Safety Tips
                </h6>
                <ul class="small text-muted mb-0 ps-3">
                    <li class="mb-1">Always test migrations on a staging database first</li>
                    <li class="mb-1">Dangerous operations are automatically backed up</li>
                    <li class="mb-1">Review all dangerous queries before executing</li>
                    <li class="mb-1">Keep backups for at least 30 days</li>
                    <li>Only admins can execute migrations</li>
                </ul>
            </div>

            <!-- Migration History -->
            <div class="section-card p-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center justify-content-between gap-2">
                    <span><i class="bi bi-clock-history text-secondary"></i> Migration History</span>
                    <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="loadMigrationLogs()" title="Refresh logs">
                        <i class="bi bi-arrow-repeat"></i>
                    </button>
                </h5>
                <div id="migrationLogsList">
                    <p class="text-muted text-center py-3 mb-0">
                        <i class="bi bi-arrow-repeat bi-spin"></i> Loading history...
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Backups Modal -->
<div class="modal fade" id="backupsModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; overflow: hidden;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-clock-history text-primary me-1"></i> Backup History
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <div id="backupsModalContent">
                    <p class="text-center text-muted py-3 mb-0">
                        <i class="bi bi-arrow-repeat bi-spin"></i> Loading...
                    </p>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Execution Result Modal -->
<div class="modal fade" id="executionModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; overflow: hidden;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-check-circle text-success me-1"></i> Migration Results
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <div id="executionResults"></div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; overflow: hidden;">
            <div class="modal-header border-0 pb-0" style="background: linear-gradient(135deg, #198754, #157347);">
                <h5 class="modal-title fw-bold text-white">
                    <i class="bi bi-download me-1"></i> Export Database
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 pt-3">
                <!-- Options -->
                <div class="row g-2 mb-3">
                    <div class="col-md-6">
                        <div class="section-card p-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="exportDataType" id="exportDataIncluded" value="1" checked>
                                <label class="form-check-label fw-semibold" for="exportDataIncluded">
                                    <i class="bi bi-database text-success"></i> Structure & Data
                                </label>
                                <small class="d-block text-muted mt-1">Export table structures with all data</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="section-card p-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="exportDataType" id="exportStructureOnly" value="0">
                                <label class="form-check-label fw-semibold" for="exportStructureOnly">
                                    <i class="bi bi-code-square text-info"></i> Structure Only
                                </label>
                                <small class="d-block text-muted mt-1">Export only CREATE TABLE statements</small>
                            </div>
                        </div>
                    </div>
                </div>

                <hr>

                <!-- Table Selection -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="fw-bold mb-0"><i class="bi bi-table me-1"></i> Select Tables</h6>
                    <div class="d-flex gap-1">
                        <button type="button" class="btn btn-sm btn-outline-success rounded-pill" onclick="selectAllTables(true)">
                            <i class="bi bi-check-square"></i> All
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="selectAllTables(false)">
                            <i class="bi bi-square"></i> None
                        </button>
                    </div>
                </div>
                <div class="input-group input-group-enhanced input-group-sm mb-2">
                    <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" id="tableSearchInput" placeholder="Search tables by name..." oninput="filterTables(this.value)">
                    <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('tableSearchInput').value='';filterTables('')" title="Clear search">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div id="tableSelectionList" class="table-selection-list" style="max-height: 270px; overflow-y: auto;">
                    <p class="text-muted text-center py-3 mb-0">
                        <i class="bi bi-arrow-repeat fa-spin"></i> Loading tables...
                    </p>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <span id="selectedCount" class="text-muted small me-auto">0 tables selected</span>
                <button type="button" class="btn btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success rounded-pill px-4 shadow-sm" id="exportBtn" onclick="startExport()">
                    <i class="bi bi-download me-1"></i> Export
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Quick Import Result Modal -->
<div class="modal fade" id="quickImportModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; overflow: hidden;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-lightning-charge text-info me-1"></i> Quick Import Results
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4" id="quickImportResults"></div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Migration Log Detail Modal -->
<div class="modal fade" id="logDetailModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; overflow: hidden;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-scroll text-secondary me-1"></i> Migration Log Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <div id="logDetailContent">
                    <p class="text-muted text-center py-3 mb-0"><i class="bi bi-arrow-repeat bi-spin"></i> Loading...</p>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<style>
.section-card{background:#fff;border-radius:16px;box-shadow:0 2px 8px rgba(0,0,0,0.04);border:1px solid rgba(0,0,0,0.06);}
.input-enhanced{border:1px solid #ced4da;transition:border-color 0.2s ease,box-shadow 0.2s ease;}
.input-enhanced:focus{border-color:#008B8B;box-shadow:0 0 0 0.2rem rgba(0,139,139,0.15),0 0 12px rgba(0,139,139,0.08);}
.input-group-enhanced:focus-within{border-color:#008B8B;box-shadow:0 0 0 0.2rem rgba(0,139,139,0.15);border-radius:6px;}
.input-group-enhanced .form-control:focus{box-shadow:none;border-color:#ced4da;}
.table-selection-list .list-group-item{transition:background 0.15s ease;}
.table-selection-list .list-group-item:hover{background:#f8f9fa;}
.modal-content{border:1px solid rgba(0,0,0,0.06);}
/* Bootstrap Icons spin animation */
@keyframes bi-spin {
  0%   { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
.bi-spin{animation:bi-spin 2s linear infinite;}
</style>

{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
const CSRF_TOKEN = "{{ csrf_token }}";
let currentMigration = null;

// File upload handler
document.getElementById('uploadForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const fileInput = document.getElementById('sqlFile');
    if (!fileInput.files.length) {
        Swal.fire('ত্রুটি', 'অনুগ্রহ করে একটি SQL ফাইল নির্বাচন করুন', 'error');
        return;
    }

    const formData = new FormData();
    formData.append('sql_file', fileInput.files[0]);
    formData.append('csrf_token', CSRF_TOKEN);
    formData.append('action', 'preview');

    try {
        showLoadingAlert('SQL ফাইল বিশ্লেষণ করা হচ্ছে...');

        const response = await fetch('/admin/database/migrations/preview', {
            method: 'POST',
            body: formData
        });

        const result = await response.json();

        if (!result.data || response.status !== 200) {
            throw new Error(result.message || 'ফাইল প্রিভিউ করতে ব্যর্থ');
        }

        currentMigration = result.data;
        displayPreview(result.data);
        
        Swal.close();
    } catch (error) {
        Swal.fire('ত্রুটি', error.message, 'error');
    }
});

// Display preview
function displayPreview(data) {
    document.getElementById('previewSection').style.display = 'block';
    document.getElementById('previewFileName').textContent = data.file_name;
    document.getElementById('previewFileSize').textContent = data.file_size;
    document.getElementById('previewTotalQueries').textContent = data.total_queries;
    document.getElementById('safeCount').textContent = data.safe_count;
    document.getElementById('dangerousCount').textContent = data.dangerous_count;

    // Display dangerous queries
    if (data.dangerous_count > 0 && data.dangerous_queries && data.dangerous_queries.length > 0) {
        document.getElementById('dangerousTableSection').style.display = 'block';
        const tbody = document.getElementById('dangerousQueriesBody');
        tbody.innerHTML = '';

        data.dangerous_queries.forEach(item => {
            const type = extractQueryType(item.query || item);
            const query = item.query || item;
            const preview = query.substring(0, 50) + (query.length > 50 ? '...' : '');
            tbody.innerHTML += `
                <tr class="table-warning">
                    <td><span class="badge bg-warning text-dark rounded-pill">${type}</span></td>
                    <td><code>${item.table || 'N/A'}</code></td>
                    <td><code class="text-truncate d-inline-block" style="max-width: 200px;">${preview}</code></td>
                </tr>
            `;
        });
    }

    // Display safe queries
    if (data.safe_count > 0 && data.safe_queries && data.safe_queries.length > 0) {
        document.getElementById('safeTableSection').style.display = 'block';
        const tbody = document.getElementById('safeQueriesBody');
        tbody.innerHTML = '';

        data.safe_queries.forEach(query => {
            const preview = query.substring(0, 60) + (query.length > 60 ? '...' : '');
            tbody.innerHTML += `
                <tr>
                    <td><code class="text-truncate">${preview}</code></td>
                </tr>
            `;
        });
    }
}

// Extract query type
function extractQueryType(query) {
    const match = query.match(/^\s*(\w+)/i);
    return match ? match[1].toUpperCase() : 'UNKNOWN';
}

// Show loading alert
function showLoadingAlert(message) {
    Swal.fire({
        title: message,
        allowOutsideClick: false,
        didOpen: () => {
            Swal.showLoading();
        }
    });
}

// Execute migration
document.addEventListener('DOMContentLoaded', function() {
    const uploadForm = document.getElementById('uploadForm');
    
    const observer = new MutationObserver(function(mutations) {
        const previewSection = document.getElementById('previewSection');
        if (previewSection.style.display !== 'none' && !document.getElementById('executeBtn')) {
            const executeBtn = document.createElement('button');
            executeBtn.type = 'button';
            executeBtn.id = 'executeBtn';
            executeBtn.className = 'btn btn-success rounded-pill px-4 shadow-sm ms-2';
            executeBtn.innerHTML = '<i class="bi bi-play-fill me-1"></i> Execute Migration';
            executeBtn.onclick = executeMigration;
            
            uploadForm.querySelector('[type="submit"]').parentElement.appendChild(executeBtn);
        }
    });

    observer.observe(uploadForm, { subtree: true, attributes: true });
});

// Execute migration
async function executeMigration() {
    if (!currentMigration) {
        Swal.fire('ত্রুটি', 'প্রথমে একটি ফাইল আপলোড ও প্রিভিউ করুন', 'error');
        return;
    }

    const dangerousCount = currentMigration.dangerous_count;
    
    let confirmMessage = `আপনি কি এই মাইগ্রেশন এক্সিকিউট করতে চান?\n\n`;
    confirmMessage += `নিরাপদ কোয়েরি: ${currentMigration.safe_count}\n`;
    
    if (dangerousCount > 0) {
        confirmMessage += `\n⚠️ বিপজ্জনক অপারেশন: ${dangerousCount}\n`;
        confirmMessage += `স্বয়ংক্রিয় ব্যাকআপ তৈরি হবে!\n`;
    }

    const result = await Swal.fire({
        title: 'মাইগ্রেশন নিশ্চিতকরণ',
        html: confirmMessage.replace(/\n/g, '<br>'),
        icon: dangerousCount > 0 ? 'warning' : 'question',
        showCancelButton: true,
        confirmButtonColor: '#28a745',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'হ্যাঁ, এক্সিকিউট!',
        cancelButtonText: 'বাতিল',
        input: dangerousCount > 0 ? 'checkbox' : null,
        inputValue: 0,
        inputPlaceholder: 'আমি ঝুঁকি বুঝতে পেরেছি এবং ব্যাকআপ তৈরি হবে',
        preConfirm: () => {
            if (dangerousCount > 0 && !Swal.getInput().checked) {
                Swal.showValidationMessage('অনুগ্রহ করে ঝুঁকি স্বীকার করুন');
                return false;
            }
            return true;
        }
    });

    if (!result.isConfirmed) return;

    try {
        showLoadingAlert('মাইগ্রেশন এক্সিকিউট করা হচ্ছে...');

        const response = await fetch('/admin/database/migrations/execute', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                csrf_token: CSRF_TOKEN
            })
        });

        const resultData = await response.json();

        Swal.close();

        if (response.status !== 200) {
            Swal.fire('ত্রুটি', resultData.message, 'error');
            return;
        }

        showExecutionResults(resultData.data);

        document.getElementById('uploadForm').reset();
        document.getElementById('previewSection').style.display = 'none';
        document.getElementById('executeBtn')?.remove();
        currentMigration = null;

        loadBackupsList();

    } catch (error) {
        Swal.fire('ত্রুটি', error.message, 'error');
    }
}

// Show execution results
function showExecutionResults(data) {
    let html = '';

    if (data.safe_results && data.safe_results.length > 0) {
        html += '<div class="mb-3">';
        html += '<h6 class="text-success fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Safe Queries</h6>';
        html += '<div class="table-responsive">';
        html += '<table class="table table-sm align-middle">';
        html += '<thead class="table-success"><tr><th>Query</th><th>Status</th></tr></thead>';
        html += '<tbody>';

        data.safe_results.forEach(r => {
            const statusBadge = r.status === 'success' 
                ? '<span class="badge bg-success rounded-pill">Success</span>' 
                : '<span class="badge bg-danger rounded-pill">Error</span>';
            html += `<tr><td><code class="small">${r.query.substring(0, 50)}...</code></td><td>${statusBadge}</td></tr>`;
        });

        html += '</tbody></table></div></div>';
    }

    if (data.dangerous_results && data.dangerous_results.length > 0) {
        html += '<div class="mb-3">';
        html += '<h6 class="text-warning fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> Dangerous Operations</h6>';
        html += '<div class="table-responsive">';
        html += '<table class="table table-sm align-middle">';
        html += '<thead class="table-warning"><tr><th>Table</th><th>Backup</th><th>Status</th></tr></thead>';
        html += '<tbody>';

        data.dangerous_results.forEach(r => {
            const statusBadge = r.status === 'success' 
                ? '<span class="badge bg-success rounded-pill">Success</span>' 
                : '<span class="badge bg-danger rounded-pill">Error</span>';
            const backupFile = r.backup ? r.backup.split('/').pop() : 'N/A';
            html += `<tr><td><code>${r.table}</code></td><td><small>${backupFile}</small></td><td>${statusBadge}</td></tr>`;
        });

        html += '</tbody></table></div></div>';
    }

    if (data.log && data.log.length > 0) {
        html += '<div class="mb-3">';
        html += '<h6 class="fw-bold"><i class="bi bi-terminal me-1"></i> Execution Log</h6>';
        html += '<pre class="bg-dark text-light p-3 rounded small" style="max-height: 200px; overflow-y: auto; font-size: 11px;">';
        html += data.log.join('\n');
        html += '</pre></div>';
    }

    document.getElementById('executionResults').innerHTML = html;
    new bootstrap.Modal(document.getElementById('executionModal')).show();

    Swal.fire({
        title: 'মাইগ্রেশন সম্পন্ন!',
        text: 'সব কোয়েরি সফলভাবে এক্সিকিউট হয়েছে।',
        icon: 'success',
        confirmButtonColor: '#28a745',
        confirmButtonText: 'ঠিক আছে'
    });
}

// Load backups list
async function loadBackupsList() {
    try {
        const response = await fetch('/admin/database/migrations/backups', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ csrf_token: CSRF_TOKEN })
        });

        const result = await response.json();

        if (!result.data || !result.data.backups || result.data.backups.length === 0) {
            document.getElementById('backupsList').innerHTML = '<p class="text-muted text-center py-3 mb-0"><i class="bi bi-inbox me-1"></i> No backups yet</p>';
            return;
        }

        let html = '<div class="list-group list-group-flush">';
        result.data.backups.slice(0, 5).forEach(backup => {
            html += `
                <div class="list-group-item list-group-item-action px-0 border-start-0 border-end-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="flex-grow-1 me-2">
                            <h6 class="mb-1"><code>${backup.name}</code></h6>
                            <small class="text-muted">${backup.date} • ${backup.size}</small>

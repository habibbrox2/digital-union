// Render table checkboxes
function renderTableSelection(tables) {
    if (!tables.length) {
        document.getElementById('tableSelectionList').innerHTML = 
            '<p class="text-muted text-center py-3 mb-0">No tables found</p>';
        updateSelectedCount();
        return;
    }
    
    let html = '<div class="list-group list-group-flush">';
    tables.forEach(function(table, index) {
        html += `
            <label class="list-group-item list-group-item-action d-flex align-items-center gap-2 px-2">
                <input class="form-check-input table-checkbox m-0" type="checkbox" 
                       value="${table.name}" checked 
                       onchange="updateSelectedCount()">
                <div class="flex-grow-1">
                    <strong>${table.name}</strong>
                    <small class="text-muted ms-2">${table.rows.toLocaleString()} rows</small>
                    <small class="text-muted ms-2">${table.size}</small>
                </div>
                <button type="button" class="btn btn-sm btn-outline-success rounded-pill" 
                        onclick="exportSingleTable('${table.name}', this)" 
                        title="Export this table">
                    <i class="bi bi-download"></i>
                </button>
                <span class="badge bg-light text-muted rounded-pill">${table.engine || '?'}</span>
            </label>
        `;
    });
    html += '</div>';
    
    document.getElementById('tableSelectionList').innerHTML = html;
    updateSelectedCount();
}

// Export single table
async function exportSingleTable(tableName, btn) {
    const originalHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-arrow-repeat bi-spin"></i>';
    
    try {
        const response = await fetch('/admin/database/migrations/export-table', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                csrf_token: CSRF_TOKEN,
                table: tableName
            })
        });
        
        const result = await response.json();
        
        if (response.status === 200 && result.data) {
            const downloadResponse = await fetch('/admin/database/migrations/download', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ csrf_token: CSRF_TOKEN })
            });
            
            if (downloadResponse.ok) {
                const blob = await downloadResponse.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = result.data.file_name;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                window.URL.revokeObjectURL(url);
                
                Swal.fire({
                    title: 'Export Complete!',
                    text: result.data.file_name + ' (' + result.data.file_size + ')',
                    icon: 'success',
                    confirmButtonText: 'ঠিক আছে'
                });
            } else {
                Swal.fire({
                    title: 'Export Ready',
                    html: '<a href="/admin/database/migrations/download" class="btn btn-success rounded-pill"><i class="bi bi-download me-1"></i> Download ' + result.data.file_name + '</a>',
                    icon: 'success',
                    confirmButtonText: 'ঠিক আছে'
                });
            }
        } else {
            Swal.fire('ত্রুটি', result.message || 'একক টেবিল এক্সপোর্ট ব্যর্থ', 'error');
        }
    } catch (error) {
        Swal.fire('ত্রুটি', error.message, 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
    }
}

// Select/deselect all tables
function selectAllTables(select) {
    document.querySelectorAll('.table-checkbox').forEach(function(cb) {
        cb.checked = select;
    });
    updateSelectedCount();
}

// Update selected count display
function updateSelectedCount() {
    const count = document.querySelectorAll('.table-checkbox:checked').length;
    const total = document.querySelectorAll('.table-checkbox').length;
    document.getElementById('selectedCount').textContent = count + ' / ' + total + ' tables selected';
}

// Filter tables by name search
function filterTables(query) {
    const normalized = query.toLowerCase().trim();
    const items = document.querySelectorAll('#tableSelectionList .list-group-item');
    let visibleCount = 0;
    items.forEach(function(item) {
        const label = item.querySelector('strong');
        const name = label ? label.textContent.toLowerCase() : '';
        if (!normalized || name.includes(normalized)) {
            item.style.display = '';
            visibleCount++;
        } else {
            item.style.display = 'none';
        }
    });
    const noResults = document.getElementById('tableNoResults');
    if (!visibleCount && items.length > 0) {
        if (!noResults) {
            const msg = document.createElement('p');
            msg.id = 'tableNoResults';
            msg.className = 'text-muted text-center py-3 mb-0';
            msg.textContent = 'No tables match "' + query + '"';
            document.getElementById('tableSelectionList').appendChild(msg);
        }
    } else if (noResults) {
        noResults.remove();
    }
    updateSelectedCount();
}


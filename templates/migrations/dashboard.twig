// ================================================================

async function loadMigrationLogs() {
    const container = document.getElementById('migrationLogsList');
    if (!container) return;

    container.innerHTML = '<p class="text-muted text-center py-3 mb-0"><i class="bi bi-arrow-repeat bi-spin"></i> Loading history...</p>';

    try {
        const response = await fetch('/admin/database/migrations/logs', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ csrf_token: CSRF_TOKEN, limit: 20 })
        });

        const result = await response.json();

        if (!result.data) {
            container.innerHTML = '<p class="text-muted text-center py-3 mb-0">Failed to load history</p>';
            return;
        }

        renderMigrationLogs(result.data);
    } catch (error) {
        container.innerHTML = '<p class="text-muted text-center py-3 mb-0">Error: ' + error.message + '</p>';
    }
}

function renderMigrationLogs(data) {
    const container = document.getElementById('migrationLogsList');
    const logs = data.logs || [];
    const summary = data.summary || {};

    if (!logs.length) {
        container.innerHTML = '<div class="text-center py-4"><i class="bi bi-inbox text-muted" style="font-size: 2rem;"></i><p class="text-muted mt-2 mb-0">No migration history yet</p><small class="text-muted">Executed migrations will appear here</small></div>';
        return;
    }

    let html = '<div class="small text-muted mb-2 d-flex justify-content-between">';
    html += '<span><strong>' + summary.total_migrations + '</strong> migrations</span>';
    html += '<span><strong>' + summary.total_queries + '</strong> queries</span>';
    html += '<span class="' + (summary.total_errors > 0 ? 'text-danger' : 'text-success') + '"><strong>' + summary.total_errors + '</strong> errors</span>';
    html += '</div>';

    html += '<div class="list-group list-group-flush" style="max-height: 250px; overflow-y: auto;">';

    logs.forEach(function(log, index) {
        const isError = log.error_count > 0;
        const hasDangerous = log.dangerous_total > 0;

        let badgeColor = 'bg-success';
        if (isError) badgeColor = 'bg-danger';
        else if (hasDangerous) badgeColor = 'bg-warning text-dark';

        const date = log.timestamp ? new Date(log.timestamp).toLocaleString() : '-';
        const displayName = log.filename.length > 30 ? log.filename.substring(0, 27) + '...' : log.filename;

        html += '<div class="list-group-item list-group-item-action py-2 px-3 border-start-0 border-end-0" onclick="showLogDetail(' + index + ')" style="cursor: pointer;">';
        html += '<div class="d-flex justify-content-between align-items-center">';
        html += '<div class="flex-grow-1 me-2">';
        html += '<div class="d-flex align-items-center gap-2">';
        html += '<span class="badge ' + badgeColor + ' rounded-pill" style="width: 8px; height: 8px; padding: 0;">&nbsp;</span>';
        html += '<code class="small">' + displayName + '</code>';
        html += '</div>';
        html += '<small class="text-muted d-block mt-1">' + date + '</small>';
        html += '</div>';
        html += '<div class="text-end small text-nowrap">';
        html += '<span class="me-2">' + log.total_queries + ' q</span>';
        if (log.error_count > 0) {
            html += '<span class="badge bg-danger rounded-pill">' + log.error_count + ' err</span>';
        } else {
            html += '<span class="badge bg-success rounded-pill">OK</span>';
        }
        html += '</div>';
        html += '</div>';
        html += '</div>';
    });

    html += '</div>';

    window._migrationLogsData = logs;

    container.innerHTML = html;
}

function showLogDetail(index) {
    const logs = window._migrationLogsData || [];
    const log = logs[index];
    if (!log) return;

    const container = document.getElementById('logDetailContent');

    let html = '';

    // Header info
    html += '<div class="row g-2 mb-3">';
    html += '<div class="col-md-6"><strong>File:</strong> <code>' + log.filename + '</code></div>';
    html += '<div class="col-md-3"><strong>Date:</strong> ' + (log.timestamp || '-') + '</div>';
    html += '<div class="col-md-3"><strong>User ID:</strong> ' + (log.user_id || 'System') + '</div>';
    html += '</div>';

    // Stats badges
    html += '<div class="d-flex flex-wrap gap-2 mb-3">';
    html += '<span class="badge bg-info rounded-pill fs-6 fw-normal">' + log.total_queries + ' Total</span>';
    html += '<span class="badge bg-success rounded-pill fs-6 fw-normal">' + log.safe_success + ' / ' + log.safe_total + ' Safe</span>';
    if (log.dangerous_total > 0) {
        html += '<span class="badge bg-warning text-dark rounded-pill fs-6 fw-normal">' + log.dangerous_total + ' Dangerous</span>';
    }
    if (log.error_count > 0) {
        html += '<span class="badge bg-danger rounded-pill fs-6 fw-normal">' + log.error_count + ' Errors</span>';
    }
    html += '</div>';

    // Results table
    if (log.results_json) {
        try {
            const results = JSON.parse(log.results_json);

            ['safe_results', 'dangerous_results'].forEach(function(key) {
                const items = results[key] || [];
                if (!items.length) return;

                const isDangerous = key === 'dangerous_results';
                html += '<h6 class="mt-3 mb-2 fw-bold ' + (isDangerous ? 'text-warning' : 'text-success') + '">';
                html += '<i class="bi bi-' + (isDangerous ? 'exclamation-triangle-fill' : 'check-circle-fill') + ' me-1"></i> ';
                html += (isDangerous ? 'Dangerous Operations' : 'Safe Queries');
                html += ' (' + items.length + ')';
                html += '</h6>';
                html += '<div class="table-responsive" style="max-height: 200px; overflow-y: auto;">';
                html += '<table class="table table-sm table-bordered align-middle">';
                html += '<thead class="' + (isDangerous ? 'table-warning' : 'table-success') + '"><tr>';
                if (isDangerous) html += '<th>Table</th><th>Backup</th>';
                html += '<th>Query</th><th>Status</th></tr></thead><tbody>';

                items.forEach(function(r) {
                    const statusClass = r.status === 'success' ? 'text-success' : 'text-danger';
                    const statusIcon = r.status === 'success' ? 'check-circle-fill' : 'x-circle-fill';
                    html += '<tr>';
                    if (isDangerous) {
                        html += '<td><code>' + (r.table || '-') + '</code></td>';
                        html += '<td><small>' + (r.backup ? r.backup.split('/').pop() : '-') + '</small></td>';
                    }
                    html += '<td><code class="small">' + (r.query ? r.query.substring(0, 60) + (r.query.length > 60 ? '...' : '') : '-') + '</code></td>';
                    html += '<td><i class="bi bi-' + statusIcon + ' ' + statusClass + ' me-1"></i> ' + (r.status || '-') + '</td>';
                    html += '</tr>';
                });

                html += '</tbody></table></div>';
            });
        } catch (e) {
            html += '<div class="alert alert-warning">Could not parse results JSON</div>';
        }
    }

    // Execution log text
    if (log.log) {
        html += '<h6 class="mt-3 mb-2 fw-bold"><i class="bi bi-terminal me-1"></i> Execution Log</h6>';
        html += '<pre class="bg-dark text-light p-3 rounded small" style="max-height: 200px; overflow-y: auto; font-size: 11px;">' + log.log + '</pre>';
    }

    container.innerHTML = html;
    new bootstrap.Modal(document.getElementById('logDetailModal')).show();
}


</script>
{% endblock %}

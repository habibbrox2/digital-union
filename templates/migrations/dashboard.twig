// Show quick import results
function showQuickImportResults(data) {
    const result = data.result || {};
    let html = '';
    
    // Summary
    html += '<div class="row g-2 mb-3">';
    html += '<div class="col-4 text-center"><h3 class="text-info fw-bold mb-0">' + (result.total || 0) + '</h3><small class="text-muted">Total</small></div>';
    html += '<div class="col-4 text-center"><h3 class="text-success fw-bold mb-0">' + (result.success || 0) + '</h3><small class="text-muted">Success</small></div>';
    html += '<div class="col-4 text-center"><h3 class="text-danger fw-bold mb-0">' + (result.errors || 0) + '</h3><small class="text-muted">Errors</small></div>';
    html += '</div>';
    
    html += '<p><strong>File:</strong> ' + (data.file_name || '-') + ' (' + (data.file_size || '-') + ')</p>';
    
    // Errors list
    if (result.error_messages && result.error_messages.length > 0) {
        html += '<h6 class="text-danger fw-bold mt-3 mb-2"><i class="bi bi-exclamation-circle me-1"></i> Errors</h6>';
        html += '<div class="alert alert-danger p-2" style="max-height: 200px; overflow-y: auto;">';
        html += '<table class="table table-sm table-borderless mb-0"><tbody>';
        result.error_messages.forEach(function(err) {
            html += '<tr><td><code class="small">' + (err.query || '') + '</code></td><td class="text-danger">' + (err.error || '') + '</td></tr>';
        });
        html += '</tbody></table></div>';
    }
    
    if (result.errors === 0) {
        html += '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill me-1"></i> All queries executed successfully!</div>';
    }
    
    document.getElementById('quickImportResults').innerHTML = html;
    new bootstrap.Modal(document.getElementById('quickImportModal')).show();
    
    Swal.fire({
        title: 'Import Complete!',
        text: result.success + ' queries executed, ' + result.errors + ' errors',
        icon: result.errors > 0 ? 'warning' : 'success',
        confirmButtonText: 'ঠিক আছে'
    });
}


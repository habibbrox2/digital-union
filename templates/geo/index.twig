{% extends "layout.twig" %}

{% block title %}উন্নত ভৌগোলিক অবস্থান{% endblock %}

{% block header_title %}ভৌগোলিক অবস্থান{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}

<div class="container py-4">
    <!-- Page Header -->
    <div class="page-header-bar mb-4">
        <div>
            <h2 class="page-header-title mb-1">{{ header_title }}</h2>
            <p class="page-header-subtitle mb-0">বিভাগ থেকে ইউনিয়ন পর্যন্ত ধাপে ধাপে ভৌগোলিক তথ্য নির্বাচন ও আমদানি করুন।</p>
        </div>
        <span class="badge-page"><i class="fas fa-map-location-dot me-1"></i> জিও</span>
    </div>

    <!-- Select Geo Location -->
    <div class="section-card mb-4">
        <h3 class="section-title"><i class="fas fa-map-location-dot text-primary"></i> ভৌগোলিক অবস্থান নির্বাচন</h3>

        <div class="row g-3">
            <div class="col-12 col-md-6 col-lg-3">
                <label for="division" class="form-label">বিভাগ</label>
                <select id="division" class="form-select input-enhanced" disabled></select>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <label for="district" class="form-label">জেলা</label>
                <select id="district" class="form-select input-enhanced" disabled></select>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <label for="upazila" class="form-label">উপজেলা</label>
                <select id="upazila" class="form-select input-enhanced" disabled></select>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <label for="union" class="form-label">ইউনিয়ন</label>
                <select id="union" class="form-select input-enhanced" disabled></select>
            </div>
        </div>
    </div>

    <!-- Upload XML -->
    <div class="section-card mb-4">
        <h3 class="section-title"><i class="fas fa-file-import text-primary"></i> URL থেকে XML ফাইল আমদানি</h3>

        <form id="xmlUploadForm" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="xml_url" class="form-label">XML ফাইলের URL লিখুন</label>
                <input type="url" name="xml_url" id="xml_url" class="form-control input-enhanced" placeholder="https://bdris.gov.bd/..." required>
                <div class="invalid-feedback">অনুগ্রহ করে একটি বৈধ XML URL লিখুন।</div>
            </div>
            <button type="submit" id="uploadButton" class="btn btn-primary">
                <i class="fas fa-upload me-1"></i> আমদানি করুন
            </button>
            <span id="uploadSpinner" class="spinner-border spinner-border-sm text-primary d-none ms-2" role="status" aria-hidden="true"></span>
        </form>

        <div id="statusMessage" class="mt-3">
            {% if status == 'success' %}
                <div class="alert alert-success"><pre class="mb-0">{{ message }}</pre></div>
            {% elseif status == 'error' %}
                <div class="alert alert-danger"><pre class="mb-0">{{ message }}</pre></div>
            {% endif %}
        </div>
    </div>

    <!-- Geo Data List -->
    <div class="section-card">
        <h3 class="section-title"><i class="fas fa-table text-primary"></i> ভৌগোলিক তথ্যের তালিকা</h3>

        <div class="table-responsive">
            <table class="table table-hover table-enhanced align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>আইডি</th>
                        <th>নাম (EN)</th>
                        <th>নাম (BN)</th>
                        <th>জিও অর্ডার</th>
                        <th>জিও কোড</th>
                        <th>আর.এম.ও কোড</th>
                        <th>সাব-নোড সংখ্যা</th>
                    </tr>
                </thead>
                <tbody id="geoData">
                    <tr><td colspan="8" class="text-center text-muted py-4">লোড হচ্ছে...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
    // --- Constants ---
    const GEO_ORDER = { division: 0, district: 1, upazila: 2, union: 3 };
    const BASE_XML_URL = 'https://bdris.gov.bd/v1/api/geo/parentGeoIdWithGeoGroupAndGeoOrder';
    const API_ENDPOINTS = {
        fetchGeo: '/geo/getByType',
        storeGeo: '/geo/store'
    };

    // --- DOM Elements ---
    const xmlUrlInput = document.getElementById('xml_url');
    const division = document.getElementById('division');
    const district = document.getElementById('district');
    const upazila = document.getElementById('upazila');
    const union = document.getElementById('union');
    const geoTableBody = document.getElementById('geoData');
    const statusMessage = document.getElementById('statusMessage');
    const uploadButton = document.getElementById('uploadButton');
    const uploadSpinner = document.getElementById('uploadSpinner');
    const selectElements = [division, district, upazila, union];

    // --- Utility Functions ---

    function setSelectsDisabled(isDisabled) {
        selectElements.forEach(el => el.disabled = isDisabled);
    }

    function setLoadingState(selectEl, isLoading) {
        if (isLoading) {
            selectEl.innerHTML = '<option value="">-- লোড হচ্ছে... --</option>';
            selectEl.disabled = true;
        } else {
            selectEl.disabled = false;
        }
    }

    function updateXmlUrl(selectEl) {
        const selected = selectEl.options[selectEl.selectedIndex];
        if (!selected || !selected.value || !selected.dataset.geoOrder) {
            xmlUrlInput.value = '';
            return;
        }

        const parentGeoId = selected.value;
        const nextGeoOrder = parseInt(selected.dataset.geoOrder, 10) + 1;

        xmlUrlInput.value = `${BASE_XML_URL}/${parentGeoId}?geoGroup=birthPlace&geoOrder=${nextGeoOrder}&geoType=${nextGeoOrder}`;
    }

    function escapeHtml(str) {
        return $('<div>').text(str ?? '').html();
    }

    function populateTable(selectEl) {
        geoTableBody.innerHTML = '';
        const options = Array.from(selectEl.options).filter(opt => opt.value);

        if (options.length === 0) {
            geoTableBody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">কোনো তথ্য পাওয়া যায়নি</td></tr>';
            return;
        }

        options.forEach((opt, index) => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${index + 1}</td>
                <td>${escapeHtml(opt.value)}</td>
                <td>${escapeHtml(opt.dataset.nameEn)}</td>
                <td>${escapeHtml(opt.dataset.nameBn)}</td>
                <td>${escapeHtml(opt.dataset.geoOrder)}</td>
                <td>${escapeHtml(opt.dataset.geoCode)}</td>
                <td>${escapeHtml(opt.dataset.rmoCode)}</td>
                <td>${escapeHtml(opt.dataset.childCount)}</td>
            `;
            geoTableBody.appendChild(tr);
        });
    }

    async function loadDropdown(selectEl, geoOrder, parentId = 0) {
        setLoadingState(selectEl, true);

        try {
            const formData = new FormData();
            formData.append('geo_order', geoOrder);
            formData.append('parent_geo_id', parentId);

            const res = await fetch(API_ENDPOINTS.fetchGeo, { method: 'POST', body: formData });

            if (!res.ok) {
                 throw new Error(`HTTP error! status: ${res.status}`);
            }

            const data = await res.json();

            selectEl.innerHTML = '';
            const placeholder = document.createElement('option');
            placeholder.value = '';
            placeholder.textContent = parentId === 0 ? '-- বিভাগ নির্বাচন করুন --' : '-- নির্বাচন করুন --';
            selectEl.appendChild(placeholder);

            if (data.status === 'success' && Array.isArray(data.data)) {
                data.data.forEach(item => {
                    const option = document.createElement('option');
                    option.value = item.id;
                    option.textContent = `${item.name_en} / ${item.name_bn} (${item.child_count})`;
                    option.dataset.nameEn = item.name_en;
                    option.dataset.nameBn = item.name_bn;
                    option.dataset.geoOrder = item.geo_order;
                    option.dataset.geoCode = item.geo_code;
                    option.dataset.rmoCode = item.rmo_code;
                    option.dataset.childCount = item.child_count;
                    selectEl.appendChild(option);
                });
            } else {
                 console.warn('API returned non-success or no array data:', data);
            }
        } catch (err) {
            console.error('Error loading dropdown:', err);
            selectEl.innerHTML = `<option value="" disabled>-- লোড ত্রুটি --</option>`;
        } finally {
            setLoadingState(selectEl, false);
            selectEl.value = '';
            updateXmlUrl(selectEl);
        }
    }

    // --- Event Listeners and Cascading Logic ---

    division.addEventListener('change', async function() {
        const divisionId = division.value || 0;
        district.value = upazila.value = union.value = '';
        upazila.innerHTML = union.innerHTML = '';

        if (divisionId) {
            await loadDropdown(district, GEO_ORDER.district, divisionId);
        } else {
            district.innerHTML = '';
        }
        populateTable(division);
        updateXmlUrl(division);
    });

    district.addEventListener('change', async function() {
        const districtId = district.value || 0;
        upazila.value = union.value = '';
        union.innerHTML = '';

        if (districtId) {
            await loadDropdown(upazila, GEO_ORDER.upazila, districtId);
        } else {
            upazila.innerHTML = '';
        }
        populateTable(district);
        updateXmlUrl(district);
    });

    upazila.addEventListener('change', async function() {
        const upazilaId = upazila.value || 0;
        union.value = '';

        if (upazilaId) {
            await loadDropdown(union, GEO_ORDER.union, upazilaId);
        } else {
            union.innerHTML = '';
        }
        populateTable(upazila);
        updateXmlUrl(upazila);
    });

    union.addEventListener('change', function() {
        populateTable(union);
        updateXmlUrl(union);
    });

    document.getElementById('xmlUploadForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const xmlUrl = xmlUrlInput.value.trim();
        const isFormValid = document.getElementById('xmlUploadForm').checkValidity();

        if (!xmlUrl || !isFormValid) {
            document.getElementById('xmlUploadForm').classList.add('was-validated');
            return;
        }

        uploadButton.disabled = true;
        uploadButton.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> প্রক্রিয়াকরণ হচ্ছে...';
        uploadSpinner.classList.remove('d-none');
        statusMessage.innerHTML = `<div class="alert alert-info">URL থেকে আমদানি করা হচ্ছে: <code>${escapeHtml(xmlUrl)}</code>...</div>`;

        const formData = new FormData();
        formData.append('xml_url', xmlUrl);

        fetch(API_ENDPOINTS.storeGeo, { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                statusMessage.innerHTML = '';
                if (data.status === 'success') {
                    statusMessage.innerHTML = `<div class="alert alert-success">✅ সফল: <pre class="mb-0">${escapeHtml(data.message)}</pre></div>`;
                } else {
                    statusMessage.innerHTML = `<div class="alert alert-danger">❌ ত্রুটি: <pre class="mb-0">${escapeHtml(data.message)}</pre></div>`;
                }
            })
            .catch(err => {
                console.error('AJAX Error on Store:', err);
                statusMessage.innerHTML = `<div class="alert alert-danger">গুরুতর ত্রুটি: নেটওয়ার্ক সমস্যা বা অপ্রত্যাশিত রেস্পন্স। ${escapeHtml(err.message)}</div>`;
            })
            .finally(() => {
                uploadButton.disabled = false;
                uploadButton.innerHTML = '<i class="fas fa-upload me-1"></i> আমদানি করুন';
                uploadSpinner.classList.add('d-none');
            });
    });

    // --- Initial Load ---
    (async function initialLoad() {
        setSelectsDisabled(true);
        await loadDropdown(division, GEO_ORDER.division);
        populateTable(division);
    })();
});
</script>

{% endblock %}
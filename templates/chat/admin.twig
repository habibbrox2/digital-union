{% extends "layout.twig" %}

{% block styles %}
<link rel="stylesheet" href="{{ url }}/assets/css/chat.css?t={{ "now"|date("Hiss") }}">
{% endblock %}

{% block content %}
<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-bold" style="color: #008B8B;">
            <i class="fas fa-comments me-2"></i>লাইভ চ্যাট সমূহ
            <span class="chat-total-unread-badge" id="totalUnreadBadge" style="display:none;">0</span>
        </h5>
        <button class="btn btn-sm btn-outline-primary" id="adminRefreshBtn">
            <i class="fas fa-sync-alt me-1"></i>রিফ্রেশ
        </button>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="chat-admin-layout">
                <!-- Conversations List -->
                <div class="chat-conversations-list" id="convList">
                    <div class="chat-conversations-header">
                        <i class="fas fa-comment-dots" style="color: #008B8B;"></i>
                        কথোপকথন
                    </div>
                    <div class="chat-search-area">
                        <div class="chat-search-row">
                            <div class="chat-search-input-wrapper">
                                <i class="fas fa-search chat-search-icon"></i>
                                <input type="text" class="chat-search-input" id="convSearchInput" placeholder="নাম, ইউনিয়ন বা বার্তা দ্বারা খুঁজুন..." autocomplete="off">
                                <button type="button" class="chat-search-clear" id="convSearchClear" style="display:none;"><i class="fas fa-times"></i></button>
                            </div>
                            <select class="chat-status-filter" id="convStatusFilter">
                                <option value="">সব</option>
                                <option value="active">সক্রিয়</option>
                                <option value="closed">বন্ধ</option>
                            </select>
                        </div>
                        <div class="chat-bulk-actions">
                            <button type="button" class="chat-bulk-btn chat-bulk-read" id="bulkReadAllBtn" title="সব পঠিত করুন">
                                <i class="fas fa-check-double"></i> সব পঠিত
                            </button>
                            <button type="button" class="chat-bulk-btn chat-bulk-close" id="bulkCloseAllBtn" title="সকল সক্রিয় কথোপকথন বন্ধ করুন">
                                <i class="fas fa-times-circle"></i> সব বন্ধ
                            </button>
                        </div>
                    </div>
                    <div id="convItems">
                        <div class="chat-no-convs">
                            <i class="fas fa-inbox fa-2x mb-2 d-block" style="color: #ddd;"></i>
                            কোনো কথোপকথন নেই
                        </div>
                    </div>
                </div>

                <!-- Conversation View -->
                <div class="chat-admin-view" id="chatAdminView">
                    <div class="chat-empty-state" id="chatEmptyState">
                        <div class="chat-empty-state-icon">
                            <i class="fas fa-comment-dots"></i>
                        </div>
                        <div class="chat-empty-state-text">
                            একটি কথোপকথন নির্বাচন করুন<br>
                            <small style="color: #bbb;">বাম দিকের তালিকা থেকে একটি চ্যাট বেছে নিন</small>
                        </div>
                    </div>

                    <div class="chat-admin-view-content" id="chatViewContent" style="display: none;">
                        <div class="chat-admin-view-header">
                            <div>
                                <div class="chat-admin-view-title" id="chatViewTitle">কথোপকথন</div>
                                <small class="text-muted" id="chatViewMeta"></small>
                            </div>
                            <div class="chat-admin-view-actions">
                                <button class="btn btn-sm btn-outline-danger" id="closeConvBtn" title="কথোপকথন বন্ধ করুন">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>
                        <div class="chat-open-tabs" id="chatOpenTabs" role="tablist" aria-label="Open conversations"></div>
                        <div class="chat-admin-messages" id="chatAdminMessages"></div>
                        <div class="chat-admin-input-area">
                            <div class="chat-admin-toolbar">
                                <button type="button" class="chat-admin-tool-btn" id="adminEmojiBtn" title="ইমোজি"><i class="far fa-smile"></i></button>
                                <button type="button" class="chat-admin-tool-btn" id="adminFileBtn" title="ফাইল আপলোড"><i class="fas fa-paperclip"></i></button>
                                <button type="button" class="chat-admin-tool-btn canned-btn" id="adminCannedBtn" title="কুইক রিপ্লাই"><i class="fas fa-bolt"></i></button>
                                <input type="file" class="chat-file-input" id="adminFileInput" accept="image/jpeg,image/png,image/gif,image/webp,application/pdf,.doc,.docx,.xls,.xlsx,.txt,.csv,.zip">
                            </div>
                            <div style="position: relative;">
                                <div class="chat-admin-emoji-picker" id="adminEmojiPicker"></div>
                                <div class="chat-canned-panel" id="adminCannedPanel">
                                    <div class="canned-search">
                                        <input type="text" id="cannedSearchInput" placeholder="খুঁজুন..." autocomplete="off">
                                    </div>
                                    <div id="cannedResults">
                                        <div class="canned-no-results">লোড হচ্ছে...</div>
                                    </div>
                                </div>
                                <div id="adminUploadPreview"></div>
                                <div class="chat-admin-input-row" style="position: relative;">
                                    <div class="chat-autocomplete-dropdown" id="adminAutocompleteDropdown">
                                        <div class="chat-autocomplete-header">
                                            <span><i class="fas fa-bolt"></i> কুইক রিপ্লাই সুপারিশ</span>
                                        </div>
                                        <div id="adminAutocompleteResults"></div>
                                    </div>
                                    <textarea class="chat-admin-input" id="adminChatInput" rows="2" placeholder="উত্তর লিখুন..." maxlength="1000"></textarea>
                                    <button class="btn" id="adminSendBtn" style="background: #008B8B; color: #fff; border-radius: 10px; padding: 10px 20px; white-space: nowrap;">
                                        <i class="fas fa-paper-plane me-1"></i>পাঠান
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
(function() {
    'use strict';

    let activeSessionId = null;
    let pendingFile = null;
    const openConversationIds = [];

    // Common emojis
    const EMOJIS = [
        '😀','😃','😄','😁','😅','😂','🤣',
        '😊','😇','🙂','😉','😌','😍','🥰',
        '😘','😗','😙','😚','🤗','🤩','🤔',
        '🤨','😐','😑','😶','🙄','😏','😣',
        '😥','😮','🤐','😯','😪','😫','😴',
        '😤','😡','🤬','😈','👿','💀','☠️',
        '💩','🤡','👹','👺','👻','👽','👾',
        '👍','👎','👊','✊','🤛','🤜','👏',
        '🙌','👐','🤲','🤝','🙏','✍️','💅',
        '❤️','🧡','💛','💚','💙','💜','🖤',
        '💔','❣️','💕','💞','💓','💗','💖',
        '✨','🌟','⭐','🌠','🔥','💯','✅',
    ];

    // DOM refs
    const convListEl = document.getElementById('convItems');
    const emptyState = document.getElementById('chatEmptyState');
    const viewContent = document.getElementById('chatViewContent');
    const viewTitle = document.getElementById('chatViewTitle');
    const viewMeta = document.getElementById('chatViewMeta');
    const openTabsEl = document.getElementById('chatOpenTabs');
    const adminMessages = document.getElementById('chatAdminMessages');
    const adminInput = document.getElementById('adminChatInput');
    const adminSendBtn = document.getElementById('adminSendBtn');
    const closeConvBtn = document.getElementById('closeConvBtn');
    const adminEmojiBtn = document.getElementById('adminEmojiBtn');
    const adminEmojiPicker = document.getElementById('adminEmojiPicker');
    const adminFileBtn = document.getElementById('adminFileBtn');
    const adminFileInput = document.getElementById('adminFileInput');
    const adminUploadPreview = document.getElementById('adminUploadPreview');
    let isReplyPending = false;

    function getConversationLabel(sessionId) {
        const conv = allConversations.find(function(item) { return item.session_id === sessionId; });
        return conv && conv.visitor_name ? conv.visitor_name : 'Visitor';
    }

    function renderOpenTabs() {
        if (!openTabsEl) return;
        openTabsEl.innerHTML = '';
        openConversationIds.forEach(function(sessionId) {
            const tab = document.createElement('button');
            tab.type = 'button';
            tab.className = 'chat-open-tab' + (sessionId === activeSessionId ? ' active' : '');
            tab.setAttribute('role', 'tab');
            tab.setAttribute('aria-selected', sessionId === activeSessionId ? 'true' : 'false');
            tab.title = sessionId;
            const label = document.createElement('span');
            label.textContent = getConversationLabel(sessionId);
            const close = document.createElement('span');
            close.className = 'chat-open-tab-close';
            close.innerHTML = '&times;';
            close.setAttribute('aria-label', 'Close conversation tab');
            close.addEventListener('click', function(e) {
                e.stopPropagation();
                const index = openConversationIds.indexOf(sessionId);
                if (index >= 0) openConversationIds.splice(index, 1);
                if (activeSessionId === sessionId) {
                    const nextId = openConversationIds[index] || openConversationIds[index - 1] || null;
                    if (nextId) loadConversation(nextId);
                    else {
                        activeSessionId = null;
                        emptyState.style.display = 'flex';
                        viewContent.style.display = 'none';
                    }
                }
                renderOpenTabs();
            });
            tab.appendChild(label);
            tab.appendChild(close);
            tab.addEventListener('click', function() { loadConversation(sessionId); });
            openTabsEl.appendChild(tab);
        });
    }

    // Init emoji picker
    (function buildEmojiPicker() {
        const grid = document.createElement('div');
        grid.className = 'chat-emoji-grid';
        EMOJIS.forEach(function(emoji) {
            const btn = document.createElement('button');
            btn.className = 'chat-emoji-item';
            btn.textContent = emoji;
            btn.type = 'button';
            btn.addEventListener('click', function() {
                const cursorPos = adminInput.selectionStart;
                const text = adminInput.value;
                adminInput.value = text.slice(0, cursorPos) + emoji + text.slice(cursorPos);
                adminInput.focus();
                adminInput.selectionStart = adminInput.selectionEnd = cursorPos + emoji.length;
                adminEmojiPicker.classList.remove('open');
            });
            grid.appendChild(btn);
        });
        adminEmojiPicker.appendChild(grid);
    })();

    adminEmojiBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        adminEmojiPicker.classList.toggle('open');
    });

    document.addEventListener('click', function(e) {
        if (adminEmojiPicker && !adminEmojiPicker.contains(e.target) && e.target !== adminEmojiBtn) {
            adminEmojiPicker.classList.remove('open');
        }
    });

    // File upload
    adminFileBtn.addEventListener('click', function() {
        adminFileInput.click();
    });

    adminFileInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file) return;

        if (file.size > 10 * 1024 * 1024) {
            if (typeof SweetAlertUtil !== 'undefined') {
                SweetAlertUtil.toast('ফাইলটি খুব বড়। সর্বোচ্চ ১০MB অনুমোদিত।', 'error');
            } else {
                alert('ফাইলটি খুব বড়। সর্বোচ্চ ১০MB অনুমোদিত।');
            }
            e.target.value = '';
            return;
        }

        pendingFile = file;
        adminUploadPreview.innerHTML = `
            <div class="chat-upload-preview">
                <i class="fas ${file.type.startsWith('image/') ? 'fa-file-image' : 'fa-file'}"></i>
                <span class="chat-upload-preview-name">${file.name}</span>
                <button type="button" class="chat-upload-preview-remove" id="adminUploadRemove">&times;</button>
                <div class="chat-upload-progress"><div class="chat-upload-progress-bar" id="adminUploadProgress"></div></div>
            </div>
        `;

        document.getElementById('adminUploadRemove').addEventListener('click', function() {
            pendingFile = null;
            adminUploadPreview.innerHTML = '';
            adminFileInput.value = '';
        });
    });

    // Helper functions
    function formatTime(dateStr) {
        const d = new Date(dateStr);
        const now = new Date();
        const hrs = d.getHours().toString().padStart(2, '0');
        const mins = d.getMinutes().toString().padStart(2, '0');
        const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        const msgDate = new Date(d.getFullYear(), d.getMonth(), d.getDate());
        const diffDays = Math.floor((today - msgDate) / (1000 * 60 * 60 * 24));
        if (diffDays === 0) return 'আজ ' + hrs + ':' + mins;
        if (diffDays === 1) return 'গতকাল ' + hrs + ':' + mins;
        return d.getDate().toString().padStart(2, '0') + '/' + (d.getMonth() + 1).toString().padStart(2, '0') + ' ' + hrs + ':' + mins;
    }

    function sanitizeHTML(text) {
        if (typeof text !== 'string') return '';
        if (typeof DOMPurify !== 'undefined' && DOMPurify.sanitize) {
            return DOMPurify.sanitize(text, { ALLOWED_TAGS: [], ALLOWED_ATTR: [] });
        }
        return text.replace(/<[^>]*>/g, '');
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = sanitizeHTML(text);
        return div.innerHTML;
    }

    function formatFileSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(1) + ' MB';
    }

    function getFileIcon(mimeType) {
        if (!mimeType) return 'fa-file';
        if (mimeType.startsWith('image/')) return 'fa-file-image';
        if (mimeType.includes('pdf')) return 'fa-file-pdf';
        if (mimeType.includes('word') || mimeType.includes('document')) return 'fa-file-word';
        if (mimeType.includes('excel') || mimeType.includes('spreadsheet')) return 'fa-file-excel';
        if (mimeType.includes('zip') || mimeType.includes('rar')) return 'fa-file-archive';
        return 'fa-file';
    }

    // ========================================
    // File Preview
    // ========================================
    function isPreviewableFile(msg) {
        if (!msg || !msg.file_url) return false;
        if (msg.message_type === 'image') return false;
        const type = (msg.file_type || '').toLowerCase();
        return type.indexOf('pdf') !== -1 ||
            type.indexOf('word') !== -1 || type.indexOf('document') !== -1 ||
            type.indexOf('excel') !== -1 || type.indexOf('spreadsheet') !== -1 ||
            type.indexOf('presentation') !== -1 || type.indexOf('powerpoint') !== -1 ||
            type.indexOf('text/plain') !== -1 || type.indexOf('text/csv') !== -1;
    }

    function getPreviewUrl(fileUrl, fileType) {
        const type = (fileType || '').toLowerCase();
        if (type.indexOf('pdf') !== -1) return fileUrl;
        if (type.indexOf('word') !== -1 || type.indexOf('document') !== -1 ||
            type.indexOf('excel') !== -1 || type.indexOf('spreadsheet') !== -1 ||
            type.indexOf('presentation') !== -1 || type.indexOf('powerpoint') !== -1) {
            return 'https://docs.google.com/viewer?url=' + encodeURIComponent(fileUrl) + '&embedded=true';
        }
        return null;
    }

    function showFilePreview(msg) {
        if (!msg || !msg.file_url) return;

        const existing = document.getElementById('chatFilePreview');
        if (existing) existing.remove();

        const overlay = document.createElement('div');
        overlay.className = 'chat-preview-overlay';
        overlay.id = 'chatFilePreview';

        const container = document.createElement('div');
        container.className = 'chat-preview-container';

        const header = document.createElement('div');
        header.className = 'chat-preview-header';

        const title = document.createElement('span');
        title.className = 'chat-preview-title';
        title.textContent = msg.file_name || 'File Preview';
        header.appendChild(title);

        const closeBtn = document.createElement('button');
        closeBtn.className = 'chat-preview-close';
        closeBtn.innerHTML = '&times;';
        closeBtn.setAttribute('aria-label', 'Close preview');
        closeBtn.addEventListener('click', function () { overlay.remove(); });
        header.appendChild(closeBtn);
        container.appendChild(header);

        const body = document.createElement('div');
        body.className = 'chat-preview-body';

        const type = (msg.file_type || '').toLowerCase();
        if (type.indexOf('text/plain') !== -1 || type.indexOf('text/csv') !== -1) {
            const pre = document.createElement('pre');
            pre.className = 'chat-preview-text';
            pre.textContent = '\u09b2\u09cb\u09a1 \u09b9\u099a\u09cd\u099b\u09c7...';
            body.appendChild(pre);
            container.appendChild(body);
            overlay.appendChild(container);
            document.body.appendChild(overlay);

            fetch(msg.file_url)
                .then(function (r) { return r.text(); })
                .then(function (txt) { pre.textContent = txt; })
                .catch(function () { pre.textContent = '\u09ab\u09be\u0987\u09b2 \u09b2\u09cb\u09a1 \u0995\u09b0\u09be \u09af\u09be\u09df\u09a8\u09bf\u0964'; });
            return;
        }

        const previewUrl = getPreviewUrl(msg.file_url, msg.file_type);

        if (type.indexOf('pdf') !== -1) {
            const embed = document.createElement('embed');
            embed.src = previewUrl;
            embed.type = 'application/pdf';
            embed.className = 'chat-preview-embed';
            body.appendChild(embed);
        } else if (previewUrl) {
            const iframe = document.createElement('iframe');
            iframe.src = previewUrl;
            iframe.className = 'chat-preview-embed';
            iframe.setAttribute('frameborder', '0');
            iframe.setAttribute('allowfullscreen', 'true');
            body.appendChild(iframe);
        }

        container.appendChild(body);
        overlay.appendChild(container);
        document.body.appendChild(overlay);

        overlay.addEventListener('click', function (e) {
            if (e.target === overlay) overlay.remove();
        });

        function onKeydown(e) {
            if (e.key === 'Escape') {
                overlay.remove();
                document.removeEventListener('keydown', onKeydown);
            }
        }
        document.addEventListener('keydown', onKeydown);
    }

    function renderMessageHTML(msg) {
        const senderType = getMessageSenderType(msg);
        const senderLabel = senderType === 'admin' ? 'সহায়ক' : 'দর্শক';
        let html = '<div class="chat-msg-sender-row"><span class="chat-msg-sender">' + senderLabel + '</span>';
        if (senderType === 'admin' && msg.auto_reply == 1) {
            html += '<span class="chat-msg-auto-reply-badge">🤖 স্বচালিত উত্তর</span>';
        }
        html += '</div>';

        if (msg.message_type === 'text' || !msg.message_type) {
            html += '<div class="chat-msg-text">' + escapeHtml(msg.message) + '</div>';
        }

        if (msg.file_url) {
            if (msg.message_type === 'image') {
                html += '<a href="javascript:void(0)" class="chat-msg-image-link chat-msg-image-zoom-trigger" data-img-src="' + msg.file_url + '" data-img-name="' + escapeAttr(msg.file_name || 'Image') + '" role="button"><img src="' + msg.file_url + '" class="chat-msg-image" alt="' + escapeHtml(msg.file_name || 'Image') + '" loading="lazy"></a>';
            } else {
                html += '<a href="' + msg.file_url + '" target="_blank" class="chat-msg-file" download="' + escapeHtml(msg.file_name || 'file') + '">';
                html += '<span class="chat-msg-file-icon"><i class="fas ' + getFileIcon(msg.file_type) + '"></i></span>';
                html += '<span class="chat-msg-file-info"><span class="chat-msg-file-name">' + escapeHtml(msg.file_name || 'File') + '</span>';
                if (msg.file_size) {
                    html += '<span class="chat-msg-file-size">' + formatFileSize(parseInt(msg.file_size)) + '</span>';
                }
                html += '</span></a>';                    // Preview button for previewable files
                if (isPreviewableFile(msg)) {
                    html += '<button type="button" class="chat-msg-preview-btn" data-preview-msg="' + escapeAttr(JSON.stringify(msg)) + '">';
                    html += '<i class="fas fa-eye"></i> \u09aa\u09cd\u09b0\u09bf\u09ad\u09bf\u0989';
                    html += '</button>';
                }
            }
        }

        html += '<div class="chat-msg-footer">';
        html += '<span class="chat-msg-time">' + formatTime(msg.created_at) + '</span>';
        // Read status for visitor messages
        if (senderType === 'visitor') {
            html += '<span class="chat-msg-status">';
            if (msg.read_at || msg.is_read == 1) {
                html += '<span class="status-icon status-read"><i class="fas fa-check-double"></i> পঠিত</span>';
            } else if (msg.delivered_at) {
                html += '<span class="status-icon status-delivered"><i class="fas fa-check-double"></i> প্রাপ্ত</span>';
            } else {
                html += '<span class="status-icon status-sent"><i class="fas fa-check"></i> প্রেরিত</span>';
            }
            html += '</span>';
        } else if (senderType === 'admin' && msg.auto_reply != 1) {
            html += '<span class="chat-msg-status">';
            if (msg.read_at || msg.is_read == 1) {
                html += '<span class="status-icon status-read"><i class="fas fa-check-double"></i> Seen</span>';
            } else if (msg.delivered_at) {
                html += '<span class="status-icon status-delivered"><i class="fas fa-check-double"></i> Delivered</span>';
            } else {
                html += '<span class="status-icon status-sent"><i class="fas fa-check"></i> Sent</span>';
            }
            html += '</span>';
        }
        html += '</div>';

        return html;
    }

    // Normalize both current and legacy API payloads so a missing/invalid
    // sender_type cannot move an admin reply into the visitor side.
    function getMessageSenderType(msg) {
        const sender = String((msg && (msg.sender_type || msg.sender || msg.role)) || '').toLowerCase();
        return sender === 'admin' || (msg && msg.admin_id !== null && msg.admin_id !== undefined) || Number(msg && msg.auto_reply) === 1
            ? 'admin' : 'visitor';
    }

    // Conversation search/filter + pagination
    const CONV_PAGE_SIZE = 50;
    let allConversations = [];
    let conversationsOffset = 0;
    let hasMoreConversations = true;
    let isLoadingConversations = false;
    let loadedConversationIds = new Set();
    const convSearchInput = document.getElementById('convSearchInput');
    const convSearchClear = document.getElementById('convSearchClear');
    const convStatusFilter = document.getElementById('convStatusFilter');
    let convSearchFilter = '';
    let convStatusValue = '';

    function filterConversations() {
        const q = convSearchFilter.trim().toLowerCase();

        let filtered = allConversations;

        // Apply status filter
        if (convStatusValue) {
            filtered = filtered.filter(function(conv) {
                return conv.status === convStatusValue;
            });
        }

        // Apply text search
        if (q) {
            filtered = filtered.filter(function(conv) {
                const name = (conv.visitor_name || '').toLowerCase();
                const union = (conv.visitor_union_name || '').toLowerCase();
                const msgText = (conv.last_message || '').toLowerCase();
                return name.indexOf(q) !== -1 || union.indexOf(q) !== -1 || msgText.indexOf(q) !== -1;
            });
        }

        return filtered;
    }

    function applyFilters() {
        renderConversations(filterConversations());
    }

    convSearchInput.addEventListener('input', function() {
        convSearchFilter = this.value;
        convSearchClear.style.display = this.value ? 'block' : 'none';
        applyFilters();
    });

    convStatusFilter.addEventListener('change', function() {
        convStatusValue = this.value;
        applyFilters();
    });

    convSearchClear.addEventListener('click', function() {
        convSearchInput.value = '';
        convSearchFilter = '';
        convSearchClear.style.display = 'none';
        convStatusFilter.value = '';
        convStatusValue = '';
        renderConversations(filterConversations());
        convSearchInput.focus();
    });

    // Fetch conversations with pagination
    async function loadConversations(append) {
        if (isLoadingConversations) return;
        if (append && !hasMoreConversations) return;

        isLoadingConversations = true;
        const offset = append ? conversationsOffset : 0;

        try {
            const res = await fetch('/api/chat/admin/conversations?offset=' + offset + '&limit=' + CONV_PAGE_SIZE);
            const data = await res.json();
            const newConvs = data.data || [];
            hasMoreConversations = data.has_more || false;

            if (append) {
                // Append mode: add only new conversation IDs (avoid duplicates)
                newConvs.forEach(function(conv) {
                    if (!loadedConversationIds.has(conv.session_id)) {
                        loadedConversationIds.add(conv.session_id);
                        allConversations.push(conv);
                    }
                });
                conversationsOffset = allConversations.length;
            } else {
                // Full reload: reset everything
                allConversations = newConvs;
                conversationsOffset = newConvs.length;
                loadedConversationIds.clear();
                newConvs.forEach(function(conv) {
                    loadedConversationIds.add(conv.session_id);
                });
            }

            renderConversations(filterConversations());
            renderLoadMoreButton();
        } catch (e) {
            console.error('Failed to load conversations:', e);
        } finally {
            isLoadingConversations = false;
        }
    }

    // Load-more button
    function renderLoadMoreButton() {
        // Remove existing load-more button
        const existing = convListEl.querySelector('.chat-load-more-convs');
        if (existing) existing.remove();

        if (hasMoreConversations && allConversations.length > 0) {
            const loadMore = document.createElement('div');
            loadMore.className = 'chat-load-more-convs';
            loadMore.innerHTML = '<button type="button" class="chat-load-more-btn"><i class="fas fa-chevron-down"></i> আরও লোড করুন (' + conversationsOffset + ' loaded)</button>';
            loadMore.querySelector('button').addEventListener('click', function() {
                loadConversations(true);
            });
            convListEl.appendChild(loadMore);
        }
    }

    function renderConversations(convs) {
        convListEl.innerHTML = '';

        if (!convs || convs.length === 0) {
            // Show different empty message based on whether there's an active search
            if (convSearchFilter.trim()) {
                convListEl.innerHTML = '<div class="chat-no-convs"><i class="fas fa-search fa-2x mb-2 d-block" style="color: #ddd;"></i>কিছু পাওয়া যায়নি</div>';
            } else {
                convListEl.innerHTML = '<div class="chat-no-convs"><i class="fas fa-inbox fa-2x mb-2 d-block" style="color: #ddd;"></i>কোনো কথোপকথন নেই</div>';
            }
            return;
        }

        convs.forEach(function(conv) {
            const item = document.createElement('div');
            item.className = 'chat-conversation-item' + (conv.session_id === activeSessionId ? ' active' : '');
            item.dataset.sessionId = conv.session_id;

            const name = conv.visitor_name || 'অজ্ঞাত দর্শক';
            const union = conv.visitor_union_name || '';
            let preview = conv.last_message || 'কোনো বার্তা নেই';
            let previewPrefix = '';
            if (conv.last_message_type === 'image') previewPrefix = '🖼️ ';
            else if (conv.last_message_type === 'file') previewPrefix = '📎 ';

            if (preview.length > 50) preview = preview.substring(0, 50) + '...';
            const time = conv.last_message_time ? formatTime(conv.last_message_time) : formatTime(conv.created_at);
            const isActive = conv.status === 'active';

            item.innerHTML = `
                <div class="chat-conv-name">${escapeHtml(name)}</div>
                ${union ? '<div class="chat-conv-union"><i class="fas fa-map-marker-alt" style="font-size: 11px; margin-right: 4px;"></i>' + escapeHtml(union) + '</div>' : ''}
                <div class="chat-conv-preview">${previewPrefix}${escapeHtml(preview)}</div>
                <div class="chat-conv-meta">
                    <span class="chat-conv-time">${time}</span>
                    <div>
                        ${parseInt(conv.unread) > 0 ? '<span class="chat-conv-unread">' + conv.unread + '</span>' : ''}
                        <span class="chat-conv-status ${isActive ? 'active' : 'closed'}">${isActive ? 'সক্রিয়' : 'বন্ধ'}</span>
                    </div>
                </div>
            `;

            item.addEventListener('click', function() {
                loadConversation(conv.session_id);
            });

            convListEl.appendChild(item);
        });
    }

    // Load a specific conversation
    async function loadConversation(sessionId) {
        activeSessionId = sessionId;
        if (!openConversationIds.includes(sessionId)) openConversationIds.push(sessionId);
        renderOpenTabs();

        document.querySelectorAll('.chat-conversation-item').forEach(function(el) {
            el.classList.toggle('active', el.dataset.sessionId === sessionId);
        });

        try {
            const res = await fetch('/api/chat/admin/conversations/' + encodeURIComponent(sessionId));
            const data = await res.json();
            const messages = data.data || [];

            emptyState.style.display = 'none';
            viewContent.style.display = 'flex';

            const activeConv = document.querySelector('.chat-conversation-item.active');
            const convName = activeConv ? (activeConv.querySelector('.chat-conv-name')?.textContent || 'অজ্ঞাত') : 'অজ্ঞাত';
            const convUnion = activeConv ? (activeConv.querySelector('.chat-conv-union')?.textContent || '') : '';
            viewTitle.textContent = convName;
            viewMeta.innerHTML = '<i class="fas fa-map-marker-alt" style="color: #008B8B; font-size: 12px; margin-right: 4px;"></i> ' + (convUnion ? escapeHtml(convUnion.trim()) : '<span style="color: #bbb;">ইউনিয়ন দেওয়া হয়নি</span>') + ' &nbsp;·&nbsp; ' + messages.length + ' টি বার্তা';

            renderConversationMessages(messages, true);
            renderOpenTabs();
            if (data.session) {
                viewMeta.insertAdjacentHTML('beforeend', '<span class="chat-visitor-meta"><i class="fas fa-globe-asia"></i> ' + escapeHtml(data.session.visitor_location || 'Unknown') + ' &nbsp;·&nbsp; <i class="fas fa-mobile-alt"></i> ' + escapeHtml(data.session.visitor_device || 'Unknown') + ' &nbsp;·&nbsp; <i class="fas fa-window-maximize"></i> ' + escapeHtml(data.session.visitor_browser || 'Unknown') + ' &nbsp;·&nbsp; ' + escapeHtml(data.session.visitor_os || 'Unknown') + '</span>');
            }
            adminInput.focus();

        } catch (e) {
            console.error('Failed to load conversation:', e);
        }
    }

    function renderConversationMessages(messages, forceBottom) {
        adminMessages.innerHTML = '';
        (messages || []).forEach(function(msg) {
            const div = document.createElement('div');
            const senderType = getMessageSenderType(msg);
            div.className = 'chat-msg ' + senderType;
            div.setAttribute('data-msg-id', msg.id || '');
            div.setAttribute('data-sender', senderType);
            div.innerHTML = renderMessageHTML(msg);
            div.setAttribute('data-auto-reply', msg.auto_reply || 0);
            adminMessages.appendChild(div);
        });
        if (forceBottom) adminMessages.scrollTop = adminMessages.scrollHeight;
    }

    async function refreshActiveConversation() {
        if (!activeSessionId || isReplyPending) return;
        try {
            const res = await fetch('/api/chat/admin/conversations/' + encodeURIComponent(activeSessionId));
            const data = await res.json();
            if (data.status !== 'success' || !activeSessionId) return;
            const nearBottom = adminMessages.scrollHeight - adminMessages.scrollTop - adminMessages.clientHeight < 48;
            renderConversationMessages(data.data || [], nearBottom);
        } catch (e) {
            // Keep the current response view when background refresh fails.
        }
    }

    // ========================================
    // Optimistic message append helper
    // ========================================
    function renderAdminMessageEl(msg) {
        const div = document.createElement('div');
        div.className = 'chat-msg ' + getMessageSenderType(msg);
        div.setAttribute('data-msg-id', msg.id || '');
        div.setAttribute('data-sender', getMessageSenderType(msg));
        div.innerHTML = renderMessageHTML(msg);
        return div;
    }

    function appendAdminMessage(msgEl) {
        adminMessages.appendChild(msgEl);
        adminMessages.scrollTop = adminMessages.scrollHeight;
    }

    // ========================================
    // Image Gallery Collection
    // ========================================
    function collectAdminGalleryImages() {
        var result = [];
        var container = adminMessages;
        if (!container) return result;

        var triggers = container.querySelectorAll('.chat-msg-image-zoom-trigger');
        triggers.forEach(function (trigger) {
            var imgEl = trigger.querySelector('.chat-msg-image');
            if (!imgEl) return;
            result.push({
                element: imgEl,
                name: trigger.dataset.imgName || imgEl.alt || 'Image',
                url: trigger.dataset.imgSrc || imgEl.src || '',
            });
        });
        return result;
    }

    // ========================================
    // File Preview — Event Delegation
    // ========================================
    adminMessages.addEventListener('click', function(e) {
        const btn = e.target.closest('.chat-msg-preview-btn');
        if (btn && btn.dataset.previewMsg) {
            e.preventDefault();
            try {
                const msg = JSON.parse(btn.dataset.previewMsg);
                showFilePreview(msg);
            } catch (parseErr) {
                console.error('[Admin Chat] Failed to parse preview data:', parseErr);
            }
        }

        // Image zoom modal — triggered by clicking the image or its wrapper link
        const imgLink = e.target.closest('.chat-msg-image-zoom-trigger');
        if (imgLink) {
            e.preventDefault();
            const imgUrl = imgLink.dataset.imgSrc || '';
            const imgName = imgLink.dataset.imgName || '';
            const imgEl = imgLink.querySelector('.chat-msg-image');
            if (imgUrl && typeof ChatImageZoom !== 'undefined') {
                // Collect all images in the current conversation for gallery navigation
                const images = collectAdminGalleryImages();
                const currentIdx = images.findIndex(function (im) {
                    return im.url === imgUrl;
                });
                if (imgEl && imgEl.complete) {
                    ChatImageZoom.open(imgEl, imgName, images, currentIdx >= 0 ? currentIdx : 0);
                } else {
                    ChatImageZoom.openUrl(imgUrl, imgName, images, currentIdx >= 0 ? currentIdx : 0);
                }
            } else if (imgUrl) {
                window.open(imgUrl, '_blank', 'noopener,noreferrer');
            }
        }
    });

    // ========================================
    // Send admin reply (optimistic updates)
    // ========================================
    async function sendReply() {
        const text = adminInput.value.trim();
        const hasFile = !!pendingFile;
        if (!text && !hasFile) return;
        isReplyPending = true;

        adminInput.value = '';

        if (hasFile) {
            const progressBar = document.getElementById('adminUploadProgress');
            if (progressBar) progressBar.style.width = '30%';

            // Save file info before clearing pendingFile
            const fileToUpload = pendingFile;
            const isImage = pendingFile.type.startsWith('image/');
            const fileName = pendingFile.name;
            const fileSize = pendingFile.size;
            const fileType = pendingFile.type;

            pendingFile = null;
            adminUploadPreview.innerHTML = '';
            adminFileInput.value = '';

            // Optimistically show the message text (set message_type to 'text' so the
            // text renders; the actual file attachment appears after upload completes)
            const fileMsg = {
                sender_type: 'admin',
                message: text || '[ফাইল] ' + fileName,
                message_type: 'text',
                file_url: null,
                file_name: fileName,
                file_size: fileSize,
                file_type: fileType,
                created_at: new Date().toISOString(),
                is_read: 1,
            };
            const tempFileMsg = renderAdminMessageEl(fileMsg);
            // Add a small spinner to show it's uploading
            const spinner = document.createElement('span');
            spinner.innerHTML = ' <i class="fas fa-spinner fa-spin" style="font-size: 11px; color: #999;"></i>';
            tempFileMsg.querySelector('.chat-msg-footer')?.appendChild(spinner);
            appendAdminMessage(tempFileMsg);

            const formData = new FormData();
            formData.append('file', fileToUpload);
            formData.append('session_id', activeSessionId);
            formData.append('message', text);

            try {
                const res = await fetch('/api/chat/admin/upload', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();

                if (data.status === 'success') {
                    if (progressBar) progressBar.style.width = '100%';
                    // Replace the optimistic text message with the real file message
                    const realMsg = {
                        sender_type: 'admin',
                        message: text || '[ফাইল] ' + data.data.file_name,
                        message_type: isImage ? 'image' : 'file',
                        file_url: data.data.file_url,
                        file_name: data.data.file_name,
                        file_size: fileSize,
                        file_type: fileType,
                        created_at: new Date().toISOString(),
                        is_read: 1,
                    };
                    const realMsgEl = renderAdminMessageEl(realMsg);
                    tempFileMsg.replaceWith(realMsgEl);
                    refreshFirstPage();
                } else {
                    tempFileMsg.style.opacity = '0.5';
                    tempFileMsg.title = 'পাঠানো ব্যর্থ';
                    if (typeof SweetAlertUtil !== 'undefined') {
                        SweetAlertUtil.toast('ফাইল পাঠানো যায়নি: ' + (data.message || 'অজানা ত্রুটি'), 'error');
                    } else {
                        alert('ফাইল পাঠানো যায়নি: ' + (data.message || 'অজানা ত্রুটি'));
                    }
                }
            } catch (e) {
                tempFileMsg.style.opacity = '0.5';
                tempFileMsg.title = 'পাঠানো ব্যর্থ';
                if (typeof SweetAlertUtil !== 'undefined') {
                    SweetAlertUtil.toast('ফাইল পাঠানো যায়নি।', 'error');
                } else {
                    alert('ফাইল পাঠানো যায়নি।');
                }
            }
            isReplyPending = false;
            return;
        }

        // --- Text only path (already optimistic) ---
        adminSendBtn.disabled = true;

        const tempMsg = document.createElement('div');
        tempMsg.className = 'chat-msg admin';
        tempMsg.innerHTML = '<span class="chat-msg-sender">সহায়ক</span><div class="chat-msg-text">' + escapeHtml(text) + '</div><div class="chat-msg-footer"><span class="chat-msg-time">এখনই</span></div>';
        appendAdminMessage(tempMsg);

        try {
            const res = await fetch('/api/chat/admin/reply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ session_id: activeSessionId, message: text })
            });
            const data = await res.json();

            if (data.status === 'success') {
                refreshFirstPage();
            } else {
                tempMsg.style.opacity = '0.5';
                tempMsg.title = 'পাঠানো ব্যর্থ';
                if (typeof SweetAlertUtil !== 'undefined') {
                    SweetAlertUtil.toast('বার্তা পাঠানো যায়নি: ' + (data.message || 'অজানা ত্রুটি'), 'error');
                } else {
                    alert('বার্তা পাঠানো যায়নি: ' + (data.message || 'অজানা ত্রুটি'));
                }
            }
        } catch (e) {
            tempMsg.style.opacity = '0.5';
            tempMsg.title = 'পাঠানো ব্যর্থ';
            if (typeof SweetAlertUtil !== 'undefined') {
                SweetAlertUtil.toast('বার্তা পাঠানো যায়নি। আবার চেষ্টা করুন।', 'error');
            } else {
                alert('বার্তা পাঠানো যায়নি। আবার চেষ্টা করুন।');
            }
        } finally {
            adminSendBtn.disabled = false;
            adminInput.focus();
            isReplyPending = false;
        }
    }

    // ========================================
    // Typing Indicator (Admin side)
    // ========================================
    let lastAdminTypingSent = 0;
    let typingCheckInterval = null;

    function sendAdminTypingNotification() {
        if (!activeSessionId) return;
        const now = Date.now();
        if (now - lastAdminTypingSent < 3000) return;
        lastAdminTypingSent = now;

        fetch('/api/chat/admin/typing', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ session_id: activeSessionId })
        }).catch(function() {});
    }

    adminInput.addEventListener('input', function() {
        sendAdminTypingNotification();
    });

    // Typing sound state
    let _wasVisitorTyping = false;
    let _typingAudioCtx = null;

    function playTypingSound() {
        try {
            const AC = window.AudioContext || window.webkitAudioContext;
            if (!AC) return;
            if (!_typingAudioCtx) _typingAudioCtx = new AC();
            const ctx = _typingAudioCtx;
            const now = ctx.currentTime;

            // Short filtered noise burst for a natural keyboard click
            const bufferSize = Math.floor(ctx.sampleRate * 0.04);
            const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
            const data = buffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) {
                data[i] = (Math.random() * 2 - 1) * Math.exp(-i / (ctx.sampleRate * 0.008));
            }
            const noise = ctx.createBufferSource();
            noise.buffer = buffer;

            const filter = ctx.createBiquadFilter();
            filter.type = 'bandpass';
            filter.frequency.value = 1800;
            filter.Q.value = 1.5;

            const gain = ctx.createGain();
            gain.gain.setValueAtTime(0.06, now);
            gain.gain.exponentialRampToValueAtTime(0.001, now + 0.04);

            noise.connect(filter);
            filter.connect(gain);
            gain.connect(ctx.destination);
            noise.start(now);
            noise.stop(now + 0.04);
        } catch (e) {}
    }

    function startTypingCheck() {
        if (typingCheckInterval) clearInterval(typingCheckInterval);
        let typingEl = document.getElementById('adminTypingIndicator');
        if (typingEl) typingEl.remove();
        _wasVisitorTyping = false;

        if (activeSessionId) {
            typingCheckInterval = setInterval(function() {
                if (!activeSessionId) return;
                fetch('/api/chat/admin/typing?session_id=' + encodeURIComponent(activeSessionId))
                    .then(function(res) { return res.json(); })
                    .then(function(data) {
                        if (data.status === 'success' && data.data) {
                            const isTyping = !!data.data.is_typing;

                            // Play typing sound when visitor starts typing
                            if (isTyping && !_wasVisitorTyping) {
                                playTypingSound();
                            }
                            _wasVisitorTyping = isTyping;

                            if (isTyping) {
                                let el = document.getElementById('adminTypingIndicator');
                                if (!el && adminMessages) {
                                    el = document.createElement('div');
                                    el.id = 'adminTypingIndicator';
                                    el.className = 'chat-typing chat-admin-typing visible';
                                    el.innerHTML = '<span></span><span></span><span></span>';
                                    adminMessages.appendChild(el);
                                    adminMessages.scrollTop = adminMessages.scrollHeight;
                                } else if (el) {
                                    el.classList.add('visible');
                                }
                            } else {
                                const el = document.getElementById('adminTypingIndicator');
                                if (el) el.remove();
                            }
                        } else {
                            _wasVisitorTyping = false;
                            const el = document.getElementById('adminTypingIndicator');
                            if (el) el.remove();
                        }
                    }).catch(function() {});
            }, 4000);
        }
    }

    function stopTypingCheck() {
        if (typingCheckInterval) {
            clearInterval(typingCheckInterval);
            typingCheckInterval = null;
        }
        _wasVisitorTyping = false;
        const el = document.getElementById('adminTypingIndicator');
        if (el) el.remove();
    }

    // Cleanup on page unload
    window.addEventListener('beforeunload', function() {
        stopTypingCheck();
        stopTotalUnreadPolling();
        if (_refreshTimer) {
            clearInterval(_refreshTimer);
            _refreshTimer = null;
        }
        if (_activeConversationTimer) {
            clearInterval(_activeConversationTimer);
            _activeConversationTimer = null;
        }
    });

    // Merge typing into loadConversation
    const origLoadConv = loadConversation;
    loadConversation = async function(sessionId) {
        stopTypingCheck();
        await origLoadConv(sessionId);
        startTypingCheck();
    };

    // Close conversation (single handler with typing cleanup)
    closeConvBtn.addEventListener('click', async function() {
        if (!activeSessionId) return;
        if (typeof SweetAlertUtil !== 'undefined') {
            const confirmed = await SweetAlertUtil.question('কথোপকথন বন্ধ করুন', 'এই কথোপকথনটি বন্ধ করবেন?');
            if (!confirmed.isConfirmed) return;
        } else if (!confirm('এই কথোপকথনটি বন্ধ করবেন?')) {
            return;
        }

        try {
            const res = await fetch('/api/chat/admin/close/' + encodeURIComponent(activeSessionId), { method: 'POST' });
            const data = await res.json();
            if (data.status === 'success') {
                stopTypingCheck();
                const closedIndex = openConversationIds.indexOf(activeSessionId);
                if (closedIndex >= 0) openConversationIds.splice(closedIndex, 1);
                activeSessionId = null;
                renderOpenTabs();
                emptyState.style.display = 'flex';
                viewContent.style.display = 'none';
                loadConversations();
            }
        } catch (e) {
            if (typeof SweetAlertUtil !== 'undefined') {
                SweetAlertUtil.toast('কথোপকথন বন্ধ করতে ব্যর্থ হয়েছে।', 'error');
            } else {
                alert('বন্ধ করতে ব্যর্থ হয়েছে।');
            }
        }
    });

    // ========================================
    // Canned Responses (Quick Replies)
    // ========================================
    let allCannedResponses = [];
    const cannedPanel = document.getElementById('adminCannedPanel');
    const cannedBtn = document.getElementById('adminCannedBtn');
    const cannedResults = document.getElementById('cannedResults');
    const cannedSearchInput = document.getElementById('cannedSearchInput');

    async function loadCannedResponses() {
        try {
            const res = await fetch('/api/chat/admin/canned');
            const data = await res.json();
            allCannedResponses = data.data || [];
        } catch (e) {
            console.error('Failed to load canned responses:', e);
        }
    }

    function renderCannedResponses(filter) {
        if (!allCannedResponses || allCannedResponses.length === 0) {
            cannedResults.innerHTML = '<div class="canned-no-results">কোনো কুইক রিপ্লাই নেই<br><small>/settings/chat/canned এ তৈরি করুন</small></div>';
            return;
        }

        let filtered = allCannedResponses;
        if (filter && filter.trim()) {
            const q = filter.toLowerCase();
            filtered = allCannedResponses.filter(function(item) {
                return (item.title && item.title.toLowerCase().indexOf(q) !== -1) ||
                       (item.message && item.message.toLowerCase().indexOf(q) !== -1) ||
                       (item.category && item.category.toLowerCase().indexOf(q) !== -1);
            });
        }

        if (filtered.length === 0) {
            cannedResults.innerHTML = '<div class="canned-no-results">কিছু পাওয়া যায়নি</div>';
            return;
        }

        // Group by category
        const categories = {};
        filtered.forEach(function(item) {
            const cat = item.category || 'অন্যান্য';
            if (!categories[cat]) categories[cat] = [];
            categories[cat].push(item);
        });

        let html = '';
        const catKeys = Object.keys(categories);
        catKeys.forEach(function(cat, idx) {
            if (idx > 0) html += '<div style="border-top: 1px solid #e9ecef;"></div>';
            html += '<div class="canned-group-header">' + escapeHtml(cat) + '</div>';
            categories[cat].forEach(function(item) {
                let preview = item.message || '';
                if (preview.length > 60) preview = preview.substring(0, 60) + '...';
                html += '<div class="canned-item" data-canned-id="' + item.id + '" data-canned-message="' + escapeAttr(item.message) + '">';
                html += '<div class="canned-item-title">' + escapeHtml(item.title) + '</div>';
                html += '<div class="canned-item-text">' + escapeHtml(preview) + '</div>';
                html += '</div>';
            });
        });

        cannedResults.innerHTML = html;

        // Click handlers
        cannedResults.querySelectorAll('.canned-item').forEach(function(el) {
            el.addEventListener('click', function() {
                const message = this.dataset.cannedMessage || '';
                if (message) {
                    adminInput.value = message;
                    adminInput.focus();
                    // Auto-resize
                    adminInput.style.height = 'auto';
                    adminInput.style.height = Math.min(adminInput.scrollHeight, 80) + 'px';
                    // Close panel
                    cannedPanel.classList.remove('open');
                    cannedBtn.classList.remove('active');
                }
            });
        });
    }

    function escapeAttr(text) {
        if (typeof text !== 'string') return '';
        return text.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // Toggle canned panel
    cannedBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        const isOpen = cannedPanel.classList.contains('open');
        // Close other overlays
        adminEmojiPicker.classList.remove('open');
        
        if (!isOpen) {
            renderCannedResponses('');
            cannedSearchInput.value = '';
        }
        cannedPanel.classList.toggle('open');
        this.classList.toggle('active');
        if (!isOpen) {
            setTimeout(function() { cannedSearchInput.focus(); }, 100);
        }
    });

    // Search
    cannedSearchInput.addEventListener('input', function() {
        renderCannedResponses(this.value);
    });

    // Close on outside click
    document.addEventListener('click', function(e) {
        if (cannedPanel && !cannedPanel.contains(e.target) && e.target !== cannedBtn) {
            cannedPanel.classList.remove('open');
            if (cannedBtn) cannedBtn.classList.remove('active');
        }
    });

    // ========================================
    // Autocomplete Reply while typing
    // ========================================
    const autocompleteDropdown = document.getElementById('adminAutocompleteDropdown');
    const autocompleteResults = document.getElementById('adminAutocompleteResults');
    let selectedAutocompleteIndex = -1;
    let autocompleteTimer = null;

    function filterCannedForAutocomplete(query) {
        if (!query || query.trim().length < 2) {
            autocompleteDropdown.classList.remove('open');
            return [];
        }
        const q = query.toLowerCase();
        return allCannedResponses.filter(function(item) {
            return (item.title && item.title.toLowerCase().indexOf(q) !== -1) ||
                   (item.message && item.message.toLowerCase().indexOf(q) !== -1);
        }).slice(0, 8);
    }

    function renderAutocompleteSuggestions(results) {
        autocompleteResults.innerHTML = '';
        if (!results || results.length === 0) {
            autocompleteDropdown.classList.remove('open');
            return;
        }

        selectedAutocompleteIndex = -1;

        results.forEach(function(item, idx) {
            const el = document.createElement('div');
            el.className = 'chat-autocomplete-item';
            el.dataset.index = idx;
            el.dataset.message = item.message;

            const titleSpan = document.createElement('span');
            titleSpan.className = 'chat-autocomplete-item-title';
            titleSpan.textContent = item.title;

            const previewSpan = document.createElement('span');
            previewSpan.className = 'chat-autocomplete-item-preview';
            let preview = item.message || '';
            if (preview.length > 80) preview = preview.substring(0, 80) + '...';
            previewSpan.textContent = preview;

            el.appendChild(titleSpan);
            el.appendChild(previewSpan);

            el.addEventListener('click', function() {
                applyAutocompleteMessage(item.message);
            });

            el.addEventListener('mouseenter', function() {
                selectedAutocompleteIndex = idx;
                updateAutocompleteHighlight();
            });

            autocompleteResults.appendChild(el);
        });

        autocompleteDropdown.classList.add('open');
    }

    function updateAutocompleteHighlight() {
        const items = autocompleteResults.querySelectorAll('.chat-autocomplete-item');
        items.forEach(function(el, idx) {
            el.classList.toggle('selected', idx === selectedAutocompleteIndex);
        });
    }

    function applyAutocompleteMessage(message) {
        if (!message) return;
        adminInput.value = message;
        adminInput.focus();
        adminInput.style.height = 'auto';
        adminInput.style.height = Math.min(adminInput.scrollHeight, 80) + 'px';
        autocompleteDropdown.classList.remove('open');
        selectedAutocompleteIndex = -1;
    }

    // Handle input events for autocomplete
    adminInput.addEventListener('input', function() {
        // Debounced autocomplete (typing indicator handled by the original input listener)
        if (autocompleteTimer) clearTimeout(autocompleteTimer);
        autocompleteTimer = setTimeout(function() {
            const query = adminInput.value;
            // Close emoji/canned overlays when showing autocomplete
            if (query.trim().length >= 2) {
                adminEmojiPicker.classList.remove('open');
                cannedPanel.classList.remove('open');
                cannedBtn.classList.remove('active');
            }
            const results = filterCannedForAutocomplete(query);
            renderAutocompleteSuggestions(results);
        }, 250);
    });

    // Handle keyboard navigation in autocomplete
    adminInput.addEventListener('keydown', function(e) {
        if (!autocompleteDropdown.classList.contains('open')) {
            // Let existing Enter handler work
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendReply();
            }
            return;
        }

        const items = autocompleteResults.querySelectorAll('.chat-autocomplete-item');
        if (items.length === 0) return;

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            selectedAutocompleteIndex = Math.min(selectedAutocompleteIndex + 1, items.length - 1);
            updateAutocompleteHighlight();
            items[selectedAutocompleteIndex].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            selectedAutocompleteIndex = Math.max(selectedAutocompleteIndex - 1, 0);
            updateAutocompleteHighlight();
            items[selectedAutocompleteIndex].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'Enter' || e.key === 'Tab') {
            e.preventDefault();
            if (selectedAutocompleteIndex >= 0 && selectedAutocompleteIndex < items.length) {
                const msg = items[selectedAutocompleteIndex].dataset.message;
                applyAutocompleteMessage(msg);
            } else {
                // Fall through to send if no item selected
                if (e.key === 'Enter' && !e.shiftKey) {
                    sendReply();
                }
            }
        } else if (e.key === 'Escape') {
            autocompleteDropdown.classList.remove('open');
            selectedAutocompleteIndex = -1;
        }
    });

    // Close autocomplete on outside click
    document.addEventListener('click', function(e) {
        if (autocompleteDropdown && !autocompleteDropdown.contains(e.target) && e.target !== adminInput) {
            autocompleteDropdown.classList.remove('open');
            selectedAutocompleteIndex = -1;
        }
    });

    // ========================================
    // Total Unread Count Badge
    // ========================================
    const totalUnreadBadge = document.getElementById('totalUnreadBadge');
    let totalUnreadTimer = null;

    async function fetchTotalUnread() {
        try {
            const res = await fetch('/api/chat/admin/unread/total');
            const data = await res.json();
            if (data.status === 'success') {
                const count = parseInt(data.data.total) || 0;
                updateTotalUnreadBadge(count);
            }
        } catch (e) {
            // Silently fail
        }
    }

    function updateTotalUnreadBadge(count) {
        if (!totalUnreadBadge) return;
        if (count > 0) {
            totalUnreadBadge.textContent = count > 99 ? '99+' : count;
            totalUnreadBadge.style.display = 'inline-flex';
        } else {
            totalUnreadBadge.style.display = 'none';
        }
    }

    function startTotalUnreadPolling() {
        fetchTotalUnread();
        totalUnreadTimer = setInterval(fetchTotalUnread, 10000);
    }

    function stopTotalUnreadPolling() {
        if (totalUnreadTimer) {
            clearInterval(totalUnreadTimer);
            totalUnreadTimer = null;
        }
    }

    // ========================================
    // Bulk Actions: Read All / Close All
    // ========================================
    const bulkReadAllBtn = document.getElementById('bulkReadAllBtn');
    const bulkCloseAllBtn = document.getElementById('bulkCloseAllBtn');

    bulkReadAllBtn.addEventListener('click', async function() {
        if (isLoadingConversations) return;
        this.disabled = true;
        this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> প্রক্রিয়াকরণ...';

        try {
            const res = await fetch('/api/chat/admin/read-all', { method: 'POST' });
            const data = await res.json();
            if (data.status === 'success') {
                // Update the total unread badge to 0 immediately
                updateTotalUnreadBadge(0);
                // Refresh conversations to update unread counts
                await refreshFirstPage();
                // If viewing a conversation, reload it
                if (activeSessionId) {
                    await refreshActiveConversation();
                }
            }
        } catch (e) {
            console.error('Failed to mark all as read:', e);
            if (typeof SweetAlertUtil !== 'undefined') {
                SweetAlertUtil.toast('সব বার্তা পঠিত করতে ব্যর্থ হয়েছে।', 'error');
            } else {
                alert('সব বার্তা পঠিত করতে ব্যর্থ হয়েছে।');
            }
        } finally {
            this.disabled = false;
            this.innerHTML = '<i class="fas fa-check-double"></i> সব পঠিত';
        }
    });

    bulkCloseAllBtn.addEventListener('click', async function() {
        if (typeof SweetAlertUtil !== 'undefined') {
            const confirmed = await SweetAlertUtil.question('সব কথোপকথন বন্ধ করুন', 'আপনি কি সব সক্রিয় কথোপকথন বন্ধ করতে চান? এই কাজটি পূর্বাবস্থায় ফেরানো যাবে না।');
            if (!confirmed.isConfirmed) return;
        } else if (!confirm('আপনি কি সব সক্রিয় কথোপকথন বন্ধ করতে চান? এই কাজটি পূর্বাবস্থায় ফেরানো যাবে না।')) {
            return;
        }
        this.disabled = true;
        this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> প্রক্রিয়াকরণ...';

        try {
            const res = await fetch('/api/chat/admin/close-all', { method: 'POST' });
            const data = await res.json();
            if (data.status === 'success') {
                // Clear active view
                stopTypingCheck();
                activeSessionId = null;
                emptyState.style.display = 'flex';
                viewContent.style.display = 'none';
                // Reload conversation list
                await loadConversations(false);
            }
        } catch (e) {
            console.error('Failed to close all:', e);
            if (typeof SweetAlertUtil !== 'undefined') {
                SweetAlertUtil.toast('সব কথোপকথন বন্ধ করতে ব্যর্থ হয়েছে।', 'error');
            } else {
                alert('সব কথোপকথন বন্ধ করতে ব্যর্থ হয়েছে।');
            }
        } finally {
            this.disabled = false;
            this.innerHTML = '<i class="fas fa-times-circle"></i> সব বন্ধ';
        }
    });

    // Load canned responses on init
    loadCannedResponses();

    // Send on Enter (Shift+Enter for new line) - Moved to autocomplete handler above
    adminInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendReply();
        }
    });

    adminSendBtn.addEventListener('click', sendReply);

    // Auto-refresh conversations every 10s (only first page, preserves pagination state)
    async function refreshFirstPage() {
        if (isLoadingConversations) return;
        try {
            const res = await fetch('/api/chat/admin/conversations?offset=0&limit=' + CONV_PAGE_SIZE);
            const data = await res.json();
            const freshConvs = data.data || [];
            const newHasMore = data.has_more || false;

            // Use a Map for O(1) lookups instead of O(n²) findIndex
            const convMap = new Map();
            allConversations.forEach(function(c) {
                convMap.set(c.session_id, c);
            });

            // Merge fresh first-page items into allConversations (update status, unread, etc.)
            // This preserves older loaded pages while updating the most recent items
            freshConvs.forEach(function(fc) {
                const existing = convMap.get(fc.session_id);
                if (existing) {
                    // Update existing item in place
                    Object.assign(existing, fc);
                } else {
                    // New conversation — add to front
                    allConversations.unshift(fc);
                    loadedConversationIds.add(fc.session_id);
                }
            });

            // Update offset and has_more
            conversationsOffset = allConversations.length;
            hasMoreConversations = newHasMore || allConversations.length >= CONV_PAGE_SIZE;

            renderConversations(filterConversations());
            renderLoadMoreButton();
        } catch (e) {
            console.error('Failed to refresh conversations:', e);
        }
    }

    // Start total unread badge polling
    startTotalUnreadPolling();

    let _refreshTimer = setInterval(refreshFirstPage, 10000);
    let _activeConversationTimer = setInterval(refreshActiveConversation, 5000);

    // Initial load. A global admin FAB can pass the running session ID so the
    // clicked notification opens that conversation directly.
    loadConversations(false).then(function() {
        const requestedSessionId = new URLSearchParams(window.location.search).get('session_id');
        if (requestedSessionId && allConversations.some(function(conv) { return conv.session_id === requestedSessionId; })) {
            loadConversation(requestedSessionId);
            window.history.replaceState({}, document.title, window.location.pathname);
        }
    });

    // Refresh button - inline onclick migrated to addEventListener
    var refreshBtn = document.getElementById('adminRefreshBtn');
    if (refreshBtn) {
        refreshBtn.addEventListener('click', function() {
            location.reload();
        });
    }
})();
</script>
{% endblock %}

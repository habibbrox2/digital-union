    .action-btn {
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.55rem 1.1rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        border: none;
    }

    .action-btn::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        transform: translate(-50%, -50%);
        transition: width 0.6s ease, height 0.6s ease;
    }

    .action-btn:active::after {
        width: 300px;
        height: 300px;
    }

    .action-btn:hover {
        transform: translateY(-2px);
    }

    .action-btn-approve:hover { box-shadow: 0 6px 20px rgba(40,167,69,0.35); }
    .action-btn-reject:hover { box-shadow: 0 6px 20px rgba(220,53,69,0.35); }
    .action-btn-hold:hover { box-shadow: 0 6px 20px rgba(108,117,125,0.3); }
    .action-btn-reactivate:hover { box-shadow: 0 6px 20px rgba(23,162,184,0.3); }
    .action-btn-view:hover { box-shadow: 0 6px 20px rgba(0,123,255,0.3); }
    .action-btn-reset:hover { box-shadow: 0 6px 20px rgba(255,193,7,0.35); }
    .action-btn-fix:hover { box-shadow: 0 6px 20px rgba(52,58,64,0.3); }
    .action-btn-renew:hover { box-shadow: 0 6px 20px rgba(23,162,184,0.3); }
    .action-btn-history:hover { box-shadow: 0 6px 20px rgba(108,117,125,0.2); }

    .action-fix-msg {
        display: none;

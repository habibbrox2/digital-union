        }



        .main-content {
            margin-left: 0 !important;
            width: 100% !important;
        }

        .content-body {
            box-shadow: none !important;
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }

        .card {
            box-shadow: none !important;
            border: 1px solid #ccc !important;
            border-radius: 0 !important;
        }

        .card-body {
            padding: 1rem !important;
        }

        .applicant-photo {
            box-shadow: none !important;
            border: 2px solid #999 !important;
        }
    }

    /* ===== Photo Lightbox Modal ===== */
    .photo-lightbox-modal .modal-content {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
    }

    .photo-lightbox-modal .modal-dialog {
        margin: 0;
        max-width: 100vw;
        max-height: 100vh;
    }

    .photo-lightbox-modal.show {
        background: rgba(0, 0, 0, 0.92);
        backdrop-filter: blur(4px);
    }

    .photo-lightbox-image {
        max-width: 92vw;
        max-height: 90vh;
        width: auto;
        height: auto;
        object-fit: contain;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        animation: lightboxEntrance 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @keyframes lightboxEntrance {
        from {
            opacity: 0;
            transform: scale(0.85) translateY(20px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .photo-lightbox-close,
    .photo-lightbox-download {
        position: absolute;
        z-index: 1060;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(255,255,255,0.15);
        border: none;
        color: #fff;
        font-size: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.25s ease;
        backdrop-filter: blur(4px);
        text-decoration: none;
    }

    .photo-lightbox-close { top: 20px; right: 24px; }
    .photo-lightbox-download { top: 20px; left: 24px; }

    .photo-lightbox-close:hover,
    .photo-lightbox-download:hover {
        background: rgba(255,255,255,0.3);
        transform: scale(1.1) rotate(0deg);
    }

    .photo-lightbox-close:hover { transform: scale(1.1) rotate(90deg); }
    .photo-lightbox-download:hover { transform: scale(1.1) translateY(-2px); }

    .photo-lightbox-close:focus-visible,
    .photo-lightbox-download:focus-visible {
        outline: 3px solid #fff;
        outline-offset: 3px;
    }

    /* ===== Photo Lightbox Rotation ===== */
    .photo-lightbox-image {
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Rotation degree classes — set via JS */
    .photo-lightbox-image.rotate-90  { transform: rotate(90deg); }
    .photo-lightbox-image.rotate-180 { transform: rotate(180deg); }
    .photo-lightbox-image.rotate-270 { transform: rotate(270deg); }

    /* ===== Photo Lightbox Keyboard Hint ===== */
    .photo-lightbox-hint {
        position: absolute;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1060;
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(6px);
        padding: 8px 16px;
        border-radius: 24px;
        color: rgba(255,255,255,0.7);
        font-size: 0.78rem;
        transition: opacity 0.4s ease, transform 0.4s ease;
        opacity: 0;
        transform: translateX(-50%) translateY(10px);
        pointer-events: none;
    }

    .photo-lightbox-modal.show .photo-lightbox-hint {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
        transition-delay: 0.6s;
    }

    .photo-lightbox-hint .rotation-badge {

{# Approve Page.twig (Refactored for display only) #}
{% extends "layout.twig" %}

{% block title %}  {{ title }}{% endblock %}

{% block header_title %} {{ header_title }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<link rel="stylesheet" href="/assets/css/forms.css?t={{ "now"|date("Hiss") }}">

<div class="container form-page px-3 approve-page">
    <div class="form-shell">
        <div class="form-hero">
            <h1 id="formTitle">{{ data.certificate_type_bn ?? '' }} অনুমোদন</h1>
        </div>

    <!-- Application Status Badge -->
    <div class="text-center mb-4">
        <span class="badge bg-{{ data.status == 'approved' ? 'success' : (data.status == 'rejected' ? 'danger' : 'warning') }} rounded-pill px-4 py-2 fs-6 shadow-sm status-badge-pulse">
            <i class="bi bi-{{ data.status == 'approved' ? 'check-circle' : (data.status == 'rejected' ? 'x-circle' : 'hourglass-split') }} me-2"></i>
            {{ data.status_bn|default(data.status) }}
        </span>
        
        {% if data.status == 'approved' and license_number is not empty %}
            <div class="mt-3 d-flex align-items-center justify-content-center gap-2">
                <span class="badge bg-light text-dark border px-3 py-2 fs-6 rounded-pill shadow-sm">
                    <i class="bi bi-passport text-success me-2"></i>
                    <span class="text-muted small">লাইসেন্স/সনদ নং:</span>
                    <strong class="ms-1 text-success">{{ license_number }}</strong>
                </span>
            </div>
        {% endif %}
    </div>



            <fieldset class="form-section">
                <legend>ব্যক্তির তথ্য</legend>
            {# ================= Mappings & Variables ================= #}

            {# ================= Occupation Mapping ================= #}
            {% set occupationMap = {
                'teacher': 'শিক্ষক',
                'engineer': 'ইঞ্জিনিয়ার',
                'doctor': 'ডাক্তার',
                'nurse': 'নার্স',
                'farmer': 'কৃষক',
                'business': 'ব্যবসায়ী',
                'lawyer': 'আইনজীবী',
                'police': 'পুলিশ',
                'driver': 'ড্রাইভার',
                'soldier': 'সেনা',
                'scientist': 'বিজ্ঞানী',
                'accountant': 'হিসাবরক্ষক',
                'artist': 'শিল্পী',
                'writer': 'লেখক',
                'student': 'ছাত্র/ছাত্রী',
                'shopkeeper': 'দোকানদার',
                'worker': 'কর্মচারী',
                'technician': 'প্রযুক্তিবিদ',
                'manager': 'ম্যানেজার',
                'housewife': 'গৃহিণী',
                'labour': 'শ্রমিক',
                'শিক্ষক': 'শিক্ষক',
                'ইঞ্জিনিয়ার': 'ইঞ্জিনিয়ার',
                'ডাক্তার': 'ডাক্তার',
                'নার্স': 'নার্স',
                'কৃষক': 'কৃষক',
                'ব্যবসায়ী': 'ব্যবসায়ী',
                'আইনজীবী': 'আইনজীবী',
                'পুলিশ': 'পুলিশ',
                'ড্রাইভার': 'ড্রাইভার',
                'সেনা': 'সেনা',
                'বিজ্ঞানী': 'বিজ্ঞানী',
                'হিসাবরক্ষক': 'হিসাবরক্ষক',
                'শিল্পী': 'শিল্পী',
                'লেখক': 'লেখক',
                'ছাত্র/ছাত্রী': 'ছাত্র/ছাত্রী',
                'দোকানদার': 'দোকানদার',
                'কর্মচারী': 'কর্মচারী',
                'প্রযুক্তিবিদ': 'প্রযুক্তিবিদ',
                'ম্যানেজার': 'ম্যানেজার',
                'গৃহিণী': 'গৃহিণী',
                'শ্রমিক': 'শ্রমিক',
                'অন্যান্য': 'অন্যান্য'
            } %}

            {# ================= Occupation Bangla ================= #}
            {% set occupationKey = data.occupation|lower %}
            {% set occupationBangla = occupationMap[occupationKey]|default(data.occupation) %}
            {% set occupationInfo = {
                'label': 'পেশা',
                'value': occupationBangla
            } %}

            {# ================= Info List ================= #}
            {% set infoList = [
                {'label':'নাম', 'value': data.name_bn},
                {'label':'নাম (ইংরেজি)', 'value': data.name_en},
                {'label': certificate_type == 'warish' ? 'মৃত্যু নিবন্ধন' : 'পরিচয়পত্র',  'value': data.nid ?: data.birth_id ?: data.passport_no},
                {'label': certificate_type == 'warish' ? 'মৃত্যু তারিখ' : 'জন্ম তারিখ', 'value': data.birth_date|date('d-m-Y')|bn},
                {'label':'লিঙ্গ', 'value': 
                    data.gender|lower == 'male' ? 'পুরুষ' : 
                    (data.gender|lower == 'female' ? 'মহিলা' : 'অন্যান্য')
                },
                {'label':'ধর্ম', 'value': 
                    data.religion|lower == 'islam' ? 'ইসলাম' :
                    (data.religion|lower == 'hindu' ? 'হিন্দু' :
                    (data.religion|lower == 'christian' ? 'খ্রিস্টান' :
                    (data.religion|lower == 'buddhism' ? 'বৌদ্ধ' :
                    'অন্যান্য')))
                },
                {'label':'পিতা', 'value': data.father_name_bn ~ ' (' ~ data.father_name_en ~ ')'},
                {'label':'মাতা', 'value': data.mother_name_bn ~ ' (' ~ data.mother_name_en ~ ')'},
                {'label':'বাসিন্দার ধরন', 'value': data.resident == 'permanent' ? 'স্থায়ী' : 'অস্থায়ী'},
                {'label':'শিক্ষাগত যোগ্যতা', 'value': data.educational_qualification},
                occupationInfo,
                {'label':'বৈবাহিক অবস্থা', 'value':
                    data.marital_status|lower == 'single' ? 'অবিবাহিত' :
                    (data.marital_status|lower == 'married' ? 'বিবাহিত' :
                    (data.marital_status|lower == 'divorced' ? 'বিচ্ছিন্ন' :
                    (data.marital_status|lower == 'widowed' ? 'বিধবা/বিধুর' :
                    'অন্যান্য')))
                }
            ] %}

            {# ================= Display ================= #}
            <div class="row g-4 info-grid">
                {% for item in infoList %}
                    <div class="col-lg-4 col-md-6 col-sm-12">
                        <div class="info-item">
                            <span class="info-label">{{ item.label }}</span>
                            <span class="info-value">{{ item.value ?: '—' }}</span>
                        </div>
                    </div>
                {% endfor %}
                
                {% if data.spouse_name_bn %}
                    <div class="col-lg-6 col-md-12">
                        <div class="info-item">
                            <span class="info-label">স্বামী/স্ত্রীর নাম</span>
                            <span class="info-value">{{ data.spouse_name_bn }} ({{ data.spouse_name_en }})</span>
                        </div>
                    </div>
                {% endif %}
            </div>

            <!-- আবেদনকারীর ছবি -->
            <div class="photo-wrapper text-center mt-4">
                <div class="photo-ring" data-bs-toggle="modal" data-bs-target="#photoLightbox" title="পূর্ণ আকারে দেখুন (ক্লিক করুন)">
                    <img src="{{ url }}/{{ data.applicant_photo ?: 'assets/images/default-user.png' }}" 
                        alt="আবেদনকারীর ছবি" 
                        class="applicant-photo"
                        loading="lazy">
                    <div class="photo-ring-overlay">
                        <i class="bi bi-zoom-in"></i>
                        <span class="d-block" style="font-size:0.6rem;margin-top:2px;">পূর্ণ আকার</span>
                    </div>
                </div>
            </div>

            </fieldset>

            <fieldset class="form-section">
                <legend>বর্তমান ঠিকানা</legend>
                <div class="address-display">
                    <div class="address-line">
                        <span class="address-tag">বাড়ি</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.present_holding_no ?: '—' }}</span>
                        <span class="address-divider">|</span>
                        <span class="address-tag">গ্রাম</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.present_village_bn ?: '—' }}</span>
                        <span class="address-divider">|</span>
                        <span class="address-tag">ওয়ার্ড</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.present_ward_no ? (data.present_ward_no|bn) : '—' }}</span>
                    </div>
                    <div class="address-line mt-2">
                        <span class="address-tag">পোস্ট অফিস</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.present_postoffice_bn ?: '—' }}</span>
                        <span class="address-divider">|</span>
                        <span class="address-tag">ইউনিয়ন</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.present_union_bn ?: '—' }}</span>
                        <span class="address-divider">|</span>
                        <span class="address-tag">উপজেলা</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.present_upazila_bn ?: '—' }}</span>
                        <span class="address-divider">|</span>
                        <span class="address-tag">জেলা</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.present_district_bn ?: '—' }}</span>
                    </div>
                </div>
            </fieldset>

            <fieldset class="form-section">
                <legend>স্থায়ী ঠিকানা</legend>
                <div class="address-display">
                    <div class="address-line">
                        <span class="address-tag">বাড়ি</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.permanent_holding_no ?: '—' }}</span>
                        <span class="address-divider">|</span>
                        <span class="address-tag">গ্রাম</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.permanent_village_bn ?: '—' }}</span>
                        <span class="address-divider">|</span>
                        <span class="address-tag">ওয়ার্ড</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.permanent_ward_no ? (data.permanent_ward_no|bn) : '—' }}</span>
                    </div>
                    <div class="address-line mt-2">
                        <span class="address-tag">পোস্ট অফিস</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.permanent_postoffice_bn ?: '—' }}</span>
                        <span class="address-divider">|</span>
                        <span class="address-tag">ইউনিয়ন</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.permanent_union_bn ?: '—' }}</span>
                        <span class="address-divider">|</span>
                        <span class="address-tag">উপজেলা</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.permanent_upazila_bn ?: '—' }}</span>
                        <span class="address-divider">|</span>
                        <span class="address-tag">জেলা</span>
                        <span class="address-sep">:</span>
                        <span class="address-val">{{ data.permanent_district_bn ?: '—' }}</span>
                    </div>
                </div>
            </fieldset>

            <fieldset class="form-section">
                <legend>আবেদনকারীর তথ্য</legend>
                <div class="row mb-3 align-items-center">
                    <div class="col-lg-2 col-md-3 col-12">
                        <span class="fw-bold">আবেদন আইডি</span>
                    </div>
                    <div class="col-lg-4 col-md-3 col-12">
                        <span class="text-muted">{{ data.application_id }}</span>
                    </div>
                    <div class="col-lg-2 col-md-3 col-12">
                        <span class="fw-bold">আবেদনকারীর নাম</span>
                    </div>
                    <div class="col-lg-4 col-md-3 col-12">
                        <span class="text-muted">{{ data.applicant_name ?: '—' }}</span>
                    </div>
                </div>
                <div class="row align-items-center">
                    <div class="col-lg-2 col-md-3 col-12">
                        <span class="fw-bold">মোবাইল নম্বর</span>
                    </div>
                    <div class="col-lg-4 col-md-3 col-12">
                        <span class="text-muted">{{ data.applicant_phone ?: '—' }}</span>
                    </div>
                </div>
            </fieldset>

            {% include 'partials/certificate_fields.twig' %}
            <!-- ডকুমেন্টস -->
            <fieldset class="form-section">
                <legend>সংযুক্ত ডকুমেন্টস
                    {% if data.documents is not empty %}
                        <span class="badge bg-primary rounded-pill ms-2">{{ documents|length }}</span>
                    {% endif %}
                </legend>
                {% if data.documents is empty %}
                    <div class="text-center py-4">
                        <i class="bi bi-file-earmark-x fs-1 text-muted"></i>
                        <p class="text-muted fst-italic mt-2">কোনো ডকুমেন্ট আপলোড করা হয়নি।</p>
                    </div>
                {% else %}
                    <div class="documents-grid" id="documentsGrid">
                        {% for doc_path in documents %}
                            {% set ext = doc_path|split('.')|last|lower %}
                            {% set isImage = ext in ['jpg','jpeg','png','gif','webp'] %}
                            <div class="document-card">
                                <div class="document-preview{% if isImage %} doc-gallery-trigger{% endif %}"
                                     {% if isImage %}
                                     data-doc-url="{{ url }}/{{ doc_path }}"
                                     data-doc-name="{{ doc_path|split('/')|last }}"
                                     role="button"
                                     tabindex="0"
                                     aria-label="{{ doc_path|split('/')|last }} — পূর্ণ আকারে দেখুন"
                                     {% endif %}>
                                    {% if isImage %}
                                        <img src="{{ url }}/{{ doc_path }}" alt="Document: {{ doc_path|split('/')|last }}" loading="lazy">
                                        <!-- Zoom overlay on hover -->
                                        <div class="doc-gallery-overlay">
                                            <i class="bi bi-arrows-fullscreen"></i>
                                            <span>পূর্ণ আকার</span>
                                        </div>
                                    {% else %}
                                        <div class="document-icon-big">
                                            <i class="bi bi-file-earmark-text"></i>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="document-info">
                                    <span class="document-name" title="{{ doc_path | split('/') | last }}">{{ doc_path | split('/') | last }}</span>
                                    <div class="document-actions">
                                        <a href="{{ url }}/{{ doc_path }}" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary document-view-btn">
                                            <i class="bi bi-eye me-1"></i> দেখুন
                                        </a>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </fieldset>

            <!-- অনুমোদন ফর্ম -->
            <form id="approvalForm" method="POST" action="/applications/{{ data.certificate_type }}/approve/{{ data.application_id }}" class="mb-4" autocomplete="on">
                <input type="hidden" id="certificate_type" name="certificate_type" value="{{ data.certificate_type }}">
                <input type="hidden" id="application_id" name="application_id" value="{{ data.application_id }}">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                <hr class="my-5">

                <!-- তথ্য যাচাইকারীর তথ্য -->
                <fieldset class="form-section">
                    <legend>তথ্য যাচাইকারীর তথ্য</legend>

                    {% if union_members is not empty %}
                    <!-- Quick Select Dropdown -->
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <div class="alert alert-info mb-3 d-flex align-items-center gap-2">
                                <i class="bi bi-info-circle fs-5"></i>
                                <span>নীচের ড্রপডাউন থেকে যাচাইকারী নির্বাচন করুন। তথ্য স্বয়ংক্রিয়ভাবে পূরণ হবে।</span>
                            </div>

                            <label for="verifier_select" class="form-label fw-semibold small mb-2">
                                <i class="bi bi-person-check"></i> যাচাইকারী নির্বাচন করুন:
                            </label>

                            <div class="input-group input-group-sm">
                                <select id="verifier_select"
                                        class="form-select form-select-sm shadow-sm"
                                        onchange="selectVerifierFromDropdown()">
                                    <option value="">-- যাচাইকারী নির্বাচন করুন --</option>

                                    {% for role_id, group in union_members %}
                                        <optgroup label="{{ group.role_name }}">
                                            {% for member in group.members %}
                                                <option value="{{ member.user_id }}"
                                                        data-name-bn="{{ member.name_bn }}"
                                                        data-name-en="{{ member.name_en }}"
                                                        data-role-id="{{ member.role_id|default('') }}"
                                                        data-phone="{{ member.phone }}"
                                                        data-email="{{ member.email }}"
                                                        data-ward-no="{{ member.ward_no|default('') }}"
                                                        {% if member.user_id == approval.verifier_id %}selected{% endif %}>
                                                    {{ member.name_bn }}{% if member.name_en %} ({{ member.name_en }}){% endif %} - 📱 {{ member.phone }}{% if member.ward_no %} | ওয়ার্ড: {{ member.ward_no }}{% endif %}
                                                </option>
                                            {% endfor %}
                                        </optgroup>
                                    {% endfor %}
                                </select>
                                <button type="button"
                                        class="btn btn-outline-danger"
                                        id="clearVerifierBtn"
                                        title="যাচাইকারী পরিষ্কার করুন">
                                    <i class="bi bi-x-circle"></i> পরিষ্কার
                                </button>
                            </div>
                        </div>
                    </div>
                    {% endif %}

                    <!-- Hidden Fields for Verifier -->
                    <input type="hidden" id="verifier_id" name="verifier_id" value="{{ approval.verifier_id|default('') }}">
                    <input type="hidden" id="verifier_ward_no" name="verifier_ward_no" value="{{ approval.verifier_ward_no|default('') }}">

                    <!-- Verifier Manual Name Input -->
                    <div class="form-section-inner">
                        <div class="row g-3">
                            <div class="col-lg-6 col-md-6 col-sm-12">
                                <label for="verifier_name_bn" class="form-label fw-semibold small mb-1">
                                    যাচাইকারীর নাম (বাংলা):
                                </label>
                                <input type="text" 
                                       id="verifier_name_bn" 
                                       name="verifier_name_bn"
                                       class="form-control form-control-sm shadow-sm input-enhanced"
                                       placeholder="বাংলায় যাচাইকারীর নাম লিখুন"
                                       value="{{ approval.verifier_name_bn|default('') }}">
                            </div>

                            <div class="col-lg-6 col-md-6 col-sm-12">
                                <label for="verifier_name_en" class="form-label fw-semibold small mb-1">
                                    যাচাইকারীর নাম (ইংরেজি):
                                </label>
                                <input type="text" 
                                       id="verifier_name_en" 
                                       name="verifier_name_en"
                                       class="form-control form-control-sm shadow-sm input-enhanced"
                                       placeholder="English name of verifier"
                                       value="{{ approval.verifier_name_en|default('') }}">
                            </div>

                            <div class="col-lg-6 col-md-6 col-sm-12" id="verifier_ward_section" style="display:none;">
                                <label for="verifier_ward_no_display" class="form-label fw-semibold small mb-1">
                                    ওয়ার্ড নম্বর:
                                </label>
                                <input type="text" 
                                       id="verifier_ward_no_display" 
                                       class="form-control form-control-sm shadow-sm bg-light"
                                       readonly>
                            </div>
                        </div>

                        <!-- Verification Date and Note -->
                        <div class="row g-3 mt-3">
                            <div class="col-lg-6 col-md-6 col-sm-12">
                                <label for="verification_date" class="form-label fw-semibold small mb-1">
                                    যাচাই তারিখ: <span class="text-danger">*</span>
                                </label>
                                <input type="text" 
                                       id="verification_date" 
                                       name="verification_date"
                                       class="form-control form-control-sm datepicker shadow-sm input-enhanced"
                                       placeholder="DD-MM-YYYY"
                                       value="{{ approval.verification_date|default('now'|date('d-m-Y')) }}" 
                                       required>
                            </div>

                            <div class="col-lg-6 col-md-6 col-sm-12">
                                <label for="verification_note" class="form-label fw-semibold small mb-1">
                                    যাচাই মন্তব্য:
                                </label>
                                <textarea id="verification_note" 
                                          name="verification_note" 
                                          rows="2"
                                          class="form-control form-control-sm shadow-sm input-enhanced"
                                          placeholder="যাচাই সংক্রান্ত মন্তব্য লিখুন">{{ approval.verification_note|default('সফলভাবে যাচাই করা হয়েছে।') }}</textarea>
                            </div>
                        </div>
                    </div>
                </fieldset>

                <!-- অনুমোদন তথ্য -->
                <fieldset class="form-section">
                    <legend>অনুমোদন তথ্য</legend>

                    {% if union_members is not empty %}
                    <!-- Quick Select Dropdown for Approver -->
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <div class="alert alert-warning mb-3 d-flex align-items-center gap-2">
                                <i class="bi bi-info-circle fs-5"></i>
                                <span>নীচের ড্রপডাউন থেকে অনুমোদনকারী নির্বাচন করুন। তথ্য স্বয়ংক্রিয়ভাবে পূরণ হবে।</span>
                            </div>

                            <label for="approver_select" class="form-label fw-semibold small mb-2">
                                <i class="bi bi-person-check-fill"></i> অনুমোদনকারী নির্বাচন করুন:
                            </label>

                            <div class="input-group input-group-sm">
                                <select id="approver_select"
                                        class="form-select form-select-sm shadow-sm"
                                        onchange="selectApproverFromDropdown()">
                                    <option value="">-- অনুমোদনকারী নির্বাচন করুন --</option>

                                        {% for role_id, group in union_members %}
                                            <optgroup label="{{ group.role_name }}">
                                                {% for member in group.members %}
                                                    <option value="{{ member.user_id }}"
                                                            data-name-bn="{{ member.name_bn }}"
                                                            data-name-en="{{ member.name_en }}"
                                                            data-role-id="{{ member.role_id|default('') }}"
                                                            data-phone="{{ member.phone }}"
                                                            data-email="{{ member.email }}"
                                                            data-ward-no="{{ member.ward_no|default('') }}"
                                                            {% if member.user_id == approval.approver_id %}selected{% endif %}>
                                                        {{ member.name_bn }}{% if member.name_en %} ({{ member.name_en }}){% endif %} - 📱 {{ member.phone }}{% if member.ward_no %} | ওয়ার্ড: {{ member.ward_no }}{% endif %}
                                                    </option>
                                                {% endfor %}
                                            </optgroup>
                                        {% endfor %}

                                </select>
                                <button type="button"
                                        class="btn btn-outline-danger"
                                        id="clearApproverBtn"
                                        title="অনুমোদনকারী পরিষ্কার করুন">
                                    <i class="bi bi-x-circle"></i> পরিষ্কার
                                </button>
                            </div>
                        </div>
                    </div>
                    {% endif %}

                    <!-- Hidden Fields for Approver -->
                    <input type="hidden" id="approver_id" name="approver_id" value="{{ approval.approver_id|default('') }}">
                    <input type="hidden" id="approver_ward_no" name="approver_ward_no" value="{{ approval.approver_ward_no|default('') }}">

                    <!-- Approver Manual Name Input -->
                    <div class="form-section-inner">
                        <div class="row g-3">
                            <div class="col-lg-6 col-md-6 col-sm-12">
                                <label for="approver_name_bn" class="form-label fw-semibold small mb-1">
                                    অনুমোদনকারীর নাম (বাংলা):
                                </label>
                                <input type="text" 
                                       id="approver_name_bn" 
                                       name="approver_name_bn"
                                       class="form-control form-control-sm shadow-sm input-enhanced"
                                       placeholder="বাংলায় অনুমোদনকারীর নাম লিখুন"
                                       value="{{ approval.approver_name_bn|default('') }}">
                            </div>

                            <div class="col-lg-6 col-md-6 col-sm-12">
                                <label for="approver_name_en" class="form-label fw-semibold small mb-1">
                                    অনুমোদনকারীর নাম (ইংরেজি):
                                </label>
                                <input type="text" 
                                       id="approver_name_en" 
                                       name="approver_name_en"
                                       class="form-control form-control-sm shadow-sm input-enhanced"
                                       placeholder="English name of approver"
                                       value="{{ approval.approver_name_en|default('') }}">
                            </div>

                            <div class="col-lg-6 col-md-6 col-sm-12" id="approver_ward_section" style="display:none;">
                                <label for="approver_ward_no_display" class="form-label fw-semibold small mb-1">
                                    ওয়ার্ড নম্বর:
                                </label>
                                <input type="text" 
                                       id="approver_ward_no_display" 
                                       class="form-control form-control-sm shadow-sm bg-light"
                                       readonly>
                            </div>
                        </div>

                        <!-- Approval Date and Note -->
                        <div class="row g-3 mt-3">
                            <div class="col-lg-6 col-md-6 col-sm-12">
                                <label for="approval_date" class="form-label fw-semibold small mb-1">
                                    অনুমোদনের তারিখ: <span class="text-danger">*</span>
                                </label>
                                <input type="text" 
                                       id="approval_date" 
                                       name="approval_date"
                                       class="form-control form-control-sm datepicker shadow-sm input-enhanced"
                                       placeholder="DD-MM-YYYY"
                                       value="{{ approval.approval_date|default('now'|date('d-m-Y')) }}" 
                                       required>
                            </div>

                            <div class="col-lg-6 col-md-6 col-sm-12">
                                <div class="d-flex align-items-center justify-content-between gap-2 mb-1">
                                    <label for="issue_time" class="form-label fw-semibold small mb-0">
                                        লাইসেন্স ইস্যু সময়:
                                    </label>
                                    <span id="issue_time_live" class="badge bg-light text-dark border" title="Current time (live)">
                                        --:--:--
                                    </span>
                                </div>
                                <input type="time" 
                                       id="issue_time" 
                                       name="issue_time"
                                       step="1"
                                       data-prefilled="{{ approval.issue_time is defined and approval.issue_time is not empty ? '1' : '0' }}"
                                       class="form-control form-control-sm shadow-sm input-enhanced"
                                       value="{{ approval.issue_time is defined ? approval.issue_time : '' }}"
                                       required>
                            </div>
                        </div>

                        <!-- Approval Note -->
                        <div class="row g-3 mt-3">
                            <div class="col-lg-12">
                                <label for="approval_note" class="form-label fw-semibold small mb-1">
                                    মন্তব্য:
                                </label>
                                <textarea id="approval_note" 
                                          name="approval_note" 
                                          rows="2"
                                          class="form-control form-control-sm shadow-sm input-enhanced"
                                          placeholder="অনুমোদন সংক্রান্ত মন্তব্য লিখুন">{{ approval.approval_note|default('আবেদনটি অনুমোদিত হলো।') }}</textarea>
                            </div>
                        </div>
                    </div>
                </fieldset>

                {% if data.certificate_type == 'trade' %}
                    {% include 'common/trade_extra.twig' %}
                {% endif %}

                <!-- সনদের ফি তথ্য -->
                <fieldset class="form-section">
                    <legend>সনদ ফি তথ্য</legend>
                    <div class="row g-3">
                        <div class="col-lg-4 col-md-6 col-sm-12">
                            <label for="certificate_fee" class="form-label fw-semibold small mb-1">
                                সনদের ফি (টাকা): <span class="text-danger">*</span>
                            </label>
                            <input type="number" 
                                   id="certificate_fee" 
                                   name="certificate_fee"
                                   class="form-control form-control-sm shadow-sm input-enhanced"
                                   placeholder="সনদের ফি লিখুন"
                                   value="{{ approval.certificate_fee|default('') }}"
                                   min="0" 
                                   step="0.01" 
                                   required>
                        </div>

                        <div class="col-lg-4 col-md-6 col-sm-12">
                            <label for="payment_method" class="form-label fw-semibold small mb-1">
                                পরিশোধের মাধ্যম: <span class="text-danger">*</span>
                            </label>
                            <select id="payment_method" 
                                    name="payment_method"
                                    class="form-select form-select-sm shadow-sm input-enhanced" 
                                    required>
                                <option value="Cash" {% if approval.payment_method=='Cash' %}selected{% endif %}>💵 ক্যাশ</option>
                                <option value="Bkash" {% if approval.payment_method=='Bkash' %}selected{% endif %}>📱 বিকাশ</option>
                                <option value="Nagad" {% if approval.payment_method=='Nagad' %}selected{% endif %}>📱 নগদ</option>
                                <option value="Rocket" {% if approval.payment_method=='Rocket' %}selected{% endif %}>📱 রকেট</option>
                            </select>
                        </div>

                        <div class="col-lg-4 col-md-6 col-sm-12">
                            <label for="payment_status" class="form-label fw-semibold small mb-1">
                                পরিশোধের অবস্থা: <span class="text-danger">*</span>
                            </label>
                            <select id="payment_status" 
                                    name="payment_status"
                                    class="form-select form-select-sm shadow-sm input-enhanced" 
                                    required>
                                <option value="Paid" {% if approval.payment_status=='Paid' %}selected{% endif %}>✅ পরিশোধিত</option>
                                <option value="Unpaid" {% if approval.payment_status=='Unpaid' %}selected{% endif %}>⏳ অপরিশোধিত</option>
                            </select>
                        </div>
                    </div>
                </fieldset>

                <hr class="my-5">

                <!-- Action Buttons -->
                <div class="action-buttons-container section-appear">
                    <!-- Primary Actions -->
                    <div class="action-group action-group-primary">
                        <button type="submit" 
                                id="approve" 
                                class="btn btn-success action-btn action-btn-approve">
                            <i class="bi bi-check-circle me-2"></i> {{ data.status == 'approved' ? 'অনুমোদন হালনাগাদ' : 'অনুমোদন করুন' }}
                        </button>

                        <button type="button" 
                                id="reject" 
                                class="btn btn-danger action-btn action-btn-reject">
                            <i class="bi bi-x-circle me-2"></i> বাতিল করুন
                        </button>

                        <button type="button" 
                                id="on_hold" 
                                class="btn btn-secondary action-btn action-btn-hold">
                            <i class="bi bi-pause-circle me-2"></i> অন-হোল্ড
                        </button>

                        <button type="button" 
                                id="reactivate" 
                                class="btn btn-info action-btn action-btn-reactivate">
                            <i class="bi bi-arrow-repeat me-2"></i> পুনরায় চালু
                        </button>
                    </div>

                    <!-- Secondary Actions -->
                    <div class="action-group action-group-secondary">
                        <a href="/{{ data.certificate_type }}_verify/application/{{ data.application_id }}/{{ union.union_code }}/0" 
                           class="btn btn-primary action-btn action-btn-view">
                            <i class="bi bi-files me-2"></i> আবেদন কপি
                        </a>

                        {% if data.status == 'approved' %}
                            <div class="btn-group" role="group">
                                <a href="/application/{{ data.certificate_type }}/bangla/{{ data.sonod_number }}" 
                                   class="btn btn-outline-success action-btn" 
                                   target="_blank"
                                   title="সার্টিফিকেট ডাউনলোড (বাংলা)">
                                    <i class="bi bi-file-earmark-pdf me-1"></i> সার্টিফিকেট (বাংলা)
                                </a>
                                <a href="/application/{{ data.certificate_type }}/english/{{ data.sonod_number }}" 
                                   class="btn btn-outline-success action-btn" 
                                   target="_blank"
                                   title="Certificate Download (English)">
                                    <i class="bi bi-file-earmark-pdf me-1"></i> Certificate (English)
                                </a>
                            </div>
                        {% endif %}

                        <button type="reset" 
                                class="btn btn-warning action-btn action-btn-reset">
                            <i class="bi bi-arrow-clockwise me-2"></i> রিসেট
                        </button>

                        {# Fix Sonod #}
                        <div class="position-relative d-inline-block">
                            <button type="button" 
                                    id="fix_sonod" 
                                    class="btn btn-dark action-btn action-btn-fix"
                                    title="Click to fix Sonod number & status if inconsistent">
                                <i class="bi bi-tools me-2"></i> Fix Sonod
                            </button>
                            <small id="fix_sonod_msg" class="action-fix-msg"></small>
                        </div>

                        {% if data.certificate_type == 'trade' %}
                            <button type="button" 
                                    id="renew" 
                                    class="btn btn-info action-btn action-btn-renew">
                                <i class="bi bi-arrow-repeat me-2"></i> নবায়ন
                            </button>
                            <button type="button" 
                                    id="viewHistory" 
                                    class="btn btn-outline-secondary action-btn action-btn-history">
                                <i class="bi bi-clock-history me-2"></i> নবায়ন ইতিহাস
                            </button>
                        {% endif %}
                    </div>
                </div>

            </form>




    </div>
</div>

<!-- Approved Modal - Enhanced -->
<div class="modal fade" id="approvedModal" tabindex="-1" aria-labelledby="approvedModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content modal-approved-content">
            <div class="modal-header bg-success text-white border-0">
                <div class="d-flex align-items-center gap-2">
                    <div class="modal-success-icon">
                        <i class="bi bi-check-circle-fill fs-2"></i>
                    </div>
                    <div>
                        <h5 class="modal-title fw-bold" id="approvedModalLabel">আবেদন অনুমোদিত</h5>
                        <p class="mb-0 small text-white-50" id="approvedModalSubtitle">আবেদনটি সফলভাবে অনুমোদিত হয়েছে</p>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Success Animation -->
                <div class="text-center mb-4">
                    <div class="success-checkmark">
                        <div class="check-icon">
                            <span class="icon-line line-tip"></span>
                            <span class="icon-line line-long"></span>
                            <div class="icon-circle"></div>
                            <div class="icon-fix"></div>
                        </div>
                    </div>
                    <h5 class="fw-bold text-success mt-3" id="approvedModalCongrats">অভিনন্দন!</h5>
                    <p class="text-muted mb-3" id="approvedModalBodyText">আপনার আবেদন সফলভাবে অনুমোদিত হয়েছে। নিচের তথ্য ও অপশনগুলো দেখুন।</p>
                </div>

                <div class="modal-info-grid">
                    <div class="modal-info-item">
                        <div class="modal-info-icon bg-primary-subtle">
                            <i class="bi bi-upc-scan text-primary"></i>
                        </div>
                        <div>
                            <span class="modal-info-label">ট্র্যাকিং নম্বর</span>
                            <span class="modal-info-value" id="approved_application_id">—</span>
                        </div>
                    </div>
                    <div class="modal-info-item">
                        <div class="modal-info-icon bg-info-subtle">
                            <i class="bi bi-qr-code text-info"></i>
                        </div>
                        <div>
                            <span class="modal-info-label">ইউনিয়ন কোড</span>
                            <span class="modal-info-value" id="approved_union_code">—</span>
                        </div>
                    </div>
                    <div class="modal-info-item">
                        <div class="modal-info-icon bg-secondary-subtle">
                            <i class="bi bi-code-square text-secondary"></i>
                        </div>
                        <div>
                            <span class="modal-info-label">RMO কোড</span>
                            <span class="modal-info-value" id="approved_rmo_code">—</span>
                        </div>
                    </div>
                    <div class="modal-info-item">
                        <div class="modal-info-icon bg-warning-subtle">
                            <i class="bi bi-file-earmark-text text-warning"></i>
                        </div>
                        <div>
                            <span class="modal-info-label">আবেদনের ধরন</span>
                            <span class="modal-info-value" id="approved_certificate_type">—</span>
                        </div>
                    </div>
                    <div class="modal-info-item modal-info-item-full">
                        <div class="modal-info-icon bg-success-subtle">
                            <i class="bi bi-passport text-success"></i>
                        </div>
                        <div>
                            <span class="modal-info-label">লাইসেন্স/সনদ নং</span>
                            <span class="modal-info-value fw-bold fs-5 text-success" id="approved_license_number">—</span>
                        </div>
                    </div>
                </div>

                <hr class="my-3">

                <div class="modal-actions-grid">
                    <a id="approved_download_link" class="modal-action-btn btn-download" target="_blank" href="#">
                        <i class="bi bi-download"></i>
                        <span>আবেদন কপি</span>
                    </a>
                    <a id="approved_certificate_link" class="modal-action-btn btn-certificate" target="_blank" href="#">
                        <i class="bi bi-file-earmark-pdf"></i>
                        <span>সার্টিফিকেট (বাংলা)</span>
                    </a>
                    <a id="approved_certificate_en_link" class="modal-action-btn btn-certificate-en" target="_blank" href="#">
                        <i class="bi bi-file-earmark-pdf"></i>
                        <span>Certificate (English)</span>
                    </a>
                    <a id="approved_view_link" class="modal-action-btn btn-view" target="_blank" href="#">
                        <i class="bi bi-eye"></i>
                        <span>আবেদন দেখুন</span>
                    </a>
                    <button type="button" id="approved_new_btn" class="modal-action-btn btn-new">
                        <i class="bi bi-plus-circle"></i>
                        <span>নতুন আবেদন</span>
                    </button>
                    <button type="button" class="modal-action-btn btn-close-action" data-bs-dismiss="modal">
                        <i class="bi bi-x-lg"></i>
                        <span>বন্ধ করুন</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Photo Lightbox Modal -->
<div class="modal fade photo-lightbox-modal" id="photoLightbox" tabindex="-1" aria-hidden="true" data-bs-backdrop="false" role="dialog" aria-modal="true" aria-label="আবেদনকারীর ছবি — পূর্ণ আকার">
    <div class="modal-dialog modal-fullscreen modal-dialog-centered">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-body p-0 d-flex align-items-center justify-content-center position-relative">
                <button type="button"
                        class="photo-lightbox-close"
                        data-bs-dismiss="modal"
                        aria-label="বন্ধ করুন"
                        title="বন্ধ করুন (Esc)">
                    <i class="bi bi-x-lg"></i>
                </button>
                <!-- Download button -->
                <a href="{{ url }}/{{ data.applicant_photo ?: 'assets/images/default-user.png' }}"
                   class="photo-lightbox-download"
                   download="{{ data.name_bn|default('applicant')|replace({' ':'_', '/':'_'}) }}_photo.jpg"
                   aria-label="ছবি ডাউনলোড করুন"
                   title="ছবি ডাউনলোড করুন">
                    <i class="bi bi-download"></i>
                </a>
                <!-- Rotation hint -->
                <div class="photo-lightbox-hint" id="photoLightboxHint" aria-live="polite" aria-atomic="true">
                    <span class="rotation-badge" id="photoRotationBadge">0°</span>
                    <span class="rotation-help"><i class="bi bi-arrow-left"></i> <i class="bi bi-arrow-right"></i> ঘোরান | <i class="bi bi-download"></i> ডাউনলোড</span>
                </div>
                <img src="{{ url }}/{{ data.applicant_photo ?: 'assets/images/default-user.png' }}"
                     alt="আবেদনকারীর ছবি — পূর্ণ আকার"
                     class="photo-lightbox-image"
                     id="photoLightboxImage"
                     data-rotation="0">
            </div>
        </div>
    </div>
</div>

<!-- Document Gallery Modal -->
<div class="modal fade photo-lightbox-modal" id="documentGallery" tabindex="-1" aria-hidden="true" data-bs-backdrop="false" role="dialog" aria-modal="true" aria-label="ডকুমেন্ট গ্যালারি">
    <div class="modal-dialog modal-fullscreen modal-dialog-centered">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-body p-0 d-flex align-items-center justify-content-center position-relative">
                <!-- Close button -->
                <button type="button"
                        class="photo-lightbox-close"
                        data-bs-dismiss="modal"
                        aria-label="বন্ধ করুন"
                        title="বন্ধ করুন (Esc)">
                    <i class="bi bi-x-lg"></i>
                </button>
                <!-- Download button -->
                <a href="#"
                   class="photo-lightbox-download"
                   id="docGalleryDownload"
                   download="document.jpg"
                   aria-label="ডকুমেন্ট ডাউনলোড করুন"
                   title="ডকুমেন্ট ডাউনলোড করুন">
                    <i class="bi bi-download"></i>
                </a>

                <!-- Previous / Next navigation arrows -->
                <button type="button"
                        class="doc-gallery-nav doc-gallery-prev"
                        id="docGalleryPrev"
                        aria-label="পূর্ববর্তী ডকুমেন্ট"
                        title="পূর্ববর্তী (←)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <button type="button"
                        class="doc-gallery-nav doc-gallery-next"
                        id="docGalleryNext"
                        aria-label="পরবর্তী ডকুমেন্ট"
                        title="পরবর্তী (→)">
                    <i class="bi bi-chevron-right"></i>
                </button>

                <!-- Top info bar: counter + document name -->
                <div class="doc-gallery-topbar" id="docGalleryTopbar">
                    <span class="doc-gallery-counter" id="docGalleryCounter">1 / 1</span>

            font-size: 0.7rem;
            gap: 6px;
        }

        .photo-lightbox-hint .rotation-badge {
            min-width: 26px;
            height: 18px;
            font-size: 0.65rem;
        }
    }

    /* ===== Document Gallery Trigger Overlay ===== */
    .doc-gallery-trigger {
        position: relative;
        cursor: pointer;
        overflow: hidden;
    }

    .doc-gallery-trigger img {
        transition: transform 0.4s ease, filter 0.4s ease;
    }

    .doc-gallery-trigger:hover img {
        transform: scale(1.08);
        filter: brightness(0.7);
    }

    .doc-gallery-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        color: #fff;
        font-size: 1.2rem;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .doc-gallery-overlay span {
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.3px;
        text-transform: uppercase;
    }

    .doc-gallery-trigger:hover .doc-gallery-overlay {
        opacity: 1;
    }

    /* ===== Document Gallery Navigation Arrows ===== */
    .doc-gallery-nav {
        position: absolute;
        z-index: 1061;
        top: 50%;
        transform: translateY(-50%);
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: rgba(255,255,255,0.12);
        border: none;
        color: #fff;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: blur(4px);
        opacity: 0;
    }

    .photo-lightbox-modal.show .doc-gallery-nav {
        opacity: 1;
        transition-delay: 0.2s;
    }

    .doc-gallery-prev { left: 18px; }
    .doc-gallery-next { right: 18px; }

    .doc-gallery-nav:hover {
        background: rgba(255,255,255,0.25);
        transform: translateY(-50%) scale(1.1);
    }

    .doc-gallery-nav:active {
        transform: translateY(-50%) scale(0.95);
    }

    .doc-gallery-nav:focus-visible {
        outline: 3px solid #fff;
        outline-offset: 3px;
    }

    /* ===== Document Gallery Top Bar ===== */
    .doc-gallery-topbar {
        position: absolute;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1060;
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(6px);
        padding: 7px 18px;
        border-radius: 24px;
        color: rgba(255,255,255,0.8);
        font-size: 0.8rem;
        transition: opacity 0.4s ease, transform 0.4s ease;
        opacity: 0;
        transform: translateX(-50%) translateY(-10px);
        pointer-events: none;
        max-width: calc(100vw - 140px);
    }

    .photo-lightbox-modal.show .doc-gallery-topbar {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
        transition-delay: 0.4s;
    }

    .doc-gallery-counter {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 42px;
        height: 22px;
        background: rgba(255,255,255,0.15);
        border-radius: 11px;
        padding: 0 8px;
        font-size: 0.72rem;
        font-weight: 700;
        color: #fff;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .doc-gallery-filename {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 300px;
        font-size: 0.78rem;
        opacity: 0.75;
    }

    @media (max-width: 768px) {
        .doc-gallery-nav {
            width: 40px;
            height: 40px;
            font-size: 1.1rem;
        }
        .doc-gallery-prev { left: 10px; }
        .doc-gallery-next { right: 10px; }
        .doc-gallery-topbar {
            top: 12px;
            padding: 5px 12px;
            gap: 8px;
            font-size: 0.7rem;
            max-width: calc(100vw - 100px);
        }
        .doc-gallery-filename {
            max-width: 120px;
        }
        .doc-gallery-counter {
            min-width: 32px;
            height: 18px;
            font-size: 0.65rem;
        }
    }

    @media (max-width: 576px) {
        .doc-gallery-nav {
            width: 34px;
            height: 34px;
            font-size: 0.95rem;
        }
        .doc-gallery-prev { left: 6px; }
        .doc-gallery-next { right: 6px; }
    }

    /* ===== Responsive Adjustments ===== */
    @media (max-width: 768px) {

        .action-group { gap: 0.4rem; }
        .action-btn { padding: 0.45rem 0.85rem; font-size: 0.8rem; }
    }

    @media (max-width: 576px) {

        .modal-approved-content { border-radius: 12px; margin: 0.5rem; }
        .applicant-photo { width: 110px; height: 110px; }
    }
</style>

    .btn-close-action:hover { background: #fbe9e7; border-color: #f44336; color: #c62828; }

    /* ===== Section Appear Animation (via IntersectionObserver) ===== */
    .section-appear {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1), transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .section-appear.appeared {
        opacity: 1;
        transform: translateY(0);
    }



    /* ===== Print Styles ===== */
    @media print {
        .sidebar, header, footer, .top-button, .breadcrumb-nav, .page-loader,
        .action-buttons-container,
        .photo-ring-overlay, #approvalForm, .action-group, .photo-lightbox-modal {
            display: none !important;

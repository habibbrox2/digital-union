    .modal-action-btn i {
        font-size: 1.3rem;
    }

    .btn-download:hover { background: #e8f5e9; border-color: #28a745; color: #28a745; }
    .btn-certificate:hover { background: #fff8e1; border-color: #ffc107; color: #f39c12; }
    .btn-certificate-en:hover { background: #fff3e0; border-color: #ff9800; color: #e65100; }

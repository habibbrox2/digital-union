{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {

    /* ===============================
       Set Current Time for Issue Time Input (Real-time sync)
    =============================== */
    const issueTimeInput = document.getElementById('issue_time');
    const issueTimeLive = document.getElementById('issue_time_live');
    let issueTimeTimer = null;
    let issueTimeTimeout = null;
    let liveClockTimer = null;
    let liveClockTimeout = null;

    const isDefaultIssueTime = (v) => {
        const value = String(v || '').trim();
        return value === '' || value === '12:00' || value === '12:00:00';
    };

    const formatTimeHHMMSS = (d) => {
        const hours = String(d.getHours()).padStart(2, '0');
        const minutes = String(d.getMinutes()).padStart(2, '0');
        const seconds = String(d.getSeconds()).padStart(2, '0');
        return `${hours}:${minutes}:${seconds}`;
    };

    const startLiveClock = () => {
        if (!issueTimeLive || liveClockTimer || liveClockTimeout) return;

        const tick = () => {
            issueTimeLive.textContent = formatTimeHHMMSS(new Date());
        };

        tick();
        const msToNextSecond = 1000 - (Date.now() % 1000);
        liveClockTimeout = setTimeout(() => {
            liveClockTimeout = null;
            tick();
            liveClockTimer = setInterval(tick, 1000);
        }, msToNextSecond);
    };

    const stopLiveClock = () => {
        if (liveClockTimeout) {
            clearTimeout(liveClockTimeout);
            liveClockTimeout = null;
        }
        if (!liveClockTimer) return;
        clearInterval(liveClockTimer);
        liveClockTimer = null;
    };

    const startIssueTimeSync = () => {
        if (!issueTimeInput || issueTimeTimer || issueTimeTimeout) return;

        const tick = () => {
            // Avoid overwriting user input if they already set a custom time.
            if (!isDefaultIssueTime(issueTimeInput.value)) {
                stopIssueTimeSync();
                return;
            }
            issueTimeInput.value = formatTimeHHMMSS(new Date());
        };

        // Align to the next full second so the timer doesn't drift too much.
        tick();
        const msToNextSecond = 1000 - (Date.now() % 1000);
        issueTimeTimeout = setTimeout(() => {
            issueTimeTimeout = null;
            tick();
            issueTimeTimer = setInterval(tick, 1000);
        }, msToNextSecond);
    };

    const stopIssueTimeSync = () => {
        if (issueTimeTimeout) {
            clearTimeout(issueTimeTimeout);
            issueTimeTimeout = null;
        }
        if (!issueTimeTimer) return;
        clearInterval(issueTimeTimer);
        issueTimeTimer = null;
    };

    if (issueTimeInput) {
        const hasDbPrefill = issueTimeInput.dataset?.prefilled === '1';

        // If server rendered the placeholder default, replace it with real time.
        if (!hasDbPrefill && isDefaultIssueTime(issueTimeInput.value)) {
            startIssueTimeSync();
        }

        // Let user edit without fighting the real-time updater.
        issueTimeInput.addEventListener('focus', stopIssueTimeSync);
        issueTimeInput.addEventListener('blur', () => {
            if (!hasDbPrefill && isDefaultIssueTime(issueTimeInput.value)) startIssueTimeSync();
        });
        issueTimeInput.addEventListener('input', () => {
            if (!isDefaultIssueTime(issueTimeInput.value)) stopIssueTimeSync();
        });
    }

    // Live clock display (independent from input syncing)
    startLiveClock();
    window.addEventListener('beforeunload', () => {
        stopIssueTimeSync();
        stopLiveClock();
    });

    /* ===============================
       Helpers
    =============================== */

    const $id = id => document.getElementById(id);
    const on = (id, event, handler) => {
        const el = $id(id);
        if (el) el.addEventListener(event, handler);
    };

    const csrfToken = () => document.querySelector('meta[name="csrf_token"]')?.getAttribute('content') || '';
    const certType  = () => $id('certificate_type')?.value || '';
    const appId     = () => $id('application_id')?.value || '';

    function getTodayDate() {
        const t = new Date();
        return `${String(t.getDate()).padStart(2,'0')}-${String(t.getMonth()+1).padStart(2,'0')}-${t.getFullYear()}`;
    }

    /* ===============================
       Scroll Animation via IntersectionObserver
    =============================== */
    const observeSections = () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry, index) => {
                if (entry.isIntersecting) {
                    // Stagger the animations slightly
                    const delay = Array.from(entry.target.parentElement?.children || []).indexOf(entry.target) * 80;
                    setTimeout(() => {
                        entry.target.classList.add('appeared');
                    }, Math.min(delay, 500));
                    observer.unobserve(entry.target);
                }
            });
        }, {
            threshold: 0.1,
            rootMargin: '0px 0px -40px 0px'
        });

        document.querySelectorAll('.section-appear').forEach(el => observer.observe(el));
    };

    observeSections();

    /* ===============================
       Button Loading State
    =============================== */
    function btnLoading(btn) {
        if (!btn) return function(){};
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span> প্রসেসিং...';
        btn.classList.add('btn-loading');
        return function() {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
            btn.classList.remove('btn-loading');
        };
    }

    function displayMessage(status, message, licenseNumber = null) {
        let fullMessage = message;
        if (licenseNumber) fullMessage += `\n\n📜 লাইসেন্স নম্বর: ${licenseNumber}`;

        Swal.fire({
            icon: status === 'success' ? 'success' : 'error',
            title: status === 'success' ? '✅ সফল হয়েছে!' : '❌ ব্যর্থ হয়েছে!',
            text: fullMessage,
            confirmButtonText: 'OK',
            confirmButtonColor: status === 'success' ? '#28a745' : '#dc3545'
        }).then(() => {
            if (status === 'success') history.back();
        });
    }

    function postData(url, body, onSuccess, button) {
        const restore = button ? btnLoading(button) : function(){};
        fetch(url, {
            method: 'POST',
            headers: {'Content-Type':'application/x-www-form-urlencoded'},
            body
        })
        .then(r => r.json())
        .then(res => {
            restore();
            if (res.status === 'success') onSuccess(res);
            else displayMessage('error', res.message || 'Unknown error');
        })
        .catch(() => {
            restore();
            displayMessage('error', '❌ কিছু ভুল হয়েছে, আবার চেষ্টা করুন।');
        });
    }

    function validateTradeApprovalFields() {
        if (certType() !== 'trade') {
            return true;
        }

        const fiscalYear = $id('fiscal_year')?.value?.trim() || '';
        const ownershipTypeId = $id('ownership_type_id')?.value?.trim() || '';
        const businessTypeId = $id('business_type_id')?.value?.trim() || '';

        if (!fiscalYear) {
            displayMessage('error', 'অনুগ্রহ করে সনদের অর্থবছর নির্বাচন করুন।');
            return false;
        }
        if (!ownershipTypeId) {
            displayMessage('error', 'অনুগ্রহ করে মালিকানার ধরণ নির্বাচন করুন।');
            return false;
        }
        if (!businessTypeId) {
            displayMessage('error', 'অনুগ্রহ করে ব্যবসার ধরণ নির্বাচন করুন।');
            return false;
        }

        return true;
    }

    /* ===============================
       Photo Lightbox Keyboard Navigation & Accessibility
    =============================== */
    const photoLightbox = document.getElementById('photoLightbox');
    const photoLightboxImg = document.getElementById('photoLightboxImage');
    const photoRotationBadge = document.getElementById('photoRotationBadge');
    let photoKeyHandler = null;

    if (photoLightbox && photoLightboxImg) {
        // When modal opens: focus the close button, trap focus
        photoLightbox.addEventListener('shown.bs.modal', function () {
            const closeBtn = photoLightbox.querySelector('.photo-lightbox-close');
            if (closeBtn) closeBtn.focus();

            // Attach keyboard listener
            if (photoKeyHandler) {
                document.removeEventListener('keydown', photoKeyHandler);
            }
            photoKeyHandler = function (e) {
                // Esc — close modal (Bootstrap handles this, but reinforce)
                if (e.key === 'Escape') {
                    const modal = bootstrap.Modal.getInstance(photoLightbox);
                    if (modal) modal.hide();
                    return;
                }

                // Left arrow — rotate counterclockwise
                if (e.key === 'ArrowLeft') {
                    e.preventDefault();
                    let rot = parseInt(photoLightboxImg.dataset.rotation || '0', 10);
                    rot = ((rot - 90) % 360 + 360) % 360;
                    applyPhotoRotation(rot);
                    return;
                }

                // Right arrow — rotate clockwise
                if (e.key === 'ArrowRight') {
                    e.preventDefault();
                    let rot = parseInt(photoLightboxImg.dataset.rotation || '0', 10);
                    rot = ((rot + 90) % 360 + 360) % 360;
                    applyPhotoRotation(rot);
                    return;
                }
            };
            document.addEventListener('keydown', photoKeyHandler);
        });

        // Clean up listener when modal hides
        photoLightbox.addEventListener('hidden.bs.modal', function () {
            if (photoKeyHandler) {
                document.removeEventListener('keydown', photoKeyHandler);
                photoKeyHandler = null;
            }
            // Reset rotation on close
            applyPhotoRotation(0);
        });

        function applyPhotoRotation(degrees) {
            photoLightboxImg.dataset.rotation = degrees;
            // Remove all rotation classes
            photoLightboxImg.classList.remove('rotate-90', 'rotate-180', 'rotate-270');
            if (degrees !== 0) {
                photoLightboxImg.classList.add('rotate-' + degrees);
            }
            // Update badge with a quick bounce animation
            if (photoRotationBadge) {
                photoRotationBadge.textContent = degrees + '°';
                photoRotationBadge.style.transform = 'scale(1.3)';
                setTimeout(function () {
                    photoRotationBadge.style.transform = 'scale(1)';
                }, 150);
            }
        }
    }

    /* ===============================
       Document Gallery State & Navigation
    =============================== */
    const docGallery = document.getElementById('documentGallery');
    const docGalleryImg = document.getElementById('docGalleryImage');
    const docGalleryPrev = document.getElementById('docGalleryPrev');
    const docGalleryNext = document.getElementById('docGalleryNext');
    const docGalleryCounter = document.getElementById('docGalleryCounter');
    const docGalleryFilename = document.getElementById('docGalleryFilename');
    const docGalleryDownload = document.getElementById('docGalleryDownload');
    const docGalleryRotationBadge = document.getElementById('docGalleryRotationBadge');
    let docGalleryItems = [];
    let docGalleryIndex = 0;
    let docGalleryKeyHandler = null;

    function buildDocGalleryItems() {
        const triggers = document.querySelectorAll('.doc-gallery-trigger');
        const items = [];
        triggers.forEach(function (t) {
            const url = t.getAttribute('data-doc-url');
            const name = t.getAttribute('data-doc-name');
            if (url) {
                items.push({ url: url, name: name || 'document' });
            }
        });
        return items;
    }

    function updateDocGallery() {
        if (!docGalleryItems.length || !docGalleryImg) return;

        var item = docGalleryItems[docGalleryIndex];
        docGalleryImg.src = item.url;
        docGalleryImg.alt = 'Document: ' + (item.name || '');
        docGalleryImg.dataset.rotation = '0';
        docGalleryImg.classList.remove('rotate-90', 'rotate-180', 'rotate-270');

        if (docGalleryCounter) {
            docGalleryCounter.textContent = (docGalleryIndex + 1) + ' / ' + docGalleryItems.length;
            docGalleryCounter.style.transform = 'scale(1.2)';
            setTimeout(function () { docGalleryCounter.style.transform = 'scale(1)'; }, 150);
        }

        if (docGalleryFilename) {
            docGalleryFilename.textContent = item.name || '';
        }

        if (docGalleryDownload) {
            docGalleryDownload.href = item.url;
            docGalleryDownload.download = item.name || 'document.jpg';
        }

        if (docGalleryRotationBadge) {
            docGalleryRotationBadge.textContent = '0°';
        }

        // Toggle nav button visibility (disable at bounds)
        if (docGalleryPrev) {
            docGalleryPrev.disabled = docGalleryIndex <= 0;
            docGalleryPrev.style.opacity = docGalleryIndex <= 0 ? '0.3' : '';
        }
        if (docGalleryNext) {
            docGalleryNext.disabled = docGalleryIndex >= docGalleryItems.length - 1;
            docGalleryNext.style.opacity = docGalleryIndex >= docGalleryItems.length - 1 ? '0.3' : '';
        }
    }

    function openDocGallery(index) {
        docGalleryItems = buildDocGalleryItems();
        if (!docGalleryItems.length) return;
        docGalleryIndex = Math.max(0, Math.min(index, docGalleryItems.length - 1));
        updateDocGallery();
        var modal = new bootstrap.Modal(document.getElementById('documentGallery'));
        modal.show();
    }

    // Click / Enter / Space on trigger elements
    document.querySelectorAll('.doc-gallery-trigger').forEach(function (el) {
        el.addEventListener('click', function (e) {
            var triggers = document.querySelectorAll('.doc-gallery-trigger');
            var idx = Array.from(triggers).indexOf(this);
            openDocGallery(idx);
        });
        el.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                var triggers = document.querySelectorAll('.doc-gallery-trigger');
                var idx = Array.from(triggers).indexOf(this);
                openDocGallery(idx);
            }
        });
    });

    // Nav button clicks
    if (docGalleryPrev) {
        docGalleryPrev.addEventListener('click', function () {
            if (docGalleryIndex > 0) {
                docGalleryIndex--;
                updateDocGallery();
            }
        });
    }
    if (docGalleryNext) {
        docGalleryNext.addEventListener('click', function () {
            if (docGalleryIndex < docGalleryItems.length - 1) {
                docGalleryIndex++;
                updateDocGallery();
            }
        });
    }

    // Keyboard navigation for document gallery
    if (docGallery) {
        docGallery.addEventListener('shown.bs.modal', function () {
            // Focus the close button
            var closeBtn = docGallery.querySelector('.photo-lightbox-close');
            if (closeBtn) closeBtn.focus();

            // Attach key handler
            if (docGalleryKeyHandler) {
                document.removeEventListener('keydown', docGalleryKeyHandler);
            }
            docGalleryKeyHandler = function (e) {
                // Esc — close
                if (e.key === 'Escape') {
                    var modal = bootstrap.Modal.getInstance(docGallery);
                    if (modal) modal.hide();
                    return;
                }

                // Left arrow — previous document
                if (e.key === 'ArrowLeft') {
                    e.preventDefault();
                    if (docGalleryIndex > 0) {
                        docGalleryIndex--;
                        updateDocGallery();
                        // Quick pulse animation on the image
                        docGalleryImg.style.transform = 'scale(0.96)';
                        setTimeout(function () { docGalleryImg.style.transform = ''; }, 200);
                    }
                    return;
                }

                // Right arrow — next document
                if (e.key === 'ArrowRight') {
                    e.preventDefault();
                    if (docGalleryIndex < docGalleryItems.length - 1) {
                        docGalleryIndex++;
                        updateDocGallery();
                        docGalleryImg.style.transform = 'scale(0.96)';
                        setTimeout(function () { docGalleryImg.style.transform = ''; }, 200);
                    }
                    return;
                }
            };
            document.addEventListener('keydown', docGalleryKeyHandler);
        });

        docGallery.addEventListener('hidden.bs.modal', function () {
            if (docGalleryKeyHandler) {
                document.removeEventListener('keydown', docGalleryKeyHandler);
                docGalleryKeyHandler = null;
            }
            // Reset rotation badge
            if (docGalleryRotationBadge) docGalleryRotationBadge.textContent = '0°';
        });
    }

    /* ===============================
       Init approval date
    =============================== */

    const approvalInput = $id('approval_date');
    if (approvalInput && !approvalInput.value.trim()) {
        approvalInput.value = getTodayDate();
    }

    const approvalForm = $id('approvalForm');

    /* ===============================
       Approve
    =============================== */

    on('approve', 'click', e => {
        e.preventDefault();

        if (!$id('approval_date')?.value.trim()) {
            displayMessage('error', 'অনুগ্রহ করে অনুমোদনের তারিখ নির্বাচন করুন।');
            return;
        }

        if (!validateTradeApprovalFields()) {
            return;
        }

        if (certType() === 'trade') {
            Swal.fire({
                title: 'লাইসেন্স নম্বর লিখুন',
                input: 'text',
                inputValue: $id('license_number')?.value || '',
                showCancelButton: true,
                confirmButtonText: '✅ OK',
                cancelButtonText: '❌ বাতিল',
                inputValidator: v => !v.trim() && 'লাইসেন্স নম্বর আবশ্যক!'
            }).then(r => {
                if (r.isConfirmed) processApproval(r.value.trim());
            });
        } else {
            processApproval(null);
        }
    });

    function processApproval(licenseNumber) {
        if (!approvalForm) return;

        const fd = new FormData(approvalForm);
        fd.delete('license_number');
        if (licenseNumber) fd.set('license_number', licenseNumber);

        postData(
            `/applications/${certType()}/approve/${appId()}`,
            new URLSearchParams(fd).toString(),
            res => showApprovedModal(res, licenseNumber),
            $id('approve')
        );
    }

    /**
     * Show approved modal with links and details returned from server
     */
    function showApprovedModal(res, licenseNumber) {
        try {
            const aId = res.application_id || appId();
            const unionCode = res.union_code || '';
            const rmoCode = res.rmo_code || '';
            const cert = res.certificate_type || certType() || '';
            const license = licenseNumber || res.license_number || res.sonod_number || '';

            document.getElementById('approved_application_id').textContent = aId || '—';
            document.getElementById('approved_union_code').textContent = unionCode || '—';
            document.getElementById('approved_rmo_code').textContent = rmoCode || '—';
            document.getElementById('approved_certificate_type').textContent = res.certificate_type_bn || cert || '—';                document.getElementById('approved_license_number').textContent = license || '—';

            // Show all action buttons first, then hide certificate links if no license
            document.querySelectorAll('.modal-action-btn.btn-certificate, .modal-action-btn.btn-certificate-en').forEach(el => {
                el.classList.toggle('d-none', !(license && license !== '—'));
            });

            const downloadUrl = `/${cert}_verify/application/${aId}/${unionCode || 0}/${rmoCode || 0}`;
            const viewUrl = `/${cert}_verify/application/${aId}/${unionCode || 0}/0`;
            const certificateUrl = `/application/${cert}/bangla/${license}`;
            const certificateEnUrl = "/application/${cert}/english/${license}";

            // Determine if this is an update (already approved)
            const isUpdate = res.is_update === true;

            // Update modal title with certificate type name
            const modalTitle = document.getElementById('approvedModalLabel');
            if (modalTitle) {
                const certBn = res.certificate_type_bn || cert || '';
                modalTitle.innerHTML = `<i class="bi bi-check-circle-fill me-2"></i> ${certBn} ${isUpdate ? 'হালনাগাদ' : 'অনুমোদিত'}`;
            }

            // Update modal subtitle
            const modalSubtitle = document.getElementById('approvedModalSubtitle');
            if (modalSubtitle) {
                modalSubtitle.textContent = isUpdate ? 'অনুমোদনের তথ্য সফলভাবে হালনাগাদ করা হয়েছে' : 'আবেদনটি সফলভাবে অনুমোদিত হয়েছে';
            }

            // Update modal body texts
            const modalCongrats = document.getElementById('approvedModalCongrats');
            if (modalCongrats) {
                modalCongrats.textContent = isUpdate ? '✅ হালনাগাদ সম্পন্ন!' : 'অভিনন্দন!';
            }

            const modalBodyText = document.getElementById('approvedModalBodyText');
            if (modalBodyText) {
                modalBodyText.textContent = isUpdate
                    ? 'অনুমোদনের তথ্য সফলভাবে হালনাগাদ করা হয়েছে। নিচের তথ্য ও অপশনগুলো দেখুন।'
                    : 'আপনার আবেদন সফলভাবে অনুমোদিত হয়েছে। নিচের তথ্য ও অপশনগুলো দেখুন।';
            }

            const dl = document.getElementById('approved_download_link');
            const vl = document.getElementById('approved_view_link');
            const cl = document.getElementById('approved_certificate_link');
            const clEn = document.getElementById('approved_certificate_en_link');
            if (dl) dl.href = downloadUrl;
            if (vl) vl.href = viewUrl;
            [cl, clEn].forEach(link => {
                if (link) {
                    const isEn = link.id === 'approved_certificate_en_link';
                    link.href = isEn ? certificateEnUrl : certificateUrl;
                }
            });

            const newBtn = document.getElementById('approved_new_btn');
            if (newBtn) newBtn.addEventListener('click', function(){
                // go to applications list for this certificate type
                window.location.href = `/applications/${cert}`;
            });

            // show bootstrap modal
            const modalEl = document.getElementById('approvedModal');
            if (modalEl && typeof bootstrap !== 'undefined') {
                const modal = new bootstrap.Modal(modalEl);
                modal.show();
            } else if (modalEl) {
                modalEl.style.display = 'block';
            }
        } catch (e) {
            console.error('Error showing approved modal', e);
            displayMessage('success', res.message || 'আবেদন অনুমোদিত হয়েছে', licenseNumber);
        }
    }

    /* ===============================
       Reject
    =============================== */

    on('reject', 'click', e => {
        e.preventDefault();

        Swal.fire({
            title: 'আবেদন বাতিল করবেন?',
            icon: 'warning',
            input: 'textarea',
            inputPlaceholder: 'বাতিলের কারণ লিখুন...',
            showCancelButton: true,
            preConfirm: v => !v.trim() ? 'কারণ লিখতে হবে!' : v.trim()
        }).then(r => {
            if (!r.isConfirmed) return;

            const body = new URLSearchParams({
                reject_reason: r.value,
                csrf_token: csrfToken()
            }).toString();

            postData(
                `/applications/${certType()}/reject/${appId()}`,
                body,
                () => Swal.fire('❌ আবেদন বাতিল হয়েছে!', '', 'success').then(()=>history.back()),
                $id('reject')
            );
        });
    });

    /* ===============================
       Reset
    =============================== */



    /* ===============================
       On Hold
    =============================== */

    on('on_hold', 'click', e => {
        e.preventDefault();

        Swal.fire({
            title: 'অন-হোল্ড করুন',
            input: 'textarea',
            showCancelButton: true,
            preConfirm: v => !v.trim() ? 'কারণ লিখুন!' : v.trim()
        }).then(r => {
            if (!r.isConfirmed) return;

            const body = new URLSearchParams({
                id: appId(),
                note: r.value,
                csrf_token: csrfToken()
            }).toString();

            postData(
                `/applications/${certType()}/on_hold`,
                body,
                res => Swal.fire('✅ Success', res.message, 'success').then(()=>location.reload()),
                $id('on_hold')
            );
        });
    });

    /* ===============================
       Reactivate
    =============================== */

    on('reactivate', 'click', e => {
        e.preventDefault();

        const body = new URLSearchParams({
            id: appId(),
            csrf_token: csrfToken()
        }).toString();

        postData(
            `/applications/${certType()}/reactivate`,
            body,
            res => Swal.fire('✅ Success', res.message, 'success').then(()=>location.reload()),
            $id('reactivate')
        );
    });

    /* ===============================
       Fix Sonod
    =============================== */

    on('fix_sonod', 'click', e => {
        e.preventDefault();

        const msg = $id('fix_sonod_msg');
        const body = new URLSearchParams({
            application_id: appId(),
            csrf_token: csrfToken()
        }).toString();

        postData(
            `/applications/${certType()}/fix_sonod_status`,
            body,
            res => {
                if (msg) {
                    msg.textContent = `Updated! Sonod: ${res.sonod_number}, Status: ${res.status_val}`;
                    msg.style.display = 'block';
                    setTimeout(()=>msg.style.display='none',5000);
                }
            },
            $id('fix_sonod')
        );
    });

    /* ===============================
       Renew (trade only) — Only send renewal-relevant fields
    =============================== */

    on('renew', 'click', e => {
        e.preventDefault();

        const renewFields = [
            'fiscal_year',
            'license_fee',
            'vat_amount',
            'occupation_tax',
            'income_tax',
            'signboard_tax',
            'surcharge',
            'total_fee',
            'ownership_type_id',
            'business_type_id'
        ];

        const fd = new URLSearchParams();
        fd.set('csrf_token', csrfToken());
        renewFields.forEach(name => {
            const el = $id(name);
            if (el && el.value) fd.set(name, el.value);
        });

        postData(
            `/applications/${certType()}/renew/${appId()}`,
            fd.toString(),
            () => Swal.fire('✅ লাইসেন্স নবায়ন সফল!', '', 'success').then(()=>location.reload()),
            $id('renew')
        );
    });
    /* ===============================
       View License Renewal History
    =============================== */

    on('viewHistory', 'click', e => {
        e.preventDefault();
        // Open renewal history view
        window.open(`/applications/trade/renewal-history/${appId()}`, '_blank', 'width=1200,height=700');
    });

    /* ===============================
       Live License Number Availability Check (trade only)
    =============================== */

    const licenseInput = $id('license_number');
    const licenseStatusIcon = $id('license_status_icon');
    const licenseStatusText = $id('license_status_text');
    const licenseMsg = $id('license_availability_msg');
    let licenseCheckTimer = null;

    function setLicenseStatus(available, existingAppId) {
        if (!licenseInput || !licenseStatusIcon || !licenseStatusText || !licenseMsg) return;

        if (available === null) {
            // Checking…
            licenseStatusIcon.innerHTML = '<span class="spinner-border spinner-border-sm text-secondary" role="status"></span>';
            licenseStatusText.textContent = 'যাচাই...';
            licenseStatusText.className = 'input-group-text bg-light text-secondary';
            licenseInput.classList.remove('is-valid', 'is-invalid');
            licenseMsg.textContent = '';
            licenseMsg.className = 'form-text';
            return;
        }

        if (available) {
            licenseStatusIcon.innerHTML = '<i class="bi bi-check-circle-fill text-success"></i>';
            licenseStatusText.textContent = 'উপলব্ধ';
            licenseStatusText.className = 'input-group-text bg-light text-success fw-semibold';
            licenseInput.classList.remove('is-invalid');
            licenseInput.classList.add('is-valid');
            licenseMsg.textContent = '✅ এই লাইসেন্স নম্বরটি ব্যবহার করা যাবে।';
            licenseMsg.className = 'form-text text-success';
        } else {
            licenseStatusIcon.innerHTML = '<i class="bi bi-x-circle-fill text-danger"></i>';
            licenseStatusText.textContent = 'ইতিমধ্যে ব্যবহৃত';
            licenseStatusText.className = 'input-group-text bg-light text-danger fw-semibold';
            licenseInput.classList.remove('is-valid');
            licenseInput.classList.add('is-invalid');
            const existingInfo = existingAppId ? ` (আবেদন: ${existingAppId})` : '';
            licenseMsg.textContent = `❌ এই লাইসেন্স নম্বরটি ইতিমধ্যে ব্যবহৃত হচ্ছে।${existingInfo}`;
            licenseMsg.className = 'form-text text-danger fw-semibold';
        }
    }

    function clearLicenseStatus() {
        if (licenseStatusIcon) licenseStatusIcon.innerHTML = '';
        if (licenseStatusText) licenseStatusText.textContent = '';
        if (licenseStatusText) licenseStatusText.className = 'input-group-text bg-light';
        if (licenseInput) licenseInput.classList.remove('is-valid', 'is-invalid');
        if (licenseMsg) { licenseMsg.textContent = ''; licenseMsg.className = 'form-text'; }
    }

    function checkLicenseAvailability(sonodNumber) {
        if (!sonodNumber || sonodNumber.trim() === '') {
            clearLicenseStatus();
            return;
        }

        setLicenseStatus(null); // Show spinner

        const currentAppId = encodeURIComponent(appId());
        fetch(`/api/check-license-availability?sonod_number=${encodeURIComponent(sonodNumber.trim())}&certificate_type=${encodeURIComponent(certType())}&exclude_application_id=${currentAppId}`)
            .then(r => r.json())
            .then(res => {
                setLicenseStatus(res.available, res.existing_application_id);
            })
            .catch(() => {
                // On network error, show indeterminate state
                if (licenseStatusIcon) licenseStatusIcon.innerHTML = '<i class="bi bi-question-circle text-warning"></i>';
                if (licenseStatusText) licenseStatusText.textContent = 'যাচাই ব্যর্থ';
                if (licenseMsg) { licenseMsg.textContent = '⚠️ সার্ভারে সংযোগ করা যায়নি।'; licenseMsg.className = 'form-text text-warning'; }
            });
    }

    if (licenseInput) {
        licenseInput.addEventListener('input', function () {
            clearTimeout(licenseCheckTimer);
            const val = this.value.trim();

            // Only check if at least 3 characters
            if (val.length < 3) {
                clearLicenseStatus();
                return;
            }

            // Debounce: wait 400ms after user stops typing
            licenseCheckTimer = setTimeout(() => checkLicenseAvailability(val), 400);
        });

        // Also check on blur (when user clicks away) to catch any final value
        licenseInput.addEventListener('blur', function () {
            const val = this.value.trim();
            if (val.length >= 3) {
                clearTimeout(licenseCheckTimer);
                checkLicenseAvailability(val);
            }
        });

        // Run an initial check if there's a pre-filled value
        const initialVal = licenseInput.value.trim();
        if (initialVal.length >= 3) {
            checkLicenseAvailability(initialVal);
        }
    }

    /* ===============================
       Dropdown Functions
    =============================== */

    window.selectVerifierFromDropdown = function() {
        const select = document.getElementById('verifier_select');
        const selectedOption = select.options[select.selectedIndex];
        
        if (!selectedOption.value) {
            return;
        }
        
        // Get user data and store in fields
        const userId = selectedOption.value;
        const nameBn = selectedOption.dataset['nameBn'] || '';
        const nameEn = selectedOption.dataset['nameEn'] || '';
        const wardNo = selectedOption.dataset['wardNo'] || '';
        const roleId = selectedOption.dataset['roleId'] || '';
        
        document.getElementById('verifier_id').value = userId || '';
        document.getElementById('verifier_name_bn').value = nameBn;
        document.getElementById('verifier_name_en').value = nameEn;
        
        // Show/hide ward_no section only if role_id = 4 or ward_no exists
        const wardSection = document.getElementById('verifier_ward_section');
        const wardDisplay = document.getElementById('verifier_ward_no_display');
        
        if ((roleId == 4 || roleId == '4') && wardNo) {
            document.getElementById('verifier_ward_no').value = wardNo;
            wardDisplay.value = wardNo;
            wardSection.style.display = 'block';
        } else {
            wardSection.style.display = 'none';
        }
        
        console.log('Verifier selected:', { userId, nameBn, nameEn, wardNo, roleId });
    };

    document.addEventListener('DOMContentLoaded', function() {
        var clearVerifierBtn = document.getElementById('clearVerifierBtn');
        if (clearVerifierBtn) {
            clearVerifierBtn.addEventListener('click', clearVerifierSelection);
        }
    });

    window.clearVerifierSelection = function() {
        document.getElementById('verifier_select').selectedIndex = 0;
        document.getElementById('verifier_id').value = '';
        document.getElementById('verifier_name_bn').value = '';
        document.getElementById('verifier_name_en').value = '';
        document.getElementById('verifier_ward_no').value = '';
        document.getElementById('verifier_ward_section').style.display = 'none';
        
        console.log('Verifier selection cleared');
    };

    window.selectApproverFromDropdown = function() {
        const select = document.getElementById('approver_select');
        const selectedOption = select.options[select.selectedIndex];
        
        if (!selectedOption.value) {
            return;
        }
        
        // Get user data and store in fields
        const userId = selectedOption.value;
        const nameBn = selectedOption.dataset['nameBn'] || '';
        const nameEn = selectedOption.dataset['nameEn'] || '';
        const wardNo = selectedOption.dataset['wardNo'] || '';
        const roleId = selectedOption.dataset['roleId'] || '';
        
        document.getElementById('approver_id').value = userId || '';
        document.getElementById('approver_name_bn').value = nameBn;
        document.getElementById('approver_name_en').value = nameEn;
        
        // Show/hide ward_no section only if role_id = 4 or ward_no exists
        const wardSection = document.getElementById('approver_ward_section');
        const wardDisplay = document.getElementById('approver_ward_no_display');
        
        if ((roleId == 4 || roleId == '4') && wardNo) {
            document.getElementById('approver_ward_no').value = wardNo;
            wardDisplay.value = wardNo;
            wardSection.style.display = 'block';
        } else {
            wardSection.style.display = 'none';
        }
        
        console.log('Approver selected:', { userId, nameBn, nameEn, wardNo, roleId });
    };

    document.addEventListener('DOMContentLoaded', function() {
        var clearApproverBtn = document.getElementById('clearApproverBtn');
        if (clearApproverBtn) {
            clearApproverBtn.addEventListener('click', clearApproverSelection);
        }
    });

    window.clearApproverSelection = function() {
        document.getElementById('approver_select').selectedIndex = 0;
        document.getElementById('approver_id').value = '';
        document.getElementById('approver_name_bn').value = '';
        document.getElementById('approver_name_en').value = '';
        document.getElementById('approver_ward_no').value = '';
        document.getElementById('approver_ward_section').style.display = 'none';
        
        console.log('Approver selection cleared');
    };
});
</script>



{% endblock %}

    <link href="https://fonts.maateen.me/solaiman-lipi/font.css" rel="stylesheet">
<style type="text/css">


    body {
        font-family: 'solaimanlipi', sans-serif !important;
        font-size: 14px;
        width: 670px;
        height: 842px;
        margin: auto;

        
    }

    @media  print {
        * {
            -webkit-print-color-adjust: exact;
        }
    }

    /*
        @page  {
            header: page-header;
            footer: page-footer;
            margin: 10px 0px;
            padding: 0px;

        } */
    
    .expired-overlay {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-45deg);
        opacity: 0.5;
        z-index: 1000;
        pointer-events: none;
    }
    .expired-overlay img {
        width: 600px;
        height: auto;
        display: block;
    }
</style>

{% set is_expired = business_meta.expiry_date and business_meta.expiry_date < 'now'|date('Y-m-d') %}
 
<section>
    {% if is_expired %}
    <div class="expired-overlay">
        <img src="{{ url }}/assets/images/expire.png" alt="মেয়াদ উত্তীর্ণ" />
    </div>
    {% endif %}
    <div class="container">
        <div class="card" style="margin:20px 0px; padding: 10px 0px 20px 0px">

                            <table border="0px" width="110%" align="center"
                       style="border-collapse:collapse; margin:2px auto; padding-top: 50px">
                    <tr>

                        <td style="text-align:center;">
                            <font style="font-size:25px; font-weight:bold; color:#3c01c5;"> {{ union.union_name_bn }} </font>

                            <br/>

                            <font style="font-size:16px; font-weight:bold;">
                               {{ union.upazila_name_bn }},{{ union.district_name_bn }}-{{ union.postcode|bn }} <br>
                                মোবাইলঃ {{ union.phone | bn }} , ই-মেইলঃ {{ union.email }}<br>
                                    ওয়েব সাইট : {{ union.website }}</font>

                        </td>

                    </tr>
                </table>


                <table
                    style="width:95%; margin-left:48px;border-color:lightgray;border-collapse:collapse;margin-top:10px;"
                    cellpadding="0" cellspacing="0">

                    <tr>
                        <td style="text-align:center;font-size:25px;font-weight:bold;padding-bottom: 5px">
                            <font style="">
                                <u>ট্রেড লাইসেন্স যাচাই</u>
                            </font>
                        </td>
                    </tr>

                    <tr>
                        <td>
                            <table style="width: 100%">
                                <tr>
                                    <td>ইস্যু
                                        তারিখঃ {{ citizen.issue_date|date('d-m-Y')|bn }}</td>
                                    <td style="text-align: right;padding-right: 5px;">মেয়াদ
                                        উত্তীর্ণঃ {{ business_meta.expiry_date | date('d-m-Y') | bn }}</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <tr>

                        <td>

                            <table border="1" style="width:700px;border-color:lightgray;border-collapse:collapse;"
                                   cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="width:100px; text-align:center;font-weight:700;font-size:17px;">সনদ নং
                                        :
                                    </td>
                                    
                                    {% set sonod_number_bn = citizen.sonod_number | bn %}
                                        {% for digit in sonod_number_bn | split('') %}
                                            <td style="text-align:center; font-weight:bold; font-size:20px;"> {{ digit }} </td>
                                    {% endfor %}
                                                                    </tr>
                            </table>
                        </td>

                    </tr>

                </table>

                <table style="width:95%; margin-left:48px;margin-top:10px;" cellpadding="0" cellspacing="0">

                    <tr>

                        <td valign="top" style="text-align: center;">


                            
                                
                                    <img src="https://lgdhaka.com/assets/images/application/default.jpg" height="80px"
                                         width="80px"/>


                                
                            
                        </td>

                    </tr>

                </table>


                <table width="95%" cellpadding="0" cellspacing="0" border="0"
                       style="border-collapse:collapse;margin-left: 50px; margin-top: 20px; ">
                    <tr>
                        <td style="text-indent: 20px;text-align:left; font-size:16px;">ব্যবসা প্রতিষ্ঠানের নাম</td>
                        <td style="font-size:16px; text-align:left;">
                            :&nbsp; {{ business_meta.business_name_bn }} </td>
                        <td style="text-indent: 20px;text-align:left; font-size:16px;">ব্যবসার ধরণ</td>
                        <td style="font-size:16px; text-align:left;">
                            :&nbsp;{{ business_meta.business_type_bn }}</td>
                    </tr>

                    <tr>
                        <td style="text-indent: 20px;text-align:left; font-size:16px;">মোবাইল</td>
                        <td style="font-size:16px; text-align:left;">
                            :&nbsp;{{ citizen.applicant_phone | bn }}</td>
                        <td style="text-indent: 20px;text-align:left; font-size:16px;">ই-মেইল</td>
                        <td style="font-size:16px; text-align:left;">:&nbsp;</td>
                    </tr>
                </table>

                <table width="88%" cellpadding="0" cellspacing="0" border="1"
                       style="border-collapse:collapse;border:1px dashed lightgray; text-align: center; margin:0 auto; margin-top: 20px">

                    <tr style="text-align: center;font-weight:bolder;">
                        <th>নং</th>
                        <td style="font-weight: 700px; font-size: 17px;">প্রোপাইটরের নাম</td>
                        <th style="font-weight: 700px; font-size: 17px;">পিতা/স্বামীর নাম</th>
                        <th style="font-weight: 700px; font-size: 17px;">পরিচয় পত্র/ জন্ম নিবন্ধন</th>
                        <th style="font-weight: 700px; font-size: 17px;">মোবাইল</th>
                    </tr>

                    
                    

                        <tr height="20px" style="text-align: center;">
                            <td>১</td>
                            <td>{{ citizen.name_bn }}</td>

                            <td>

                                                                    {{ citizen.father_name_bn }}
                                

                            </td>
                            <td>

                                                                    
                                {% if citizen.birth_id %}
                                    {{ citizen.birth_id | bn }}
                                {% elseif citizen.nid %}
                                    {{ citizen.nid | bn }}
                                {% elseif citizen.passport_no %}
                                    {{ citizen.passport_no | bn }}
                                {% endif %}

                            </td>

                            <td>{{ citizen.applicant_phone | bn }}</td>

                        </tr>
                    
                </table>


                <table class="jolchap" align="center" border="0" height="415px" width='99%' cellspacing="0"
                       cellspacing='0'
                       style="border-collapse:collapse;margin:0 auto;table-layout:fixed; margin-top: 10px">

                    <tr>
                        <td align='left'
                            style="font-size:16px;text-indent:55px; font-color:black; width: 200px; padding-left: 50px">
                            ব্যবসা প্রতিষ্ঠানের ঠিকানা
                        </td>
                        <td style="font-weight:bold; font-size:18px; text-align:left;">
                            : {{ business_meta.business_village_bn }}
                            ,&nbsp;ওয়ার্ড-{{ business_meta.business_ward_no | bn }}
                            ,&nbsp;{{ business_meta.business_postoffice_bn }}
                            ,&nbsp;{{ business_meta.business_upazila_bn }}
                            ,&nbsp;{{ business_meta.business_district_bn }}
                        </td>
                    </tr>

                    
                        {% if business_meta.license_fee is not null %}
                        <tr>
                            <td align="left" nowrap style="font-size:16px;text-indent:55px;width: 200px; padding-left: 50px">
                                ট্রেড লাইসেন্স
                            </td>
                            <td style="text-align:left;font-size:16px;">
                                :&nbsp;{{ business_meta.license_fee | bn }}&nbsp;টাকা
                            </td>
                        </tr>
                        {% endif %}

                        {% if business_meta.vat_amount is not null %}
                        <tr>
                            <td align="left" nowrap style="font-size:16px;text-indent:55px;width: 200px; padding-left: 50px">
                                ভ্যাট (১৫%)
                            </td>
                            <td style="text-align:left;font-size:16px;">
                                :&nbsp;{{ business_meta.vat_amount | bn }}&nbsp;টাকা
                            </td>
                        </tr>
                        {% endif %}

                        {% if business_meta.occupation_tax is not null %}
                        <tr>
                            <td align="left" nowrap style="font-size:16px;text-indent:55px;width: 200px; padding-left: 50px">
                                পেশা জীবিকা কর
                            </td>
                            <td style="text-align:left;font-size:16px;">
                                :&nbsp;{{ business_meta.occupation_tax | bn }}&nbsp;টাকা
                            </td>
                        </tr>
                        {% endif %}

                        {% if business_meta.income_tax is not null %}
                        <tr>
                            <td align="left" nowrap style="font-size:16px;text-indent:55px;width: 200px; padding-left: 50px">
                                আয়কর / উৎপলে কর
                            </td>
                            <td style="text-align:left;font-size:16px;">
                                :&nbsp;{{ business_meta.income_tax | bn }}&nbsp;টাকা
                            </td>
                        </tr>
                        {% endif %}

                        {% if business_meta.signboard_tax is not null %}
                        <tr>
                            <td align="left" nowrap style="font-size:16px;text-indent:55px;width: 200px; padding-left: 50px">
                                সাইনবোর্ড কর
                            </td>
                            <td style="text-align:left;font-size:16px;">
                                :&nbsp;{{ business_meta.signboard_tax | bn }}&nbsp;টাকা
                            </td>
                        </tr>
                        {% endif %}

                        {% if business_meta.surcharge is not null %}
                        <tr>
                            <td align="left" nowrap style="font-size:16px;text-indent:55px;width: 200px; padding-left: 50px">
                                সারচার্জ
                            </td>
                            <td style="text-align:left;font-size:16px;">
                                :&nbsp;{{ business_meta.surcharge | bn }}&nbsp;টাকা
                            </td>
                        </tr>
                        {% endif %}

                        {% if business_meta.total_fee is not null %}
                        <tr>
                            <td align="left" nowrap style="font-size:16px;text-indent:55px;width: 200px; padding-left: 50px">
                                সর্বমোট
                            </td>
                            <td style="text-align:left;font-size:16px;">
                                :&nbsp;{{ business_meta.total_fee | bn }}&nbsp;টাকা মাত্র।
                            </td>
                        </tr>
                        {% endif %}


                </table>

                <table border='0' width='98%' cellpadding='0' cellspacing='0'
                       style="border-collapse:collapse;margin:0 auto;padding-top:10px;">

                    <tr>
                        <td style="font-size:17px;  padding-left:50px;" height="80">&nbsp; &nbsp; &nbsp; &nbsp; উল্লেখিত
                            প্রতিষ্ঠানের অনুকূলে প্রদত্ত লাইসেন্স ফি গ্রহন
                            করিয়া {{ business_meta.fiscal_year | bn }} সালের জন্য আবশ্যকীয়
                            বাণিজ্য চালাইয়া যাইবার অনুমতি দেওয়া হইল
                            । {{ business_meta.expiry_date | date('d-m-Y') | bn }} সন
                            পর্যন্ত এই লাইসেন্স বৈধ বলিয়া বিবেচিত হইবে এবং প্রতি বছর নবায়ন করিতে হইবে ।
                        </td>

                    </tr>

                </table>

            
        </div>
    </div>
</section>




<!DOCTYPE html>
<html lang="bn">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link href="https://fonts.maateen.me/solaiman-lipi/font.css" rel="stylesheet">
<style type="text/css">

        * {
            margin: 0;
            padding: 0;
        }
        body {
            font-family: "solaimanlipi", Arial !important;
            font-size: 14px;
             width: 100%;
        }
        .container {
            width: 100%;
            margin: 0 auto;
        }
        @media  print {
            * {
                -webkit-print-color-adjust: exact;
            }
        }

        @page  {
            header: page-header;
            footer: page-footer;
            margin: 20px 0px;
            padding: 0px;

        }
</style>
</head> 
<body>

    <section>
        <div class="container">
            <div class="card" style="margin:20px 0px; padding: 10px 0px 20px 0px">

                                <table border="0px" width="98%" align="center" style="border-collapse:collapse; margin:2px auto; padding-top: 50px">
                        <tr>
                            <td style="width:1.5in; text-align:center;"><img src="{{ url }}/assets/logo/logo.png" height="100px" width="100px" /></td>

                            <td style="text-align:center;">
                                <font style="font-size:25px; font-weight:bold; color:#3c01c5;"> {{ union.union_name_bn }}</font>

                                <br />

                                <font style="font-size:16px; font-weight:bold;">
                                    {{ union.upazila_name_bn }},{{ union.district_name_bn }}-{{ union.postcode|bn }} <br>
                                    মোবাইলঃ {{ union.phone | bn }} , ই-মেইলঃ {{ union.email }}<br>
                                    ওয়েব সাইট : {{ union.website }}</font>

                            </td>

                            <td style="width:1.2in; text-align:left;">

                                <img src="{{ url }}/assets/img/band-cross.png" height="100px" width="100px" style="position:relative;right:10px;" />

                            </td>

                        </tr>
                    </table>


                    <table style="width:95%; margin-left:48px;border-color:lightgray;border-collapse:collapse;margin-top:10px;" cellpadding="0" cellspacing="0">

                    <tr>
                        <td colspan="2" style="text-align:center;font-size:25px;font-weight:bold;padding-bottom: 5px">
                            <font style="">
                                <u>নতুন ভোটার সনদ যাচাই</u>
                            </font>
                        </td>
                    </tr>

                    <tr>

                        <td>

                            <table border="1" style="width: 600px;border-color:lightgray;border-collapse:collapse;" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="width:100px; text-align:center;font-weight:700;font-size:17px;">সনদ নং :</td>
                                     {% set sonod_number_bn = citizen.sonod_number | bn_number %}
                                       {% for digit in sonod_number_bn | split('') %}
                                    <td style="text-align:center; font-weight:bold; font-size:20px;">
                                    {{ digit }} </td>
                                     {% endfor %}
                                                                    </tr>
                            </table>
                        </td>


                        <td rowspan="3" valign="top" style="text-align: left;" >


                            
                        </td>

                    </tr>

                    <tr>
                        <td colspan="2" style="font-size:18px; text-indent:50px; padding-top: 5px; padding-bottom: 5px;">এই মর্মে প্রত্যয়ন পত্র প্রদান করা যাইতেছে যে,</td>
                    </tr>
                </table>


                <table class="jolchap" align="center" border="0" height="415px" width='99%' cellspacing="0" cellspacing='0' style="border-collapse:collapse;margin:0 auto;table-layout:fixed;">

                    <tr>
                        <td align="left" style="font-size:16px;text-indent:55px; font-color:black; width: 175px; padding-left: 50px">নাম </font>
                        </td>
                        <td>
                            <font style="font-size:16px;">: {{ citizen.name_bn }}</font>
                        </td>
                    </tr>

                    
                    <tr>
                        <td align="left" style="font-size:16px;text-indent:55px; font-color:black; width: 175px; padding-left: 50px ">পিতার নাম </td>
                        <td>
                            <font style="font-size:16px; ">: {{ citizen.father_name_bn  }} </font>
                        </td>
                    </tr>

                    <tr>
                        <td align="left" style="font-size:16px;text-indent:55px; font-color:black; width: 175px; padding-left: 50px">মাতার নাম</td>
                        <td>
                            <font style="font-size:16px;  ">: {{ citizen.mother_name_bn }}</font>
                        </td>
                    </tr>
                    
                     {% if citizen.marital_status == 'Married' %}
                     <tr>
                        <td align="left" style="font-size:16px;text-indent:55px; font-color:black; width: 175px; padding-left: 50px"> স্বামী/স্ত্রীর নাম</td>
                        <td>
                            <font style="font-size:16px;  ">: {{ citizen.spouse_name_bn }}</font>
                        </td>
                    </tr>
                     {% endif %}
                    <tr>
                        <td nowrap align="left" style="font-size:16px;text-indent:55px; font-color:black; width: 175px; padding-left: 50px;vertical-align:top; ">বর্তমান ঠিকানা </td>

                        <td style=" vertical-align:top;">
                            <p style="line-height:25px;font-size:16px; ">

                                : গ্রামঃ : {{ citizen.present_village_bn }}
                                <br> &nbsp; ডাকঘরঃ  {{ citizen.present_postoffice_bn }}
                                <br> &nbsp; উপজেলাঃ {{ citizen.present_upazila_bn }}
                                <br> &nbsp; জেলাঃ {{ citizen.present_district_bn }}</p>
                        </td>
                    </tr>

                    <tr>
                        <td nowrap align="left" style="font-size:16px;text-indent:55px; font-color:black; width: 175px; padding-left: 50px; vertical-align:top; ">স্থায়ী ঠিকানা </td>

                        <td style=" vertical-align:top;">

                            <p style="line-height:25px;font-size:16px;  ">
                                : গ্রামঃ {{ citizen.permanent_village_bn }}
                                <br> &nbsp; ডাকঘরঃ  {{ citizen.permanent_postoffice_bn }}
                                <br> &nbsp; উপজেলাঃ {{ citizen.permanent_upazila_bn }}
                                <br> &nbsp; জেলাঃ {{  citizen.permanent_district_bn }}
                            </p>
                        </td>
                    </tr>

                    <tr>
                        <td align="left" nowrap style="font-size:16px;text-indent:55px; font-color:black; width: 175px; padding-left: 50px">ওয়ার্ড নং </td>
                        <td>
                            <font style="font-size:16px;  ">:  {{ citizen.present_ward_no|bn }}</font>
                        </td>
                    </tr>

                    
					
					{% if citizen.birth_id or citizen.nid or citizen.passport_no %}
						<tr>
							<td align="left" nowrap style="font-size:16px; text-indent:55px; width: 175px; padding-left: 50px; color: black;">
								{% if citizen.birth_id %}
									জন্ম নিবন্ধন নং
								{% elseif citizen.nid %}
									ন্যাশনাল আইডি নং
								{% else %}
									পার্সপোর্ট নং
								{% endif %}
							</td>
							<td style="font-size:16px;">
								:
								{% if citizen.birth_id %}
									{{ citizen.birth_id | bn }}
								{% elseif citizen.nid %}
									{{ citizen.nid | bn }}
								{% elseif citizen.passport_no %}
									{{ citizen.passport_no }}
								{% endif %}
							</td>
						</tr>
					{% endif %}



                    
                    
                    <tr>
                        <td align="left" nowrap style="font-size:16px;text-indent:55px; font-color:black; width: 175px; padding-left: 50px">তারিখ </td>
                        <td>
                            <font style="font-size:16px;">:  {{ citizen.issue_date|date('d-m-Y')|bn }}</font>
                        </td>
                    </tr>

                </table>

                <table border='0' width='98%' cellpadding='0' cellspacing='0' style="border-collapse:collapse;margin:0 auto;padding-top:10px;">

                    <tr>
                        <td style="font-size:17px;  padding-left:50px;" height="80">&nbsp; &nbsp; &nbsp; &nbsp;  অত্র ইউনিয়নের একজন <font style="font-size:17px;">স্থায়ী
                        </font> বাসিন্দা। তিনি জন্মগতভাবে বাংলাদেশী এবং আমার পরিচিত। </td>

                    </tr>

                    <tr>
                        <td style="padding-left:72px; font-size:17px; height: 20px">আমি তাহার সর্বাঙ্গীণ মঙ্গল ও উন্নতি কামনা করি।</td>
                    </tr>

                </table>

                
             </div>
        </div>
    </section>

</body>
</html>


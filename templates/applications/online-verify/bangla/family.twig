                           উপজেলা : &nbsp; {{ citizen.present_upazila_bn }},
                           জেলা : &nbsp; {{ citizen.present_district_bn }}
                    </p>
                </td>
            </tr>

        </table>



        <table border="0px" width="99%"  align="center" style="border-collapse:collapse;margin:4px auto; " cellspacing="0" cellpadding="0">
            <tr>
                <td style="padding-left: 50px; height: 25px;"> 
                    <font style="font-size:16px; padding-left:30px;">অত্র ইউনিয়নের স্থায়ী বাসিন্দা । নিম্নে তালিকা ভুক্ত সদস্যগণ তাহার পরিবারের সদস্যঃ-</font>
                </td>
            </tr>
        </table>


<table border="1" align="center" width="93%" style="border-collapse:collapse;" cellspacing="0" cellpadding="0">
    <thead>
        <tr height="20px">
            <th style="width:5%;font-size:14px;">ক্রঃ নং</th>
            <th style="width:20%;font-size:14px;">নাম</th>
            <th style="width:10%;font-size:14px;">সম্পর্ক</th>
            <th style="width:8%;font-size:14px;">বয়স</th>
            <th style="width:5%;font-size:14px;">ক্রঃ নং</th>
            <th style="width:20%;font-size:14px;">নাম</th>
            <th style="width:10%;font-size:14px;">সম্পর্ক</th>
            <th style="width:8%;font-size:14px;">বয়স</th>
        </tr>
    </thead>
    <tbody>
        {% set total_rows = 10 %}
        {% for i in 0..(total_rows-1) %}
            <tr>
                {# Left column (1-10) #}
                {% if citizen.warish_members[i] is defined %}
                    {% set left = citizen.warish_members[i] %}
                    <td style="text-align:center;font-size:13px;">{{ (i+1)|bn }}</td>
                    <td style="text-align:center;text-indent:15px;font-size:14px;">{{ left.name_bn }}</td>
                    <td style="text-align:center;text-indent:15px;font-size:14px;">{{ left.relation_bn }}</td>
                    <td style="text-align:center;text-indent:15px;font-size:14px;">{{ left.birth_date|bn }}</td>
                {% else %}
                    <td style="text-align:center;font-size:13px;">{{ (i+1)|bn }}</td>
                    <td></td>
                     <td></td>
                      <td></td>

                {% endif %}

                {# Right column (11-20) #}
                {% set right_index = i + total_rows %}
                {% if citizen.warish_members[right_index] is defined %}
                    {% set right = citizen.warish_members[right_index] %}
                    <td style="text-align:center;font-size:13px;">{{ (right_index+1)|bn }}</td>
                    <td style="text-align:center;text-indent:15px;font-size:14px;">{{ right.name_bn }}</td>
                    <td style="text-align:center;text-indent:15px;font-size:14px;">{{ right.relation_bn }}</td>
                    <td style="text-align:center;text-indent:15px;font-size:14px;">{{ right.birth_date|bn }}</td>
                {% else %}
                    <td style="text-align:center;font-size:13px;">{{ (right_index+1)|bn }}</td>
                    <td></td>
                     <td></td>
                      <td></td>
                {% endif %}
            </tr>
        {% endfor %}

        <tr>
            <td colspan="8" style="text-align:right;font-size:12px; padding-right:60px;">
                পরিবারের সদস্য সংখ্যা <span>&nbsp;&nbsp;</span> {{ citizen.warish_members|length }} &nbsp;&nbsp;জন
            </td>
        </tr>
    </tbody>
</table>




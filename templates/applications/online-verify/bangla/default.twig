<!DOCTYPE html>
<html>
<head>
    <base href="">
    <meta charset="utf-8">
    <title>বাংলা {{ citizen.certificate_type_bn }}</title>
    <link rel="stylesheet" href="{{ url }}/assets/css/online-verify.css">

    <style type="text/css" media="all">
        body {
            font-family: 'bangla', sans-serif !important;
            font-size: 14px;
        }
        @media print {
            * { -webkit-print-color-adjust: exact; }
        }
        @page {
            header: page-header;
            footer: page-footer;
            margin: 20px 0px;
            padding: 0px;
        }
        @media print {
            body {
                font-size: 14px !important;
                font-family: 'bangla', sans-serif !important;
            }
        }
    </style>
</head>

<body>
    <section>
        <div class="container">
            <div class="card" style="margin:20px 0px; padding: 10px 0px 20px 0px">

                <table border="0px" width="98%" align="center" style="border-collapse:collapse; margin:2px auto; padding-top: 50px">
                    <tr>
                        <td style="width:1.5in; text-align:center;">
                            <img src="{{ url }}/assets/logo/logo.png" height="100px" width="100px" />
                        </td>
                        <td style="text-align:center;">
                            <div class="parishad-info">
                                <div class="parishad-name">{{ union.union_name_bn }}</div>
                                <div class="parishad-details">
                                    {{ union.upazila_name_bn }}, {{ union.district_name_bn }}-{{ union.postcode|bn }}<br>
                                    মোবাইলঃ {{ union.phone | bn }},
                                    ই-মেইলঃ {{ union.email }}<br>
                                    ওয়েব সাইট : {{ union.website }}
                                </div>
                            </div>
                        </td>
                        <td style="width:1.2in; text-align:left;">
                            <img src="{{ url }}/assets/img/band-cross.png" height="100px" width="100px" style="position:relative;right:10px;" />
                        </td>
                    </tr>
                </table>

                <table style="width:95%; margin-left:48px; border-color:lightgray; border-collapse:collapse; margin-top:10px;" cellpadding="0" cellspacing="0">
                    <tr>
                        <td colspan="2" style="text-align:center; font-size:25px; font-weight:bold; padding-bottom:5px">
                            <font><u>{{ citizen.certificate_type_bn }}</u></font>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <table border="1" style="width:600px; border-color:lightgray; border-collapse:collapse;" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="width:100px; text-align:center; font-weight:700; font-size:17px;">সনদ নং :</td>
                                    {% set sonod_number_bn = citizen.sonod_number | bn %}
                                    {% for digit in sonod_number_bn | split('') %}
                                    <td style="text-align:center; font-weight:bold; font-size:20px;">{{ digit }}</td>
                                    {% endfor %}
                                </tr>
                            </table>
                        </td>
                        <td rowspan="3" valign="top" style="text-align:left;">
                            {% if citizen.applicant_photo %}
                                <img src="{{ url }}/{{ citizen.applicant_photo }}" height="100px" width="100px" alt="profile" />
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2" style="font-size:18px; text-indent:50px; padding-top:5px; padding-bottom:5px;">
                            এই মর্মে প্রত্যয়ন পত্র প্রদান করা যাইতেছে যে,
                        </td>
                    </tr>
                </table>

                <table class="jolchap" align="center" border="0" height="415px" width="99%" cellspacing="0" style="border-collapse:collapse; margin:0 auto; table-layout:fixed;">
                    <tr>
                        <td align="left" style="font-size:16px; text-indent:55px; width:180px; padding-left:50px">নাম</td>
                        <td><font style="font-size:16px;">: {{ citizen.name_bn }}</font></td>
                    </tr>
                    <tr>
                        <td align="left" style="font-size:16px; text-indent:55px; width:180px; padding-left:50px">পিতার নাম</td>
                        <td><font style="font-size:16px;">: {{ citizen.father_name_bn }}</font></td>
                    </tr>
                    <tr>
                        <td align="left" style="font-size:16px; text-indent:55px; width:180px; padding-left:50px">মাতার নাম</td>
                        <td><font style="font-size:16px;">: {{ citizen.mother_name_bn }}</font></td>
                    </tr>
                    {% if citizen.marital_status == 'Married' %}
                    <tr>
                        <td align="left" style="font-size:16px; text-indent:55px; width:180px; padding-left:50px">স্বামী/স্ত্রীর নাম</td>
                        <td><font style="font-size:16px;">: {{ citizen.spouse_name_bn | default('N/A') }}</font></td>
                    </tr>
                    {% endif %}
                    <tr>
                        <td nowrap align="left" style="font-size:16px; text-indent:55px; width:180px; padding-left:50px; vertical-align:top;">বর্তমান ঠিকানা</td>
                        <td style="vertical-align:top;">
                            <p style="line-height:25px; font-size:16px;">
                                : গ্রামঃ {{ citizen.present_village_bn }}
                                <br> &nbsp; ডাকঘরঃ {{ citizen.present_postoffice_bn }}
                                <br> &nbsp; উপজেলাঃ {{ citizen.present_upazila_bn }}
                                <br> &nbsp; জেলা: {{ citizen.present_district_bn }}
                            </p>
                        </td>
                    </tr>
                    <tr>
                        <td nowrap align="left" style="font-size:16px; text-indent:55px; width:180px; padding-left:50px; vertical-align:top;">স্থায়ী ঠিকানা</td>
                        <td style="vertical-align:top;">
                            <p style="line-height:25px; font-size:16px;">
                                : গ্রামঃ {{ citizen.permanent_village_bn }}
                                <br> &nbsp; ডাকঘরঃ {{ citizen.permanent_postoffice_bn }}
                                <br> &nbsp; উপজেলাঃ {{ citizen.permanent_upazila_bn }}
                                <br> &nbsp; জেলা: {{ citizen.permanent_district_bn }}
                            </p>
                        </td>
                    </tr>
                    <tr>
                        <td align="left" nowrap style="font-size:16px; text-indent:55px; width:180px; padding-left:50px">ওয়ার্ড নং</td>
                        <td><font style="font-size:16px;">: {{ citizen.permanent_ward_no|bn }}</font></td>
                    </tr>
                    <tr>
                        <td align="left" nowrap style="font-size:16px; text-indent:55px; width:200px; padding-left:50px">
                            {% if citizen.birth_id %}
                                জন্ম নিবন্ধন নং
                            {% elseif citizen.nid %}
                                ন্যাশনাল আইডি নং
                            {% else %}
                                পার্সপোট নং
                            {% endif %}
                        </td>
                        <td>
                            <font style="font-size:16px;">:
                                {% if citizen.birth_id %}
                                    {{ citizen.birth_id | bn }}
                                {% elseif citizen.nid %}
                                    {{ citizen.nid | bn }}
                                {% elseif citizen.passport_no %}
                                    {{ citizen.passport_no }}
                                {% endif %}
                            </font>
                        </td>
                    </tr>
                    <tr>
                        <td align="left" nowrap style="font-size:16px; text-indent:55px; width:180px; padding-left:50px">তারিখ</td>
                        <td><font style="font-size:16px;">: {{ citizen.issue_date|date('d-m-Y')|bn }}</font></td>
                    </tr>
                </table>

                {# ───────────────────────────────────────────────
                   CERTIFICATE BODY + SANJUKTI (সংযুক্তি)
                   প্রতিটি সার্টিফিকেট টাইপে:
                   ১. বিস্তারিত paragraph
                   ২. সর্বাঙ্গীণ মঙ্গল লাইন
                   ৩. সংযুক্তি অংশ
                ─────────────────────────────────────────────── #}

                {% if certificate_type == 'nagorik' %}
                {# ── নাগরিক সনদ ── #}
                <table border="0" width="98%" cellpadding="0" cellspacing="0" style="border-collapse:collapse; margin:0 auto; padding-top:10px;">
                    <tr>
                        <td style="font-size:17px; padding-left:50px;" height="80">
                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ citizen.name_bn }} অত্র ইউনিয়নের {{ citizen.permanent_ward_no|bn }} নং ওয়ার্ডের একজন
                            <strong>{% if (citizen.resident|default('permanent')) == 'temporary' %}অস্থায়ী{% else %}স্থায়ী{% endif %}</strong>
                            বাসিন্দা। তিনি জন্মগতভাবে বাংলাদেশী নাগরিক এবং আমার ব্যক্তিগতভাবে পরিচিত।
                            আমার জানামতে তিনি সৎ, পরিশ্রমী এবং আইন মান্যকারী একজন নাগরিক।
                            তিনি কোনো আইনবিরোধী বা রাষ্ট্রবিরোধী কার্যকলাপে জড়িত নন।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            আমি তাহার সর্বাঙ্গীণ মঙ্গল ও উন্নতি কামনা করি।
                        </td>
                    </tr>
                </table>

                {% elseif certificate_type == 'trade' %}
                {# ── ট্রেড লাইসেন্স সনদ ── #}
                <table border="0" width="98%" cellpadding="0" cellspacing="0" style="border-collapse:collapse; margin:0 auto; padding-top:10px;">
                    <tr>
                        <td style="font-size:17px; padding-left:50px;" height="80">
                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ citizen.name_bn }} অত্র ইউনিয়নের একজন নিয়মিত ব্যবসায়ী। তিনি দীর্ঘদিন যাবৎ সুনামের সহিত ব্যবসা পরিচালনা করে আসছেন এবং প্রতি বৎসর নিয়মিতভাবে ট্রেড লাইসেন্স নবায়ন করেন।
                            আমার জানামতে তিনি ব্যবসায়িক কার্যক্রমে সৎ ও আইনসম্মতভাবে পরিচালিত।
                            তিনি সকল সরকারি বিধিমালা যথাযথভাবে পালন করেন।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            আমি তাহার ব্যবসায়িক সমৃদ্ধি ও সর্বাঙ্গীণ মঙ্গল কামনা করি।
                        </td>
                    </tr>
                </table>

                {% elseif certificate_type == 'warish' %}
                {# ── ওয়ারিশ সনদ ── #}
                <table border="0" width="98%" cellpadding="0" cellspacing="0" style="border-collapse:collapse; margin:0 auto; padding-top:10px;">
                    <tr>
                        <td style="font-size:17px; padding-left:50px;" height="80">
                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ citizen.name_bn }} মৃত ব্যক্তির একজন বৈধ ওয়ারিশ এবং সংশ্লিষ্ট সম্পত্তির উত্তরাধিকারী।
                            আমার জানামতে মৃত ব্যক্তির পরিবারের সদস্য হিসেবে তিনি আইনানুগভাবে ওয়ারিশ সম্পত্তি প্রাপ্তির যোগ্য।
                            উক্ত সনদ যে কোনো আইনগত বা প্রশাসনিক কাজে ব্যবহার করা যাইবে।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            আমি তাহার সর্বাঙ্গীণ মঙ্গল ও উন্নতি কামনা করি।
                        </td>
                    </tr>
                </table>

                {% elseif certificate_type == 'character' %}
                {# ── চারিত্রিক সনদ ── #}
                <table border="0" width="98%" cellpadding="0" cellspacing="0" style="border-collapse:collapse; margin:0 auto; padding-top:10px;">
                    <tr>
                        <td style="font-size:17px; padding-left:50px;" height="80">
                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ citizen.name_bn }} অত্র ইউনিয়নের {{ citizen.permanent_ward_no|bn }} নং ওয়ার্ডের একজন
                            {% if (citizen.resident|default('permanent')) == 'temporary' %}অস্থায়ী{% else %}স্থায়ী{% endif %}
                            বাসিন্দা। তিনি জন্মগতভাবে বাংলাদেশী এবং আমার ব্যক্তিগতভাবে পরিচিত।
                            তাহার স্বভাব ও নৈতিক চরিত্র অত্যন্ত ভাল এবং সমাজে প্রশংসনীয়।
                            তিনি কোনো আইনবিরোধী বা সমাজবিরোধী কার্যকলাপে কখনো জড়িত হননি।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            আমি তাহার সর্বাঙ্গীণ মঙ্গল ও উন্নতি কামনা করি।
                        </td>
                    </tr>
                </table>

                {% elseif certificate_type == 'new-voter' %}
                {# ── নতুন ভোটার সনদ ── #}
                <table border="0" width="98%" cellpadding="0" cellspacing="0" style="border-collapse:collapse; margin:0 auto; padding-top:10px;">
                    <tr>
                        <td style="font-size:17px; padding-left:50px;" height="80">
                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ citizen.name_bn }} অত্র ইউনিয়নের {{ citizen.permanent_ward_no|bn }} নং ওয়ার্ডের একজন
                            {% if (citizen.resident|default('permanent')) == 'temporary' %}অস্থায়ী বাসিন্দা{% else %}স্থায়ী বাসিন্দা{% endif %}।
                            তিনি জন্মগতভাবে বাংলাদেশী নাগরিক এবং আমার ব্যক্তিগতভাবে পরিচিত।
                            ভোটার তালিকা হালনাগাদের সময় বাড়িতে না থাকায় তাহার নাম তালিকায় অন্তর্ভুক্ত হয়নি।
                            বর্তমানে তিনি উক্ত ওয়ার্ডের স্থায়ী বাসিন্দা হিসেবে ভোটার তালিকায় নাম অন্তর্ভুক্তির আবেদন করিতেছেন।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            আমি তাহার সর্বাঙ্গীণ মঙ্গল ও উন্নতি কামনা করি।
                        </td>
                    </tr>
                </table>

                {% elseif certificate_type == 'voter' %}
                {# ── ভোটার স্থানান্তর সনদ ── #}
                <table border="0" width="98%" cellpadding="0" cellspacing="0" style="border-collapse:collapse; margin:0 auto; padding-top:10px;">
                    <tr>
                        <td style="font-size:17px; padding-left:50px;" height="80">
                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ citizen.name_bn }} অত্র ইউনিয়নের {{ citizen.permanent_ward_no|bn }} নং ওয়ার্ডের একজন বাসিন্দা।
                            তিনি বর্তমানে অত্র ইউনিয়ন থেকে অন্যত্র ভোটার আইডি স্থানান্তর করিতে ইচ্ছুক।
                            আমার জানামতে তিনি উক্ত ওয়ার্ডের বৈধ ভোটার এবং তাহার আইডি স্থানান্তরে কোনো বাধা নেই।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            আমি তাহার সর্বাঙ্গীণ মঙ্গল ও উন্নতি কামনা করি।
                        </td>
                    </tr>
                </table>

                {% elseif certificate_type == 'vumihin' %}
                {# ── ভূমিহীন সনদ ── #}
                <table border="0" width="98%" cellpadding="0" cellspacing="0" style="border-collapse:collapse; margin:0 auto; padding-top:10px;">
                    <tr>
                        <td style="font-size:17px; padding-left:50px;" height="80">
                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ citizen.name_bn }} অত্র ইউনিয়নের একজন ভূমিহীন নাগরিক।
                            আমার জানামতে তাহার নিজের নামে কোনো জমি বা বসতভিটা নেই।
                            তিনি অত্যন্ত দরিদ্র ও অসহায় অবস্থায় জীবনযাপন করিতেছেন।
                            মানবিক বিবেচনায় সরকারি পুনর্বাসন কর্মসূচির আওতায় তাহাকে অন্তর্ভুক্ত করার জন্য সংশ্লিষ্ট কর্তৃপক্ষের নিকট বিনীত অনুরোধ জানানো যাইতেছে।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            আমি তাহার সর্বাঙ্গীণ মঙ্গল ও উন্নতি কামনা করি।
                        </td>
                    </tr>
                </table>

                {% elseif certificate_type == 'death' %}
                {# ── মৃত্যু সনদ ── #}
                <table border="0" width="98%" cellpadding="0" cellspacing="0" style="border-collapse:collapse; margin:0 auto; padding-top:10px;">
                    <tr>
                        <td style="font-size:17px; padding-left:50px;" height="80">
                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ data.deceased_name }} অত্র ইউনিয়নের একজন বাসিন্দা ছিলেন।
                            তিনি {{ data.death_date | date('d-m-Y') | bn }} তারিখে মৃত্যুবরণ করিয়াছেন।
                            মৃত্যুর সময় তাহার বয়স ছিল আনুমানিক {{ data.age | default('') | bn }} বৎসর।
                            তাহার মৃত্যুর বিষয়টি স্থানীয়ভাবে সর্বজনবিদিত এবং এই মর্মে সনদ প্রদান করা হইল।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            মহান আল্লাহ তাহার রুহের মাগফিরাত করুন।
                        </td>
                    </tr>
                </table>

                {% elseif certificate_type == 'yearlyincome' %}

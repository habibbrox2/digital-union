                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ citizen.name_bn }} নদীভাঙনের শিকার একজন ক্ষতিগ্রস্ত নাগরিক।
                            নদীভাঙনের কারণে তাহার ভিটেমাটি ও বাসস্থান সম্পূর্ণরূপে নদীগর্ভে বিলীন হইয়া গিয়াছে।
                            বর্তমানে তিনি অত্র এলাকায় অস্থায়ীভাবে বসবাস করিতেছেন।
                            মানবিক বিবেচনায় তাহাকে সরকারি পুনর্বাসন কর্মসূচিতে অন্তর্ভুক্ত করার জন্য সংশ্লিষ্ট কর্তৃপক্ষের নিকট বিনীত অনুরোধ জানানো যাইতেছে।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            আমি তাহার সর্বাঙ্গীণ মঙ্গল ও উন্নতি কামনা করি।
                        </td>
                    </tr>
                </table>

                {% elseif certificate_type == 'Onnanno' %}
                {# ── অন্যান্য সনদ ── #}
                <table border="0" width="98%" cellpadding="0" cellspacing="0" style="border-collapse:collapse; margin:0 auto; padding-top:10px;">
                    <tr>
                        <td style="font-size:17px; padding-left:50px;" height="80">
                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ citizen.name_bn }} অত্র ইউনিয়নের {{ citizen.permanent_ward_no|bn }} নং ওয়ার্ডের একজন
                            {% if (citizen.resident|default('permanent')) == 'temporary' %}অস্থায়ী বাসিন্দা{% else %}স্থায়ী বাসিন্দা{% endif %}
                            এবং আমার ব্যক্তিগতভাবে পরিচিত।
                            উপরোক্ত ব্যক্তির বিষয়ে প্রয়োজনীয় তথ্য যাচাই করিয়া এই প্রত্যয়নপত্র প্রদান করা হইল।
                            সংশ্লিষ্ট কর্তৃপক্ষ প্রয়োজনীয় ব্যবস্থা গ্রহণ করিলে বাধিত হইব।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            আমি তাহার সর্বাঙ্গীণ মঙ্গল ও উন্নতি কামনা করি।
                        </td>
                    </tr>
                </table>

                {% else %}
                {# ── Default fallback ── #}
                <table border="0" width="98%" cellpadding="0" cellspacing="0" style="border-collapse:collapse; margin:0 auto; padding-top:10px;">
                    <tr>
                        <td style="font-size:17px; padding-left:50px;" height="80">
                            &nbsp;&nbsp;&nbsp;&nbsp;
                            {{ citizen.name_bn }} অত্র ইউনিয়নের {{ citizen.permanent_ward_no|bn }} নং ওয়ার্ডের একজন
                            {% if (citizen.resident|default('permanent')) == 'temporary' %}অস্থায়ী বাসিন্দা{% else %}স্থায়ী বাসিন্দা{% endif %}
                            এবং উপরের তথ্য অনুযায়ী এই সনদ প্রদান করা হইল।
                            সংশ্লিষ্ট কর্তৃপক্ষের নিকট প্রয়োজনীয় সহযোগিতার অনুরোধ জানানো যাইতেছে।
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:72px; font-size:17px; height:20px;">
                            আমি তাহার সর্বাঙ্গীণ মঙ্গল ও উন্নতি কামনা করি।
                        </td>
                    </tr>
                </table>
                {% endif %}

                {# ═══════════════════════════════════════
                   সংযুক্তি — সব সার্টিফিকেটে প্রযোজ্য
                ═══════════════════════════════════════ #}
                <table border="0" width="99%" style="border-collapse:collapse; margin:5px auto; height:100px;" cellspacing="0" cellpadding="0">
                    <tbody>
                        <tr>
                            <td style="font-size:16px; text-indent:70px; width:150px; font-weight:bold; padding-left:55px; padding-top:10px; height:50px;">
                                <span>সংযুক্তিঃ</span>
                            </td>
                            <td style="font-size:16px;">
                                &nbsp; তিনি অত্র ইউনিয়নের
                                {% if (citizen.resident|default('permanent')) == 'temporary' %}অস্থায়ী বাসিন্দা{% else %}স্থায়ী বাসিন্দা{% endif %}
                                এবং আমার ব্যক্তিগতভাবে পরিচিত। আমার জানামতে তিনি আইন শৃঙ্খলা পরিপন্থী কোনো কাজের সাথে জড়িত নহেন। তাহার স্বভাব চরিত্র ভালো।
                                আমি তাঁর সর্বাঙ্গীণ মঙ্গল কামনা করি।
                            </td>
                        </tr>
                    </tbody>
                </table>

            </div>
        </div>
    </section>
</body>
</html>
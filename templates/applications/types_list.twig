{# templates/applications/certificate_type_list.twig #}
{% extends "layout.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block header_title %}
{% include 'components/sweetAlert.twig' %}
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="mb-0">{{ header_title }}</h4>
        <a href="/" class="btn btn-primary btn-sm">হোম</a>
    </div>
{% endblock %}

{% block content %}
    <div class="container py-4">
        {% if types is not empty %}
            <div class="row">
                {% for type in types %}
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body d-flex flex-column justify-content-between">
                                <h5 class="card-title text-capitalize text-primary">
                                    # {{ type.certificate_type_en|replace({'_': ' '})|title }}
                                </h5>
                                <p class="card-text small text-muted">সনদ টাইপ: {{ type.certificate_type_bn}}</p>
                                <div class="mt-auto">
                                    <a href="/applications/{{ type.type_url }}" class="btn btn-outline-primary btn-sm w-100 mb-2">
                                        বিস্তারিত আবেদনসমূহ ({{ type.total_applications }})
                                    </a>
                                    <a href="/{{ type.type_url }}/apply" class="btn btn-success btn-sm w-100">
                                        নতুন আবেদন করুন
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="alert alert-warning text-center">
                কোনো সনদ টাইপ পাওয়া যায়নি।
            </div>
        {% endif %}
    </div>
{% endblock %}

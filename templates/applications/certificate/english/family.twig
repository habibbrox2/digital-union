		        {% if data.present_district_en %}District: {{ data.present_district_en }}{% elseif data.present_district_bn %}District: {{ data.present_district_bn }}{% endif %}
		    </td>
		</tr>


            </table>

            <!-- Family Statement -->
            <table><tr><td class="warish-statement"> &nbsp; &nbsp;&nbsp; &nbsp; A permanent resident of this Union. The following members listed below are the members of his/her family:</td></tr></table>

            <!-- Family List -->
            <table class="warish-table">
                <tr>
                    <th>Serial</th>
                    <th>Name</th>
                    <th>Relation</th>
                    <th>Age/DOB</th>
                    <th>ID/Reg. No.</th>
                    <th>Marital Status</th>
                    <th>Alive/Deceased</th>
                </tr>
                {% for member in data.warish_members %}
                    <tr>

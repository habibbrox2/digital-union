{# New Voter applied form.twig #}
{% extends "layout.twig" %}

{% block title %}{{title}}{% endblock %}

{% block header_title %}{{header_title}}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}

        <style>
        /* Updated Rules Section */
        .rules {
            background: #f8f9fa;
            border-left: 5px solid #007bff;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
        }

        .rules h5 {
            color: #0056b3;
            font-weight: bold;
        }

        .rules ul {
            padding-left: 20px;
        }

        .rules li {
            font-size: 16px;
            color: #333;
            line-height: 1.6;
        }


        .form-check-input {
            border-color:rgb(0, 0, 0) !important;
        }

        .form-check-input:checked {
            background-color: #28a745 !important; 
            border-color: #28a745 !important;
        }

    </style>
<style>
    #applicationForm input.form-control,
    #applicationForm select.form-control,
    #applicationForm textarea.form-control {
        font-size: 14px;
        padding: 6px 10px;
        height: 35px;
    }

    #applicationForm label.form-label {
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 4px;
    }

    #applicationForm .mb-3 {
        margin-bottom: 10px;
    }

    #applicationForm .mb-6 {
        margin-bottom: 15px;
    }

    /* Warish table spacing adjust */
    #warish_container .form-control {
        padding: 5px;
        font-size: 13px;
        height: 32px;
    }

    #applicationForm .btn {
        font-size: 13px;
        padding: 5px 10px;
    }

    #photo_preview {
        max-height: 130px;
    }

    /* Optional: spacing fix between rows */
    #applicationForm .row {
        margin-bottom: 10px;
    }

    /* Radio and checkbox spacing */
    #applicationForm .form-check-label {
        margin-right: 15px;
        font-size: 14px;
    }

    #applicationForm .form-check-input {
        transform: scale(0.9);
        margin-right: 5px;
    }
    .form-horizontal .form-group {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
}

.form-horizontal .form-label {
    width: 150px; /* লেবেলের প্রস্থ */
    margin-bottom: 0;
    font-size: 14px;
    font-weight: 500;
}

.form-horizontal .form-control {
    flex: 1;
    font-size: 14px;
    padding: 6px 10px;
    height: 35px;
}

.form-horizontal select.form-control,
.form-horizontal input[type="text"],
.form-horizontal input[type="number"] {
    max-width: 100%;
}

</style>

    <div class="container mt-4">
            {% if status == 'success' %}
            <div class="alert alert-success">
                {{ message }}
            </div>
            {% elseif status == 'error' %}
                <div class="alert alert-danger">
                    {{ message }}
                </div>
            {% endif %}

        <h2 class="text-center" style="color: #007bff; font-weight: bold;">{{ title }}2</h2> <!-- কালার পরিবর্তন করা হয়েছে -->

        <!-- নিয়মাবলিঃ -->
        <div class="rules bg-light p-3 rounded mt-3"> 
            <h5 class="text-center"><strong>নিয়মাবলি</strong></h5>
            <ul>
                <li><strong>বাংলায় সার্টিফিকেট পেতে শুধুমাত্র বাংলায় ঘর গুলো পূরণ করুন।</strong></li>
                <li><strong>ইংরেজি সার্টিফিকেট পেতে বাংলা এবং ইংরেজি উভয় ঘর পূরণ করুন।</strong></li>
                <li><strong>তথ্য সঠিকভাবে পূরণ করুন, ভুল তথ্যের জন্য কর্তৃপক্ষ দায়ী থাকবে না।</strong></li>
                <li><strong>যে সকল ঘর (*) চিহ্নিত, তা অবশ্যই পূরণ করতে হবে।</strong></li>
            </ul>
        </div>
        

    

    <script>

        $(document).ready(function () {

            // ডিফল্ট জেলা লোড ও callback ফাংশন সহ
            fetchGeoData(1, 0, '#district_dropdown', function() {
                $('#district_dropdown').val('3026').trigger('change');
            });

            // জেলা পরিবর্তনে উপজেলা লোড
            $('#district_dropdown').on('change', function () {
                const parentGeoId = $(this).find('option:selected').data('geo-id');
                resetDropdown('#upazila_dropdown', 'উপজেলা নির্বাচন করুন');
                resetDropdown('#union_dropdown', 'ইউনিয়ন নির্বাচন করুন');

                if (parentGeoId) {
                    fetchGeoData(2, parentGeoId, '#upazila_dropdown');
                }
            });

            // উপজেলা পরিবর্তনে ইউনিয়ন লোড
            $('#upazila_dropdown').on('change', function () {
                const upazilaNameEn = $(this).find('option:selected').data('name-en');
                const districtNameEn = $('#district_dropdown').find('option:selected').data('name-en');

                resetDropdown('#union_dropdown', 'ইউনিয়ন নির্বাচন করুন');

                if (districtNameEn && upazilaNameEn) {
                    loadUnions(districtNameEn, upazilaNameEn, '#union_dropdown');
                }
            });

            // AJAX দিয়ে ডাটা ফেচ ফাংশন, callback প্যারামিটার নিয়ে
            function fetchGeoData(geoOrder, parentGeoId, dropdownSelector, callback) {
                const dropdown = $(dropdownSelector);
                dropdown.empty().append('<option value="">লোড হচ্ছে...</option>');

                $.ajax({
                    url: '/settings/geo/getdata',
                    type: 'POST',
                    dataType: 'json',
                    data: `geo_order=${geoOrder}&parent_geo_id=${parentGeoId}`,
                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                    success: function (data) {
                        dropdown.empty();
                        let placeholder = 'Select option';
                        if (dropdownSelector === '#district_dropdown') placeholder = 'জেলা নির্বাচন করুন';
                        else if (dropdownSelector === '#upazila_dropdown') placeholder = 'উপজেলা নির্বাচন করুন';
                        else if (dropdownSelector === '#union_dropdown') placeholder = 'ইউনিয়ন নির্বাচন করুন';

                        dropdown.append(`<option value="">${placeholder}</option>`);

                        $.each(data, function (index, item) {
                            dropdown.append(
                                $('<option></option>')
                                    .val(item.geo_code)
                                    .text(item.name_bn)
                                    .attr('data-geo-code', item.geo_code)
                                    .attr('data-name-en', item.name_en)
                                    .attr('data-name-bn', item.name_bn)
                                    .attr('data-geo-id', item.id)
                            );
                        });

                        if (typeof callback === 'function') {
                            callback();
                        }
                    },
                    error: function (xhr, status, error) {
                        dropdown.empty().append('<option value="">ডাটা লোডে সমস্যা হয়েছে</option>');
                        console.error('Error loading geo data:', error);
                    }
                });
            }

            // ইউনিয়ন লোড ফাংশন
            function loadUnions(districtNameEn, upazilaNameEn, dropdownSelector) {
                const dropdown = $(dropdownSelector);
                dropdown.empty().append('<option value="">লোড হচ্ছে...</option>');

                $.ajax({
                    url: '/geo/getUnion',
                    type: 'POST',
                    dataType: 'json',
                    data: {
                        district_name_en: districtNameEn,
                        upazila_name_en: upazilaNameEn
                    },
                    success: function (data) {
                        dropdown.empty();
                        dropdown.append('<option value="">ইউনিয়ন নির্বাচন করুন</option>');

                        $.each(data, function (index, item) {
                            dropdown.append(
                                $('<option></option>')
                                    .val(item.union_code)
                                    .text(item.union_name_bn)
                                    .attr('data-name-en', item.union_name_en)
                                    .attr('data-name-bn', item.union_name_bn)
                                    .attr('data-union-id', item.union_id)
                            );
                        });
                    },
                    error: function (xhr, status, error) {
                        dropdown.empty().append('<option value="">ডাটা লোডে সমস্যা হয়েছে</option>');
                        console.error('Error loading unions:', error);
                    }
                });
            }

            // ড্রপডাউন রিসেট ফাংশন
            function resetDropdown(selector, placeholder) {
                $(selector).empty().append(`<option value="">${placeholder}</option>`);
            }

        });
    </script>

        <script>
            function previewPhoto(event) {
                const photoPreview = document.getElementById('photo_preview');
                const file = event.target.files[0];

                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        photoPreview.src = e.target.result;
                        photoPreview.style.display = "block";
                    };
                    reader.readAsDataURL(file);
                } else {
                    photoPreview.style.display = "none";
                }
            }


            document.addEventListener('DOMContentLoaded', function () {
                const nameInput = document.getElementById('applicant_name');
                const originalName = document.getElementById('name_bn');
                const ownRadio = document.getElementById('own_name');
                const otherRadio = document.getElementById('other_name');

                if (!nameInput || !originalName) {
                    return;
                }

                const syncApplicantName = function () {
                    const banglaName = originalName.value || '';

                    if (otherRadio && otherRadio.checked) {
                        nameInput.readOnly = false;
                        nameInput.style.display = "block";
                        nameInput.style.backgroundColor = "";
                        if (!nameInput.value) {
                            nameInput.value = banglaName;
                        }
                        return;
                    }

                    if (ownRadio) {
                        ownRadio.checked = true;
                    }
                    nameInput.value = banglaName;
                    nameInput.readOnly = true;
                    nameInput.style.display = "block";
                    nameInput.style.backgroundColor = "#e9ecef";
                };

                originalName.addEventListener('input', function () {
                    if (!otherRadio || !otherRadio.checked) {
                        nameInput.value = this.value || '';
                    }
                });

                document.querySelectorAll('input[name="applicant_name_option"]').forEach((radio) => {
                    radio.addEventListener('change', syncApplicantName);
                });

                syncApplicantName();
            });


            document.getElementById('add_document').addEventListener('click', function () {
                const container = document.getElementById('documents_container');
                const fileInputGroup = document.createElement('div');
                fileInputGroup.classList.add('input-group', 'mb-2');

                fileInputGroup.innerHTML = `
                    <input type="file" name="documents[]" class="form-control">
                    <button type="button" class="btn btn-danger remove-file">X</button>
                `;

                container.appendChild(fileInputGroup);
            });


            document.addEventListener('click', function (event) {
                if (event.target.classList.contains('remove-file')) {
                    event.target.parentElement.remove();
                }
            });
        </script>



    <script>
        $(document).ready(function () {
            // Common function to populate dropdowns
            function populateDropdown(selector, data, selectedValue) {
                $(selector).empty().append('<option value="">চিহ্নিত করুন</option>');
                $.each(data, function (index, item) {
                    let isSelected = selectedValue == item.geo_code ? 'selected' : '';
                    $(selector).append(`<option value="${item.name_en}" data-geo-code="${item.geo_code}" data-name-en="${item.name_en}" data-name-bn="${item.name_bn}" data-geo-id="${item.id}" ${isSelected}>${item.name_en}</option>`);
                });
            }

            // Common function to reset dropdowns
            function resetDropdown(selector) {
                $(selector).empty().append('<option value="">চিহ্নিত করুন</option>');
            }

            // Function to fetch Geo data (district, upazila, union)
            function fetchGeoData(geoOrder, parentGeoId, dropdownSelector, nextGeoOrder, nextGeoIdSelector) {
                $.ajax({
                    url: '/settings/geo/getdata',
                    method: 'POST',
                    data: { geo_order: geoOrder, parent_geo_id: parentGeoId },
                    dataType: 'json',
                    success: function (data) {
                        populateDropdown(dropdownSelector, data);
                        if (nextGeoOrder) {
                            resetDropdown(nextGeoIdSelector);
                        }
                    },
                    error: function (error) {
                        console.error('Error fetching geo data', error);
                    }
                });
            }

            // Initial AJAX for default district (present and permanent)
            $.ajax({
                url: '/geo/getdata',
                method: 'POST',
                data: { geo_order: 1, parent_geo_id: 0 },
                dataType: 'json',
                success: function (data) {
                    populateDropdown('#present_district_id', data);
                    populateDropdown('#permanent_district_id', data);
                },
                error: function (error) {
                    console.error('Error fetching districts', error);
                }
            });

            // Present district change event
            $('#present_district_id').change(function () {
                const districtId = parseInt($(this).find('option:selected').attr('data-geo-id')) || 0;
                const districtNameBn = $(this).find('option:selected').attr('data-name-bn') || '';
                if (!districtId) return;
                $('#present_district').val(districtNameBn);
                fetchGeoData(2, districtId, '#present_upazila_id', 3, '#present_union_id');
            });

            // Present upazila change event
            $('#present_upazila_id').change(function () {
                const upazilaId = parseInt($(this).find('option:selected').attr('data-geo-id')) || 0;
                const upazilaNameBn = $(this).find('option:selected').attr('data-name-bn') || '';
                if (!upazilaId) return;
                $('#present_upazila').val(upazilaNameBn);
                fetchGeoData(3, upazilaId, '#present_union_id');
            });

            // Present union change event
            $('#present_union_id').change(function () {
                const unionNameBn = $(this).find('option:selected').attr('data-name-bn') || '';
                $('#present_union').val(unionNameBn);
            });

            // Permanent district change event
            $('#permanent_district_id').change(function () {
                const districtId = parseInt($(this).find('option:selected').attr('data-geo-id')) || 0;
                const districtNameBn = $(this).find('option:selected').attr('data-name-bn') || '';
                if (!districtId) return;
                $('#permanent_district').val(districtNameBn);
                fetchGeoData(2, districtId, '#permanent_upazila_id', 3, '#permanent_union_id');
            });

            // Permanent upazila change event
            $('#permanent_upazila_id').change(function () {
                const upazilaId = parseInt($(this).find('option:selected').attr('data-geo-id')) || 0;
                const upazilaNameBn = $(this).find('option:selected').attr('data-name-bn') || '';
                if (!upazilaId) return;
                $('#permanent_upazila').val(upazilaNameBn);
                fetchGeoData(3, upazilaId, '#permanent_union_id');
            });

            // Permanent union change event
            $('#permanent_union_id').change(function () {
                const unionNameBn = $(this).find('option:selected').attr('data-name-bn') || '';
                $('#permanent_union').val(unionNameBn);
            });

            // Permanent address toggle button
            $("#permanentBtn").change(function () {
            if ($(this).is(":checked")) {
                // Copy simple text fields
                $("#permanent_village_en").val($("#present_village_en").val());
                $("#permanent_village_bn").val($("#present_village_bn").val());
                $("#permanent_rbs_en").val($("#present_rbs_en").val());
                $("#permanent_rbs_bn").val($("#present_rbs_bn").val());
                $("#permanent_holding_no").val($("#present_holding_no").val());
                $("#permanent_ward_no").val($("#present_ward_no").val());
                $("#permanent_postoffice").val($("#present_postoffice").val());
                $("#permanent_postoffice_bn").val($("#present_postoffice_bn").val());

                // Copy District and trigger Upazila fetch
                const districtGeoId = $("#present_district_id").find('option:selected').attr('data-geo-id');
                $("#permanent_district_id").val($("#present_district_id").val()).attr('data-geo-id', districtGeoId).trigger("change");

                // Fetch Upazila based on District
                fetchGeoData(2, districtGeoId, "#permanent_upazila_id", 3, "#permanent_union_id");

                // Delay to ensure Upazila dropdown updates before setting value
                setTimeout(() => {
                    const upazilaGeoId = $("#present_upazila_id").find('option:selected').attr('data-geo-id');
                    $("#permanent_upazila_id").val($("#present_upazila_id").val()).attr('data-geo-id', upazilaGeoId).trigger("change");
                    fetchGeoData(3, upazilaGeoId, "#permanent_union_id");
                    setTimeout(() => {
                        const unionGeoId = $("#present_union_id").find('option:selected').attr('data-geo-id');
                        $("#permanent_union_id").val($("#present_union_id").val()).attr('data-geo-id', unionGeoId).trigger("change");
                    }, 500);
                }, 500);
            } else {

                $("#permanent_village_en, #permanent_village_bn, #permanent_rbs_en, #permanent_rbs_bn, #permanent_holding_no, #permanent_ward_no, #permanent_district_id, #permanent_upazila_id, #permanent_union_id,#permanent_district_bn, #permanent_upazila_bn, #permanent_union_bn, #permanent_postoffice, #permanent_postoffice_bn")
                    .val("")
                    .removeAttr('data-geo-id')
                    .find('option')
                    .prop('selected', false);
            }
        });


    });
    </script>

<script>
    $(document).ready(function () {
        const form = $("#applicationForm");

        form.submit(function (event) {
            event.preventDefault();

            var certificateType = "{{ certificate_type }}";
            console.log("Submitting form with certificateType:", certificateType);

            $.ajax({
                type: "POST",
                url: "/applications/" + certificateType + "/insert",
                data: new FormData(this),
                contentType: false,
                processData: false,
                dataType: "json",
                beforeSend: function () {
                    console.log("AJAX request started");
                    $(".submit-button").text("Submitting...").prop("disabled", true);
                },
                success: function (response) {
                    console.log("AJAX success response:", response);
                    if (response.status === "success") {
                        $("#application_id").text(response.application_id);
                        $("#union_code").text(response.union_code);
                        $("#rmo_code").text(response.rmo_code);
                        $("#successModal").show();
                    } else {
                        alert("⚠️ কিছু সমস্যা হয়েছে: " + response.message);
                    }
                },
                error: function (xhr) {
                    console.error("AJAX error response:", xhr);

                    let message = "⚠️ কিছু সমস্যা হয়েছে, আবার চেষ্টা করুন।";

                    try {
                        let response = JSON.parse(xhr.responseText);
                        console.log("Parsed error response:", response);
                        if (response.message) {
                            message = "⚠️ " + response.message;
                        }
                    } catch (e) {
                        console.warn("Error parsing JSON response:", e);
                        if (xhr.responseText) {
                            message = "⚠️ সার্ভার থেকে উত্তর: " + xhr.responseText;
                        }
                    }

                    alert(message);
                },
                complete: function () {
                    console.log("AJAX request completed");
                    $(".submit-button").text("Submit").prop("disabled", false);
                }
            });
        });

        // Success Modal Actions
        $("#newApplication").click(function () {
            console.log("New Application clicked, resetting form");
            $("#successModal").hide();
            form[0].reset();
            currentStep = 0;
            showStep(currentStep);
        });

        $(".btn-close-modal").click(function () {
            console.log("Modal close button clicked");
            $("#successModal").hide();
        });

        $("#downloadCopy").click(function () {
            let applicantId = $("#application_id").text();
            let union_code = $("#union_code").text().trim() || "0";
            let rmo_code = $("#rmo_code").text().trim() || "0";
            console.log("Opening copy download link for:", applicantId, union_code, rmo_code);
            window.open("/" + certificateType + "/_verify/application/" + applicantId + "/" + union_code + "/" + rmo_code, "_blank");
        });
    });
</script>

<script src="{{ url }}/assets/js/stepValidation.js?t={{ "now"|date("Hiss") }}"></script>


{% endblock %}

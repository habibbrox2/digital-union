<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ detail.application_id }}-আবেদন পত্র</title>
    <link href="https://fonts.maateen.me/solaiman-lipi/font.css" rel="stylesheet">
    <style>
        * {
            font-family: "solaimanlipi", Arial;
            margin: 0;
            padding: 0;
            -webkit-print-color-adjust: exact;
        }
        body {
            margin: 0;
            padding: 0;
            background-color: #A0A0A0;
        }
        .container {
            width: 210mm;
            height: 297mm;
            background: white;
            padding: 10mm; 
            box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
        }
        .header {
        text-align: center;
        width: 100%;
        border-collapse: collapse;
        }

        .header td {
            text-align: center;
            vertical-align: middle;
            padding: 5px;
        }

        .logo {
            height: 80px;
            width: 80px;
        }

        .parishad-name {
            color: blue;
            font-size: 26px;
            font-weight: bold;
            text-align: center;
            padding-bottom: 5px;
        }

        .sub-header {
            font-size: 16px;
            color: black;
            text-align: center;
            line-height: 1.5;
        }
            
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        .info, th, td {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        th, td {
            padding: 2px;
            text-align: left;
        }
        .title {
            font-size: 20px;
            padding: 14px;
            text-align: center;
            text-decoration: underline;
        }

        .footer {
            width: 100%;
            margin-top: 30px;
            border-collapse: collapse;
        }

        .footer .left-section {
            text-align: center;
            border-bottom: 1px solid black;
        }
        .footer .right-section {
            border-left: 1px solid black;
            border-top: 1px solid black;
            text-align: center;
        }
        .footer img {
            padding: 10px;
        }
        .footer font {
            font-size: 8px;
        }
         .dotted-title {
            text-align: center;
            font-size: 20px;
            border-bottom: 1px dotted black; 
            display: inline;
        }
    </style>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>
<body>
    {% include 'components/sweetAlert.twig' %}
    <div class="container">


<table class="header" width="100%">
    <tr>
        <td width="20%">
            <img src="{{ url }}/assets/logo/logo.png" alt="Logo" class="logo">
        </td>
        <td width="60%">
            <div class="parishad-name">
                {{ union.union_name_bn }}
            </div>
            <div class="sub-header">
                {{ union.upazila_name_bn }},{{ union.district_name_bn }}-{{ union.postcode|bn }} <br>
                মোবাইল: {{ union.phone|bn }} | ই-মেইল: {{ union.email }} <br>
                ওয়েবসাইট: {{ union.website }}
            </div>
        </td>
        <td width="20%">
            {% if detail.applicant_photo %}
                <img src="{{ url }}/{{ detail.applicant_photo }}" alt="X" class="img-fluid rounded logo">
            {% else %}
                <img src="{{ url }}/assets/img/band-cross.png" alt="X" class="logo">
            {% endif %}

        </td>
    </tr>
</table>

        <div class="title">{{title}}</div>
        
        
        <table class="info">
            <tr>
                <td> আবেদনের তারিখ</td>
                <td colspan="2"> : {{ detail.apply_date|date('d-m-Y')|bn}}</td>
            </tr>
            <tr>
                <td> সনদের প্রকার</td>
                <td colspan="5"> : {{ certificate_type_bn|default(detail.certificate_type_bn|default(detail.certificate_type)) }}</td>
            </tr>
            <tr>
                <td> পিন নম্বর</td>
                <td colspan="2"> : {{ detail.applicant_id|bn }}</td>
                <td> ট্র্যাকিং নম্বর</td>
                <td colspan="2"> : {{ detail.application_id|bn }}</td>
            </tr>
            <tr>
                <td> নাম (বাংলা)</td>
                <td colspan="2"> : {{ detail.name_bn }}</td>
                <td> নাম (ইংরেজি)</td>
                <td colspan="2"> : {{ detail.name_en }}</td>
            </tr>
            <tr>
                <td> পিতার নাম</td>
                <td colspan="2"> : {{ detail.father_name_bn }}</td>
                <td> মাতার নাম</td>
                <td colspan="2"> : {{ detail.mother_name_bn }}</td>
            </tr>
            <tr>
                <td> লিঙ্গ</td>
                <td> : {{ detail.gender|bn }}</td>
                <td>বৈবাহিক অবস্থা</td>
                <td>: {{ detail.marital_status | bn }}</td>
                    {% if detail.marital_status == 'Married' %}
                    
                        <td>স্বামী/স্ত্রীর নাম</td>
                        <td>: {{ detail.spouse_name_bn | default('N/A') }}</td>
                    
                    {% endif %}

            </tr>
            <tr>
                <td> ধর্ম</td>
                <td> : {{ detail.religion|bn }}</td>
                <td> জন্ম সনদ নম্বর</td>
                <td> : {{ detail.birth_id|bn }}</td>
                <td> হোল্ডিং নং</td>
                <td> : {{ detail.holding_no }}</td>
            </tr>
            <tr>
                <td> পেশা</td>
                <td> : {{ detail.occupation }}</td>
                <td> শিক্ষাগত যোগ্যতা</td>
                <td> : {{ detail.educational_qualification }}</td>
                <td> জন্ম তারিখ</td>
                <td> : {{ detail.birth_date|date('d-m-Y')|bn }}</td>
            </tr>
            <tr>

                <td> মোবাইল নম্বর</td>
                <td> : {{ detail.applicant_phone|bn }}</td>
                <td> ই-মেইল</td>
                <td> : </td>
            </tr>
            <tr>
                <td> ন্যাশনাল আইডি</td>
                <td> : {{ detail.nid|bn }}</td>
                <td> পাসপোর্ট নম্বর</td>
                <td> : {{ detail.passport_no }}</td>
            </tr>
            <tr>
                <td> বর্তমান ঠিকানা</td>
                <td colspan="5"> 
                    : গ্রাম/মহল্লা : {{ detail.present_village_bn }}, রাস্তা/ব্লক/সেক্টর : {{ detail.present_rbs_bn }}, 
                    ওয়ার্ড : {{ detail.present_ward_no|bn }}, পোস্ট অফিস : {{ detail.present_postoffice_bn }}, <br> 
                    উপজেলা : {{ detail.present_upazila_bn }}, জেলা : {{ detail.present_district_bn }}
                </td>
            </tr>
            <tr>
                <td> স্থায়ী ঠিকানা</td>
                <td colspan="5">
                    : গ্রাম/মহল্লা : {{ detail.permanent_village_bn }}, রাস্তা/ব্লক/সেক্টর : {{ detail.permanent_rbs_bn }}, 
                    ওয়ার্ড : {{ detail.permanent_ward_no|bn }}, পোস্ট অফিস : {{ detail.permanent_postoffice_bn }}, <br> 
                    উপজেলা : {{ detail.permanent_upazila_bn }}, জেলা : {{ detail.permanent_district_bn }}
                </td>
            </tr>
        </table>

{% set certType = detail.certificate_type|default(certificate_type|default('')) %}

{% if certType == 'trade' and business_meta %}
<div class="dotted-title">ব্যবসায়িক তথ্য / Business Info</div>
<table class="info">
    <tr>
        <td>ব্যবসায়ের নাম</td>
        <td colspan="5"> : {{ business_meta.business_name_bn|default(detail.business_name_bn) }}</td>
    </tr>
    <tr>
        <td>Business Name (English)</td>
        <td colspan="2"> : {{ business_meta.business_name_en|default(detail.business_name_en) }}</td>
        <td>ব্যবসার ধরন</td>
        <td colspan="2"> : {{ business_meta.business_type_bn|default('') }}</td>
    </tr>
    <tr>
        <td>মালিকানার ধরন</td>
        <td colspan="2"> : {{ business_meta.ownership_name_bn|default('') }}</td>
        <td>অর্থবছর</td>
        <td colspan="2"> : {{ business_meta.fiscal_year|default('')|bn }}</td>
    </tr>
    {% if business_meta.expiry_date %}
    <tr>
        <td>মেয়াদ উত্তীর্ণের তারিখ</td>
        <td colspan="5"> : {{ business_meta.expiry_date|date('d-m-Y')|bn }}</td>
    </tr>
    {% endif %}
    <tr>
        <td>ব্যবসায়ের ঠিকানা</td>
        <td colspan="5" style="white-space: normal;"> :
            গ্রাম/মহল্লা : {{ business_meta.business_village_bn|default('') }},
            রাস্তা/ব্লক/সেক্টর : {{ business_meta.business_rbs_bn|default('') }},
            ওয়ার্ড : {{ business_meta.business_ward_no|default('')|bn }},
            পোস্ট অফিস : {{ business_meta.business_postoffice_bn|default('') }}, <br>
            ইউনিয়ন : {{ business_meta.business_union_bn|default('') }},
            উপজেলা : {{ business_meta.business_upazila_bn|default('') }},
            জেলা : {{ business_meta.business_district_bn|default('') }}
        </td>
    </tr>
    {% if business_meta.total_fee or business_meta.license_fee %}
    <tr>
        <td>লাইসেন্স ফি</td>
        <td> : {{ business_meta.license_fee|default('')|bn }}</td>
        <td>VAT</td>
        <td> : {{ business_meta.vat_amount|default('')|bn }}</td>
        <td>মোট ফি</td>
        <td> : {{ business_meta.total_fee|default('')|bn }}</td>
    </tr>
    {% endif %}
</table>
{% endif %}

{% if detail.warish_members is defined and detail.warish_members is iterable and detail.warish_members|length > 0 %}
<div class="dotted-title">
    {% if certType == 'family' %}
        পরিবারের সদস্যদের তালিকা / Family Members
    {% else %}
        ওয়ারিশগণের তালিকা / Heirs List
    {% endif %}
</div>
<table class="info">
    <tr>
        <th>ক্রম</th>
        <th>নাম (বাংলা)</th>
        <th>Name (English)</th>
        <th>সম্পর্ক</th>
    </tr>
    {% for m in detail.warish_members %}
    <tr>
        <td>{{ m.serial_no|default(loop.index)|bn }}</td>
        <td>{{ m.warish_name_bn|default('') }}</td>
        <td>{{ m.warish_name_en|default('') }}</td>
        <td>{{ m.relation|default('') }}</td>
    </tr>
    {% endfor %}
</table>
{% endif %}

{% if detail.extra_data is defined and detail.extra_data is iterable and detail.extra_data|length > 0 %}
<div class="dotted-title">অতিরিক্ত তথ্য / Extra Info</div>
<table class="info">
    {% for k, v in detail.extra_data %}
        {% if v is not empty %}
            <tr>
                <td>{{ k|replace({'_':' '}) }}</td>
                <td colspan="5" style="white-space: normal;"> : {% if v is iterable %}{{ v|json_encode }}{% else %}{{ v }}{% endif %}</td>
            </tr>
        {% endif %}
    {% endfor %}
</table>
{% endif %}

{% if documents is defined and documents is iterable and documents|length > 0 %}
<div class="dotted-title">সংযুক্ত ডকুমেন্টস / Documents</div>
<table class="info">
    {% for doc_path in documents %}
        <tr>
            <td colspan="6" style="white-space: normal;">- {{ doc_path|split('/')|last }}</td>
        </tr>
    {% endfor %}
</table>
{% endif %}
 

<div class="dotted-title">নির্দেশনাবলী / Instruction</div>
			
        	<ul>
            	<li>এলাকার গণ্যমান্য ২ জন ব্যক্তি এবং ওয়ার্ড মেম্বার কর্তৃক সত্যায়িত করে ইউনিয়ন পরিষদে জমা দিন।</li>
            	<li>১ কপি পাসপোর্ট সাইজ ছবি (সত্যায়িত)।</li>
            	<li>আবেদন পত্রের অবস্থা জানার জন্য ট্র্যাকিং নম্বর দিয়ে ওয়েবসাইট থেকে যাচাই করুন।</li>
        </ul>
        
        <h3>দokument / Documents</h3>
        <table class="info">
            <tr>
                <th>ক্রম</th>
                <th>দokument নাম</th>
            </tr>
            {% if documents is defined and documents is iterable and documents|length > 0 %}
                {% for doc in documents %}
                <tr>
                    <td>{{ loop.index|bn }}</td>
                    <td>{{ doc }}</td>
                </tr>
                {% endfor %}
            {% else %}
                <tr>
                    <td colspan="2" style="text-align: center;">কোনও দokument পাওয়া যায়নি</td>
                </tr>
            {% endif %}
        </table>
        
        <h3>অনুযায়ী তথ্য / Follow-up Information</h3>
        <table class="info">
            <tr>
                <td>অনুযায তারিখ</td>
                <td>: {{ follow_up_date|date('d-m-Y')|bn if follow_up_date is defined else 'N/A' }}</td>
            </tr>
            <tr>
                <td>অনুযাযক</td>
                <td>: {{ follow_up_officer|default('N/A') }}</td>
            </tr>
            <tr>
                <td>স্থিতি</td>
                <td>: {{ follow_up_status|default('N/A') }}</td>
            </tr>
        </table>
        
        <table class="footer">
            <tr>
                <td colspan="4" class="left-section" style="padding-top:40px; padding-bottom:20px;">
                    <div class="title">সত্যায়ন / Verification</div>
                    <br>
                    <br>
                    <br>
                    <div style="text-align: center; text-decoration: overline; ">স্বাক্ষর <br> গণ্যমান্য ব্যক্তি</div>
                </td>
                <td class="right-section">
                    <img src="https://quickchart.io/qr?text={{ url }}/{{ detail.certificate_type }}_verify/application/{{ detail.application_id }}/{{ union.union_code }}/{{ union.rmo_code }}&margin=1&size=300" height="75px" width="110px">
                    <br>
                    <font style="font-size:8px;">Developed by Innovation IT</font><br>
                    <font style="font-size:8px;">www.innovationit.com.bd</font>
                </td>
            </tr>
            <tr>
                <td colspan="2" style="text-align:center;">
                    <font style="font-size:8px;">{{ union.website_url }} - {{ union.contact_email }}</font>
                </td>
            </tr>
        </table>
    	</div>
    </div>
</body>
</html>

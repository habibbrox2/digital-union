{# common/trade_extra.twig #}
    <div id="licenseNumberField" style="display: none;">
        <input type="text" id="license_number" name="license_number" value="{{ license_number }}">
    </div>
    <!-- সেশন শুরু -->
    <div class="card p-3 mb-4 shadow-sm border-warning">
        <h5 class="text-warning fw-bold"><i class="fas fa-briefcase"></i> ট্রেড লাইসেন্স ফি তথ্য</h5>
        <div class="row mt-2">
            <div class="col-md-4">
                <label class="small fw-semibold">লাইসেন্স ফি (টাকা):</label>
                <input type="number" class="form-control form-control-sm" name="license_fee" id="license_fee" placeholder="লাইসেন্স ফি লিখুন" value="{{ business_meta.license_fee }}" required>
            </div>
            <div class="col-md-4">
                <label class="small fw-semibold">ভ্যাট পরিমাণ (১৫%):</label>
                <input type="number" class="form-control form-control-sm" name="vat_amount" id="vat_amount" placeholder="ভ্যাট পরিমাণ লিখুন" value="{{ business_meta.vat_amount }}" required>
            </div>
            <div class="col-md-4">
                <label class="small fw-semibold">পেশা কর (টাকা):</label>
                <input type="number" class="form-control form-control-sm" name="occupation_tax" id="occupation_tax" placeholder="পেশা কর লিখুন" value="{{ business_meta.occupation_tax }}" required>
            </div>

            <div class="col-md-4 mt-3">
                <label class="small fw-semibold">আয়কর / উৎসে কর:</label>
                <input type="number" class="form-control form-control-sm" name="income_tax" id="income_tax" placeholder="আয়কর লিখুন" value="{{ business_meta.income_tax }}">
            </div>
            <div class="col-md-4 mt-3">
                <label class="small fw-semibold">সাইনবোর্ড কর:</label>
                <input type="number" class="form-control form-control-sm" name="signboard_tax" id="signboard_tax" placeholder="সাইনবোর্ড কর লিখুন" value="{{ business_meta.signboard_tax }}">
            </div>
            <div class="col-md-4 mt-3">
                <label class="small fw-semibold">সারচার্জ:</label>
                <input type="number" class="form-control form-control-sm" name="surcharge" id="surcharge" placeholder="সারচার্জ লিখুন" value="{{ business_meta.surcharge }}">
            </div>

            <div class="col-md-6 mt-3">
                <label class="small fw-semibold">মোট ফি (টাকা):</label>
                <input type="number" class="form-control form-control-sm" name="total_fee" id="total_fee" placeholder="মোট ফি" value="{{ business_meta.total_fee }}" readonly>
            </div>
        </div>

        <!-- অর্থবছর ও অন্যান্য -->
        <h5 class="text-warning fw-bold mt-4"><i class="fas fa-calendar-alt"></i> সনদের অর্থবছর</h5>
        <div class="row mt-2 d-flex flex-wrap gap-1 align-items-center">
            <div class="col-sm-3 d-flex flex-column">
                <label class="small fw-semibold mb-1">সনদের অর্থবছর: <span class="text-danger">*</span></label>
                <select class="form-control form-control-sm" name="fiscal_year" id="fiscal_year" required>
                    <option value="" selected disabled>অর্থবছর নির্বাচন করুন</option>
                    {% if fiscal_year_options is defined and fiscal_year_options is not empty %}
                        {% for option in fiscal_year_options %}
                            <option value="{{ option.value }}" {% if option.selected %}selected{% endif %}>{{ option.label }}</option>
                        {% endfor %}
                    {% else %}
                        {# Fallback if options not provided - Starting from 2022-2023 #}
                        <option value="2022-2023" {% if business_meta.fiscal_year == "2022-2023" %}selected{% endif %}>2022-2023</option>
                        <option value="2023-2024" {% if business_meta.fiscal_year == "2023-2024" %}selected{% endif %}>2023-2024</option>
                        <option value="2024-2025" {% if business_meta.fiscal_year == "2024-2025" %}selected{% endif %}>2024-2025</option>
                        <option value="2025-2026" {% if business_meta.fiscal_year == "2025-2026" %}selected{% endif %}>2025-2026</option>
                        <option value="2026-2027" {% if business_meta.fiscal_year == "2026-2027" %}selected{% endif %}>2026-2027</option>
                        <option value="2027-2028" {% if business_meta.fiscal_year == "2027-2028" %}selected{% endif %}>2027-2028</option>
                        <option value="2028-2029" {% if business_meta.fiscal_year == "2028-2029" %}selected{% endif %}>2028-2029</option>
                    {% endif %}
                </select>
            </div>
            <div class="col-md-4 d-flex flex-column">
                <label class="small fw-semibold mb-1">মালিকানার ধরণ:</label>
                <select class="form-control form-control-sm" name="ownership_type_id" id="ownership_type_id" required>
                    <option value="" selected>ব্যবসার ধরণ নির্বাচন করুন</option>
                    {% for ownershipType in ownership_types %}
                            <option value="{{ ownershipType.id }}" {% if ownershipType.id == business_meta.ownership_type_id %}selected{% endif %}>
                                {{ ownershipType.ownership_name_bn }}
                            </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4 d-flex flex-column">
                <label class="small fw-semibold mb-1">ব্যবসার ধরণ:</label>
                <select class="form-control form-control-sm" name="business_type_id" id="business_type_id" required>
                    <option value="" selected>ব্যবসার ধরণ নির্বাচন করুন</option>
                    {% for businessType in business_types %}
                        <option value="{{ businessType.id }}" {% if businessType.id == business_meta.business_type_id %}selected{% endif %}>
                            {{ businessType.business_name_bn }}
                        </option>
                    {% endfor %}
                </select>
            </div>
        </div>
    </div>


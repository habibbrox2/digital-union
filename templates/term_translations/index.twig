{% extends "layout.twig" %}

{% block title %}{{ title }}{% endblock %}
{% block header_title %}{{ header_title }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container py-4">
    <!-- Page Header -->
    <div class="page-header-bar mb-4">
        <div>
            <h2 class="page-header-title mb-1">{{ header_title }}</h2>
            <p class="page-header-subtitle mb-0">সিস্টেমের শব্দ ও তাদের বাংলা, ইংরেজি ও বাংলিশ অনুবাদ পরিচালনা করুন।</p>
        </div>
        <span class="badge-page"><i class="fas fa-language me-1"></i> শব্দ অনুবাদ</span>
    </div>

    <div class="row g-4">
        <!-- Form Card -->
        <div class="col-12 col-xl-5">
            <div class="section-card h-100">
                <h3 class="section-title"><i class="fas fa-edit text-primary"></i> নতুন শব্দ যোগ / সম্পাদনা</h3>

                <form id="termForm">
                    <input type="hidden" name="id" id="id">
                    <div id="responseMessage"></div>

                    <div class="mb-3">
                        <label for="slug" class="form-label">Slug</label>
                        <input type="text" name="slug" id="slug" class="form-control input-enhanced" placeholder="যেমন: application_status" required>
                    </div>

                    <div class="mb-3">
                        <label for="bn" class="form-label">বাংলা <span>*</span></label>
                        <input type="text" name="name_bn" id="bn" class="form-control input-enhanced" placeholder="বাংলা অনুবাদ" required>
                    </div>

                    <div class="mb-3">
                        <label for="en" class="form-label">English</label>
                        <input type="text" name="name_en" id="en" class="form-control input-enhanced" placeholder="English translation">
                    </div>

                    <div class="mb-3">
                        <label for="bl" class="form-label">Banglish</label>
                        <input type="text" name="name_bl" id="bl" class="form-control input-enhanced" placeholder="Banglish version" required>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input type="checkbox" name="is_certificate_type" id="is_certificate_type" value="1" class="form-check-input" role="switch">
                        <label for="is_certificate_type" class="form-check-label">সার্টিফিকেটের ধরণ হিসেবে ব্যবহার করুন</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                            <i class="fas fa-save me-1"></i> <span id="submitBtnText">সংরক্ষণ করুন</span>
                        </button>
                        <button type="button" id="resetFormBtn" class="btn btn-outline-secondary btn-lg" title="ফর্ম পরিষ্কার করুন">
                            <i class="fas fa-rotate-left"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- List Card -->
        <div class="col-12 col-xl-7">
            <div class="section-card h-100">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                    <h3 class="section-title mb-0"><i class="fas fa-list text-primary"></i> শব্দের তালিকা</h3>
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="searchTerm" class="form-control form-control-sm" placeholder="অনুসন্ধান করুন...">
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover table-enhanced align-middle mb-0" id="termTable">
                        <thead>
                            <tr>
                                <th data-column="slug" class="sortable">Slug <i class="fas fa-sort sort-icon"></i></th>
                                <th data-column="name_bn" class="sortable">বাংলা <i class="fas fa-sort sort-icon"></i></th>
                                <th data-column="name_en" class="sortable">English <i class="fas fa-sort sort-icon"></i></th>
                                <th data-column="name_bl" class="sortable">Banglish <i class="fas fa-sort sort-icon"></i></th>
                                <th class="text-center">সার্টিফিকেট</th>
                                <th class="text-center">অ্যাকশন</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                    <div id="tableEmpty" class="table-empty d-none">
                        <i class="fas fa-inbox"></i>
                        <p class="mb-0">কোনো শব্দ পাওয়া যায়নি।</p>
                    </div>
                </div>

                <div id="pagination" class="d-flex justify-content-center mt-3"></div>
            </div>
        </div>
    </div>
</div>



<script>
    let currentPage = 1;
    let currentSort = { column: 'slug', direction: 'asc' };
    let searchQuery = '';

    function escapeHtml(str) {
        return $('<div>').text(str ?? '').html();
    }

    function loadTerms(page = 1) {
        currentPage = page;

        $.post('/ajax/term_translations', {
            action: 'filter',
            page: page,
            sortColumn: currentSort.column,
            sortDirection: currentSort.direction,
            search: searchQuery
        }, function(data) {
            try {
                const response = typeof data === "string" ? JSON.parse(data) : data;

                if (response.status !== 'success') {
                    throw new Error(response.message || 'ডেটা লোড করা যায়নি');
                }

                const terms = response.data || [];
                let html = '';

                terms.forEach(term => {
                    const certBadge = term.is_certificate_type == 1
                        ? '<span class="badge bg-success-subtle text-success"><i class="fas fa-check me-1"></i> হ্যাঁ</span>'
                        : '<span class="text-muted">—</span>';
                    html += `<tr>
                        <td><code class="term-slug">${escapeHtml(term.slug)}</code></td>
                        <td class="fw-medium">${escapeHtml(term.name_bn)}</td>
                        <td>${escapeHtml(term.name_en)}</td>
                        <td>${escapeHtml(term.name_bl)}</td>
                        <td class="text-center">${certBadge}</td>
                        <td class="text-center text-nowrap">
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="editTerm(${term.id})"><i class="fas fa-pen"></i></button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteTerm(${term.id})"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>`;
                });

                $('#termTable tbody').html(html);
                $('#tableEmpty').toggleClass('d-none', terms.length > 0);
                updateSortIcons();
                renderPagination(response.total, page);
            } catch (err) {
                console.error('Invalid JSON or server error:', err);
                Swal.fire('ত্রুটি', 'ডেটা লোড করা যায়নি। অনুগ্রহ করে পরে আবার চেষ্টা করুন।', 'error');
            }
        });
    }

    function updateSortIcons() {
        $('#termTable thead th.sortable').each(function() {
            const icon = $(this).find('.sort-icon');
            if ($(this).data('column') === currentSort.column) {
                icon.removeClass('fa-sort').addClass(currentSort.direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down');
            } else {
                icon.removeClass('fa-sort-up fa-sort-down').addClass('fa-sort');
            }
        });
    }

    function renderPagination(totalItems, currentPage) {
        const itemsPerPage = 10;
        const totalPages = Math.ceil(totalItems / itemsPerPage);

        if (totalPages <= 1) {
            $('#pagination').html('');
            return;
        }

        let html = '<nav><ul class="pagination justify-content-center mb-0">';
        for (let i = 1; i <= totalPages; i++) {
            html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                <a class="page-link" href="#" data-page="${i}">${i}</a>
            </li>`;
        }
        html += '</ul></nav>';
        $('#pagination').html(html);
    }

    $(document).on('click', '#pagination .page-link', function(e) {
        e.preventDefault();
        const page = parseInt($(this).data('page'));
        if (page && page !== currentPage) {
            loadTerms(page);
        }
    });

    $('#searchTerm').on('input', function() {
        searchQuery = $(this).val().trim();
        loadTerms(1);
    });

    $('#termTable thead th.sortable').on('click', function() {
        const clickedColumn = $(this).data('column');
        if (currentSort.column === clickedColumn) {
            currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
        } else {
            currentSort.column = clickedColumn;
            currentSort.direction = 'asc';
        }
        loadTerms(1);
    });

    function setEditMode(isEdit) {
        $('#submitBtnText').text(isEdit ? 'আপডেট করুন' : 'সংরক্ষণ করুন');
    }

    function editTerm(id) {
        $.post('/ajax/term_translations', { action: 'get', id: id }, function(data) {
            const response = typeof data === "string" ? JSON.parse(data) : data;
            const term = response.data ?? response;
            $('#id').val(term.id);
            $('#slug').val(term.slug).data('old-slug', term.slug);
            $('#bn').val(term.name_bn);
            $('#en').val(term.name_en);
            $('#bl').val(term.name_bl);
            $('#is_certificate_type').prop('checked', term.is_certificate_type == 1);
            setEditMode(true);
            $('html, body').animate({ scrollTop: $('#termForm').offset().top - 20 }, 400);
        });
    }

    $('#resetFormBtn').on('click', function() {
        resetForm();
    });

    function resetForm() {
        $('#termForm')[0].reset();
        $('#id').val('');
        $('#slug').data('old-slug', '');
        $('#responseMessage').html('');
        setEditMode(false);
    }

    $('#termForm').on('submit', function(e) {
        e.preventDefault();

        const action = $('#id').val() ? 'update' : 'create';
        const slugField = $('#slug');
        const newSlug = slugField.val().trim();
        const oldSlug = slugField.data('old-slug') || '';
        const isCertificateType = $('#is_certificate_type').is(':checked') ? '1' : '0';
        const formData = $(this).serialize() + '&is_certificate_type=' + isCertificateType + '&action=' + action;

        if (action === 'update' && oldSlug && newSlug !== oldSlug) {
            Swal.fire({
                title: 'স্লাগ পরিবর্তন করবেন?',
                html: `আপনি <strong>slug</strong> পরিবর্তন করছেন।<br><br>পুরাতন: <code>${escapeHtml(oldSlug)}</code><br>নতুন: <code>${escapeHtml(newSlug)}</code>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'হ্যাঁ, পরিবর্তন করুন',
                cancelButtonText: 'বাতিল করুন'
            }).then((result) => {
                if (result.isConfirmed) {
                    submitForm(formData);
                }
            });
        } else {
            submitForm(formData);
        }
    });

    function submitForm(formData) {
        $.post('/ajax/term_translations', formData, function(response) {
            const res = typeof response === 'string' ? JSON.parse(response) : response;
            if (res.status === 'success') {
                $('#responseMessage').html(
                    `<div class="alert alert-success alert-dismissible fade show" role="alert">
                        ${escapeHtml(res.message)}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>`
                );
                resetForm();
                loadTerms(currentPage);
            } else {
                $('#responseMessage').html(
                    `<div class="alert alert-danger alert-dismissible fade show" role="alert">
                        ${escapeHtml(res.message || 'কিছু ভুল হয়েছে!')}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>`
                );
            }
        }).fail(function() {
            $('#responseMessage').html(
                `<div class="alert alert-danger alert-dismissible fade show" role="alert">
                    সার্ভার ত্রুটি। অনুগ্রহ করে আবার চেষ্টা করুন।
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>`
            );
        });
    }

    function deleteTerm(id) {
        Swal.fire({
            title: 'মুছে ফেলবেন?',
            text: 'এটি স্থায়ীভাবে মুছে ফেলা হবে।',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'হ্যাঁ, মুছে ফেলুন',
            cancelButtonText: 'বাতিল'
        }).then((result) => {
            if (result.isConfirmed) {
                $.post('/ajax/term_translations', { action: 'delete', id: id }, function() {
                    loadTerms(currentPage);
                });
            }
        });
    }

    $(document).ready(function() {
        loadTerms();
    });
</script>
{% endblock %}

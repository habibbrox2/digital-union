{% extends "layout.twig" %}

{% block title %}{{ title }}{% endblock %}
{% block header_title %}{{ header_title }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container py-5">
    <div class="card shadow-lg border-0">
        <div class="card-body">
            <h2 class="mb-4 text-center text-primary">{{ header_title }}</h2>

            <!-- Search Input -->
            <div class="row mb-4 justify-content-center">
                <div class="col-md-6">
                    <input type="text" id="searchTerm" class="form-control form-control-lg" placeholder="🔍 Search term...">
                </div>
            </div>

            <!-- Term Form -->
            <form id="termForm" class="row g-4 mb-5">
                <div id="responseMessage" class="my-3"></div>
                <input type="hidden" name="id" id="id">

                <div class="col-md-6">
                    <label for="slug" class="form-label fw-semibold">Slug</label>
                    <input type="text" name="slug" id="slug" class="form-control" placeholder="Slug name" required>
                </div>

                <div class="col-md-6">
                    <label for="bn" class="form-label fw-semibold">বাংলা</label>
                    <input type="text" name="name_bn" id="bn" class="form-control" placeholder="বাংলা অনুবাদ" required>
                </div>

                <div class="col-md-6">
                    <label for="en" class="form-label fw-semibold">English</label>
                    <input type="text" name="name_en" id="en" class="form-control" placeholder="English translation">
                </div>

                <div class="col-md-6">
                    <label for="bl" class="form-label fw-semibold">Banglish</label>
                    <input type="text" name="name_bl" id="bl" class="form-control" placeholder="Banglish version">
                </div>

                <div class="col-md-6 d-flex align-items-center">
                    <input type="checkbox" name="is_certificate_type" id="is_certificate_type" value="1" class="form-check-input me-2">
                    <label for="is_certificate_type" class="form-label mb-0">Use as Certificate Type</label>
                </div>

                <div class="col-12 text-end">
                    <button type="submit" class="btn btn-success btn-lg px-4">💾 Save</button>
                </div>
            </form>

            <!-- Table -->
            <div class="table-responsive mb-4">
                <table class="table table-hover table-bordered align-middle" id="termTable">
                    <thead class="table-primary">
                        <tr>
                            <th data-column="slug" style="cursor:pointer;">Slug ⬍</th>
                            <th data-column="name_bn" style="cursor:pointer;">বাংলা ⬍</th>
                            <th data-column="name_en" style="cursor:pointer;">English ⬍</th>
                            <th data-column="name_bl" style="cursor:pointer;">Banglish ⬍</th>
                            <th class="text-center">Is Certificate</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div id="pagination" class="d-flex justify-content-center mt-4"></div>
        </div>
    </div>
</div>



<script>
    let currentPage = 1;
    let currentSort = { column: 'slug', direction: 'asc' };
    let searchQuery = '';

    function loadTerms(page = 1) {
        currentPage = page;

        $.post('/ajax/term_translations', {
            action: 'filter',
            page: page,
            sortColumn: currentSort.column,
            sortDirection: currentSort.direction,
            search: searchQuery
        }, function(data) {
            try {
                const response = typeof data === "string" ? JSON.parse(data) : data;

                if (response.status !== 'success') {
                    throw new Error(response.message || 'Failed to load data');
                }

                const terms = response.data;
                let html = '';

                terms.forEach(term => {
                    html += `<tr>
                        <td>${term.slug}</td>
                        <td>${term.name_bn}</td>
                        <td>${term.name_en}</td>
                        <td>${term.name_bl}</td>
                        <td class="text-center">${term.is_certificate_type == 1 ? '✔️' : ''}</td>
                        <td>
                            <button class="btn btn-sm btn-warning me-1" onclick="editTerm(${term.id})">Edit</button>
                            <button class="btn btn-sm btn-danger" onclick="deleteTerm(${term.id})">Delete</button>
                        </td>
                    </tr>`;
                });

                $('#termTable tbody').html(html);
                renderPagination(response.total, page);
            } catch (err) {
                console.error('Invalid JSON or server error:', err);
                alert('Failed to load data. Please try again later.');
            }
        });
    }

    function renderPagination(totalItems, currentPage) {
        const itemsPerPage = 10;
        const totalPages = Math.ceil(totalItems / itemsPerPage);

        if (totalPages <= 1) {
            $('#pagination').html('');
            return;
        }

        let html = '<nav><ul class="pagination justify-content-center">';
        for (let i = 1; i <= totalPages; i++) {
            html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                <a class="page-link" href="#" data-page="${i}">${i}</a>
            </li>`;
        }
        html += '</ul></nav>';
        $('#pagination').html(html);
    }

    $(document).on('click', '#pagination .page-link', function(e) {
        e.preventDefault();
        const page = parseInt($(this).data('page'));
        if (page && page !== currentPage) {
            loadTerms(page);
        }
    });

    $('#searchTerm').on('input', function() {
        searchQuery = $(this).val().trim();
        loadTerms(1);
    });

    $('#termTable thead th[data-column]').on('click', function() {
        const clickedColumn = $(this).data('column');
        if (currentSort.column === clickedColumn) {
            currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
        } else {
            currentSort.column = clickedColumn;
            currentSort.direction = 'asc';
        }
        loadTerms(1);
    });

    function editTerm(id) {
        $.post('/ajax/term_translations', { action: 'get', id: id }, function(data) {
            const term = typeof data === "string" ? JSON.parse(data) : data;
            $('#id').val(term.id);
            $('#slug').val(term.slug).data('old-slug', term.slug); // Save old slug
            $('#bn').val(term.name_bn);
            $('#en').val(term.name_en);
            $('#bl').val(term.name_bl);
            $('#is_certificate_type').prop('checked', term.is_certificate_type == 1);
            $('html, body').animate({ scrollTop: $('#termForm').offset().top - 20 }, 500);
        });
    }

    $('#termForm').on('submit', function(e) {
        e.preventDefault();

        const action = $('#id').val() ? 'update' : 'create';
        const slugField = $('#slug');
        const newSlug = slugField.val().trim();
        const oldSlug = slugField.data('old-slug') || '';
        const isCertificateType = $('#is_certificate_type').is(':checked') ? '1' : '0';
        const formData = $(this).serialize() + '&is_certificate_type=' + isCertificateType + '&action=' + action;

        // Check for slug change on update
        if (action === 'update' && oldSlug && newSlug !== oldSlug) {
            Swal.fire({
                title: 'Are you sure?',
                html: `You are changing the <strong>slug</strong>.<br><br>Old: <code>${oldSlug}</code><br>New: <code>${newSlug}</code>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, change it!',
                cancelButtonText: 'No, cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    submitForm(formData);
                }
            });
        } else {
            submitForm(formData);
        }
    });

    function submitForm(formData) {
        $.post('/ajax/term_translations', formData, function(response) {
            const res = typeof response === 'string' ? JSON.parse(response) : response;
            if (res.status === 'success') {
                $('#responseMessage').html(
                    `<div class="alert alert-success alert-dismissible fade show" role="alert">
                        ${res.message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>`
                );
                $('#termForm')[0].reset();
                $('#id').val('');
                $('#slug').data('old-slug', '');
                loadTerms(currentPage);
            } else {
                $('#responseMessage').html(
                    `<div class="alert alert-danger alert-dismissible fade show" role="alert">
                        ${res.message || 'Something went wrong!'}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>`
                );
            }
        }).fail(function() {
            $('#responseMessage').html(
                `<div class="alert alert-danger alert-dismissible fade show" role="alert">
                    Server error. Please try again.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>`
            );
        });
    }

    function deleteTerm(id) {
        Swal.fire({
            title: 'Are you sure?',
            text: 'This will permanently delete the item.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                $.post('/ajax/term_translations', { action: 'delete', id: id }, function() {
                    loadTerms(currentPage);
                });
            }
        });
    }

    $(document).ready(function() {
        loadTerms();
    });
</script>
{% endblock %}

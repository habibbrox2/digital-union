{% set govt_label = 'col-lg-2 col-md-3 col-12' %}
{% set govt_input = 'col-lg-4 col-md-3 col-12' %}

<div class="address-section">
    {% if data is defined and data[prefix~'_address_id'] is defined and data[prefix~'_address_id'] %}
    <script>
        $(document).ready(function() {
            var addressId = '{{ data[prefix~'_address_id'] }}';
            if(addressId){
                $.ajax({
                    url: '/api/address/' + addressId,
                    method: 'GET',
                    dataType: 'json',
                    success: function(addr){
                        // Map data keys to actual element IDs (IDs differ from names for district/upazila/union)
                        const fieldMap = {
                            'village_en': 'village_en',
                            'village_bn': 'village_bn',
                            'rbs_en': 'rbs_en',
                            'rbs_bn': 'rbs_bn',
                            'holding_no': 'holding_no',
                            'ward_no': 'ward_no',
                            'district_en': 'district_id',  // actual ID
                            'district_bn': 'district',      // actual ID
                            'upazila_en': 'upazila_id',     // actual ID
                            'upazila_bn': 'upazila',        // actual ID
                            'union_en': 'union_id',         // actual ID
                            'union_bn': 'union',            // actual ID
                            'postoffice_en': 'postoffice_en',
                            'postoffice_bn': 'postoffice_bn'
                        };
                        for (const [dataKey, elementId] of Object.entries(fieldMap)) {
                            const el = $("#{{ prefix }}_" + elementId);
                            if (el.length && addr[dataKey] !== undefined) {
                                el.val(addr[dataKey]);
                                // Highlight prefilled fields
                                el.css('background-color', '#d4edda');
                                el.css('border', '2px solid #c3e6cb');
                            }
                        }
                        if(addr['district_en']){
                            $("#{{ prefix }}_district_id").val(addr['district_en']).trigger('change');
                        }
                        if(addr['upazila_en']){
                            setTimeout(()=>$("#{{ prefix }}_upazila_id").val(addr['upazila_en']).trigger('change'),500);
                        }
                        if(addr['union_en']){
                            setTimeout(()=>$("#{{ prefix }}_union_id").val(addr['union_en']).trigger('change'),1000);
                        }
                    }
                });
            }
        });
    </script>

    {% endif %}

    {# === Village/Mahalla (EN + BN pair) === #}
    <div class="row align-items-center mb-3">
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_village_en" class="form-label mb-0">গ্রাম/মহল্লা (ইংরেজিতে)</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="text" name="{{ prefix }}_village_en" id="{{ prefix }}_village_en" class="form-control"
                   placeholder="Enter village or neighborhood (English)"
                   value="{{ data[prefix~'_village_en']|default('') }}">
        </div>
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_village_bn" class="form-label mb-0">গ্রাম/মহল্লা (বাংলায়) <span class="text-danger">*</span></label>
        </div>
        <div class="{{ govt_input }}">
            <input type="text" name="{{ prefix }}_village_bn" id="{{ prefix }}_village_bn" class="form-control bangla"
                   placeholder="গ্রামের নাম/মহল্লা লিখুন" required
                   value="{{ data[prefix~'_village_bn']|default('') }}">
        </div>
    </div>

    {# === Road/Block/Sector (EN + BN pair) === #}
    <div class="row align-items-center mb-3">
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_rbs_en" class="form-label mb-0">রোড/ব্লক/সেক্টর (ইংরেজিতে)</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="text" name="{{ prefix }}_rbs_en" id="{{ prefix }}_rbs_en" class="form-control"
                   placeholder="Enter road/block/sector (English)"
                   value="{{ data[prefix~'_rbs_en']|default('') }}">
        </div>
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_rbs_bn" class="form-label mb-0">রোড/ব্লক/সেক্টর (বাংলায়)</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="text" name="{{ prefix }}_rbs_bn" id="{{ prefix }}_rbs_bn" class="form-control"
                   placeholder="রোড/ব্লক/সেক্টর লিখুন"
                   value="{{ data[prefix~'_rbs_bn']|default('') }}">
        </div>
    </div>

    {# === Holding No + Ward No (paired together) === #}
    <div class="row align-items-center mb-3">
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_holding_no" class="form-label mb-0">হোল্ডিং নং</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="text" name="{{ prefix }}_holding_no" id="{{ prefix }}_holding_no" class="form-control"
                   placeholder="হোল্ডিং নম্বর লিখুন"
                   value="{{ data[prefix~'_holding_no']|default('') }}">
        </div>
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_ward_no" class="form-label mb-0">ওয়ার্ড নং <span class="text-danger">*</span></label>
        </div>
        <div class="{{ govt_input }}">
            <select name="{{ prefix }}_ward_no" id="{{ prefix }}_ward_no" class="form-control" required>
                <option value="">ওয়ার্ড নির্বাচন করুন</option>
                {% for i in 1..9 %}
                    <option value="{{ i }}" {% if data[prefix~'_ward_no'] == i %}selected{% endif %}>{{ i }}</option>
                {% endfor %}
            </select>
        </div>
    </div>

    {# === District (EN select + BN text) === #}
    <div class="row align-items-center mb-3">
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_district_id" class="form-label mb-0">জেলা (ইংরেজিতে) <span class="text-danger">*</span></label>
        </div>
        <div class="{{ govt_input }}">
            <select name="{{ prefix }}_district_en" id="{{ prefix }}_district_id" class="form-control" required
                    data-selected="{{ data[prefix~'_district_en']|default('') }}">
                <option value="">জেলা নির্বাচন করুন</option>
            </select>
        </div>
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_district" class="form-label mb-0">জেলা (বাংলায়)</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="text" name="{{ prefix }}_district_bn" id="{{ prefix }}_district" class="form-control"
                   placeholder="স্বয়ংক্রিয়ভাবে পূরণ হবে"
                   value="{{ data[prefix~'_district_bn']|default('') }}">
        </div>
    </div>

    {# === Upazila/Thana (EN select + BN text) === #}
    <div class="row align-items-center mb-3">
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_upazila_id" class="form-label mb-0">উপজেলা/থানা (ইংরেজিতে) <span class="text-danger">*</span></label>
        </div>
        <div class="{{ govt_input }}">
            <select name="{{ prefix }}_upazila_en" id="{{ prefix }}_upazila_id" class="form-control" required
                    data-selected="{{ data[prefix~'_upazila_en']|default('') }}">
                <option value="">উপজেলা নির্বাচন করুন</option>
            </select>
        </div>
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_upazila" class="form-label mb-0">উপজেলা/থানা (বাংলায়)</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="text" name="{{ prefix }}_upazila_bn" id="{{ prefix }}_upazila" class="form-control"
                   placeholder="স্বয়ংক্রিয়ভাবে পূরণ হবে"
                   value="{{ data[prefix~'_upazila_bn']|default('') }}">
        </div>
    </div>

    {# === Union (EN select + BN text) === #}
    <div class="row align-items-center mb-3">
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_union_id" class="form-label mb-0">ইউনিয়ন (ইংরেজিতে) <span class="text-danger">*</span></label>
        </div>
        <div class="{{ govt_input }}">
            <select name="{{ prefix }}_union_en" id="{{ prefix }}_union_id" class="form-control"
                    data-selected="{{ data[prefix~'_union_en']|default('') }}">
                <option value="">ইউনিয়ন নির্বাচন করুন</option>
            </select>
        </div>
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_union" class="form-label mb-0">ইউনিয়ন (বাংলায়)</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="text" name="{{ prefix }}_union_bn" id="{{ prefix }}_union" class="form-control"
                   placeholder="স্বয়ংক্রিয়ভাবে পূরণ হবে"
                   value="{{ data[prefix~'_union_bn']|default('') }}">
        </div>
    </div>

    {# === Post Office (EN autocomplete + BN text) === #}
    <div class="row align-items-center mb-3">
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_postoffice_en" class="form-label mb-0">পোষ্ট অফিস (ইংরেজিতে)</label>
        </div>
        <div class="{{ govt_input }}">
            <div class="autocomplete-wrapper">
                <input type="text" name="{{ prefix }}_postoffice_en" id="{{ prefix }}_postoffice_en"
                       class="form-control" placeholder="পোষ্ট অফিস লিখুন বা নির্বাচন করুন"
                       value="{{ data[prefix~'_postoffice_en']|default('') }}" autocomplete="off">
                <ul class="autocomplete-dropdown postoffice-dropdown" id="{{ prefix }}_postoffice_list"></ul>
            </div>
        </div>
        <div class="{{ govt_label }}">
            <label for="{{ prefix }}_postoffice_bn" class="form-label mb-0">পোষ্ট অফিস (বাংলায়) <span class="text-danger">*</span></label>
        </div>
        <div class="{{ govt_input }}">
            <input type="text" name="{{ prefix }}_postoffice_bn" id="{{ prefix }}_postoffice_bn"
                   class="form-control bangla" placeholder="পোষ্ট অফিসের নাম লিখুন" required
                   value="{{ data[prefix~'_postoffice_bn']|default('') }}">
        </div>
    </div>



<script>
$(document).ready(function () {
    const prefixes = ['business', 'present', 'permanent'];
    window.postOfficeDebug = window.postOfficeDebug ?? true;
    window.postOfficeDebugLog = window.postOfficeDebugLog || function () {
        if (window.postOfficeDebug && window.console) {
            console.log.apply(console, arguments);
        }
    };

    window.isPrefixAvailable = window.isPrefixAvailable || function(prefix) {
        return $(`#${prefix}_district_id`).length > 0;
    }

    window.populateDropdown = window.populateDropdown || function(selector, data) {
        if (!$(selector).length) return;

        const selectedValue = $(selector).data('selected');
        $(selector).empty().append('<option value="">চিহ্নিত করুন</option>');
        const selectedValueNorm = selectedValue ? String(selectedValue).trim().toLowerCase() : null;

        $.each(data, function (_, item) {
            const itemIdNorm = String(item.id).trim().toLowerCase();
            const itemNameEnNorm = String(item.name_en).trim().toLowerCase();
            const isSelected = selectedValueNorm && (selectedValueNorm === itemIdNorm || selectedValueNorm === itemNameEnNorm) ? 'selected' : '';

            $(selector).append(
                `<option value="${item.name_en}" 
                    data-geo-code="${item.geo_code}" 
                    data-name-en="${item.name_en}" 
                    data-name-bn="${item.name_bn}" 
                    data-geo-id="${item.id}" ${isSelected}>${item.name_en} (${item.name_bn})</option>`
            );
        });
    }

    window.resetDropdown = window.resetDropdown || function(selector) {
        if ($(selector).length)
            $(selector).empty().append('<option value="">চিহ্নিত করুন</option>');
    }

    window.fetchGeoData = window.fetchGeoData || function(geoOrder, parentGeoId, dropdownSelector, nextGeoOrder = null, nextGeoIdSelector = null, callback = null) {
        if (!dropdownSelector || !$(dropdownSelector).length) return;

        $.ajax({
            url: '/geo/getdata',
            method: 'POST',
            data: { geo_order: geoOrder, parent_geo_id: parentGeoId },
            dataType: 'json',
            success: function (data) {
                populateDropdown(dropdownSelector, data);
                if (nextGeoOrder && nextGeoIdSelector) resetDropdown(nextGeoIdSelector);
                if (callback) callback();
            },
            error: function (err) {
                console.error('Geo fetch error:', err);
            }
        });
    }

    // ✅ Initial District Load for available prefixes
    $.ajax({
        url: '/geo/getdata',
        method: 'POST',
        data: { geo_order: 1, parent_geo_id: 0 },
        dataType: 'json',
        success: function (data) {
            prefixes.forEach(prefix => {
                if (isPrefixAvailable(prefix)) {
                    populateDropdown(`#${prefix}_district_id`, data);
                    // Trigger change if a value is pre-selected
                    const selected = $(`#${prefix}_district_id`).data('selected');
                    if (selected) {
                        $(`#${prefix}_district_id`).val(selected).trigger('change');
                    }
                }
            });

            // Auto-check after initial data load
            setTimeout(() => {
                if (addressesMatch('business', 'present')) $('#same_as_business_address').prop('checked', true);
                if (addressesMatch('present', 'permanent')) $('#permanentBtn').prop('checked', true);
                if (addressesMatch('present', 'business')) $('#copy_present_to_business').prop('checked', true);
            }, 500);
        },
        error: function (error) {
            console.error('Error loading districts:', error);
        }
    });

    // ✅ Bind dropdown change events
    prefixes.forEach(prefix => {
        if (!isPrefixAvailable(prefix)) return;

        $(`#${prefix}_district_id`).change(function () {
            const id = $(this).find('option:selected').data('geo-id') || 0;
            const nameBn = $(this).find('option:selected').data('name-bn') || '';
            if (!id) return;
            $(`#${prefix}_district`).val(nameBn);
            fetchGeoData(2, id, `#${prefix}_upazila_id`, 3, `#${prefix}_union_id`, function() {
                // Set upazila if pre-selected
                const selectedUpazila = $(`#${prefix}_upazila_id`).data('selected');
                if (selectedUpazila) {
                    $(`#${prefix}_upazila_id`).val(selectedUpazila).trigger('change');
                }
            });
        });

        $(`#${prefix}_upazila_id`).change(function () {
            const id = $(this).find('option:selected').data('geo-id') || 0;
            const nameBn = $(this).find('option:selected').data('name-bn') || '';
            if (!id) return;
            $(`#${prefix}_upazila`).val(nameBn);
            fetchGeoData(3, id, `#${prefix}_union_id`, null, null, function() {
                // Set union if pre-selected
                const selectedUnion = $(`#${prefix}_union_id`).data('selected');
                if (selectedUnion) {
                    $(`#${prefix}_union_id`).val(selectedUnion).trigger('change');
                }
            });
        });

        $(`#${prefix}_union_id`).change(function () {
            const nameBn = $(this).find('option:selected').data('name-bn') || '';
            $(`#${prefix}_union`).val(nameBn);
            const unionSelect = $(this);
            const unionName = unionSelect.find('option:selected').data('name-en') || unionSelect.val();
            window.postOfficeDebugLog('[post-office] union change', {
                prefix: prefix,
                unionName: unionName,
                unionBn: nameBn
            });
            if (unionName) {
                fetchPostOffices(
                    unionName,
                    `#${prefix}_postoffice_en`,
                    `#${prefix}_postoffice_bn`
                );
            }
        });

        $(`#${prefix}_postoffice_en`).on('input change', function () {
            const wrapper = $(this).closest('.autocomplete-wrapper');
            const dropdown = wrapper.find('.autocomplete-dropdown');
            const map = dropdown.data('bn-map') || {};
            const val = String($(this).val()).trim().toLowerCase();
            if (val && map[val]) {
                $(`#${prefix}_postoffice_bn`).val(map[val]);
            }
        });
    });

    // ✅ Fetch post offices by union name (custom dropdown)
    window.fetchPostOffices = window.fetchPostOffices || function(unionName, inputSelector, bnInputSelector) {
        if (!unionName) return;
        const input = $(inputSelector);
        if (!input.length) return;

        const dropdown = input.siblings('.autocomplete-dropdown');
        if (!dropdown.length) return;

        // Clear previous items
        dropdown.empty().removeClass('show');
        dropdown.data('bn-map', {});
        dropdown.data('items', []);
        window.postOfficeDebugLog('[post-office] fetch start', {
            unionName: unionName,
            inputSelector: inputSelector,
            bnInputSelector: bnInputSelector
        });

        $.ajax({
            url: '/api/post-offices',
            method: 'GET',
            data: { union_name: unionName },
            dataType: 'json',
            success: function (res) {
                window.postOfficeDebugLog('[post-office] fetch response', res);
                if (res.status !== 'success' || !res.data) return;

                const currentVal = String(input.val()).trim().toLowerCase();
                const map = {};
                const items = [];

                $.each(res.data, function (_, item) {
                    const enName = item.en_name || '';
                    if (enName) map[enName.trim().toLowerCase()] = item.bn_name || '';
                    items.push(item);

                    const li = $('<li>');
                    li.data('en', enName);
                    li.data('bn', item.bn_name || '');
                    li.html([
                        '<span class="postoffice-name">',
                            $('<span>').text(enName + (item.post_code ? '-' + item.post_code : '')).html(),
                        '</span>',
                        item.bn_name ? '<span class="postoffice-bn">' + $('<span>').text(item.bn_name).html() + '</span>' : ''
                    ].join(''));

                    li.on('mousedown', function(e) {
                        e.preventDefault();
                        const thisItem = $(this);
                        input.val(thisItem.data('en'));
                        $(bnInputSelector).val(thisItem.data('bn'));
                        dropdown.removeClass('show');
                        input.focus();
                    });

                    dropdown.append(li);
                });

                dropdown.data('bn-map', map);
                dropdown.data('items', items);

                // Auto-fill BN if current value matches an option
                if (currentVal && map[currentVal]) {
                    $(bnInputSelector).val(map[currentVal]);
                }

                // Do NOT auto-show dropdown during prefill
                // Dropdown will open only on user focus/click/input via showPostOfficeDropdown
            },
            error: function (err) {
                window.postOfficeDebugLog('[post-office] fetch error', err);
                console.error('Post offices fetch error:', err);
            }
        });
    }

    // ✅ Generic address copy function
    window.copyAddress = window.copyAddress || function(from, to) {
        if (!isPrefixAvailable(from) || !isPrefixAvailable(to)) return;

        const fields = ['village_en', 'village_bn', 'rbs_en', 'rbs_bn', 'holding_no', 'ward_no', 'postoffice_en', 'postoffice_bn'];
        fields.forEach(field => {
            $(`#${to}_${field}`).val($(`#${from}_${field}`).val());
        });

        const districtId = $(`#${from}_district_id`).val();
        const districtName = $(`#${from}_district`).val();
        const districtGeoId = $(`#${from}_district_id option:selected`).data('geo-id');

        $(`#${to}_district_id`).val(districtId);

        fetchGeoData(2, districtGeoId, `#${to}_upazila_id`, 3, `#${to}_union_id`, function () {
            $(`#${to}_district`).val(districtName);

            const upazilaId = $(`#${from}_upazila_id`).val();
            const upazilaName = $(`#${from}_upazila`).val();
            const upazilaGeoId = $(`#${from}_upazila_id option:selected`).data('geo-id');

            $(`#${to}_upazila_id`).val(upazilaId);

            fetchGeoData(3, upazilaGeoId, `#${to}_union_id`, null, null, function () {
                const unionId = $(`#${from}_union_id`).val();
                const unionName = $(`#${from}_union`).val();

                $(`#${to}_upazila`).val(upazilaName);
                $(`#${to}_union_id`).val(unionId);
                $(`#${to}_union`).val(unionName);
            });
        });
    }

    // ✅ Compare two addresses
    window.addressesMatch = window.addressesMatch || function(prefix1, prefix2) {
        const fields = [
            'village_en', 'village_bn', 'rbs_en', 'rbs_bn',
            'holding_no', 'ward_no', 'postoffice_en', 'postoffice_bn',
            'district_id', 'district', 'upazila_id', 'upazila',
            'union_id', 'union'
        ];
        return fields.every(field => {
            return $(`#${prefix1}_${field}`).val() === $(`#${prefix2}_${field}`).val();
        });
    }

    // ✅ Bind address copy + auto check/uncheck
    window.bindAddressSync = window.bindAddressSync || function(from, to, checkboxSelector) {
        $(checkboxSelector).change(function () {
            if ($(this).is(":checked")) {
                copyAddress(from, to);
            } else {
                $(`#${to}_address_fields input, #${to}_address_fields select`).val('');
            }
        });

        $(`#${to}_address_fields input, #${to}_address_fields select`).on('input change', function () {
            if (!addressesMatch(from, to)) {
                $(checkboxSelector).prop('checked', false);
            }
        });

        $(`#${from}_address_fields input, #${from}_address_fields select`).on('input change', function () {
            if (addressesMatch(from, to)) {
                $(checkboxSelector).prop('checked', true);
            } else {
                $(checkboxSelector).prop('checked', false);
            }
        });
    }

    // ✅ Call sync bindings
    bindAddressSync('business', 'present', '#same_as_business_address');
    bindAddressSync('present', 'permanent', '#permanentBtn');
    bindAddressSync('present', 'business', '#copy_present_to_business');

    // ✅ Manual button to copy present to permanent
    $("#copy_present_to_permanent").click(function () {
        copyAddress('present', 'permanent');
    });

    // ===== Custom Autocomplete Dropdown: show/filter on click/focus/input =====
    function showPostOfficeDropdown(input) {
        const wrapper = $(input).closest('.autocomplete-wrapper');
        const dropdown = wrapper.find('.autocomplete-dropdown');
        if (!dropdown.length) return;
        const items = dropdown.data('items');
        if (!items || items.length === 0) return;

        const val = $(input).val().toLowerCase();
        let visibleCount = 0;
        dropdown.find('li').each(function() {
            const en = ($(this).data('en') || '').toLowerCase();
            const match = !val || en.includes(val);
            $(this).toggle(match);
            if (match) visibleCount++;
        });

        if (visibleCount > 0) {
            dropdown.addClass('show');
        } else {
            dropdown.removeClass('show');
        }
    }

    $(document).on('focus click', '.autocomplete-wrapper input[type="text"]', function() {
        showPostOfficeDropdown(this);
    });

    $(document).on('input', '.autocomplete-wrapper input[type="text"]', function() {
        showPostOfficeDropdown(this);
    });

    // Hide on blur (with delay for click capture)
    $(document).on('blur', '.autocomplete-wrapper input[type="text"]', function() {
        const wrapper = $(this).closest('.autocomplete-wrapper');
        const dropdown = wrapper.find('.autocomplete-dropdown');
        setTimeout(function() {
            dropdown.removeClass('show');
        }, 200);
    });

    // Keyboard navigation
    $(document).on('keydown', '.autocomplete-wrapper input[type="text"]', function(e) {
        const wrapper = $(this).closest('.autocomplete-wrapper');
        const dropdown = wrapper.find('.autocomplete-dropdown');
        if (!dropdown.length || !dropdown.hasClass('show')) return;

        const items = dropdown.find('li:visible');
        if (items.length === 0) return;

        let active = dropdown.find('li.active');
        let idx = active.length > 0 ? items.index(active) : -1;

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            idx = Math.min(idx + 1, items.length - 1);
            items.removeClass('active').eq(idx).addClass('active');
            items[idx].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            items.removeClass('active');
            if (idx > 0) {
                idx--;
                items.eq(idx).addClass('active');
                items[idx].scrollIntoView({ block: 'nearest' });
            }
        } else if (e.key === 'Enter') {
            if (idx >= 0 && idx < items.length) {
                e.preventDefault();
                const item = items.eq(idx);
                $(this).val(item.data('en'));
                wrapper.closest('.row').find('[id$="_postoffice_bn"]').val(item.data('bn'));
                dropdown.removeClass('show');
            }
        } else if (e.key === 'Tab') {
            if (idx >= 0 && idx < items.length) {
                // Select item but let Tab naturally move focus to next field
                const item = items.eq(idx);
                $(this).val(item.data('en'));
                wrapper.closest('.row').find('[id$="_postoffice_bn"]').val(item.data('bn'));
                dropdown.removeClass('show');
            }
        } else if (e.key === 'Escape') {
            dropdown.removeClass('show');
        }
    });

});
</script>

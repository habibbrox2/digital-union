{# partials/forms/success_modal.twig #}

<!-- ================= Success Modal ================= -->
<div id="successModal" class="custom-modal fade" tabindex="-1">
    <div class="custom-modal-dialog">
        <div class="custom-modal-content shadow-lg rounded-3 p-4">
            <div class="custom-modal-header d-flex align-items-center border-bottom pb-3 mb-3">
                <i class="fa fa-check-circle text-success fs-2 me-2"></i>
                <h5 class="modal-title m-0">{{ certificate_type_bn ? (certificate_type_bn ~ ' - ') : '' }}আবেদন সফল!</h5>
                <button type="button" class="btn-close ms-auto btn-close-modal" aria-label="Close"></button>
            </div>
            <div class="custom-modal-body mb-3">
                <p class="mb-2">আপনার আবেদনটি সফলভাবে সাবমিট হয়েছে।</p>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><b>আপনার ট্র্যাকিং নম্বর:</b> <span id="application_id"></span></li>
                    <li class="list-group-item"><b>ইউনিয়ন কোড:</b> <span id="union_code"></span></li>
                    <li class="list-group-item"><b>RMO কোড:</b> <span id="rmo_code"></span></li>
                </ul>
            </div>
            <div class="custom-modal-footer d-flex justify-content-end gap-2 flex-wrap">
                <a href="#" id="approveApplication" class="btn btn-warning btn-sm" style="display:none;" target="_blank"><i class="fa fa-check-circle me-1"></i> অনুমোদন দিন</a>
                <button class="btn btn-success btn-sm" id="downloadCopy"><i class="fa fa-download me-1"></i> আবেদন কপি ডাউনলোড</button>
                <button class="btn btn-primary btn-sm" id="newApplication"><i class="fa fa-plus me-1"></i> নতুন আবেদন করুন</button>
            </div>
        </div>
    </div>
</div>

<!-- ================= Update Modal ================= -->
<div id="updateModal" class="custom-modal fade" tabindex="-1">
    <div class="custom-modal-dialog">
        <div class="custom-modal-content shadow-lg rounded-3 p-4">
            <div class="custom-modal-header d-flex align-items-center border-bottom pb-3 mb-3">
                <i class="fa fa-check-circle text-info fs-2 me-2"></i>
                <h5 class="modal-title m-0">{{ certificate_type_bn ? (certificate_type_bn ~ ' - ') : '' }}আবেদন আপডেট সফল!</h5>
                <button type="button" class="btn-close ms-auto btn-close-modal" aria-label="Close"></button>
            </div>
            <div class="custom-modal-body mb-3">
                <p class="mb-2">আপনার আবেদনটি সফলভাবে আপডেট হয়েছে।</p>
                <ul id="updateChangeList" class="list-group list-group-flush mb-3"></ul>
                <div id="updateLinks" class="d-flex gap-2 flex-wrap">
                    <a href="#" id="downloadCertificate" class="btn btn-info btn-sm" target="_blank"><i class="fa fa-download me-1"></i> সার্টিফিকেট ডাউনলোড করুন</a>
                    <a href="/applications/{{ certificate_type|default('application') }}" class="btn btn-secondary btn-sm"><i class="fa fa-list me-1"></i> সকল আবেদন দেখুন</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
/* ===== Modern Modal Styling ===== */
.custom-modal {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1050;
    opacity: 0;          /* default hidden */
    pointer-events: none; /* prevent clicks when hidden */
    transition: opacity 0.3s ease;
}

.custom-modal.show {
    opacity: 1;
    pointer-events: auto;
}


.custom-modal-dialog {
    max-width: 500px;
    width: 90%;
}

.btn-close-modal {
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    transition: transform 0.2s;
    opacity: 0.7;
}
.btn-close-modal:hover {
    transform: rotate(90deg);
    opacity: 1;
}

.list-group-item {
    border: none;
    padding: 0.25rem 0;
}

/* ===== Validation Error Styling ===== */
.is-required-empty {
    border-color: #dc3545 !important;
    box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    background-color: #fff5f5 !important;
}
.is-required-empty:focus {
    box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.4) !important;
}
select.is-required-empty {
    background-color: #fff5f5 !important;
}
.validation-error-text {
    color: #dc3545;
    font-size: 0.85em;
    margin-top: 4px;
    display: none;
}
.validation-error-text.show {
    display: block;
}
</style>


<!-- ================= JS Handling ================= -->
<script>
$(document).ready(function () {
    const form = $("#applicationForm");
    const submitButton = form.find("button[type='submit']");
    const certificateType = "{{ certificate_type|default('application') }}";
    const isLoggedIn = {{ is_logged_in ? 'true' : 'false' }};

    // ===== Validation Helper =====
    function clearFieldErrors() {
        form.find('.is-required-empty').each(function() {
            $(this).removeClass('is-required-empty');
        });
        form.find('.validation-error-text.show').each(function() {
            $(this).removeClass('show');
        });
    }

    function validateRequiredFields() {
        clearFieldErrors();
        let firstInvalid = null;

        form.find('[required]').each(function() {
            const $el = $(this);
            const val = $el.val();
            const fieldName = $el.attr('name');

            // Skip hidden inputs and disabled fields
            if ($el.is(':hidden') || $el.is(':disabled')) return true;

            // ===== Warish: birth_date OR death_year is acceptable =====
            if (certificateType === 'warish' && fieldName === 'birth_date') {
                const $deathYear = $('input[name="death_year"]');
                const deathYearVal = $deathYear.length ? $deathYear.val() : '';
                // If death_year has a value, skip the birth_date required check
                if (deathYearVal && String(deathYearVal).trim() !== '') {
                    return true;
                }
                // If birth_date is empty AND death_year is also empty, show error
                const isEmpty = val === null || val === undefined || String(val).trim() === '';
                if (isEmpty) {
                    $el.addClass('is-required-empty');
                    let $error = $el.next('.validation-error-text');
                    if ($error.length === 0) {
                        $error = $('<small class="validation-error-text">জন্মতারিখ অথবা মৃত্যুসাল যেকোনো একটি দিন</small>');
                        $el.after($error);
                    }
                    $error.addClass('show');
                    if (!firstInvalid) firstInvalid = $el;
                }
                return true; // handled — don't fall through to generic check
            }

            // Check empty: select with default value, or empty input/textarea
            const isEmpty = val === null || val === undefined || String(val).trim() === '';

            if (isEmpty) {
                $el.addClass('is-required-empty');

                // Create or show error message below the field
                let $error = $el.next('.validation-error-text');
                if ($error.length === 0) {
                    $error = $('<small class="validation-error-text">এই ফিল্ডটি পূরণ করুন</small>');
                    $el.after($error);
                }
                $error.addClass('show');

                if (!firstInvalid) firstInvalid = $el;
            }
        });

        return firstInvalid;
    }

    // Clear error styling when user interacts with a field
    form.on('input change', '[required]', function() {
        $(this).removeClass('is-required-empty');
        $(this).next('.validation-error-text').removeClass('show');
    });

    // ===== Form Submit (Ajax) =====
    form.submit(function (event) {
        event.preventDefault();

        // ===== Client-side validation =====
        const firstInvalid = validateRequiredFields();
        if (firstInvalid) {
            // Scroll to the first invalid field smoothly
            $('html, body').animate({
                scrollTop: firstInvalid.offset().top - 120
            }, 400);
            // Focus the field
            firstInvalid.focus();
            return;
        }

        const isUpdate = Boolean($("input[name='application_id']").val());
        const url = form.attr("action");

let restoreBtn;
            $.ajax({
                type: "POST",
                url: url,
                data: new FormData(this),
                contentType: false,
                processData: false,
                dataType: "json",
                beforeSend: function () {
                    restoreBtn = btnLoading(submitButton[0], 'জমা দেওয়া হচ্ছে...');
                },
                success: function (response) {
                if (response.status === "success") {

                    if (isUpdate) {
                        // ===== Update Modal =====
                        const changes = Array.isArray(response.changes) ? response.changes : [];
                        if (changes.length > 0) {
                            const listHtml = changes.map(item => `<li>${item}</li>`).join('');
                            $("#updateChangeList").html(listHtml).show();
                        } else {
                            $("#updateChangeList").hide();
                        }

                        // ===== Certificate / Approve Link =====
                        const certLink = $("#downloadCertificate");
                        const existingSonod = response.sonod_number || $("#sonod_number").val();
                        if (isLoggedIn && existingSonod) {
                            const certUrl = `/application/${certificateType}/bangla/${existingSonod}`;
                            certLink.attr("href", certUrl).text('সার্টিফিকেট ডাউনলোড করুন').show();
                        } else if (response.sonod_number) {
                            const certUrl = `/application/${certificateType}/bangla/${response.sonod_number}`;
                            certLink.attr("href", certUrl).text('সার্টিফিকেট ডাউনলোড করুন').show();
                        } else if (response.application_id) {
                            const approveUrl = `/applications/${certificateType}/approve/${response.application_id}`;
                            certLink.attr("href", approveUrl).text('অনুমোদন দিন / দেখুন').show();
                        } else {
                            certLink.hide();
                        }

                        $("#updateModal").addClass('show');

                        // Show upload warning if any
                        if (response.upload_warning) {
                            Swal.fire({
                                icon: 'warning',
                                title: 'ছবি আপলোড সতর্কতা',
                                text: response.upload_warning,
                                timer: 6000,
                                timerProgressBar: true,
                                showConfirmButton: true,
                                confirmButtonText: 'ঠিক আছে'
                            });
                        }

                    } else {
                        // ===== Success Modal =====
                        $("#application_id").text(response.application_id || 'N/A');
                        $("#union_code")    .text(response.union_code || 'N/A');
                        $("#rmo_code")       .text(response.rmo_code || 'N/A');

                        // ===== Show approve button for logged-in users =====
                        const approveBtn = $("#approveApplication");
                        if (isLoggedIn && response.application_id) {
                            approveBtn.attr("href", `/applications/${certificateType}/approve/${response.application_id}`).show();
                        } else {
                            approveBtn.hide();
                        }

                        $("#successModal").addClass('show');

                        // Show upload warning if any
                        if (response.upload_warning) {
                            Swal.fire({
                                icon: 'warning',
                                title: 'ছবি আপলোড সতর্কতা',
                                text: response.upload_warning,
                                timer: 6000,
                                timerProgressBar: true,
                                confirmButtonText: 'ঠিক আছে'
                            });
                        }
                    }

                } else {
                    Swal.fire('Error', response.message || 'Unknown error', 'error');
                }
            },
            error: function (xhr) {
                let message = "⚠️ কিছু সমস্যা হয়েছে, আবার চেষ্টা করুন।";
                try {
                    const response = JSON.parse(xhr.responseText);
                    if (response.message) message = "⚠️ " + response.message;
                } catch (e) {
                    if (xhr.responseText) message = "⚠️ সার্ভার থেকে উত্তর: " + xhr.responseText;
                }
                Swal.fire('Error', message, 'error');
            },
            complete: function () {
                if (restoreBtn) restoreBtn();
            }
        });
    });

    // ===== New Application Reset =====
    $("#newApplication").click(function () {
        $("#successModal").removeClass('show');
        clearFieldErrors();
        form[0].reset();
    });

    // ===== Close Modal (directly by ID) =====
    $('#successModal .btn-close-modal, #updateModal .btn-close-modal').on('click', function () {
        var modalId = $(this).closest('.custom-modal').attr('id');
        if (modalId) {
            $('#' + modalId).removeClass('show');
        }
    });

    // Close modal when clicking the backdrop (outside the dialog)
    $(document).on('click', '.custom-modal.show', function (e) {
        if ($(e.target).is('.custom-modal')) {
            $(this).removeClass('show');
        }
    });

    // Close modal on Escape key
    $(document).on('keydown', function (e) {
        if (e.key === 'Escape') {
            $('#successModal.show, #updateModal.show').removeClass('show');
        }
    });

    // ===== Download Copy =====
    $("#downloadCopy").click(function () {
        const applicantId = $("#application_id").text().trim() || '0';
        const union_code = $("#union_code").text().trim() || '0';
        const rmo_code = $("#rmo_code").text().trim() || '0';

        window.open(
            `/${certificateType}_verify/application/${applicantId}`,
            "_blank"
        );
    });
});

</script>

{# partials/forms/union_selection.twig #}


<!-- ===================== Form Header ===================== -->
<div class="form-intro text-center">
    <h3 class="text-danger fw-bold">নিয়মাবলি:</h3>
    <hr>
</div>

<div class="row">
    <!-- Left Side -->
    <div class="col-lg-9">

        <div class="form-note mb-3">
            {% include 'partials/forms/rules.twig' %}
        </div>

        <div class="row g-3">

            <div class="col-md-4">
                <label for="select_district_id" class="form-label fw-semibold">
                    জেলা <span class="text-danger">*</span>
                </label>

                <select id="select_district_id"
                        name="district"
                        class="form-select"
                        required>
                    <option>ঢাকা</option>
                </select>
            </div>

            <div class="col-md-4">
                <label for="select_upazila_id" class="form-label fw-semibold">
                    উপজেলা <span class="text-danger">*</span>
                </label>

                <select id="select_upazila_id"
                        name="upazila"
                        class="form-select"
                        required>
                    <option>সিলেক্ট করুন</option>
                </select>
            </div>

            <div class="col-md-4">
                <label for="union_id" class="form-label fw-semibold">
                    ইউনিয়ন <span class="text-danger">*</span>
                </label>

                <select id="union_id"
                        name="union_code"
                        class="form-select"
                        required>
                    <option>নির্বাচন করুন</option>
                </select>
            </div>

        </div>

        <!-- Search -->
        <div class="mt-4">

            <div class="input-group">

    <input
        type="search"
        id="search-data"
        name="search_query"
        class="form-control form-control-lg"
        placeholder="ন্যাশনাল আইডি নং অথবা জন্ম নিবন্ধন নং অথবা পাসপোর্ট নং অথবা পিন নং দিন ইংরেজিতে"
        aria-label="অ্যাপ্লিকেশন সার্চ করুন">

                <button class="btn btn-primary px-4" id="search-btn">

                    <i class="fa fa-search"></i>

                    SEARCH

                </button>

            </div>

            <div id="search-message"></div>

        </div>

    </div>

    <!-- Right Side -->
    <div class="col-lg-3">

        <div class="card shadow-sm border upload-card" id="uploadCard">

            <div class="card-body p-0">

                <div class="upload-preview-area" id="uploadDropZone" style="width:100%;height:225px;background: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url('/assets/images/default.jpg') center/cover no-repeat;">

                    <div class="text-center py-5">






                    </div>

                    <div
                        id="uploadPreviewContainer"
                        style="display:none">

                        <img
                            id="uploadPreviewImg"
                            class="img-fluid w-100">

                    </div>

                </div>

                <button
                    type="button"
                    class="btn btn-primary rounded-0 w-100 py-2"
                    id="uploadCardBtn">

                    <i class="fa fa-upload me-1"></i>

                    UPLOAD

                </button>

            </div>

        </div>

    </div>

</div>

<input
    type="file"
    id="applicant_photo"
    name="applicant_photo"
    accept="image/*"
    class="d-none"
    data-crop="true"
    data-crop-mode="photo"
    data-crop-trigger="#uploadCardBtn, #uploadDropZone"
    data-crop-dropzone="#uploadDropZone"
    data-preview="uploadPreviewImg"
    data-preview-container="uploadPreviewContainer"
    data-drop-zone="uploadDropZone">

<script>
/**
 * Pre-filled data preview (server data) — Crop handled by ImageCropper.autoInit()
 * Only runs when the server provides pre-existing photo data.
 */
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    {% if data.applicant_photo is defined and data.applicant_photo %}
    var img = document.getElementById('uploadPreviewImg');
    var ct = document.getElementById('uploadPreviewContainer');
    var dz = document.getElementById('uploadDropZone');
    if (img) { img.src = '{{ data.applicant_photo }}'; img.style.display = 'block'; }
    if (ct) ct.style.display = 'block';
    if (dz) { dz.style.backgroundImage = 'none'; dz.style.background = '#F2F2F2'; }
    {% elseif data.photo_url is defined and data.photo_url %}
    var img = document.getElementById('uploadPreviewImg');
    var ct = document.getElementById('uploadPreviewContainer');
    var dz = document.getElementById('uploadDropZone');
    if (img) { img.src = '{{ data.photo_url }}'; img.style.display = 'block'; }
    if (ct) ct.style.display = 'block';
    if (dz) { dz.style.backgroundImage = 'none'; dz.style.background = '#F2F2F2'; }
    {% endif %}
  });
})();
</script>


<script>
$(document).ready(function () {

    function populateDropdown(selector, data, placeholder = "চিহ্নিত করুন") {
        if (!$(selector).length) return;
        const select = $(selector);
        select.empty().append(`<option value="">${placeholder}</option>`);
        $.each(data, function (_, item) {
            select.append(
                `<option value="${item.union_code || item.name_en}" 
                    data-geo-id="${item.id || item.union_id}" 
                    data-name-en="${item.name_en || item.union_name_en}" 
                    data-name-bn="${item.name_bn || item.union_name_bn}" 
                    data-union-code="${item.union_code || ''}">
                    ${item.name_en || item.union_name_en} (${item.name_bn || item.union_name_bn})
                </option>`
            );
        });
    }

    // ========================
    // Fetch Districts
    // ========================
    function fetchDistricts(callback) {
        $.ajax({
            url: '/geo/getdata',
            method: 'POST',
            data: { geo_order: 1, parent_geo_id: 0 },
            dataType: 'json',
            success: function(data) {
                const select = $('#select_district_id');
                select.empty();
                $.each(data, function(_, district) {
                    select.append(
                        `<option value="${district.name_en}" 
                            data-geo-id="${district.id}" 
                            data-name-en="${district.name_en}" 
                            data-name-bn="${district.name_bn}">
                            ${district.name_en} (${district.name_bn})
                        </option>`
                    );
                });
                if (callback) callback();
            },
            error: function(err) { console.error('District fetch error:', err); }
        });
    }

    // ========================
    // Fetch Upazilas
    // ========================
    function fetchUpazilas(districtId, preselectUpazilaId = null, callback = null) {
        $.ajax({
            url: '/geo/getdata',
            method: 'POST',
            data: { geo_order: 2, parent_geo_id: districtId },
            dataType: 'json',
            success: function(data) {
                const select = $('#select_upazila_id');
                select.empty().append('<option value="">উপজেলা নির্বাচন করুন</option>');

                let firstUpazilaId = null;
                $.each(data, function(_, item) {
                    if (!firstUpazilaId) firstUpazilaId = item.id;
                    const selected = (item.id == preselectUpazilaId) ? 'selected' : '';
                    select.append(
                        `<option value="${item.name_en}" data-geo-id="${item.id}" data-name-bn="${item.name_bn}" ${selected}>
                            ${item.name_en} (${item.name_bn})
                        </option>`
                    );
                });

                // auto-select first if nothing pre-selected
                if (!preselectUpazilaId && firstUpazilaId) {
                    select.val(select.find(`option[data-geo-id="${firstUpazilaId}"]`).val());
                    preselectUpazilaId = firstUpazilaId;
                }

                $('#union_id').empty().append('<option value="">ইউনিয়ন নির্বাচন করুন</option>');
                if (callback) callback(preselectUpazilaId);
            },
            error: function(err) { console.error('Upazila fetch error:', err); }
        });
    }

    // ========================
    // Fetch Unions
    // ========================
    function fetchUnions(upazilaId, preselectUnionCode = null) {
        if (!upazilaId) return;
        $.ajax({
            url: '/geo/geoUnion',
            method: 'POST',
            data: { upazila_id: upazilaId },
            dataType: 'json',
            success: function(res) {
                if (res.status === 'success') {
                    populateDropdown('#union_id', res.data, 'ইউনিয়ন নির্বাচন করুন');
                    // auto-select union
                    if (preselectUnionCode) {
                        $('#union_id').val(preselectUnionCode);
                    } else if (res.data.length) {
                        $('#union_id').val(res.data[0].union_code);
                    }
                    // Save union in localStorage
                    const currentUnion = $('#union_id').val();
                    if (currentUnion) localStorage.setItem('unionCode', currentUnion);
                }
            },
            error: function(err) { console.error('Union fetch error:', err); }
        });
    }

    // ========================
    // Load saved selections
    // ========================
    const savedDistrictId = parseInt(localStorage.getItem('districtId')) || 25; // DHAKA default
    const savedUpazilaId = parseInt(localStorage.getItem('upazilaId')) || null;
    const savedUnionCode = localStorage.getItem('unionCode') || null;

    // ========================
    // Initial Load
    // ========================
    fetchDistricts(function() {
        // select district
        $('#select_district_id option').each(function() {
            if (parseInt($(this).data('geo-id')) === savedDistrictId) {
                $(this).prop('selected', true);
            }
        });

        fetchUpazilas(savedDistrictId, savedUpazilaId, function(upazilaId) {
            fetchUnions(upazilaId, savedUnionCode);
        });
    });

    // ========================
    // Bind Change Events
    // ========================
    $('#select_district_id').change(function () {
        const districtId = parseInt($(this).find('option:selected').data('geo-id')) || 0;
        localStorage.setItem('districtId', districtId);
        localStorage.removeItem('upazilaId');
        localStorage.removeItem('unionCode');
        fetchUpazilas(districtId, null, function(upazilaId) {
            fetchUnions(upazilaId);
        });
    });

    $('#select_upazila_id').change(function () {
        const upazilaId = parseInt($(this).find('option:selected').data('geo-id')) || 0;
        localStorage.setItem('upazilaId', upazilaId);
        localStorage.removeItem('unionCode');
        fetchUnions(upazilaId);
    });

    $('#union_id').change(function () {
        const unionCode = $(this).val();
        localStorage.setItem('unionCode', unionCode);
    });

});
</script>




<script>
document.addEventListener('DOMContentLoaded', () => {

    // ================= Form & Search Elements =================
    const form = document.getElementById('applicationForm');
    const searchBtn = document.getElementById('search-btn');
    const searchInput = document.getElementById('search-data');
    const searchMsg = document.getElementById('search-message');
    const addressPrefixes = ['business','present','permanent'];

    const banglaToEnglishDigits = {
        '০': '0', '১': '1', '২': '2', '৩': '3', '৪': '4',
        '৫': '5', '৬': '6', '৭': '7', '৮': '8', '৯': '9'
    };

    function normalizeSearchInput(value) {
        return value.replace(/[০-৯]/g, d => banglaToEnglishDigits[d] || d).trim();
    }

    // ================= Search Button Click =================
    searchBtn?.addEventListener('click', async () => {
        const query = normalizeSearchInput(searchInput.value);
        searchMsg.textContent = '';
        searchMsg.style.background = '';
        searchMsg.style.padding = '';
        searchMsg.style.borderRadius = '';
        if (!query) return;

        try {
            const formData = new URLSearchParams();
            formData.append('query', query);
            formData.append('union_code', $('#union_id').val() || '');
            // certificate_type is NOT sent — the backend looks it up from the application data itself

            const res = await fetch('/api/applications/search', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData.toString()
            });

            const response = await res.json();

            if (response.status === 'success') {
                fillForm(response.data);

                // Show confirmation message with applicant name + union + type + source
                const d = response.data;
                const foundName = d.name_bn || d.name_en || '';
                const foundUnion = d.union_name_bn || '';
                const foundType = d.certificate_type_bn || '';
                const foundSource = d.source || '';
                let sourceBadge = '';
                if (foundSource === 'local') {
                    sourceBadge = '<span title="স্থানীয়: স্থানীয় ডাটাবেস থেকে তথ্য আনা হয়েছে" style="display:inline-flex;align-items:center;gap:3px;background:#28a745;color:#fff;font-size:0.75em;padding:2px 8px;border-radius:10px;margin-left:6px;font-weight:bold;box-shadow:0 1px 3px rgba(40,167,69,0.3);cursor:help;"><i class="fas fa-database" style="font-size:0.8em"></i> স্থানীয়</span>';
                } else if (foundSource === 'remote') {
                    sourceBadge = '<span title="অনলাইন: দূরবর্তী API থেকে তথ্য আনা হয়েছে" style="display:inline-flex;align-items:center;gap:3px;background:linear-gradient(135deg,#17a2b8,#138496);color:#fff;font-size:0.75em;padding:2px 8px;border-radius:10px;margin-left:6px;font-weight:bold;border:1px dashed rgba(255,255,255,0.4);box-shadow:0 1px 3px rgba(23,162,184,0.3);cursor:help;"><i class="fas fa-cloud" style="font-size:0.8em"></i> অনলাইন</span>';
                }
                let confirmHtml = `<span style="color: #155724; font-weight: bold;">✅ পাওয়া গেছে: ${foundName}${sourceBadge}</span>`;
                if (foundUnion || foundType) {
                    confirmHtml += `<br><span style="color: #155724; font-size: 0.85em;">`;
                    if (foundUnion) confirmHtml += `ইউনিয়ন: ${foundUnion}`;
                    if (foundUnion && foundType) confirmHtml += ` &nbsp;|&nbsp; `;
                    if (foundType) confirmHtml += `সনদ: ${foundType}`;
                    confirmHtml += `</span>`;
                }
                searchMsg.innerHTML = confirmHtml;
                searchMsg.style.color = '';
                searchMsg.style.background = '#d4edda';
                searchMsg.style.padding = '8px 12px';
                searchMsg.style.borderRadius = '4px';

                searchInput.style.backgroundColor = 'green';
                searchInput.style.border = '2px solid green';
                searchInput.style.color = 'white';
            } else {
                preserveAndResetForm();
                searchInput.style.backgroundColor = '#ff7f7f';
                searchInput.style.border = '2px solid #ff7f7f';
                searchInput.style.color = 'white';
                searchMsg.textContent = response.message;
                searchMsg.style.color = '#ff7f7f';
            }
        } catch (err) {
            console.error(err);
            searchMsg.textContent = 'সার্ভারে সমস্যা হয়েছে।';
            searchMsg.style.color = 'red';
            form.querySelectorAll('input, select, textarea').forEach(el => el.style.borderColor = '#ff7f7f');
        }
    });

    // ================= Preserve & Reset Form =================
    function preserveAndResetForm() {
        const state = {
            district: document.getElementById('district_select_dropdown')?.value,
            upazila: document.getElementById('upazila_select_dropdown')?.value,
            union: document.getElementById('union_select_dropdown')?.value,
            search: searchInput?.value
        };

        form.reset();

        if (state.district) document.getElementById('district_select_dropdown').value = state.district;
        if (state.upazila) document.getElementById('upazila_select_dropdown').value = state.upazila;
        if (state.union) document.getElementById('union_select_dropdown').value = state.union;
        if (state.search) searchInput.value = state.search;

        form.querySelectorAll('input, select, textarea').forEach(el => {
            el.readOnly = false;
            el.disabled = false;
            el.style.backgroundColor = '';
            el.style.color = '';
            el.style.border = '';
        });
    }

    // ================= Fill Form =================
    function fillForm(data) {

        for (const key in data) {
            if (!data.hasOwnProperty(key)) continue;
            // Never overwrite certificate_type — it must stay as set by the current form page
            if (key === 'certificate_type') continue;
            const el = form.querySelector(`[name="${key}"]`);
            if (!el) continue;

            if (el.tagName === 'SELECT') el.value = data[key] ?? '';
            else if (el.type === 'checkbox') el.checked = !!data[key];
            else if (el.type === 'radio') {
                const radio = form.querySelector(`[name="${key}"][value="${data[key]}"]`);
                if (radio) radio.checked = true;
            } else if (el.type === 'file' && key === 'applicant_photo') {
                const previewEl = document.getElementById('uploadPreviewImg') || document.getElementById('photo_preview');
                const previewContainer = document.getElementById('uploadPreviewContainer');
                const dropZone = document.getElementById('uploadDropZone');
                if (previewEl) {
                    previewEl.src = data[key] ?? '';
                    previewEl.style.display = 'block';
                    if (previewContainer) previewContainer.style.display = 'block';
                    if (dropZone) {
                        dropZone.style.backgroundImage = 'none';
                        dropZone.style.background = '#F2F2F2';
                    }
                }
            } else if (el.value !== undefined) {
                el.value = data[key] ?? '';
            }

            // ====== visual highlight for prefilled fields (editable) =====
            if (el.type !== 'checkbox' && el.type !== 'radio') {
                el.style.backgroundColor = el.value ? '#d4edda' : '';
                el.style.border = el.value ? '2px solid #c3e6cb' : '';
                el.style.color = el.value ? '#000' : '';
            }
        }

        // Birth date DD-MM-YYYY
        if (data.birth_date) {
            const parts = data.birth_date.split('-');
            if (parts.length === 3) {
                const bd = document.getElementById('birth_date');
                bd.value = `${parts[2].padStart(2,'0')}-${parts[1].padStart(2,'0')}-${parts[0]}`;
                bd.style.backgroundColor = '#d4edda';
                bd.style.border = '2px solid #c3e6cb';
            }
        }

        // Marital status toggle
        const marital = form.querySelector('[name="marital_status"]')?.value;
        const spouseSection = document.getElementById('spouse_section');
        if (spouseSection) spouseSection.style.display = (marital && marital.toLowerCase() === 'married') ? 'block' : 'none';

        // Address cascading dropdowns & Bengali text fallback
        addressPrefixes.forEach(prefix => {
            cascadeAddressDropdowns(prefix, data);
        });
    }

    // ================= Cascade Address Dropdowns =================
    // The main fillForm loop already sets ALL field values via [name="key"].
    // This function only handles what the loop can't: triggering 'change' events
    // on cascading geo dropdowns (district -> upazila -> union) so their
    // AJAX-loaded options get populated, and setting Bengali text fields via
    // ID as a fallback (their IDs like "present_district" differ from data keys).
    function cascadeAddressDropdowns(prefix, data) {
        // Bengali text fallback — IDs differ from name/data keys
        const bnMap = {
            'district_bn': `${prefix}_district`,
            'upazila_bn': `${prefix}_upazila`,
            'union_bn': `${prefix}_union`,
            'postoffice_bn': `${prefix}_postoffice_bn`,
        };
        for (const [dataKey, elId] of Object.entries(bnMap)) {
            const el = document.getElementById(elId);
            if (el && data[`${prefix}_${dataKey}`]) {
                el.value = data[`${prefix}_${dataKey}`];
                el.style.backgroundColor = '#d4edda';
                el.style.border = '2px solid #c3e6cb';
            }
        }

        // Cascading: district -> upazila -> union (value set by main loop, then
        // re-set after AJAX loads to handle delayed option population)
        const de = document.getElementById(`${prefix}_district_id`);
        const ue = document.getElementById(`${prefix}_upazila_id`);
        const ue2 = document.getElementById(`${prefix}_union_id`);

        if (de && data[`${prefix}_district_en`]) {
            de.value = data[`${prefix}_district_en`];
            de.dispatchEvent(new Event('change'));
        }

        if (ue && data[`${prefix}_upazila_en`]) {
            setTimeout(() => { ue.value = data[`${prefix}_upazila_en`]; ue.dispatchEvent(new Event('change')); }, 600);
        }
        if (ue2 && data[`${prefix}_union_en`]) {
            setTimeout(() => { ue2.value = data[`${prefix}_union_en`]; ue2.dispatchEvent(new Event('change')); }, 1200);
        }
    }

    // ================= Address Copy & Sync =================
    function bindAddressSync(prefix) {
        const copyMap = {
            business: 'same_as_business_address',
            present: 'permanentBtn',
            permanent: 'copy_present_to_business'
        };

        Object.keys(copyMap).forEach(from => {
            const checkbox = document.getElementById(copyMap[from]);
            if (!checkbox) return;

            checkbox.disabled = true;
            const to = from === 'business' ? 'present' : (from === 'present' ? 'permanent' : 'business');

            checkbox.addEventListener('change', () => {
                if (checkbox.checked) copyAddress(from,to);
                else document.querySelectorAll(`#${to}_address_fields input,#${to}_address_fields select`).forEach(el=>el.value='');
            });

            document.querySelectorAll(`#${to}_address_fields input,#${to}_address_fields select`).forEach(el=>{
                el.addEventListener('input',()=>{if(!addressesMatch(from,to)) checkbox.checked=false;});
            });
            document.querySelectorAll(`#${from}_address_fields input,#${from}_address_fields select`).forEach(el=>{
                el.addEventListener('input',()=>{checkbox.checked=addressesMatch(from,to);});
            });
        });
    }

    function copyAddress(from,to){
        const fields = ['village_en','village_bn','rbs_en','rbs_bn','holding_no','ward_no',
                        'postoffice_en','postoffice_bn','district_id','upazila_id','union_id'];
        fields.forEach(f=>{
            const fromEl=document.getElementById(`${from}_${f}`);
            const toEl=document.getElementById(`${to}_${f}`);
            if(fromEl&&toEl){toEl.value=fromEl.value; toEl.dispatchEvent(new Event('change'));}
        });
    }

    function addressesMatch(p1,p2){
        const fields = ['village_en','village_bn','rbs_en','rbs_bn','holding_no','ward_no',
                        'postoffice_en','postoffice_bn','district_id','upazila_id','union_id'];
        return fields.every(f=>{
            const el1=document.getElementById(`${p1}_${f}`);
            const el2=document.getElementById(`${p2}_${f}`);
            return el1 && el2 && el1.value===el2.value;
        });
    }

});
</script>






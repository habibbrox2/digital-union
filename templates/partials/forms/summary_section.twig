{# partials/forms/summary_section.twig #}

<div class="summary-panel">
    <div class="summary-grid">
        <div class="summary-row">
            <div class="summary-label">আবেদনকারীর নাম:</div>
            <div class="summary-value">{{ data.applicant_name|default(data.name_bn|default('-')) }}</div>
        </div>
        <div class="summary-row">
            <div class="summary-label">মোবাইল নম্বর:</div>
            <div class="summary-value">{{ data.applicant_phone|default('-') }}</div>
        </div>
        <div class="summary-row">
            <div class="summary-label">জেলা:</div>
            <div class="summary-value">{{ data.district_name|default('-') }}</div>
        </div>
        <div class="summary-row">
            <div class="summary-label">উপজেলা:</div>
            <div class="summary-value">{{ data.upazila_name|default('-') }}</div>
        </div>
        <div class="summary-row">
            <div class="summary-label">ইউনিয়ন:</div>
            <div class="summary-value">{{ data.union_name|default('-') }}</div>
        </div>
        <div class="summary-row">
            <div class="summary-label">বর্তমান ঠিকানা:</div>
            <div class="summary-value">
                {% if data.present_address is defined %}
                    {{ data.present_address.house_no|default('') }} {{ data.present_address.road_no|default('') }} {{ data.present_address.area|default('') }} {{ data.present_address.post_code|default('') }}
                {% else %}
                    -
                {% endif %}
            </div>
        </div>
        <div class="summary-row">
            <div class="summary-label">স্থায়ী ঠিকানা:</div>
            <div class="summary-value">
                {% if data.permanent_address is defined %}
                    {{ data.permanent_address.house_no|default('') }} {{ data.permanent_address.road_no|default('') }} {{ data.permanent_address.area|default('') }} {{ data.permanent_address.post_code|default('') }}
                {% else %}
                    -
                {% endif %}
            </div>
        </div>
    </div>

    {% if data.members is defined and data.members|length %}
    <div class="summary-table-wrap">
        <div class="summary-subtitle">পরিবারের সদস্যগণ</div>
        <table class="summary-table">
            <thead>
                <tr>
                    <th>ক্রমিক</th>
                    <th>নাম (বাংলা)</th>
                    <th>নাম (English)</th>
                    <th>সম্পর্ক</th>
                    <th>জন্ম তারিখ</th>
                    <th>NID</th>
                    <th>বৈবাহিক অবস্থা</th>
                    <th>জীবিত/মৃত</th>
                </tr>
            </thead>
            <tbody>
                {% for member in data.members %}
                <tr>
                    <td>{{ member.serial_no|default(loop.index) }}</td>
                    <td>{{ member.name_bn|default('-') }}</td>
                    <td>{{ member.name_en|default('-') }}</td>
                    <td>{{ member.relation_bn|default('-') }}</td>
                    <td>{{ member.birth_date|default('-') }}</td>
                    <td>{{ member.nid|default('-') }}</td>
                    <td>{{ member.marital_status|default('-') }}</td>
                    <td>{{ member.is_dead == '1' ? 'মৃত' : 'জীবিত' }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}

    {% if data.documents is defined and data.documents|length %}
    <div class="summary-docs">
        <div class="summary-subtitle">আপলোড করা ডকুমেন্টসমূহ</div>
        <ul>
            {% for doc in data.documents %}
            <li><a href="{{ doc }}" target="_blank">ডকুমেন্ট {{ loop.index }}</a></li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}
</div>

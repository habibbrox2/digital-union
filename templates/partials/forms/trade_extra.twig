{# partials/forms/trade_extra.twig #}
{% set govt_label = 'col-lg-2 col-md-3 col-12' %}
{% set govt_input = 'col-lg-4 col-md-3 col-12' %}

<div id="licenseNumberField" style="display: none;">
    <input type="text" id="license_number" name="license_number" value="{{ license_number }}">
</div>

{# === ট্রেড লাইসেন্স ফি তথ্য === #}
<div class="form-section mb-3">
    <legend class="section-title">ট্রেড লাইসেন্স ফি তথ্য</legend>

    {# Row 1: License Fee | VAT | Occupation Tax #}
    <div class="row align-items-center mb-3 gx-4 gy-3">
        <div class="{{ govt_label }}">
            <label for="license_fee" class="form-label mb-0">লাইসেন্স ফি (টাকা) <span class="text-danger">*</span></label>
        </div>
        <div class="{{ govt_input }}">
            <input type="number" class="form-control" name="license_fee" id="license_fee"
                   placeholder="লাইসেন্স ফি লিখুন" value="{{ business_meta.license_fee }}" required>
        </div>
        <div class="{{ govt_label }}">
            <label for="vat_amount" class="form-label mb-0">ভ্যাট পরিমাণ (১৫%) <span class="text-danger">*</span></label>
        </div>
        <div class="{{ govt_input }}">
            <input type="number" class="form-control" name="vat_amount" id="vat_amount"
                   placeholder="ভ্যাট পরিমাণ লিখুন" value="{{ business_meta.vat_amount }}" required>
        </div>
    </div>

    {# Row 2: Occupation Tax | Income Tax #}
    <div class="row align-items-center mb-3 gx-4 gy-3">
        <div class="{{ govt_label }}">
            <label for="occupation_tax" class="form-label mb-0">পেশা কর (টাকা) <span class="text-danger">*</span></label>
        </div>
        <div class="{{ govt_input }}">
            <input type="number" class="form-control" name="occupation_tax" id="occupation_tax"
                   placeholder="পেশা কর লিখুন" value="{{ business_meta.occupation_tax }}" required>
        </div>
        <div class="{{ govt_label }}">
            <label for="income_tax" class="form-label mb-0">আয়কর / উৎসে কর</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="number" class="form-control" name="income_tax" id="income_tax"
                   placeholder="আয়কর লিখুন" value="{{ business_meta.income_tax }}">
        </div>
    </div>

    {# Row 3: Signboard Tax | Surcharge #}
    <div class="row align-items-center mb-3 gx-4 gy-3">
        <div class="{{ govt_label }}">
            <label for="signboard_tax" class="form-label mb-0">সাইনবোর্ড কর</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="number" class="form-control" name="signboard_tax" id="signboard_tax"
                   placeholder="সাইনবোর্ড কর লিখুন" value="{{ business_meta.signboard_tax }}">
        </div>
        <div class="{{ govt_label }}">
            <label for="surcharge" class="form-label mb-0">সারচার্জ</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="number" class="form-control" name="surcharge" id="surcharge"
                   placeholder="সারচার্জ লিখুন" value="{{ business_meta.surcharge }}">
        </div>
    </div>

    {# Row 4: Total Fee (single field) #}
    <div class="row align-items-center mb-3 gx-4 gy-3">
        <div class="{{ govt_label }}">
            <label for="total_fee" class="form-label mb-0">মোট ফি (টাকা)</label>
        </div>
        <div class="{{ govt_input }}">
            <input type="number" class="form-control" name="total_fee" id="total_fee"
                   placeholder="মোট ফি" value="{{ business_meta.total_fee }}">
        </div>
    </div>
</div>

{# === সনদের অর্থবছর === #}
<div class="form-section mb-3">
    <legend class="section-title">সনদের অর্থবছর</legend>

    {# Row 1: Fiscal Year | Ownership Type | Business Type #}
    <div class="row align-items-center mb-3 gx-4 gy-3">
        <div class="{{ govt_label }}">
            <label for="fiscal_year" class="form-label mb-0">সনদের অর্থবছর <span class="text-danger">*</span></label>
        </div>
        <div class="{{ govt_input }}">
            <select class="form-control" name="fiscal_year" id="fiscal_year" required>
                <option value="" selected disabled>অর্থবছর নির্বাচন করুন</option>
                {% if fiscal_year_options is defined and fiscal_year_options is not empty %}
                    {% for option in fiscal_year_options %}
                        <option value="{{ option.value }}" {% if option.selected %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                {% else %}
                    <option value="2022-2023" {% if business_meta.fiscal_year == "2022-2023" %}selected{% endif %}>2022-2023</option>
                    <option value="2023-2024" {% if business_meta.fiscal_year == "2023-2024" %}selected{% endif %}>2023-2024</option>
                    <option value="2024-2025" {% if business_meta.fiscal_year == "2024-2025" %}selected{% endif %}>2024-2025</option>
                    <option value="2025-2026" {% if business_meta.fiscal_year == "2025-2026" %}selected{% endif %}>2025-2026</option>
                    <option value="2026-2027" {% if business_meta.fiscal_year == "2026-2027" %}selected{% endif %}>2026-2027</option>
                    <option value="2027-2028" {% if business_meta.fiscal_year == "2027-2028" %}selected{% endif %}>2027-2028</option>
                    <option value="2028-2029" {% if business_meta.fiscal_year == "2028-2029" %}selected{% endif %}>2028-2029</option>
                {% endif %}
            </select>
        </div>
        <div class="{{ govt_label }}">
            <label for="ownership_type_id" class="form-label mb-0">মালিকানার ধরণ</label>
        </div>
        <div class="{{ govt_input }}">
            <select class="form-control" name="ownership_type_id" id="ownership_type_id">
                <option value="" selected>ব্যবসার ধরণ নির্বাচন করুন</option>
                {% for ownershipType in ownership_types %}
                    <option value="{{ ownershipType.id }}" {% if ownershipType.id == business_meta.ownership_type_id %}selected{% endif %}>
                        {{ ownershipType.ownership_name_bn }}
                    </option>
                {% endfor %}
            </select>
        </div>
    </div>

    {# Row 2: Business Type (single field) #}
    <div class="row align-items-center mb-3 gx-4 gy-3">
        <div class="{{ govt_label }}">
            <label for="business_type_id" class="form-label mb-0">ব্যবসার ধরণ</label>
        </div>
        <div class="{{ govt_input }}">
            <select class="form-control" name="business_type_id" id="business_type_id">
                <option value="" selected>ব্যবসার ধরণ নির্বাচন করুন</option>
                {% for businessType in business_types %}
                    <option value="{{ businessType.id }}" {% if businessType.id == business_meta.business_type_id %}selected{% endif %}>
                        {{ businessType.business_name_bn }}
                    </option>
                {% endfor %}
            </select>
        </div>
    </div>
</div>

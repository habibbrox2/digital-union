<!DOCTYPE html>
<html lang="bn">
<head>
    <!-- Basic Page Info -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <title>{{ title|default('স্মার্ট ইউনিয়ন পরিষদ অ্যাডমিন') }}</title>

    {# ✅ CSRF Token Meta Tags #}
    <meta name="csrf_token" content="{{ csrf_token }}">
    <meta name="path" content="{{ url|default('') }}">

    {# ✅ CSRF JS - Load Early #}
    <script src="{{ url }}/assets/js/csrf.js?t={{ "now"|date("Hiss") }}"></script>

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <!-- Site favicon -->
    <link rel="shortcut icon" href="{{ url }}/assets/images/favicon.png">

    <!-- Login Shared Styles -->
    <link rel="stylesheet" href="{{ url }}/assets/css/login.css">
</head>
<body>

<div class="login-dark">
    <form id="loginForm" method="POST" action="/login" autocomplete="off" novalidate>

        {# ✅ CSRF token auto-injected by csrf.js #}

        {# Hidden redirect field #}
        <input type="hidden" name="redirect" value="{{ redirect|default('/dashboard') }}">

        {# ✅ Logo #}
        <div class="illustration">
            <img src="{{ url }}/assets/images/login_logo.png" alt="Smart Union Logo" width="40%" height="auto">
        </div>

        {# ✅ Session timeout notice #}
        {% if timeout %}
        <div class="timeout-notice">
            <i class="fas fa-clock me-2"></i>
            আপনার সেশন মেয়াদ শেষ হয়েছে। দয়া করে আবার লগইন করুন।
        </div>
        {% endif %}

        {# ✅ Static messages from server #}
        {% if message %}
        <div class="alert alert-{{ message_type|default('info') }}" role="alert">
            {{ message|raw }}
        </div>
        {% endif %}

        {# ✅ SweetAlert messages #}
        {% if sweetAlert %}
        <div class="alert alert-{{ sweetAlert.type }}" role="alert">
            <strong>{{ sweetAlert.title }}:</strong> {{ sweetAlert.message }}
        </div>
        {% endif %}

        {# ✅ Dynamic alert for AJAX responses #}
        <div id="dynamicAlert" class="d-none" role="alert"></div>

        {# ✅ Username/Email Field #}
        <div class="form-group">
            <label for="username" class="form-label">
                ইউজারনেম বা ইমেইল
            </label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-user"></i></span>
                <input class="form-control"
                       type="text"
                       id="username"
                       name="username"
                       placeholder="আপনার ইউজারনেম বা ইমেইল লিখুন"
                       required
                       autocomplete="username"
                       autofocus>
            </div>
        </div>
        {# ✅ Password Field #}
        <div class="form-group">

            <label for="password" class="form-label">
                পাসওয়ার্ড
            </label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-lock"></i></span>

                <input class="form-control"
                       type="password"
                       id="password"
                       name="password"
                       placeholder="আপনার পাসওয়ার্ড লিখুন"
                       required
                       autocomplete="current-password">
                <button class="btn-toggle"
                        type="button"
                        id="togglePassword"
                        title="পাসওয়ার্ড দেখান/লুকান">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
        </div>

        {# ✅ Remember Me Checkbox #}
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="remember" name="remember">
            <label class="form-check-label" for="remember">
                মনে রাখুন
            </label>
        </div>

        {# ✅ Login Button #}
        <button type="submit" class="btn-primary" id="loginBtn">
            <i class="fas fa-sign-in-alt me-2"></i> লগইন করুন
        </button>

        {# ✅ Forgot Password Link #}
        <a href="/password-reset" class="forgot">
            <i class="fas fa-question-circle me-1"></i>
            পাসওয়ার্ড ভুলে গেছেন?
        </a>

        {# ✅ Home Page Link #}
        <a href="/" class="home-link">
            <i class="fas fa-home me-1"></i> হোম পেজ
        </a>
    </form>
</div>

{# ✅ SweetAlert2 (if needed) #}
{% if sweetAlert %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    Swal.fire({
        icon: '{{ sweetAlert.type }}',
        title: '{{ sweetAlert.title }}',
        text: '{{ sweetAlert.message }}',
        confirmButtonText: 'ঠিক আছে',
        timer: 3000
    });
</script>
{% endif %}

<script>
    // ✅ Password Toggle
    document.getElementById('togglePassword')?.addEventListener('click', function() {
        const passwordInput = document.getElementById('password');
        const icon = this.querySelector('i');

        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            passwordInput.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    });

    // ✅ Enhanced AJAX Login Handler
    document.getElementById('loginForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const form = this;
        const btn = document.getElementById('loginBtn');
        const alertBox = document.getElementById('dynamicAlert');

        const restoreBtn = btnLoading(btn, 'লগইন করুন...');

        // Hide previous alerts
        alertBox.classList.add('d-none');
        alertBox.className = 'd-none';

        try {
            const formData = new FormData(form);
            formData.append('return_json', '1'); // Request JSON response

            const response = await fetch('/login', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                // ✅ Success
                alertBox.className = 'alert alert-success';
                alertBox.innerHTML = '<i class="fas fa-check-circle me-2"></i>' + data.message;

                // Redirect after delay
                setTimeout(() => {
                    window.location.href = data.redirect || '/dashboard';
                }, 1000);
            } else {
                // ✅ Error
                alertBox.className = 'alert alert-danger';
                alertBox.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i>' + data.message;

                restoreBtn();
            }
        } catch (error) {
            // ✅ Network error
            alertBox.className = 'alert alert-danger';
            alertBox.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>সংযোগ ত্রুটি। আবার চেষ্টা করুন।';

            restoreBtn();

            console.error('Login error:', error);
        }
    });

    // ✅ Enter key on any field submits form
    document.querySelectorAll('#loginForm input').forEach(input => {
        input.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('loginForm').dispatchEvent(new Event('submit'));
            }
        });
    });
</script>

<script src="{{ url }}/assets/script.js?t={{ "now"|date("Hiss") }}"></script>
</body>
</html>

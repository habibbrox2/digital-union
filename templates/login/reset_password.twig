<!DOCTYPE html>
<html lang="bn">
<head>
    <!-- Basic Page Info -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <title>{{ title|default('স্মার্ট ইউনিয়ন পরিষদ অ্যাডমিন') }}</title>

    {# ✅ CSRF Token Meta Tags #}
    <meta name="csrf_token" content="{{ csrf_token }}">
    <meta name="path" content="{{ url|default('') }}">

    {# ✅ CSRF JS - Load Early #}
    <script src="{{ url }}/assets/js/csrf.js?t={{ "now"|date("Hiss") }}"></script>

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <!-- Site favicon -->
    <link rel="shortcut icon" href="{{ url }}/assets/images/favicon.png">

    <!-- Login Shared Styles -->
    <link rel="stylesheet" href="{{ url }}/assets/css/login.css">
</head>
<body>

<div class="login-dark">
    <form id="resetPasswordForm" method="POST" action="/new-password" autocomplete="off" novalidate>

        {# ✅ CSRF token auto-injected by csrf.js #}

        {# Hidden token field #}
        <input type="hidden" name="token" value="{{ token }}">

        {# ✅ Logo #}
        <div class="illustration">
            <img src="{{ url }}/assets/images/login_logo.png" alt="Smart Union Logo" width="40%" height="auto">
        </div>

        {# ✅ Static messages from server #}
        {% if message %}
        <div class="alert alert-{{ message_type|default('info') }}" role="alert">
            {{ message|raw }}
        </div>
        {% endif %}

        {# ✅ SweetAlert messages #}
        {% if sweetAlert %}
        <div class="alert alert-{{ sweetAlert.type }}" role="alert">
            <strong>{{ sweetAlert.title }}:</strong> {{ sweetAlert.message }}
        </div>
        {% endif %}

        {# ✅ Dynamic alert for AJAX responses #}
        <div id="dynamicAlert" class="d-none" role="alert"></div>

        {# ✅ New Password Field #}
        <div class="form-group">
            <label for="password" class="form-label">
                <i class="fas fa-lock me-1"></i>
                নতুন পাসওয়ার্ড
            </label>
            <div class="input-group">
                <input class="form-control"
                       type="password"
                       id="password"
                       name="password"
                       placeholder="নতুন পাসওয়ার্ড লিখুন"
                       required
                       minlength="6">
                <button class="btn-toggle"
                        type="button"
                        id="togglePassword1"
                        title="পাসওয়ার্ড দেখান/লুকান">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
            <small class="form-text">কমপক্ষে ৬ অক্ষর হতে হবে।</small>
        </div>

        {# ✅ Confirm Password Field #}
        <div class="form-group">
            <label for="confirm_password" class="form-label">
                <i class="fas fa-lock me-1"></i>
                পাসওয়ার্ড নিশ্চিত করুন
            </label>
            <div class="input-group">
                <input class="form-control"
                       type="password"
                       id="confirm_password"
                       name="confirm_password"
                       placeholder="পাসওয়ার্ড পুনরায় লিখুন"
                       required
                       minlength="6">
                <button class="btn-toggle"
                        type="button"
                        id="togglePassword2"
                        title="পাসওয়ার্ড দেখান/লুকান">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
        </div>

        {# ✅ Reset Button #}
        <button type="submit" class="btn-primary" id="submitBtn">
            <i class="fas fa-check me-2"></i> পাসওয়ার্ড পরিবর্তন করুন
        </button>

        {# ✅ Back to Login Link #}
        <a href="/login" class="back-link">
            <i class="fas fa-arrow-left me-1"></i>
            লগইন পৃষ্ঠায় ফিরুন
        </a>

        {# ✅ Home Page Link #}
        <a href="/" class="home-link">
            <i class="fas fa-home me-1"></i> হোম পেজ
        </a>
    </form>
</div>

{# ✅ SweetAlert2 #}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // ✅ Show static SweetAlert if needed
    {% if sweetAlert %}
    Swal.fire({
        icon: '{{ sweetAlert.type }}',
        title: '{{ sweetAlert.title }}',
        text: '{{ sweetAlert.message }}',
        confirmButtonText: 'ঠিক আছে',
        timer: 3000
    });
    {% endif %}

    // ✅ Password visibility toggle
    document.getElementById('togglePassword1')?.addEventListener('click', function() {
        const input = document.getElementById('password');
        const icon = this.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    });

    document.getElementById('togglePassword2')?.addEventListener('click', function() {
        const input = document.getElementById('confirm_password');
        const icon = this.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    });

    // ✅ Enhanced AJAX Form Handler
    document.getElementById('resetPasswordForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const form = this;
        const btn = document.getElementById('submitBtn');
        const alertBox = document.getElementById('dynamicAlert');

        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirm_password').value;

        // Validate passwords match
        if (password !== confirmPassword) {
            alertBox.className = 'alert alert-warning';
            alertBox.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>পাসওয়ার্ড মিলছে না!';
            alertBox.classList.remove('d-none');
            return;
        }

        const restoreBtn = btnLoading(btn, 'পাসওয়ার্ড পরিবর্তন করুন...');

        // Hide previous alerts
        alertBox.classList.add('d-none');
        alertBox.className = 'd-none';

        try {
            const formData = new FormData(form);
            formData.append('return_json', '1');

            const response = await fetch('/new-password', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                // ✅ Success
                alertBox.className = 'alert alert-success';
                alertBox.innerHTML = '<i class="fas fa-check-circle me-2"></i>' + data.message;
                alertBox.classList.remove('d-none');

                // Redirect to login
                setTimeout(() => {
                    window.location.href = data.redirect || '/login';
                }, 1500);
            } else {
                // ✅ Error
                alertBox.className = 'alert alert-danger';
                alertBox.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i>' + data.message;
                alertBox.classList.remove('d-none');

                // Re-enable button
                restoreBtn();
            }
        } catch (error) {
            // ✅ Network error
            alertBox.className = 'alert alert-danger';
            alertBox.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>সংযোগ ত্রুটি। আবার চেষ্টা করুন।';
            alertBox.classList.remove('d-none');

            // Re-enable button
            restoreBtn();

            console.error('Form error:', error);
        }
    });

    // ✅ Enter key submits form
    document.getElementById('confirm_password').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            document.getElementById('resetPasswordForm').dispatchEvent(new Event('submit'));
        }
    });
</script>

<script src="{{ url }}/assets/script.js?t={{ "now"|date("Hiss") }}"></script>
</body>
</html>

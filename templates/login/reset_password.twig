{# reset_password.twig #}
<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title|default('Reset Password') }}</title>
    
    {# ✅ CSRF Token Meta Tag #}
    <meta name="csrf_token" content="{{ csrf_token }}">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    {# ✅ CSRF JS - Load Early #}
    <script src="{{ url }}/assets/js/csrf.js?t={{ "now"|date("Hiss") }}"></script>
    
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            background-repeat: no-repeat;
            background-attachment: fixed;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px;
        }

        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(255,255,255,0.1) 0%, transparent 70%),
                radial-gradient(circle at 80% 80%, rgba(255,255,255,0.05) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        .card {
            position: relative;
            z-index: 1;
            border-radius: 15px;
            box-shadow: 0 15px 30px rgba(0,0,0,0.3);
            background: rgba(255, 255, 255, 0.95);
        }

        h2 {
            color: #4a2fbd;
            font-weight: 700;
        }

        .input-group-text.bg-primary {
            background-color: #4a2fbd !important;
            border: none !important;
            color: white !important;
        }

        .form-control:focus {
            box-shadow: 0 0 5px #4a2fbd;
            border-color: #4a2fbd;
        }

        .btn-primary {
            background-color: #4a2fbd;
            border-color: #4a2fbd;
            font-weight: 600;
            font-size: 1.1rem;
            position: relative;
            transition: all 0.3s ease;
        }

        .btn-primary:hover, .btn-primary:focus {
            background-color: #3a208b;
            border-color: #3a208b;
            box-shadow: 0 0 8px #3a208b;
            transform: translateY(-2px);
        }

        .btn-primary:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .btn-loading {
            pointer-events: none;
        }

        .btn-loading::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            top: 50%;
            left: 50%;
            margin-left: -8px;
            margin-top: -8px;
            border: 2px solid #ffffff;
            border-radius: 50%;
            border-top-color: transparent;
            animation: spin 0.6s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        a.text-primary {
            color: #4a2fbd !important;
            font-weight: 600;
        }

        a.text-primary:hover {
            color: #3a208b !important;
            text-decoration: underline;
        }

        .alert {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
    </style>
</head>
<body>

    <div class="card p-5" style="max-width: 420px; width: 100%;">
        <h2 class="text-center mb-4">
            <i class="fas fa-lock-open text-primary me-2"></i>
            নতুন পাসওয়ার্ড সেট করুন
        </h2>

        {# ✅ Static messages from server #}
        {% if message %}
        <div class="alert alert-{{ message_type|default('info') }} alert-dismissible fade show" role="alert">
            {{ message|raw }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        {% endif %}

        {# ✅ SweetAlert messages #}
        {% if sweetAlert %}
        <div class="alert alert-{{ sweetAlert.type }} alert-dismissible fade show" role="alert">
            <strong>{{ sweetAlert.title }}:</strong> {{ sweetAlert.message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        {% endif %}

        {# ✅ Dynamic alert for AJAX responses #}
        <div id="dynamicAlert" class="alert d-none" role="alert"></div>

        <form id="resetPasswordForm" action="/new-password" method="POST" autocomplete="off" novalidate>
            {# ✅ CSRF token auto-injected by csrf.js #}
            
            <!-- Hidden token field - supports both field names -->
            <input type="hidden" name="token" value="{{ token }}">
            
            <!-- New Password Field -->
            <div class="mb-3">
                <label for="password" class="form-label fw-semibold">
                    <i class="fas fa-lock me-1"></i>
                    নতুন পাসওয়ার্ড
                </label>
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-primary">
                        <i class="fas fa-lock"></i>
                    </span>
                    <input class="form-control" 
                           type="password" 
                           id="password" 
                           name="password" 
                           placeholder="নতুন পাসওয়ার্ড লিখুন" 
                           required 
                           minlength="6">
                    <button class="btn btn-outline-secondary" 
                            type="button" 
                            id="togglePassword1"
                            title="পাসওয়ার্ড দেখান/লুকান">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <small class="text-muted">কমপক্ষে ৬ অক্ষর হতে হবে।</small>
            </div>

            <!-- Confirm Password Field -->
            <div class="mb-3">
                <label for="confirm_password" class="form-label fw-semibold">
                    <i class="fas fa-lock me-1"></i>
                    পাসওয়ার্ড নিশ্চিত করুন
                </label>
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-primary">
                        <i class="fas fa-lock"></i>
                    </span>
                    <input class="form-control" 
                           type="password" 
                           id="confirm_password" 
                           name="confirm_password" 
                           placeholder="পাসওয়ার্ড পুনরায় লিখুন" 
                           required 
                           minlength="6">
                    <button class="btn btn-outline-secondary" 
                            type="button" 
                            id="togglePassword2"
                            title="পাসওয়ার্ড দেখান/লুকান">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
            </div>

            <!-- Reset Button -->
            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold fs-5" id="submitBtn">
                <i class="fas fa-check me-2"></i> পাসওয়ার্ড পরিবর্তন করুন
            </button>
        </form>

        <!-- Back to Login Link -->
        <div class="text-center mt-4">
            <a href="/login" class="text-decoration-none text-muted small">
                <i class="fas fa-arrow-left me-1"></i>
                লগইন পৃষ্ঠায় ফিরুন
            </a>
        </div>

        <!-- Home Page Link -->
        <div class="text-center mt-3">
            <a href="/" class="btn btn-outline-primary btn-sm fw-semibold">
                <i class="fas fa-home me-1"></i> হোম পেজ
            </a>
        </div>
    </div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

{# ✅ SweetAlert2 #}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // ✅ Show static SweetAlert if needed
    {% if sweetAlert %}
    Swal.fire({
        icon: '{{ sweetAlert.type }}',
        title: '{{ sweetAlert.title }}',
        text: '{{ sweetAlert.message }}',
        confirmButtonText: 'ঠিক আছে',
        timer: 3000
    });
    {% endif %}

    // ✅ Password visibility toggle
    document.getElementById('togglePassword1')?.addEventListener('click', function() {
        const input = document.getElementById('password');
        const icon = this.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    });

    document.getElementById('togglePassword2')?.addEventListener('click', function() {
        const input = document.getElementById('confirm_password');
        const icon = this.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    });

    // ✅ Enhanced AJAX Form Handler
    document.getElementById('resetPasswordForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const form = this;
        const btn = document.getElementById('submitBtn');
        const alertBox = document.getElementById('dynamicAlert');
        const btnText = btn.innerHTML;
        
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirm_password').value;
        
        // Validate passwords match
        if (password !== confirmPassword) {
            alertBox.className = 'alert alert-warning';
            alertBox.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>পাসওয়ার্ড মিলছে না!';
            alertBox.classList.remove('d-none');
            return;
        }
        
        // Disable button and show loading
        btn.disabled = true;
        btn.classList.add('btn-loading');
        btn.innerHTML = '<span style="opacity: 0;">পাসওয়ার্ড পরিবর্তন করুন</span>';
        
        // Hide previous alerts
        alertBox.classList.add('d-none');
        
        try {
            const formData = new FormData(form);
            formData.append('return_json', '1');
            
            const response = await fetch('/new-password', {
                method: 'POST',
                body: formData
            });
            
            const data = await response.json();
            
            if (data.success) {
                // ✅ Success
                alertBox.className = 'alert alert-success';
                alertBox.innerHTML = '<i class="fas fa-check-circle me-2"></i>' + data.message;
                alertBox.classList.remove('d-none');
                
                // Redirect to login
                setTimeout(() => {
                    window.location.href = data.redirect || '/login';
                }, 1500);
            } else {
                // ✅ Error
                alertBox.className = 'alert alert-danger';
                alertBox.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i>' + data.message;
                alertBox.classList.remove('d-none');
                
                // Re-enable button
                btn.disabled = false;
                btn.classList.remove('btn-loading');
                btn.innerHTML = btnText;
            }
        } catch (error) {
            // ✅ Network error
            alertBox.className = 'alert alert-danger';
            alertBox.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>সংযোগ ত্রুটি। আবার চেষ্টা করুন।';
            alertBox.classList.remove('d-none');
            
            // Re-enable button
            btn.disabled = false;
            btn.classList.remove('btn-loading');
            btn.innerHTML = btnText;
            
            console.error('Form error:', error);
        }
    });

    // ✅ Auto-hide alerts after 5 seconds
    setTimeout(() => {
        const alerts = document.querySelectorAll('.alert:not(#dynamicAlert)');
        alerts.forEach(alert => {
            if (alert.classList.contains('show')) {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }
        });
    }, 5000);

    // ✅ Enter key submits form
    document.getElementById('confirm_password').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            document.getElementById('resetPasswordForm').dispatchEvent(new Event('submit'));
        }
    });
</script>

</body>
</html>


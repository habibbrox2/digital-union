<!DOCTYPE html>
<html lang="bn">
<head>
    <!-- Basic Page Info -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <title>{{ title|default('স্মার্ট ইউনিয়ন পরিষদ অ্যাডমিন') }}</title>

    {# ✅ CSRF Token Meta Tags #}
    <meta name="csrf_token" content="{{ csrf_token }}">
    <meta name="path" content="{{ url|default('') }}">

    {# ✅ CSRF JS - Load Early #}
    <script src="{{ url }}/assets/js/csrf.js?t={{ "now"|date("Hiss") }}"></script>

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <!-- Site favicon -->
    <link rel="shortcut icon" href="{{ url }}/assets/images/favicon.png">

    <!-- Login Shared Styles -->
    <link rel="stylesheet" href="{{ url }}/assets/css/login.css">
</head>
<body>

<div class="login-dark">
    <form id="passwordResetForm" method="POST" action="/password-reset" autocomplete="off" novalidate>

        {# ✅ CSRF token auto-injected by csrf.js #}

        {# ✅ Logo #}
        <div class="illustration">
            <img src="{{ url }}/assets/images/login_logo.png" alt="Smart Union Logo" width="40%" height="auto">
        </div>

        {# ✅ Static messages from server #}
        {% if message %}
        <div class="alert alert-{{ message_type|default('info') }}" role="alert">
            {{ message|raw }}
        </div>
        {% endif %}

        {# ✅ SweetAlert messages #}
        {% if sweetAlert %}
        <div class="alert alert-{{ sweetAlert.type }}" role="alert">
            <strong>{{ sweetAlert.title }}:</strong> {{ sweetAlert.message }}
        </div>
        {% endif %}

        {# ✅ Dynamic alert for AJAX responses #}
        <div id="dynamicAlert" class="d-none" role="alert"></div>

        {# ✅ Email Field #}
        <div class="form-group">
            <label for="email" class="form-label">
                <i class="fas fa-envelope me-1"></i>
                আপনার ইমেইল
            </label>
            <input class="form-control"
                   type="email"
                   id="email"
                   name="email"
                   placeholder="আপনার ইমেইল প্রদান করুন"
                   required
                   autocomplete="email">
            <small class="form-text">আমরা এই ইমেইলে রিসেট লিংক পাঠাব।</small>
        </div>

        {# ✅ Submit Button #}
        <button type="submit" class="btn-primary" id="submitBtn">
            <i class="fas fa-paper-plane me-2"></i> রিসেট লিংক পাঠান
        </button>

        {# ✅ Back to Login Link #}
        <a href="/login" class="back-link">
            <i class="fas fa-arrow-left me-1"></i>
            লগইন পৃষ্ঠায় ফিরুন
        </a>

        {# ✅ Home Page Link #}
        <a href="/" class="home-link">
            <i class="fas fa-home me-1"></i> হোম পেজ
        </a>
    </form>
</div>

{# ✅ SweetAlert2 #}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // ✅ Show static SweetAlert if needed
    {% if sweetAlert %}
    Swal.fire({
        icon: '{{ sweetAlert.type }}',
        title: '{{ sweetAlert.title }}',
        text: '{{ sweetAlert.message }}',
        confirmButtonText: 'ঠিক আছে',
        timer: 3000
    });
    {% endif %}

    // ✅ Enhanced AJAX Form Handler
    document.getElementById('passwordResetForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const form = this;
        const btn = document.getElementById('submitBtn');
        const alertBox = document.getElementById('dynamicAlert');

        const restoreBtn = btnLoading(btn, 'রিসেট লিংক পাঠান...');

        // Hide previous alerts
        alertBox.classList.add('d-none');
        alertBox.className = 'd-none';

        try {
            const formData = new FormData(form);
            formData.append('return_json', '1');

            const response = await fetch('/password-reset', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                // ✅ Success
                alertBox.className = 'alert alert-success';
                alertBox.innerHTML = '<i class="fas fa-check-circle me-2"></i>' + data.message;
                alertBox.classList.remove('d-none');

                // Clear form
                form.reset();

                // Re-enable button after delay
                setTimeout(() => {
                    restoreBtn();
                }, 2000);
            } else {
                // ✅ Error
                alertBox.className = 'alert alert-danger';
                alertBox.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i>' + data.message;
                alertBox.classList.remove('d-none');

                // Re-enable button
                restoreBtn();
            }
        } catch (error) {
            // ✅ Network error
            alertBox.className = 'alert alert-danger';
            alertBox.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>সংযোগ ত্রুটি। আবার চেষ্টা করুন।';
            alertBox.classList.remove('d-none');

            // Re-enable button
            restoreBtn();

            console.error('Form error:', error);
        }
    });

    // ✅ Enter key submits form
    document.getElementById('email').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            document.getElementById('passwordResetForm').dispatchEvent(new Event('submit'));
        }
    });
</script>

<script src="{{ url }}/assets/script.js?t={{ "now"|date("Hiss") }}"></script>
</body>
</html>

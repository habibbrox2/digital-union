<!-- SweetAlert2 JS -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
// ===============================
// Global Base URL
// ===============================
var BASE_URL     = 'https://lgdhaka.co';
var BASE_API_URL = 'https://lgdhaka.com';

jQuery(document).ready(function ($) {

    // ===============================
    // জেলা List (Script থেকে)
    // ===============================
    var districts = [
        {id:9,name:'কুমিল্লা'}, {id:10,name:'ফেনী'}, {id:11,name:'ব্রাহ্মণবাড়িয়া'}, {id:12,name:'রাঙ্গামাটি'},
        {id:13,name:'নোয়াখালী'}, {id:14,name:'চাঁদপুর'}, {id:15,name:'লক্ষ্মীপুর'}, {id:16,name:'চট্টগ্রাম'},
        {id:17,name:'কক্সবাজার'}, {id:19,name:'বান্দরবান'}, {id:20,name:'সিরাজগঞ্জ'}, {id:21,name:'পাবনা'},
        {id:22,name:'বগুড়া'}, {id:23,name:'রাজশাহী'}, {id:24,name:'নাটোর'}, {id:25,name:'জয়পুরহাট'},
        {id:26,name:'চাঁপাইনবাবগঞ্জ'}, {id:27,name:'নওগাঁ'}, {id:28,name:'যশোর'}, {id:29,name:'সাতক্ষীরা'},
        {id:30,name:'মেহেরপুর'}, {id:31,name:'নড়াইল'}, {id:32,name:'চুয়াডাঙ্গা'}, {id:33,name:'কুষ্টিয়া'},
        {id:34,name:'মাগুরা'}, {id:35,name:'খুলনা'}, {id:36,name:'বাগেরহাট'}, {id:37,name:'ঝিনাইদহ'},
        {id:38,name:'ঝালকাঠি'}, {id:39,name:'পটুয়াখালী'}, {id:40,name:'পিরোজপুর'}, {id:41,name:'বরিশাল'},
        {id:42,name:'ভোলা'}, {id:43,name:'বরগুনা'}, {id:44,name:'সিলেট'}, {id:45,name:'মৌলভীবাজার'},
        {id:46,name:'হবিগঞ্জ'}, {id:47,name:'সুনামগঞ্জ'}, {id:48,name:'নরসিংদী'}, {id:49,name:'গাজীপুর'},
        {id:50,name:'শরীয়তপুর'}, {id:51,name:'নারায়ণগঞ্জ'}, {id:52,name:'টাঙ্গাইল'}, {id:53,name:'কিশোরগঞ্জ'},
        {id:54,name:'মানিকগঞ্জ'}, {id:55,name:'ঢাকা'}, {id:56,name:'মুন্সিগঞ্জ'}, {id:57,name:'রাজবাড়ী'},
        {id:58,name:'মাদারীপুর'}, {id:59,name:'গোপালগঞ্জ'}, {id:60,name:'ফরিদপুর'}, {id:61,name:'পঞ্চগড়'},
        {id:62,name:'দিনাজপুর'}, {id:63,name:'লালমনিরহাট'}, {id:64,name:'নীলফামারী'}, {id:65,name:'গাইবান্ধা'},
        {id:66,name:'ঠাকুরগাঁও'}, {id:67,name:'রংপুর'}, {id:68,name:'কুড়িগ্রাম'}, {id:69,name:'শেরপুর'},
        {id:70,name:'ময়মনসিংহ'}, {id:71,name:'জামালপুর'}, {id:72,name:'নেত্রকোণা'}, {id:5114,name:'খাগড়াছড়ি'},
        {id:6366,name:'খাগড়াছড়ি'}, {id:6660,name:'তুরাগ'}
    ];

    // জেলা option যোগ করা
    let districtOptions = '';
    districts.forEach(function(d){
        let selected = (d.id == 55) ? 'selected' : '';
        districtOptions += `<option value="${d.id}" ${selected}>${d.name}</option>`;
    });
    $('#app_district_id').html(districtOptions);
    $('#app_district_id').prop('disabled', true);

    // ===============================
    // Load Upazila by District (on load)
    // ===============================
    let district_id = $('#app_district_id').val();
    if (district_id) {
        $.get(BASE_API_URL + '/geo/code/get', {id: district_id, type: 3}, function (data) {
            let option = "<option value=''>চিহ্নিত করুন</option>";
            data.upzilla.forEach(function (el) {
                option += `<option value="${el.id}">${el.bn_name}</option>`;
            });
            $('#app_upazila_id').html(option);
        });
    }

    // ===============================
    // Upazila → Union
    // ===============================
    $('#app_upazila_id').on('change', function () {
        let upazila_id = $(this).val();
        $('#union_id, #ward_id, #moholla').html("<option value=''>চিহ্নিত করুন</option>");
        if (!upazila_id) return;
        $.get(BASE_API_URL + '/geo/code/get_union', { id: upazila_id }, function (data) {
            let option = "<option value=''>চিহ্নিত করুন</option>";
            data.union.forEach(function (item) {
                option += `<option value="${item.union_code}">${item.bn_name}</option>`;
            });
            $('#union_id').html(option);
        });
    });

    // ===============================
    // Union → Ward
    // ===============================
    $('#union_id').on('change', function () {
        let union_id = $(this).val();
        $('#ward_id, #moholla').html("<option value=''>চিহ্নিত করুন</option>");
        if (!union_id) return;
        $.get(BASE_API_URL + '/geo/code/get_word_no', { id: union_id }, function (data) {
            let option = "<option value=''>চিহ্নিত করুন</option>";
            data.word.forEach(function (item) {
                option += `<option value="${item.ward_no}">${item.ward_no}</option>`;
            });
            $('#ward_id').html(option);
        });
    });

    // ===============================
    // Ward → Moholla
    // ===============================
    $('#ward_id').on('change', function () {
        let ward_id = $(this).val();
        let union_id = $('#union_id').val();
        $('#moholla').html("<option value=''>চিহ্নিত করুন</option>");
        if (!ward_id || !union_id) return;
        $.get(BASE_API_URL + '/geo/code/get_moholla', { id: ward_id, union_id: union_id }, function (data) {
            let option = "<option value=''>চিহ্নিত করুন</option>";
            data.moholla.forEach(function (item) {
                option += `<option value="${item.id}">${item.name}</option>`;
            });
            $('#moholla').html(option);
        });
    });

    // ===============================
    // Tax Verification Submit
    // ===============================
    $('#tax-verification-form').on('submit', function (e) {
        e.preventDefault();
        let formData = $(this).serialize();
        let btn = $(this).find('button[type=submit]');
        let output = $('#tax-verification-info');

        $.ajax({
            type: 'GET',
            url: BASE_API_URL + '/verify/get_verify_tax',
            data: formData,
            beforeSend: function () {
                btn.prop('disabled', true);
                output.html('');
            },
            success: function (res) {
                output.html(res);
            },
            complete: function () {
                btn.prop('disabled', false);
            },
            error: function () {
                alert('কিছু সমস্যা হয়েছে!');
            }
        });
    });

    // ===============================
    // Check Existing Application
    // ===============================
    let TypeApplication = ['nagorik', 'death', 'obibahito', 'punobibaho', 'ekoinam', 'sonaton', 'prottyon', 'nodibanga', 'character', 'vumihin', 'yearlyincome', 'protibondi', 'onumoti', 'voter', 'onapotti', 'rastakhonon', 'warish', 'family', 'trade', 'bibahito'];

    $('#search').on('click', function () {
        let searchData = $('#search-data').val();
        let applicationType = $('#appType').val();
        let Type = $('#type').val();

        if (!searchData || !applicationType || !Type) {
            Swal.fire({
                icon: 'error',
                title: 'দুঃখিত...',
                text: 'সব তথ্য পূরণ করুন!',
                confirmButtonText: 'ঠিক আছে'
            });
            return;
        }

        // Map numeric Type to string
        const postType = TypeApplication[parseInt(Type) - 1];

        // Payload
        const payload = { searchData, applicationType, type: postType, call_from: 'web' };

        // Handle AJAX response
        function handleResponse(res) {
            let info = '';
            if (res.data && res.data.sonod_no && parseInt(applicationType) === 2) {
                info = 'পিন নং : <b>' + res.data.pin + '</b> এবং সনদ নং <b>' + res.data.sonod_no + '</b>' +
                       '<br/><br/><a href="' + BASE_API_URL + '/verify/' + postType + '_bn/' + res.data.sonod_no + '/' + res.data.union_id + '/' + res.data.type + '" class="btn btn-info" target="_blank">সনদটি বাংলায় প্রিন্ট করুন</a>' +
                       '<br/><br/><a href="' + BASE_API_URL + '/verify/' + postType + '_en/' + res.data.sonod_no + '/' + res.data.union_id + '/' + res.data.type + '" class="btn btn-info" target="_blank">সনদটি ইংরেজিতে প্রিন্ট করুন</a>';
                showSweetAlert(res.status, info);

            } else if (res.data && res.data.tracking && parseInt(applicationType) === 1) {
                info = 'পিন নং : <b>' + res.data.pin + '</b> এবং ট্র্যাকিং নং <b>' + res.data.tracking + '</b>' +
                       '<br/><br/><a href="' + BASE_API_URL + '/verify/' + postType + '_application/' + res.data.tracking + '/' + res.data.union_id + '/' + res.data.type + '" class="btn btn-info" target="_blank">আবেদনটি প্রিন্ট করুন</a>';
                showSweetAlert('এই সনদ এর আবেদন ইতিঃপূর্বে করা হয়েছে!', info);

            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'দুঃখিত...',
                    text: res.message || 'দুঃখিত! আপনার আবেদনটি পাওয়া যায়নি।',
                    confirmButtonText: 'ঠিক আছে'
                });
            }
        }

        // ------------------------------
        // Main API call with CSRF support
        // ------------------------------
    $.ajax({
        type: 'POST',
        url: BASE_URL + '/api/check/existing/application',
        contentType: 'application/json',
        data: JSON.stringify({ searchData, applicationType, type: Type, call_from: 'web' }),
        success: function(res) {
            handleResponse(res);
        },
        error: function() {
            // ------------------------------
            // Fallback: proxy route
            // ------------------------------
            $.ajax({
                type: 'POST',
                url: BASE_URL + '/api2/check/existing/application',
                data: { searchData, applicationType, type: Type, call_from: 'web' },
                success: function(res) {
                    handleResponse(res);
                },
                error: function() {
                    Swal.fire({
                        icon: 'error',
                        title: 'দুঃখিত...',
                        text: 'দুঃখিত! সার্ভার উপলব্ধ নয়।',
                        confirmButtonText: 'ঠিক আছে'
                    });
                }
            });
        }
    });

        // SweetAlert helper
        function showSweetAlert(title, htmlContent) {
            Swal.fire({
                title: '<strong>' + title + '</strong>',
                icon: 'success',
                html: htmlContent,
                showConfirmButton: true,
                confirmButtonText: 'ঠিক আছে!'
            });
        }

    });

});
</script>





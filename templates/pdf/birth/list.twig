{% extends "layout.twig" %}

{% block title %}জন্ম নিবন্ধন তালিকা{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container my-5">
    <div class="d-flex align-items-center justify-content-center gap-2 mb-4">
        <span class="bt-title-badge"><i class="bi bi-baby"></i></span>
        <h2 class="mb-0 text-center bt-title fw-bold">জন্ম নিবন্ধন তালিকা</h2>
    </div>

    <div class="card shadow-lg rounded-4 border-0 bt-card">
        <div class="card-header bt-header text-white d-flex justify-content-between align-items-center py-3 rounded-top-4 flex-wrap">
            <h5 class="mb-2 mb-md-0"><i class="bi bi-list-columns-reverse me-2"></i> রেজিস্টার তালিকা</h5>
            <a href="{{ url }}/birth/form" class="btn btn-light btn-sm fw-bold d-flex align-items-center gap-1 bt-add-btn shadow-sm">
                <i class="bi bi-plus-circle-fill text-success"></i> নতুন এন্ট্রি
            </a>
        </div>

        <div class="card-body p-0">

            {# ================= Controls: Show Entries + Search ================= #}
            <div class="d-flex justify-content-between align-items-center p-3 flex-wrap gap-2 bg-light border-bottom bt-controls">
                <div class="d-flex align-items-center flex-wrap gap-2">
                    <span class="me-2 text-muted">Show</span>
                    <select id="entriesSelect" class="form-select form-select-sm d-inline-block w-auto shadow-sm bt-select">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                    <span class="ms-2 text-muted">entries</span>
                </div>
                <div class="flex-grow-1 flex-md-grow-0">
                    <div class="input-group input-group-sm shadow-sm bt-search">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search bt-search-icon"></i></span>
                        <input type="text" id="tableSearch" class="form-control border-start-0" placeholder="নাম, সনদ নাম্বার, অফিস বা ঠিকানা দিয়ে সার্চ করুন...">
                        <button class="btn btn-outline-secondary border-start-0 d-none bt-clear" type="button" id="searchClear" title="মুছুন"><i class="bi bi-x-lg"></i></button>
                    </div>
                </div>
            </div>

            {# ================= Desktop Table ================= #}
            <div class="table-responsive d-none d-md-block">
                <table id="birthTable" class="table table-hover table-striped mb-0 align-middle bt-table">
                    <thead class="text-center sticky-top bt-thead">
                        <tr>
                            <th style="width:14%">সনদ নাম্বার</th>
                            <th style="width:20%">নাম</th>
                            <th style="width:18%">পিতা/মাতার নাম</th>
                            <th style="width:12%">জন্ম তারিখ</th>
                            <th style="width:14%">অফিসের নাম</th>
                            <th style="width:14%">ঠিকানা</th>
                            <th style="width:8%">অ্যাকশন</th>
                        </tr>
                    </thead>
                    <tbody id="birthTableBody">
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> ডেটা লোড হচ্ছে...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            {# ================= Mobile Cards ================= #}
            <div id="birthCardContainer" class="d-md-none p-2"></div>

            {# ================= Pagination ================= #}
            <div class="d-flex justify-content-between align-items-center p-3 flex-wrap gap-2 border-top bg-light rounded-bottom-4">
                <div id="tableInfo" class="text-muted small"></div>
                <nav>
                    <ul id="tablePagination" class="pagination pagination-sm mb-0"></ul>
                </nav>
            </div>

        </div>
    </div>
</div>

{# ---------------- Delete Confirm Modal ---------------- #}
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-danger border-3 shadow-lg">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="deleteModalLabel">
            <i class="bi bi-exclamation-triangle-fill me-1"></i> ডিলিট নিশ্চিত করুন
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center">
        <i class="bi bi-trash-fill display-4 mb-3" style="color:#ff4d4d;"></i>
        <p class="fs-5 fw-semibold">আপনি কি নিশ্চিতভাবে এই রেকর্ডটি ডিলিট করতে চান?</p>
        <small class="text-muted">এই পদক্ষেপটি পূর্বাবস্থায় ফেরানো যাবে না।</small>
      </div>
      <div class="modal-footer justify-content-center">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            <i class="bi bi-x-circle me-1"></i> বাতিল
        </button>
        <a id="confirmDeleteBtn" href="#" class="btn btn-danger shadow-sm">
            <i class="bi bi-trash-fill me-1"></i> ডিলিট করুন
        </a>
      </div>
    </div>
  </div>
</div>

{# ================= Modern JS ================= #}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const tbody = document.getElementById('birthTableBody');
    const cardContainer = document.getElementById('birthCardContainer');
    const entriesSelect = document.getElementById('entriesSelect');
    const tableSearch = document.getElementById('tableSearch');
    const searchClear = document.getElementById('searchClear');
    const paginationContainer = document.getElementById('tablePagination');
    const tableInfo = document.getElementById('tableInfo');
    const BASE_URL = '{{ url|e('js') }}';

    let currentPage = 1;
    let entries = Number(entriesSelect.value);
    let allRows = [];

    const enToBnDigits = { '0':'০','1':'১','2':'২','3':'৩','4':'৪','5':'৫','6':'৬','7':'৭','8':'৮','9':'৯' };
    const formatDateToBnDDMMYYYY = dateString => {
        const d = new Date(dateString);
        const day = String(d.getDate()).padStart(2,'0');
        const month = String(d.getMonth()+1).padStart(2,'0');
        const year = String(d.getFullYear());
        const bn = str => str.split('').map(ch => enToBnDigits[ch]||ch).join('');
        return `${bn(day)}-${bn(month)}-${bn(year)}`;
    };

    const getInitial = name => (name && name.trim()) ? name.trim().charAt(0) : '?';

    const loadData = async () => {
        tbody.innerHTML = `<tr><td colspan="7" class="text-center text-primary py-4">
            <span class="spinner-border spinner-border-sm me-2" role="status"></span> ডেটা লোড হচ্ছে...
        </td></tr>`;
        cardContainer.innerHTML = `<div class="text-center text-primary py-4">
            <span class="spinner-border spinner-border-sm me-2" role="status"></span> ডেটা লোড হচ্ছে...
        </div>`;
        try {
            const res = await fetch(`${BASE_URL}/api/births`);
            const data = await res.json();
            allRows = data.map(b => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="text-center fw-semibold">${b.registration_number}</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="bt-avatar">${getInitial(b.name_bn)}</span>
                            <span class="fw-semibold">${b.name_bn}</span>
                        </div>
                    </td>
                    <td><span class="d-block text-primary"><i class="bi bi-person-fill me-1"></i>পিতা: ${b.father_name_bn}</span><span class="d-block text-success"><i class="bi bi-person-fill me-1"></i>মাতা: ${b.mother_name_bn}</span></td>
                    <td class="text-center"><span class="bt-date-pill">${formatDateToBnDDMMYYYY(b.birth_date)}</span></td>
                    <td><span class="bt-office-pill">${b.office_name_en || b.office_name_bn || 'N/A'}</span></td>
                    <td class="small"><span class="d-block text-info">জন্মস্থান: ${b.district_bn||'নাই'}, ${b.country_bn||'নাই'}</span><span class="d-block text-secondary">স্থায়ী ঠিকানা: ${b.permanent_address_bn||''}</span></td>
                    <td class="text-center">
                        <div class="d-flex flex-wrap gap-1 justify-content-center">
                            <a href="${BASE_URL}/birth/pdf/${b.id}" class="btn btn-sm btn-info text-white" title="PDF"><i class="bi bi-file-earmark-pdf-fill"></i></a>
                            <a href="${BASE_URL}/birth/edit/${b.id}" class="btn btn-sm btn-success" title="Edit"><i class="bi bi-pencil-square"></i></a>
                            <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal" data-id="${b.id}" title="Delete"><i class="bi bi-trash"></i></button>
                        </div>
                    </td>
                `;
                tr.dataset.id = b.id;
                tr.dataset.registration_number = b.registration_number;
                tr.dataset.name_bn = b.name_bn;
                tr.dataset.father_name_bn = b.father_name_bn;
                tr.dataset.mother_name_bn = b.mother_name_bn;
                tr.dataset.birth_date = b.birth_date;
                tr.dataset.office_name = b.office_name_en || b.office_name_bn || 'N/A';
                tr.dataset.address = `${b.district_bn||'নাই'}, ${b.country_bn||'নাই'} - ${b.permanent_address_bn||''}`;
                return tr;
            });

            renderTable();
        } catch(err) {
            tbody.innerHTML = `<tr><td colspan="7" class="text-center text-danger py-4"><i class="bi bi-x-octagon me-1"></i> ডেটা লোড করতে সমস্যা হয়েছে।</td></tr>`;
            cardContainer.innerHTML = `<div class="text-center text-danger py-4"><i class="bi bi-x-octagon me-1"></i> ডেটা লোড করতে সমস্যা হয়েছে।</div>`;
            console.error(err);
        }
    };

    const renderTable = () => {
        const query = tableSearch.value.trim().toLowerCase();
        const filtered = allRows.filter(r =>
            r.dataset.registration_number.toLowerCase().includes(query) ||
            r.dataset.name_bn.toLowerCase().includes(query) ||
            r.dataset.father_name_bn.toLowerCase().includes(query) ||
            r.dataset.mother_name_bn.toLowerCase().includes(query) ||
            r.dataset.office_name.toLowerCase().includes(query) ||
            r.dataset.address.toLowerCase().includes(query)
        );

        // Empty states (initial load vs. no search match)
        if (!filtered.length) {
            const icon = query ? 'bi-search' : 'bi-info-circle';
            const msg = query ? 'কোনো রেকর্ড মেলেনি।' : 'কোনো তথ্য নেই।';
            tbody.innerHTML = `<tr><td colspan="7" class="text-center text-muted py-4"><i class="bi ${icon} me-1"></i> ${msg}</td></tr>`;
            cardContainer.innerHTML = `<div class="text-center text-muted py-4"><i class="bi ${icon} me-1"></i> ${msg}</div>`;
            renderPagination(filtered);
            updateInfo(filtered);
            return;
        }

        const start = (currentPage-1)*entries;
        const end = start + entries;

        // Desktop table
        tbody.innerHTML = '';
        filtered.slice(start, end).forEach(r => tbody.appendChild(r));

        // Mobile cards
        cardContainer.innerHTML = '';
        filtered.slice(start, end).forEach(r => {
            const card = document.createElement('div');
            card.className = 'card mb-3 shadow-sm bt-mobile-card';
            card.innerHTML = `
                <div class="card-header bt-mobile-header fw-bold d-flex justify-content-between align-items-center">
                    <span class="d-flex align-items-center gap-2">
                        <span class="bt-avatar bt-avatar-sm">${getInitial(r.dataset.name_bn)}</span>
                        ${r.dataset.registration_number}
                    </span>
                    <div class="d-flex gap-1">
                        <a href="${BASE_URL}/birth/pdf/${r.dataset.id}" class="btn btn-sm btn-info text-white" title="PDF"><i class="bi bi-file-earmark-pdf-fill"></i></a>
                        <a href="${BASE_URL}/birth/edit/${r.dataset.id}" class="btn btn-sm btn-success" title="Edit"><i class="bi bi-pencil-square"></i></a>
                        <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal" data-id="${r.dataset.id}"><i class="bi bi-trash"></i></button>
                    </div>
                </div>
                <div class="card-body p-2">
                    <p class="mb-1"><strong>নাম:</strong> ${r.dataset.name_bn}</p>
                    <p class="mb-1"><strong>পিতা:</strong> ${r.dataset.father_name_bn}</p>
                    <p class="mb-1"><strong>মাতা:</strong> ${r.dataset.mother_name_bn}</p>
                    <p class="mb-1"><strong>জন্ম তারিখ:</strong> ${formatDateToBnDDMMYYYY(r.dataset.birth_date)}</p>
                    <p class="mb-1"><strong>অফিস:</strong> ${r.dataset.office_name}</p>
                    <p class="mb-0"><strong>ঠিকানা:</strong> ${r.dataset.address}</p>
                </div>
            `;
            cardContainer.appendChild(card);
        });

        renderPagination(filtered);
        updateInfo(filtered);
    };

    const renderPagination = (rows) => {
        paginationContainer.innerHTML = '';
        const pageCount = Math.max(1, Math.ceil(rows.length/entries));
        if (currentPage > pageCount) currentPage = pageCount;
        const createPageItem = (label, page, disabled=false, active=false) => {
            const li = document.createElement('li');
            li.className = `page-item ${disabled?'disabled':''} ${active?'active':''}`;
            li.innerHTML = `<a class="page-link" href="#">${label}</a>`;
            if(!disabled) li.addEventListener('click', e => { e.preventDefault(); currentPage=page; renderTable(); });
            return li;
        };

        paginationContainer.appendChild(createPageItem('«', currentPage-1, currentPage===1));
        for(let i=1;i<=pageCount;i++) paginationContainer.appendChild(createPageItem(i, i, false, i===currentPage));
        paginationContainer.appendChild(createPageItem('»', currentPage+1, currentPage===pageCount));
    };

    const updateInfo = (rows) => {
        const start = rows.length? (currentPage-1)*entries+1 : 0;
        const end = Math.min(currentPage*entries, rows.length);
        tableInfo.textContent = `Showing ${start} to ${end} of ${rows.length} entries`;
    };

    entriesSelect.addEventListener('change', () => { entries = Number(entriesSelect.value); currentPage=1; renderTable(); });
    tableSearch.addEventListener('input', () => {
        searchClear.classList.toggle('d-none', !tableSearch.value);
        currentPage=1; renderTable();
    });
    searchClear.addEventListener('click', () => {
        tableSearch.value=''; searchClear.classList.add('d-none');
        currentPage=1; renderTable(); tableSearch.focus();
    });

    // Delete Modal
    const deleteModal = document.getElementById('deleteModal');
    const confirmBtn = document.getElementById('confirmDeleteBtn');
    deleteModal.addEventListener('show.bs.modal', e => {
        confirmBtn.href = `${BASE_URL}/birth/delete/` + e.relatedTarget.getAttribute('data-id');
    });

    loadData();
});
</script>

{# ================= Modern CSS ================= #}
<style>
:root{
    --bt-primary: #008B8B;
    --bt-primary-dark: #006d6d;
    --bt-primary-light: #e3f4f4;
    --bt-gradient: linear-gradient(135deg, #008B8B 0%, #00b3b3 100%);
}

.bt-card.rounded-4 { border-radius: 1.25rem !important; }
.bt-title { color: var(--bt-primary-dark); letter-spacing: 0.01rem; }
.bt-title-badge{
    display:inline-flex; align-items:center; justify-content:center;
    width:46px; height:46px; border-radius:50%;
    background: var(--bt-gradient); color:#fff; font-size:1.35rem;
    box-shadow: 0 6px 16px rgba(0,139,139,0.35);
}
.bt-header{ background: var(--bt-gradient); border-bottom:none; }
.bt-add-btn{ transition: transform .15s ease, box-shadow .15s ease; }
.bt-add-btn:hover{ transform: translateY(-1px); box-shadow: 0 6px 14px rgba(0,0,0,.18); }

.bt-controls{ background: #f6f9fa !important; }

.bt-select, .bt-search .form-control, .bt-search .input-group-text{ border-radius: 0.5rem; }
.bt-search .form-control{ border-top-left-radius:0; border-bottom-left-radius:0; }
.bt-search .input-group-text{ border-top-right-radius:0; border-bottom-right-radius:0; }
.bt-search-icon{ color: var(--bt-primary); }
.bt-search:focus-within{ box-shadow: 0 0 0 .2rem rgba(0,139,139,.15); }

.bt-table thead th{
    border-bottom: none;
    letter-spacing: 0.03rem;
    font-weight: 600;
    font-size: 0.82rem;
    background-color: var(--bt-primary);
    color: #fff;
    white-space: nowrap;
}
.bt-thead.sticky-top{ top: 0; z-index: 2; }
.bt-table tbody tr td{ font-size: 0.9rem; padding: 12px 10px; vertical-align: middle; }
.bt-table.table-striped tbody tr:nth-of-type(odd){ background-color: #f7fbfb; }
.bt-table.table-hover tbody tr:hover{ background-color: var(--bt-primary-light) !important; }

.bt-avatar{
    display:inline-flex; align-items:center; justify-content:center;
    width:34px; height:34px; flex:0 0 34px; border-radius:50%;
    background: var(--bt-gradient); color:#fff; font-weight:700; font-size:1rem;
    box-shadow: 0 2px 6px rgba(0,139,139,.3);
}
.bt-avatar-sm{ width:26px; height:26px; flex-basis:26px; font-size:.8rem; }

.bt-date-pill{
    display:inline-block; padding:.2rem .55rem; border-radius:999px;
    background: var(--bt-primary-light); color: var(--bt-primary-dark);
    font-weight:600; font-size:.82rem;
}
.bt-office-pill{
    display:inline-block; padding:.15rem .5rem; border-radius:.4rem;
    background:#eef2f4; color:#37474f; font-size:.82rem;
}

.pagination .page-item .page-link{
    padding: 0.3rem 0.75rem; margin: 0 0.2rem; border-radius: 0.4rem;
    transition: background 0.2s ease; color: var(--bt-primary);
}
.pagination .page-item.active .page-link{ background-color: var(--bt-primary); border-color: var(--bt-primary); color:#fff; }
.pagination .page-item.active .page-link:hover{ background-color: var(--bt-primary-dark); border-color: var(--bt-primary-dark); }
.pagination .page-link:hover{ background-color: var(--bt-primary-light); }

.bt-mobile-header{ background: var(--bt-gradient); color:#fff; }
.bt-mobile-card{ border-radius:.9rem; border:1px solid #e3e9ec; }

@media (max-width: 768px){
    #birthTable{ display:none; }
    .card{ font-size:0.9rem; }
}
</style>
{% endblock %}

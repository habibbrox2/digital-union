                            <div class="col-md-4">
                                <label for="mother_name_bn" class="form-label">মাতার নাম (Bengali) <span class="text-danger">*</span></label>
                                <input type="text" id="mother_name_bn" name="mother_name_bn" class="form-control" placeholder="বাংলায় নাম লিখুন" required
                                    value="{{ birth.mother_name_bn ?? '' }}">
                                <div class="invalid-feedback">মাতার নাম দিন।</div>
                            </div>
                            <div class="col-md-4">
                                <label for="mother_name_en" class="form-label">Mother's Name (EN) <span class="text-danger">*</span></label>
                                <input type="text" id="mother_name_en" name="mother_name_en" class="form-control" placeholder="Enter mother's name in English" required
                                    value="{{ birth.mother_name_en ?? '' }}">
                                <div class="invalid-feedback">Mother's name required.</div>
                            </div>
                            <div class="col-md-4">
                                <label for="mother_nationality_en" class="form-label">Mother's Nationality</label>
                                <input type="text" id="mother_nationality_en" name="mother_nationality_en" class="form-control" placeholder="Bangladeshi"
                                    value="{{ birth.mother_nationality_en ?? 'Bangladeshi' }}">
                                <input type="hidden" id="mother_nationality_bn" name="mother_nationality_bn" value="{{ birth.mother_nationality_bn ?? 'বাংলাদেশী' }}">
                            </div>
                        </div>
                    </div>
                </div>

{# ================= Office of the Registrar ================= #}
<div class="card shadow-sm mb-4 rounded-4 border-0">
    <div class="card-header bg-secondary text-white">
        <i class="bi bi-building-check me-2"></i> Office of the Registrar
    </div>
    <div class="card-body">
        <div class="row g-3">

            <!-- District -->
            <div class="col-md-4">
                <label for="district_office_en" class="form-label">District (Registrar Office) <span class="text-danger">*</span></label>
                <select id="district_office_en" name="district_office_en" class="form-select" required>
                    <option value="">চিহ্নিত করুন</option>
                    {% for d in districts %}
                    <option value="{{ d.name_en|default('')|trim }}" 
                            data-geo-id="{{ d.id }}" 
                            data-name-bn="{{ d.name_bn|default('')|trim }}"
                            {% if birth.district_office_en|default('')|trim == d.name_en|trim %}selected{% endif %}>
                        {{ d.name_en }} / {{ d.name_bn }}
                    </option>
                    {% endfor %}
                </select>
                <input type="hidden" id="district_office_bn" name="district_office_bn" value="{{ birth.district_office_bn|default('')|trim }}">
                <div class="invalid-feedback">Select district.</div>
            </div>

            <!-- Upazila -->
            <div class="col-md-4">
                <label for="upazila_office_en" class="form-label">Upazila (Registrar Office) <span class="text-danger">*</span></label>
                <select id="upazila_office_en" name="upazila_office_en" class="form-select" required>
                    <option value="">চিহ্নিত করুন</option>
                    {% for u in upazilas %}
                    <option value="{{ u.name_en|default('')|trim }}" 
                            data-geo-id="{{ u.id }}" 
                            data-name-bn="{{ u.name_bn|default('')|trim }}"
                            {% if birth.upazila_office_en|default('')|trim == u.name_en|trim %}selected{% endif %}>
                        {{ u.name_en }} / {{ u.name_bn }}
                    </option>
                    {% endfor %}
                </select>
                <input type="hidden" id="upazila_office_bn" name="upazila_office_bn" value="{{ birth.upazila_office_bn|default('')|trim }}">
                <div class="invalid-feedback">Select upazila.</div>
            </div>

            <!-- Union -->
            <div class="col-md-4">
                <label for="union_office_en" class="form-label">Union (Registrar Office)</label>
                <select id="union_office_en" name="union_office_en" class="form-select">
                    <option value="">চিহ্নিত করুন</option>
                    {% for u in unions %}
                    <option value="{{ u.name_en|default('')|trim }}" 
                            data-geo-id="{{ u.id }}" 
                            data-name-bn="{{ u.name_bn|default('')|trim }}"
                            {% if birth.union_office_en|default('')|trim == u.name_en|trim %}selected{% endif %}>
                        {{ u.name_en }} / {{ u.name_bn }}
                    </option>
                    {% endfor %}
                </select>
                <input type="hidden" id="union_office_bn" name="union_office_bn" value="{{ birth.union_office_bn|default('')|trim }}">
            </div>

        </div>

        <div class="row g-3">
            <!-- Office Name (EN) -->
            <div class="col-md-6">
                <label for="office_name_en" class="form-label">Office Name (EN) <span class="text-danger">*</span></label>
                <input type="text" id="office_name_en" name="office_name_en" class="form-control" placeholder="Office name in English" required
                    value="{{ birth.office_name_en|default('')|trim }}">
                <div class="invalid-feedback">Enter office name in English.</div>
            </div>

            <!-- Office Name (BN) -->
            <div class="col-md-6">
                <label for="office_name_bn" class="form-label">Union / Office Name (BN)</label>
                <input type="text" id="office_name_bn" name="office_name_bn" class="form-control" placeholder="উপজেলার অফিসের নাম বাংলায়"
                    value="{{ birth.office_name_bn|default('')|trim }}">
                <div class="invalid-feedback">Enter union/office name in Bangla.</div>
            </div>
        </div>
    </div>
</div>

{# ================= Place of Birth Info ================= #}

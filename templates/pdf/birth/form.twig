                    <option value="India" {% if birth.country_en|default('')|trim == 'India' %}selected{% endif %}>India</option>
                    <option value="Pakistan" {% if birth.country_en|default('')|trim == 'Pakistan' %}selected{% endif %}>Pakistan</option>

{# /birth/form.twig  #}
{% extends "layout.twig" %}

{% block title %} জন্ম নিবন্ধন{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container my-5">
    <h1 class="mb-4 text-center">{{ header_title ?? (birth.id ? 'জন্ম নিবন্ধন (সম্পাদনা)' : 'নতুন জন্ম নিবন্ধন') }}</h1>

    <a href="/birth" class="btn btn-secondary text-end mb-3">
        <i class="bi bi-arrow-left"></i> ফিরে যান / Back to List
    </a>


{% if birth.id is not defined %}
<!-- ================= UBRN Verification Form ================= -->
<div class="card shadow-sm mb-4 rounded-4 border-0">
    <div class="card-header bg-primary text-white d-flex align-items-center">
        <i class="bi bi-qr-code-scan me-2"></i>
        <span>UBRN Verification</span>
    </div>
    <div class="card-body">
        <form id="frm" autocomplete="on">
            <input type="hidden" id="local_csrf" name="local_csrf" value="">
            <input type="hidden" id="server_token" name="server_token" value="">
            <input type="hidden" id="captcha_de_text" name="captcha_de_text" value="">

            <div class="row g-3">

                <!-- UBRN -->
                <div class="col-md-6">
                    <label for="ubrn" class="form-label">জন্ম নিবন্ধন নম্বর <span class="text-danger">*</span></label>
                    <input id="ubrn" name="ubrn" type="text" class="form-control" placeholder="20002611471127204" required>
                </div>

                <!-- Birth Date -->
                <div class="col-md-6">
                    <label for="birthdate" class="form-label">জন্ম তারিখ <span class="text-danger">*</span></label>
                    <input id="birthdate" name="birthdate" type="text" class="form-control datepicker" placeholder="DD-MM-YYYY" required>
                </div>

                <!-- Captcha -->
                <div class="col-md-6">
                    <label class="form-label">Captcha <span class="text-danger">*</span></label>
                    <div class="d-flex align-items-center gap-2 mb-2" id="captchaBlock">
                        <img src="" alt="captcha" class="border rounded p-1" id="captchaImg">
                        <button id="refreshBtn" type="button" class="btn btn-outline-secondary btn-sm" title="Refresh Captcha">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                    <input id="captchaInput" name="captcha" type="text" class="form-control" placeholder="Type text from image" required>
                </div>

                <!-- Verify Button -->
                <div class="col-md-6 d-flex align-items-end">
                    <button id="verifyBtn" type="submit" class="btn btn-success w-100">
                        <i class="bi bi-check-circle me-1"></i> Verify
                    </button>
                </div>

            </div>
        </form>

        <!-- Status -->
        <div id="alertBox" class="mt-3 text-info"></div>
    </div>
</div>





<!-- ===================== Custom Styles ===================== -->
<style>
    #captchaBlock img {
        width: 280px;      /* fixed width */
        height: 60px;      /* fixed height */
        object-fit: contain; /* maintain aspect ratio */
        border: 1px solid #ced4da;
        border-radius: 5px;
        background: #f8f9fa;
    }

    #captchaBlock button {
        height: 38px;      /* match input height */
    }

    @media (max-width: 576px) {
        #captchaBlock {
            flex-direction: column;
            align-items: flex-start;
        }
        #captchaBlock img, #captchaBlock button {
            width: 100%;
        }
    }
</style>
{% endif %}


	








<!-- ================= Main Birth Form ================= -->

        <form id="birthForm" action="/birth/save" method="post" class="needs-validation" novalidate>
            <input type="hidden" name="id" value="{{ birth.id ?? '' }}">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <div id="formAlert" class="mb-3">
                {% if alert %}
                    <div class="alert alert-{{ alert.type }} alert-dismissible fade show" role="alert">
                        {{ alert.message|raw }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endif %}
            </div>
	<div class="card shadow-sm mb-4 rounded-4 border-0">
	    <div class="card-header bg-success text-white">
	        <i class="bi bi-journal-check me-2"></i> Birth Registration
	    </div>
	    <div class="card-body">
	            <div class="row g-3">
	                <div class="col-md-4">
	                    <label for="registration_number" class="form-label">Birth Registration Number <span class="text-danger">*</span></label>
	                    <input type="text" id="registration_number" name="registration_number" class="form-control"
	                           placeholder="20250000000000001" pattern="\d{17}" maxlength="17" required
	                           value="{{ birth.registration_number ?? '' }}">
	                    <div class="invalid-feedback">১৭ ডিজিটের রেজিস্ট্রেশন নম্বর দিন।</div>
	                </div>
	
	                <div class="col-md-4">
	                    <label for="date_of_registration" class="form-label">Date of Registration <span class="text-danger">*</span></label>
	                    <input type="text" id="date_of_registration" name="date_of_registration" class="form-control datepicker"
	                           placeholder="DD-MM-YYYY" required value="{{ birth.date_of_registration ? birth.date_of_registration|date('d-m-Y') : '' }}">
	                    <div class="invalid-feedback">নিবন্ধনের তারিখ দিন।</div>
	                </div>
	
	                <div class="col-md-4">
	                    <label for="date_of_issuance" class="form-label">Date of Issuance <span class="text-danger">*</span></label>
	                    <input type="text" id="date_of_issuance" name="date_of_issuance" class="form-control datepicker"
	                           placeholder="DD-MM-YYYY" required value="{{ birth.date_of_issuance ? birth.date_of_issuance|date('d-m-Y') : '' }}">
	                </div>
	            </div>
	        </div>
            </div>
		
		{# ================= Personal Info ================= #}
		<div class="card shadow-sm mb-4 rounded-4 border-0">
		    <div class="card-header bg-success text-white">
		        <i class="bi bi-person-fill me-2"></i> Personal Information
		    </div>
		    <div class="card-body">
		        <div class="row g-3">
		            <div class="col-md-6">
		                <label for="name_bn" class="form-label">নাম (Bengali) <span class="text-danger">*</span></label>
		                <input type="text" id="name_bn" name="name_bn" class="form-control" placeholder="বাংলায় নাম লিখুন" required
		                    value="{{ birth.name_bn ?? '' }}">
		                <div class="invalid-feedback">নাম লিখুন।</div>
		            </div>
		            <div class="col-md-6">
		                <label for="name_en" class="form-label">Name (English) <span class="text-danger">*</span></label>
		                <input type="text" id="name_en" name="name_en" class="form-control" placeholder="Enter name in English" required
		                    value="{{ birth.name_en ?? '' }}">
		                <div class="invalid-feedback">Name in English is required.</div>
		            </div>
		              <div class="col-md-6">
		                <label for="birth_date" class="form-label">Date of Birth <span class="text-danger">*</span></label>
		                <input type="text" id="birth_date" name="birth_date" class="form-control datepicker" placeholder="DD-MM-YYYY" required
		                    value="{{ birth.birth_date ? birth.birth_date|date('d-m-Y') : '' }}">
		                <div class="invalid-feedback">Enter birth date.</div>
		            </div>
		            <div class="col-md-6">
		                <label for="sex" class="form-label">Sex <span class="text-danger">*</span></label>
		                <select id="sex" name="sex" class="form-select" required>
		                    <option value="">Select</option>
		                    <option value="male" {% if birth.sex == 'male' %}selected{% endif %}>Male</option>
		                    <option value="female" {% if birth.sex == 'female' %}selected{% endif %}>Female</option>
		                    <option value="other" {% if birth.sex == 'other' %}selected{% endif %}>Other</option>
		                </select>
		                <div class="invalid-feedback">Select gender.</div>
		            </div>
		
		        </div>
		    </div>
		</div>


                {# ================= Parents Info ================= #}

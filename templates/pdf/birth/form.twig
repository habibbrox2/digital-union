            if (keyInput && linkInput && keyInput.value.trim() === "" && linkInput.value.trim() === "") {
                const r = qrList[Math.floor(Math.random() * qrList.length)];
                keyInput.value = r.label;
                linkInput.value = r.url;
            }
        });
    }
    const countryMap = {
        'Bangladesh':'বাংলাদেশ',
        'India':'ভারত',
        'Pakistan':'পাকিস্তান',

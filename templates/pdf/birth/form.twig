                    <option value="">চিহ্নিত করুন</option>
                    {% for d in districts %}
                    <option value="{{ d.name_en|default('')|trim }}" 
                            data-geo-id="{{ d.id }}" 
                            data-name-bn="{{ d.name_bn|default('')|trim }}"
                            {% if birth.district_en|default('')|trim == d.name_en|trim %}selected{% endif %}>
                        {{ d.name_en }} / {{ d.name_bn }}
                    </option>
                    {% endfor %}
                </select>
                <input type="hidden" id="district_bn" name="district_bn" value="{{ birth.district_bn|default('')|trim }}">
                <div class="invalid-feedback">Select district.</div>

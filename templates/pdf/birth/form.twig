                {# ================= QR Verification Section ================= #}
                <div class="card shadow-sm mb-4 rounded-4 border-0">
                    <div class="card-header bg-dark text-white">
                        <i class="bi bi-qr-code-scan me-2"></i> QR Verification (Optional)
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="verify_key" class="form-label">Verify Key</label>
                                <input type="text" id="verify_key" name="verify_key" class="form-control" placeholder="Enter verify key (optional)"
                                    value="{{ birth.verify_key ?? '' }}">
                            </div>
                            <div class="col-md-6">
                                <label for="verify_link" class="form-label">Verify Link</label>
                                <input type="text" id="verify_link" name="verify_link" class="form-control" placeholder="https://example.com/verify (optional)"
                                    value="{{ birth.verify_link ?? '' }}">
                            </div>
                        </div>
                    </div>
                </div>
            
            <div class="d-flex justify-content-end align-items-center mt-4">
                <button type="submit" id="saveBtn" class="btn btn-success px-4">
                    <i class="bi bi-save me-1"></i> {{ birth.id ? 'Update & Generate PDF' : 'Save & Generate PDF' }}
                </button>
                <div id="formLoader" class="spinner-border text-success ms-3 d-none" role="status"></div>
            </div>
        </form>





</div>


<script>
(async function(){
  const frm = document.getElementById('frm');
  const birthForm = document.getElementById('birthForm');
  const captchaImg = document.querySelector('#captchaBlock img');
  const ub = document.getElementById('ubrn');
  const bd = document.getElementById('birthdate');
  const capIn = document.getElementById('captchaInput');
  const verifyBtn = document.getElementById('verifyBtn');
  const refreshBtn = document.getElementById('refreshBtn');
  const serverTokenField = document.getElementById('server_token');
  const captchaDeField = document.getElementById('captcha_de_text');
  const alertBox = document.getElementById('alertBox');

  // ===================== Helpers =====================
  function getLocalCsrf() {
    const el = document.getElementById('local_csrf');
    return el ? el.value : '';
  }

  function formatDateToDDMMYYYY(dateStr) {
    if(!dateStr) return '';
    const [year, month, day] = dateStr.split('-');
    return `${day}-${month}-${year}`;
  }

  function showAlert(message, type='danger') {
    if(!alertBox) return;
    alertBox.innerHTML = `<div class="alert alert-${type}" role="alert">${message}</div>`;
  }

  function clearAlert() {
    if(alertBox) alertBox.innerHTML = '';
  }

  // ===================== CAPTCHA INIT =====================
  async function initCaptcha() {
    try {
      const res = await fetch('/birth/bdris/init');
      const j = await res.json();
      if (!j.ok) return showAlert('⚠️ Captcha লোড করা যায়নি।');

      serverTokenField.value = j.token || '';
      captchaDeField.value = j.captcha_de_text || '';
      if(captchaImg) captchaImg.src = j.captcha_data_uri || '';
      if(!ub.value) ub.value = '';
      if(!bd.value) bd.value = '';
      capIn.value = '';
      clearAlert();
    } catch(err) {
      console.error('Network error:', err);
      showAlert('⚠️ নেটওয়ার্ক ত্রুটি ঘটেছে।');
    }
  }

  // ===================== PREFILL =====================
  function prefillForm(data) {
    if(!data) return;
    const setVal = (id, val) => { const el = document.getElementById(id); if(el) el.value = val || ''; };

    setVal('registration_number', data.birth_registration_number_en);
    setVal('date_of_registration', formatDateToDDMMYYYY(data.registration_date_en));
    setVal('date_of_issuance', formatDateToDDMMYYYY(data.issuance_date_en));
    setVal('birth_date', formatDateToDDMMYYYY(data.date_of_birth_en));
    setVal('name_en', data.name_en);
    setVal('name_bn', data.name_bn);
    setVal('sex', data.sex_en?.toLowerCase());
    setVal('father_name_en', data.father_name_en);
    setVal('father_name_bn', data.father_name_bn);
    setVal('mother_name_en', data.mother_name_en);
    setVal('mother_name_bn', data.mother_name_bn);
    setVal('office_name_en', data.registration_office_en);
    setVal('office_name_bn', data.registration_office_bn);

    // Cascade prefill
    if(window.birthCascade) window.birthCascade.prefillCascade(data.place_of_birth_en);
    if(window.officeCascade) window.officeCascade.prefillCascade(data.district_en, data.upazila_en, data.union_en);

    // ✅ Enable Bootstrap validation after successful prefill
    if (birthForm) {
      birthForm.classList.add('needs-validation');
      birthForm.setAttribute('novalidate', 'novalidate');

      // Run validation check for all prefilled inputs
      const inputs = birthForm.querySelectorAll('input, select, textarea');
      let allValid = true;
      inputs.forEach(input => {
        if (!input.checkValidity()) allValid = false;
      });

      // Visual feedback
      birthForm.classList.add('was-validated');

      if (!allValid) {
        showAlert('⚠️ কিছু প্রিফিল্ড ফিল্ডে ত্রুটি আছে, অনুগ্রহ করে যাচাই করুন।', 'warning');
      } else {
        showAlert('✅ ফিল্ডগুলি সফলভাবে প্রিফিল হয়েছে এবং যাচাই সম্পন্ন।', 'success');
      }
    }
  }

  // ===================== FORM SUBMIT =====================
  frm.addEventListener('submit', async e => {
    e.preventDefault();
    clearAlert();

    verifyBtn.disabled = true;
    verifyBtn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i> যাচাই করা হচ্ছে...';

    try {
      const payload = new FormData();
      payload.append('ubrn', ub.value.trim());
      payload.append('birthdate', bd.value.trim());
      payload.append('captcha', capIn.value.trim());
      payload.append('server_token', serverTokenField.value);
      payload.append('captcha_de_text', captchaDeField.value);
      payload.append('local_csrf', getLocalCsrf());

      const r = await fetch('/birth/bdris/submit', { method: 'POST', body: payload });
      const j = await r.json();

      if (j.ok) {
        prefillForm(j.data);
      } else {
        showAlert(j.message || '⚠️ BDRIS থেকে তথ্য পাওয়া যায়নি।');
      }

    } catch(err) {
      console.error('Network error:', err);
      showAlert('⚠️ নেটওয়ার্ক ত্রুটি ঘটেছে।');
    } finally {
      verifyBtn.disabled = false;
      verifyBtn.innerHTML = '<i class="bi bi-check-circle me-1"></i> যাচাই';
    }
  });

  refreshBtn.addEventListener('click', initCaptcha);
  initCaptcha();

})();
</script>



        'pakistani':'পাকিস্তানি',
        'nepalese':'নেপালি'
    };
    function syncNationality(enId, bnId) {
        const en = document.getElementById(enId), bn = document.getElementById(bnId);
        if (!en) return;
        if (!en.value.trim()) en.value = 'Bangladeshi';
        if (bn) bn.value = nationalityMap[en.value.trim().toLowerCase()] || 'বাংলাদেশী';
        en.addEventListener('input', () => {
            if (bn) bn.value = nationalityMap[en.value.trim().toLowerCase()] || '';
        });
    }
    syncNationality('father_nationality_en', 'father_nationality_bn');
    syncNationality('mother_nationality_en', 'mother_nationality_bn');

    // AJAX save (only works if form already validated)
    const loader = document.getElementById('formLoader');
    if (birthForm) {
        birthForm.setAttribute('autocomplete','on');
        birthForm.addEventListener('submit', async (e) => {
            if (!birthForm.classList.contains('needs-validation')) return; // wait until prefill
            e.preventDefault(); e.stopPropagation();
            birthForm.classList.add('was-validated');
        
            if (!birthForm.checkValidity()) {
                // scroll to first invalid field
                const firstInvalid = birthForm.querySelector(':invalid');
                if (firstInvalid) {
                    firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    firstInvalid.focus({ preventScroll: true });
                }
                return;
            }
        
            if(loader) loader.classList.remove('d-none');
            showAlert('info','⏳ Processing...');
        
            const formData = new FormData(birthForm);
            try {
                const res = await fetch(birthForm.action, { 
                    method:'POST', 
                    headers:{'X-Requested-With':'XMLHttpRequest'}, 
                    body: formData 
                });
                const json = await res.json();
                if (json.alert) showAlert(json.alert.type, json.alert.message);
                if (json.pdf_url) window.open(json.pdf_url, '_blank');
            } catch(err) {
                showAlert('danger', `⚠️ Network error: ${err.message}`);
            } finally {
                if(loader) loader.classList.add('d-none');
            }
        });
    }
});
</script>

<script>
document.addEventListener('DOMContentLoaded', async () => {

    // ------------------------
    // Utility Functions
    // ------------------------
    const sleep = (ms) => new Promise(r => setTimeout(r, ms));
    const normalize = (s='') => String(s).replace(/\s+/g,' ').trim().toLowerCase();
    const showLoading = (select) => { if(select) select.innerHTML = '<option value="">লোড হচ্ছে...</option>'; };

    const getCsrfToken = () => {
        const meta = document.querySelector('meta[name="csrf_token"]');
        return meta ? meta.content : '';
    };

    // ------------------------
    // Fetch Geo Data (FormData + CSRF)
    // ------------------------
    const fetchGeoData = async (order, parent) => {
        try {
            const fd = new FormData();
            fd.append("geo_order", order);
            fd.append("parent_geo_id", parent);
            fd.append("csrf_token", getCsrfToken());

            const res = await fetch("/geo/getdata", { method: "POST", body: fd });
            if (!res.ok) throw new Error('Network error');
            const json = await res.json();
            return json.data || json || [];
        } catch (err) {
            console.error("Geo Load Error:", err);
            return [];
        }
    };

    // ------------------------
    // Populate Dropdown
    // ------------------------
    const populateDropdown = (select, data, prefill='') => {
        if(!select) return;
        select.innerHTML = '<option value="">চিহ্নিত করুন</option>';

        data.forEach(item => {
            const opt = document.createElement('option');
            opt.value = (item.name_en || '').trim();
            opt.textContent = `${item.name_en || ''} / ${item.name_bn || ''}`;
            opt.dataset.geoId  = item.id ?? '';
            opt.dataset.nameBn = item.name_bn || '';
            select.appendChild(opt);
        });

        if(prefill) {
            for(const opt of select.options){
                if(!opt.value) continue;
                if(normalize(opt.value) === normalize(prefill) || normalize(opt.dataset.nameBn||'') === normalize(prefill)){
                    opt.selected = true;
                    break;
                }
            }
        }
    };

    const selectOptionByValue = (select, value) => {
        if(!select || !value) return false;
        for(const opt of select.options){
            if(!opt.value) continue;
            if(normalize(opt.value) === normalize(value) || normalize(opt.dataset.nameBn||'') === normalize(value)){
                opt.selected = true;
                return true;
            }
        }
        return false;
    };

    const waitForOptions = async (select, timeout=3000, interval=100) => {
        if(!select) return false;
        const start = Date.now();
        while(Date.now() - start < timeout){
            if(select.options && select.options.length > 1) return true;
            await sleep(interval);
        }
        return false;
    };

    // ------------------------
    // Cascade Setup
    // ------------------------
    function setupCascade(districtId, upazilaId=null, unionId=null, hiddenDistrictBn=null, hiddenUpazilaBn=null, hiddenUnionBn=null, officeNameInput=null){

        const district  = districtId ? document.getElementById(districtId) : null;
        const upazila   = upazilaId ? document.getElementById(upazilaId) : null;
        const union     = unionId ? document.getElementById(unionId) : null;

        const hdBn      = hiddenDistrictBn ? document.getElementById(hiddenDistrictBn) : null;
        const huBn      = hiddenUpazilaBn ? document.getElementById(hiddenUpazilaBn) : null;
        const huUnionBn = hiddenUnionBn ? document.getElementById(hiddenUnionBn) : null;

        const officeInput = officeNameInput ? document.getElementById(officeNameInput) : null;

        const ensureDistrictsLoaded = async () => {
            if(!district) return;
            if(!district.options || district.options.length <= 1){
                showLoading(district);
                const list = await fetchGeoData(1, 0);
                populateDropdown(district, list);
                await waitForOptions(district, 2000);
            }
        };

        const updateUpazila = async (districtValue, prefillUpazila='') => {
            if(!districtValue || !district) return;
            await ensureDistrictsLoaded();
            selectOptionByValue(district, districtValue);

            const selOpt = district.selectedOptions[0];
            const parentId = selOpt?.dataset?.geoId || '';
            if(hdBn) hdBn.value = selOpt?.dataset?.nameBn || '';

            if(upazila){
                showLoading(upazila);
                const data = await fetchGeoData(2, parentId);
                populateDropdown(upazila, data, prefillUpazila);
                await waitForOptions(upazila, 2500);
                if(prefillUpazila) selectOptionByValue(upazila, prefillUpazila);
                if(huBn) huBn.value = upazila.selectedOptions[0]?.dataset?.nameBn || '';

                if(union) union.innerHTML = '<option value="">চিহ্নিত করুন</option>';
                if(huUnionBn) huUnionBn.value = '';
                if(officeInput) officeInput.value = '';
            }
        };

        const updateUnion = async (upazilaValue, prefillUnion='') => {
            if(!upazilaValue || !upazila) return;
            await waitForOptions(upazila, 3000);
            selectOptionByValue(upazila, upazilaValue);

            const selOpt = upazila.selectedOptions[0];
            const parentId = selOpt?.dataset?.geoId || '';
            if(huBn) huBn.value = selOpt?.dataset?.nameBn || '';

            if(union){
                showLoading(union);
                const data = await fetchGeoData(3, parentId);
                populateDropdown(union, data, prefillUnion);
                await waitForOptions(union, 3000);
                if(prefillUnion) selectOptionByValue(union, prefillUnion);
                if(huUnionBn) huUnionBn.value = union.selectedOptions[0]?.dataset?.nameBn || '';
            }

            if(officeInput && selOpt) officeInput.value = selOpt?.dataset?.nameBn || '';
        };

        if(district){
            district.addEventListener('change', async () => {
                if(district.value) await updateUpazila(district.value);
            });
        }

        if(upazila){
            upazila.addEventListener('change', async () => {
                if(upazila.value){
                    await updateUnion(upazila.value);
                    if(huBn) huBn.value = upazila.selectedOptions[0]?.dataset?.nameBn || '';
                    if(officeInput) officeInput.value = upazila.selectedOptions[0]?.dataset?.nameBn || '';
                }
            });
        }

        const prefillCascade = async(prefillDistrict='', prefillUpazila='', prefillUnion='') => {
            await ensureDistrictsLoaded();
            if(district) await updateUpazila(prefillDistrict || district.value || '', prefillUpazila);
            if(upazila) await updateUnion(prefillUpazila || upazila.value || '', prefillUnion);

            if(hdBn && district?.selectedOptions[0]) hdBn.value = district.selectedOptions[0].dataset.nameBn || '';
            if(huBn && upazila?.selectedOptions[0])  huBn.value = upazila.selectedOptions[0].dataset.nameBn || '';
            if(huUnionBn && union?.selectedOptions[0]) huUnionBn.value = union.selectedOptions[0].dataset.nameBn || '';
        };

        return { prefillCascade, updateUpazila, updateUnion };
    }

    // ------------------------
    // Initialize Cascades
    // ------------------------
    window.officeCascade = setupCascade(
        'district_office_en',
        'upazila_office_en',
        'union_office_en',
        'district_office_bn',
        'upazila_office_bn',
        'union_office_bn'
    );

    window.birthCascade = setupCascade(
        'district_en',
        'upazila_en',
        'union_en',
        'district_bn',
        'upazila_bn',
        'union_bn'
    );

    // ------------------------
    // Prefill Birth
    // ------------------------
    (async () => {
        if(window.birthCascade){
            await window.birthCascade.prefillCascade(
                "{{ birth.district_en|default('')|trim }}",
                "{{ birth.upazila_en|default('')|trim }}",
                "{{ birth.union_en|default('')|trim }}"
            );
        }
    })();

    // ------------------------
    // Prefill Office
    // ------------------------
    (async () => {
        if(window.officeCascade){
            await window.officeCascade.prefillCascade(
                "{{ birth.district_office_en|default('')|trim }}",
                "{{ birth.upazila_office_en|default('')|trim }}",
                "{{ birth.union_office_en|default('')|trim }}"
            );
        }
    })();

});
</script>







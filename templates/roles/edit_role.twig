{% extends 'layout.twig' %}

{% block title %}Edit Role{% endblock %}
{% block header_title %}{{ header_title|default('Edit Role') }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container mt-4">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark">
          <h4 class="mb-0"><i class="fas fa-user-shield"></i> Edit Role</h4>
        </div>
        <div class="card-body">
          <div class="alert alert-info mb-3">
            <i class="fas fa-info-circle"></i>
            <strong>ID:</strong> {{ role.role_id }} | 
            <strong>Created:</strong> {{ role.created_at|date('M d, Y H:i') }}
          </div>

          <form method="post" action="/roles/{{ role.role_id }}/edit">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />

            <div class="mb-3">
              <label for="name" class="form-label fw-bold">Role Name <span class="text-danger">*</span></label>
              <input class="form-control form-control-lg" 
                     id="name" 
                     name="name" 
                     value="{{ role.role_name|e }}" 
                     maxlength="191"
                     required />
              <small class="form-text text-muted d-block mt-2">
                <i class="fas fa-info-circle"></i>
                Update the role name if needed
              </small>
            </div>

            <div class="mb-3">
              <label for="description" class="form-label fw-bold">Description</label>
              <textarea class="form-control" 
                        id="description" 
                        name="description" 
                        rows="4"
                        maxlength="1000">{{ role.description|e }}</textarea>
              <small class="form-text text-muted d-block mt-2">
                <i class="fas fa-info-circle"></i>
                Update the role description
              </small>
            </div>

            <div class="d-flex gap-2 mt-4">
              <button class="btn btn-warning btn-lg" type="submit">
                <i class="fas fa-save"></i> Update Role
              </button>
              <a href="/roles" class="btn btn-secondary btn-lg">
                <i class="fas fa-times"></i> Cancel
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
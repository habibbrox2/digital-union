{% extends 'layout.twig' %}

{% block title %}ভূমিকা সম্পাদনা{% endblock %}
{% block header_title %}{{ header_title|default('ভূমিকা সম্পাদনা') }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
{% include 'components/rbac_ui.twig' %}
<div class="container-fluid py-4">
    <div class="rbac-header">
        <div>
            <h4><i class="bi bi-pencil-square text-warning me-2"></i>ভূমিকা সম্পাদনা</h4>
            <div class="subtitle">{{ role.role_name|replace({'_':' '})|title }} (আইডি: {{ role.role_id }})</div>
        </div>
        <a href="/roles" class="btn btn-outline-secondary rbac-btn">
            <i class="bi bi-arrow-left me-1"></i> তালিকায় ফিরুন
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="rbac-card p-4">
                <form method="post" action="/roles/{{ role.role_id }}/edit" id="roleForm" novalidate>
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />

                    <div class="mb-3">
                        <label for="name" class="form-label fw-semibold small text-secondary">ভূমিকার নাম <span class="text-danger">*</span></label>
                        <input class="form-control form-control-lg rbac-input"
                               id="name"
                               name="name"
                               value="{{ role.role_name|e }}"
                               maxlength="191"
                               required
                               minlength="2" />
                        <div class="invalid-feedback">ভূমিকার নাম দিন (কমপক্ষে ২ অক্ষর)।</div>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted">প্রয়োজনে ভূমিকার নাম পরিবর্তন করুন</small>
                            <small class="text-muted char-counter" data-target="name">0/191</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label fw-semibold small text-secondary">বিবরণ</label>
                        <textarea class="form-control rbac-input"
                                  id="description"
                                  name="description"
                                  rows="4"
                                  maxlength="1000">{{ role.description|e }}</textarea>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted">ভূমিকার বিবরণ আপডেট করুন</small>
                            <small class="text-muted char-counter" data-target="description">0/1000</small>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button class="btn btn-warning rbac-btn shadow-sm" type="submit">
                            <i class="bi bi-check2-circle me-1"></i> আপডেট করুন
                        </button>
                        <a href="/roles/{{ role.role_id }}" class="btn btn-outline-secondary rbac-btn">
                            <i class="bi bi-x-circle me-1"></i> বাতিল
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="rbac-card p-4">
                <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-info-circle text-info"></i> ভূমিকা সংক্ষিপ্ত
                </h6>
                <ul class="list-unstyled mb-0 small rbac-summary">
                    <li><span class="label">আইডি</span><span class="fw-medium">#{{ role.role_id }}</span></li>
                    <li><span class="label">নাম</span><span class="fw-medium">{{ role.role_name|replace({'_':' '})|title }}</span></li>
                    <li><span class="label">তৈরি</span><span class="fw-medium">{{ role.created_at|date('d-m-Y') }}</span></li>
                </ul>
                <div class="d-grid gap-2 mt-3">
                    <a href="/roles/{{ role.role_id }}/permissions" class="btn btn-outline-primary rbac-btn">
                        <i class="bi bi-key me-1"></i> অনুমতি পরিচালনা
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('roleForm');
    if (!form) return;
    document.querySelectorAll('.char-counter').forEach(function (counter) {
        const el = document.getElementById(counter.dataset.target);
        if (!el) return;
        const update = () => counter.textContent = `${el.value.length}/${el.maxLength}`;
        el.addEventListener('input', update);
        update();
    });
    form.addEventListener('submit', function (e) {
        if (!form.checkValidity()) {
            e.preventDefault();
            e.stopPropagation();
            form.classList.add('was-validated');
        }
    });
});
</script>
{% endblock %}

{# templates/roles/manage_permissions.twig #}
{% extends 'layout.twig' %}

{% block title %}{{ role.role_name }} এর অনুমতি পরিচালনা{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
{% include 'components/rbac_ui.twig' %}
<div class="container-fluid py-4">
    <div class="rbac-header">
        <div>
            <h4><i class="bi bi-key text-primary me-2"></i>অনুমতি নির্ধারণ</h4>
            <div class="subtitle">ভূমিকা: <strong>{{ role.role_name }}</strong></div>
        </div>
        <a href="/roles" class="btn btn-outline-secondary rbac-btn">
            <i class="bi bi-arrow-left me-1"></i> ভূমিকায় ফিরুন
        </a>
    </div>

    <div class="rbac-card">
        <div class="d-flex align-items-center justify-content-between p-3 border-bottom flex-wrap gap-2">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-list-check text-primary me-2"></i>{{ role.role_name }} এর জন্য অনুমতি নির্বাচন
            </h5>
            <span class="badge rounded-pill rbac-badge-primary" id="selected-count">০ নির্বাচিত</span>
        </div>

        <div class="p-4">
            <!-- Loader -->
            <div id="permissions-loader" class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">লোড হচ্ছে...</span>
                </div>
                <p class="mt-3 text-muted">অনুমতিসমূহ লোড হচ্ছে...</p>
            </div>

            <!-- Container -->
            <div id="permissions-container" style="display: none;">
                <div class="input-group mb-3 shadow-sm">
                    <span class="input-group-text bg-white">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" id="permission-search" class="form-control rbac-input border-start-0" placeholder="নাম বা মডিউল দিয়ে খুঁজুন...">
                    <button class="btn btn-outline-secondary" type="button" id="permission-clear" title="মুছুন">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <form id="permissions-form" method="POST" action="/roles/{{ role.role_id }}/permissions">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="permissions_json" id="permissions_json">

                    <div class="table-responsive">
                        <table class="table table-hover align-middle" id="permissions-table">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 5%">
                                        <input type="checkbox" id="select-all" class="form-check-input rbac-perm-check" aria-label="সব নির্বাচন">
                                    </th>
                                    <th style="width: 22%">অনুমতির নাম</th>
                                    <th style="width: 15%">মডিউল</th>
                                    <th style="width: 58%">বিবরণ</th>
                                </tr>
                            </thead>
                            <tbody id="permissions-body"></tbody>
                        </table>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-success rbac-btn shadow-sm">
                            <i class="bi bi-check2-circle me-1"></i> অনুমতি সংরক্ষণ
                        </button>
                        <a href="/roles" class="btn btn-outline-secondary rbac-btn">
                            <i class="bi bi-x-circle me-1"></i> বাতিল
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const roleId = {{ role.role_id }};
    const loader = document.getElementById('permissions-loader');
    const container = document.getElementById('permissions-container');
    const tbody = document.getElementById('permissions-body');
    const form = document.getElementById('permissions-form');
    const searchInput = document.getElementById('permission-search');
    const clearBtn = document.getElementById('permission-clear');
    const selectAllCheckbox = document.getElementById('select-all');
    const permissionsJsonInput = document.getElementById('permissions_json');
    const selectedCountBadge = document.getElementById('selected-count');

    fetch(`/api/roles/${roleId}/permissions`)
        .then(response => response.json())
        .then(data => {
            renderPermissions(data);
            loader.style.display = 'none';
            container.style.display = 'block';
        })
        .catch(error => {
            loader.innerHTML = '<div class="alert alert-danger">অনুমতি লোড করা যায়নি</div>';
            console.error('Error loading permissions:', error);
        });

    function renderPermissions(permissions) {
        tbody.innerHTML = '';
        if (!permissions.length) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">কোনো অনুমতি পাওয়া যায়নি।</td></tr>';
            updateSelectedCount();
            return;
        }
        permissions.forEach((perm) => {
            const tr = document.createElement('tr');
            tr.className = 'permission-row';
            tr.innerHTML = `
                <td>
                    <input type="checkbox" class="form-check-input permission-checkbox rbac-perm-check"
                           value="${perm.id}" data-perm-id="${perm.id}"
                           ${perm.assigned ? 'checked' : ''}>
                </td>
                <td class="fw-bold text-primary">${perm.name}</td>
                <td><span class="badge rounded-pill rbac-badge-light">${perm.module}</span></td>
                <td><small class="text-muted">${perm.description || '(বিবরণ নেই)'}</small></td>
            `;
            tbody.appendChild(tr);
        });
        updateSelectAllState();
        updateSelectedCount();
    }

    function updateSelectedCount() {
        const checked = document.querySelectorAll('.permission-checkbox:checked').length;
        selectedCountBadge.textContent = `${checked} নির্বাচিত`;
    }

    function updateSelectAllState() {
        const checkboxes = document.querySelectorAll('.permission-checkbox');
        const checkedCount = document.querySelectorAll('.permission-checkbox:checked').length;
        selectAllCheckbox.checked = checkedCount === checkboxes.length && checkboxes.length > 0;
        selectAllCheckbox.indeterminate = checkedCount > 0 && checkedCount < checkboxes.length;
    }

    selectAllCheckbox.addEventListener('change', function() {
        document.querySelectorAll('.permission-checkbox').forEach(cb => cb.checked = this.checked);
        updateSelectAllState();
        updateSelectedCount();
    });

    tbody.addEventListener('change', function(e) {
        if (e.target.classList.contains('permission-checkbox')) {
            updateSelectAllState();
            updateSelectedCount();
        }
    });

    function applySearch() {
        const query = searchInput.value.toLowerCase();
        document.querySelectorAll('.permission-row').forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(query) ? '' : 'none';
        });
    }
    searchInput.addEventListener('input', applySearch);
    clearBtn.addEventListener('click', function() {
        searchInput.value = '';
        applySearch();
        searchInput.focus();
    });

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        const checkedBoxes = document.querySelectorAll('.permission-checkbox:checked');
        const selectedIds = Array.from(checkedBoxes).map(cb => parseInt(cb.value));
        permissionsJsonInput.value = JSON.stringify(selectedIds);
        form.submit();
    });
});
</script>
{% endblock %}

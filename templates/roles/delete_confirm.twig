{% extends 'layout.twig' %}

{% block title %}Delete Role - Confirmation{% endblock %}
{% block header_title %}{{ header_title|default('Delete Role - Confirmation') }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container mt-4">
  <div class="row">
    <div class="col-md-6 offset-md-3">
      <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">
          <h4 class="mb-0"><i class="fas fa-trash"></i> Delete Role - Confirm</h4>
        </div>
        <div class="card-body">
          <div class="alert alert-warning mb-4">
            <i class="fas fa-exclamation-triangle"></i> <strong>WARNING:</strong> This action cannot be undone!
          </div>

          <div class="mb-4">
            <p class="fw-bold">Role to delete:</p>
            <ul class="list-unstyled ps-3">
              <li class="mb-2"><strong>ID:</strong> <span class="badge bg-secondary">{{ role.role_id }}</span></li>
              <li class="mb-2"><strong>Name:</strong> {{ role.role_name|e }}</li>
              <li class="mb-2"><strong>Description:</strong> {{ role.description|e }}</li>
              <li class="mb-2"><strong>Created:</strong> {{ role.created_at|date('M d, Y H:i') }}</li>
            </ul>
          </div>

          <p class="text-muted mb-4">
            <i class="fas fa-info-circle"></i>
            Are you sure you want to delete this role? This will remove role assignments from all users.
          </p>

          <form method="post" action="/roles/{{ role.role_id }}/delete">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />
            
            <div class="d-flex gap-2">
              <button class="btn btn-danger btn-lg" type="submit">
                <i class="fas fa-trash"></i> Yes, Delete Role
              </button>
              <a href="/roles" class="btn btn-secondary btn-lg">
                <i class="fas fa-arrow-left"></i> Cancel
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
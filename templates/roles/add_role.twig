{% extends 'layout.twig' %}

{% block title %}Create New Role{% endblock %}
{% block header_title %}{{ header_title|default('Create New Role') }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
<div class="container mt-4">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-success text-white">
          <h4 class="mb-0"><i class="fas fa-user-shield"></i> Create New Role</h4>
        </div>
        <div class="card-body">
          <form method="post" action="/roles/add">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />

            {% if templates|length > 0 %}
            <div class="mb-3">
              <label for="template_id" class="form-label fw-bold">Use Template (Optional)</label>
              <select class="form-select form-select-lg" 
                      id="template_id" 
                      name="template_id"
                      onchange="updateTemplateInfo()">
                <option value="">-- Create Manually --</option>
                {% for template in templates %}
                <option value="{{ template.id }}" data-permissions="{{ template.permission_count }}">
                  {{ template.name }} ({{ template.permission_count }} permissions)
                </option>
                {% endfor %}
              </select>
              <small class="form-text text-muted d-block mt-2">
                <i class="fas fa-info-circle"></i>
                Select a template to automatically assign its permissions to this role
              </small>
              <div id="template-info" class="alert alert-info mt-2" style="display: none;">
                <strong>Template Info:</strong> <span id="template-desc"></span>
              </div>
            </div>
            {% endif %}

            <div class="mb-3">
              <label for="name" class="form-label fw-bold">Role Name <span class="text-danger">*</span></label>
              <input class="form-control form-control-lg" 
                     id="name" 
                     name="name" 
                     placeholder="e.g., Editor, Moderator" 
                     maxlength="191"
                     value="{{ form_data.name|default('') }}"
                     required />
              <small class="form-text text-muted d-block mt-2">
                <i class="fas fa-info-circle"></i>
                Unique identifier for this role (2-191 characters)
              </small>
            </div>

            <div class="mb-3">
              <label for="description" class="form-label fw-bold">Description</label>
              <textarea class="form-control" 
                        id="description" 
                        name="description" 
                        rows="4" 
                        placeholder="What is the purpose of this role?"
                        maxlength="1000">{{ form_data.description|default('') }}</textarea>
              <small class="form-text text-muted d-block mt-2">
                <i class="fas fa-info-circle"></i>
                Explain what permissions this role will have
              </small>
            </div>

            <div class="d-flex gap-2 mt-4">
              <button class="btn btn-success btn-lg" type="submit">
                <i class="fas fa-plus"></i> Create Role
              </button>
              <a href="/roles" class="btn btn-secondary btn-lg">
                <i class="fas fa-times"></i> Cancel
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function updateTemplateInfo() {
  const select = document.getElementById('template_id');
  const infoDiv = document.getElementById('template-info');
  const infoSpan = document.getElementById('template-desc');
  
  if (select.value) {
    const option = select.options[select.selectedIndex];
    const permissions = option.dataset.permissions;
    infoSpan.textContent = `This template includes ${permissions} permissions.`;
    infoDiv.style.display = 'block';
  } else {
    infoDiv.style.display = 'none';
  }
}
</script>
{% endblock %}


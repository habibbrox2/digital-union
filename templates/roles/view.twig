{% extends 'layout.twig' %}

{% block title %}ভূমিকা: {{ role.role_name }}{% endblock %}
{% block header_title %}{{ header_title|default(role.role_name) }}{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
{% include 'components/rbac_ui.twig' %}
<div class="container-fluid py-4">
    <div class="rbac-header">
        <div>
            <h4>
                <i class="bi bi-person-badge text-primary me-2"></i>{{ role.role_name|replace({'_':' '})|title }}
            </h4>
            <div class="subtitle">ভূমিকার বিস্তারিত ও নির্ধারিত অনুমতিসমূহ</div>
        </div>
        <a href="/roles" class="btn btn-outline-secondary rbac-btn">
            <i class="bi bi-arrow-left me-1"></i> তালিকায় ফিরুন
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="rbac-card">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 p-3 border-bottom">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-card-text text-primary me-2"></i>তথ্য</h5>
                    <span class="badge rounded-pill rbac-badge-primary">
                        <i class="bi bi-key me-1"></i>{{ permissionCount }}টি অনুমতি
                    </span>
                </div>
                <div class="p-4">
                    <div class="mb-4">
                        <div class="text-muted small text-uppercase fw-bold mb-1">বিবরণ</div>
                        <p class="mb-0">{{ role.description|default('কোনো বিবরণ দেওয়া হয়নি।') }}</p>
                    </div>

                    <div class="text-muted small text-uppercase fw-bold mb-3">নির্ধারিত অনুমতিসমূহ</div>
                    {% if permissions is empty %}
                        <div class="alert alert-light border mb-0">
                            <i class="bi bi-info-circle me-2"></i>এই ভূমিকায় এখনও কোনো অনুমতি নির্ধারণ করা হয়নি।
                        </div>
                    {% else %}
                        <div class="row g-2">
                            {% for p in permissions %}
                                <div class="col-12 col-md-6">
                                    <div class="rbac-pill">
                                        <i class="bi bi-shield-check pill-icon"></i>
                                        <div>
                                            <span class="fw-semibold">{{ p.name }}</span>
                                            <span class="badge rounded-pill rbac-badge-light ms-1">{{ p.module }}</span>
                                            {% if p.description %}
                                                <small class="d-block text-muted mt-1">{{ p.description }}</small>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <a href="/roles/{{ role.role_id }}/permissions" class="btn btn-primary rbac-btn">
                            <i class="bi bi-key me-1"></i> অনুমতি পরিচালনা
                        </a>
                        <a href="/roles/edit/{{ role.role_id }}" class="btn btn-outline-warning rbac-btn">
                            <i class="bi bi-pencil me-1"></i> সম্পাদনা
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="rbac-card p-4">
                <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-info-circle text-info"></i> সারসংক্ষেপ
                </h6>
                <ul class="list-unstyled mb-0 small rbac-summary">
                    <li><span class="label">আইডি</span><span class="fw-medium">#{{ role.role_id }}</span></li>
                    <li><span class="label">নাম</span><span class="fw-medium">{{ role.role_name|replace({'_':' '})|title }}</span></li>
                    <li><span class="label">অনুমতি</span><span class="fw-medium">{{ permissionCount }}টি</span></li>
                    <li><span class="label">তৈরি</span><span class="fw-medium">{{ role.created_at|date('d-m-Y') }}</span></li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% extends "layout.twig" %}

{% block title %}ভূমিকা ব্যবস্থাপনা{% endblock %}

{% block content %}
{% include 'components/sweetAlert.twig' %}
{% include 'components/rbac_ui.twig' %}
<div class="container-fluid py-4">

    <!-- Header -->
    <div class="rbac-header">
        <div>
            <h4>
                <i class="bi bi-people-fill text-primary me-2"></i>ভূমিকা ব্যবস্থাপনা
            </h4>
            <div class="subtitle">সিস্টেমের ভূমিকা ও অনুমতি পরিচালনা করুন</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="/roles/add" class="btn btn-success rbac-btn shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> নতুন ভূমিকা
            </a>
            <a href="/permissions/assign" class="btn btn-info rbac-btn">
                <i class="bi bi-link-45deg me-1"></i> অনুমতি
            </a>
            <a href="/manage-permissions" class="btn btn-primary rbac-btn">
                <i class="bi bi-sliders me-1"></i> ব্যবস্থাপনা
            </a>
        </div>
    </div>

    <!-- Stat cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="rbac-card rbac-stat p-3 d-flex align-items-center gap-3">
                <div class="rbac-stat-icon rbac-badge-primary"><i class="bi bi-people"></i></div>
                <div>
                    <div class="text-muted small">মোট ভূমিকা</div>
                    <div class="fs-4 fw-bold mb-0">{{ roles|length }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rbac-card rbac-stat p-3 d-flex align-items-center gap-3">
                <div class="rbac-stat-icon rbac-badge-info"><i class="bi bi-key"></i></div>
                <div>
                    <div class="text-muted small">মোট অনুমতি</div>
                    <div class="fs-4 fw-bold mb-0">{{ total_permissions|default('-') }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rbac-card rbac-stat p-3 d-flex align-items-center gap-3">
                <div class="rbac-stat-icon rbac-badge-warning"><i class="bi bi-link-45deg"></i></div>
                <div>
                    <div class="text-muted small">অনুমতি নির্ধারণ</div>
                    <a href="/permissions/assign" class="fw-bold text-decoration-none">যান →</a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rbac-card rbac-stat p-3 d-flex align-items-center gap-3">
                <div class="rbac-stat-icon rbac-badge-success"><i class="bi bi-sliders"></i></div>
                <div>
                    <div class="text-muted small">উন্নত ব্যবস্থাপনা</div>
                    <a href="/manage-permissions" class="fw-bold text-decoration-none">যান →</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Roles table -->
    <div class="rbac-card">
        <div class="d-flex align-items-center justify-content-between p-3 border-bottom">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-list-ul text-primary me-2"></i>সিস্টেম ভূমিকাসমূহ
            </h5>
            <span class="badge rounded-pill rbac-badge-light">{{ roles|length }} ভূমিকা</span>
        </div>

        {% if roles is empty %}
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                <div class="text-muted">কোনো ভূমিকা পাওয়া যায়নি।</div>
                <a href="/roles/add" class="btn btn-primary rbac-btn mt-3">
                    <i class="bi bi-plus-lg me-1"></i> নতুন ভূমিকা তৈরি করুন
                </a>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 rbac-table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 8%;">আইডি</th>
                            <th style="width: 22%;">ভূমিকার নাম</th>
                            <th style="width: 35%;">বিবরণ</th>
                            <th style="width: 20%; text-align: center;">পদক্ষেপ</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for role in roles %}
                            {% if role.role_name|lower not in ['admin', 'superadmin', 'administrator', 'root', 'system admin', 'master admin', 'god mode', 'chief admin', 'global admin', 'platform admin'] %}
                                <tr>
                                    <td><span class="badge rounded-pill rbac-badge-primary">{{ role.role_id }}</span></td>
                                    <td><strong>{{ role.role_name|replace({'_':' '})|title }}</strong></td>
                                    <td>
                                        {% if role.description %}
                                            <small class="text-muted">{{ role.description[:60] ~ (role.description|length > 60 ? '…' : '') }}</small>
                                        {% else %}
                                            <span class="badge rounded-pill rbac-badge-light">বিবরণ নেই</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="/roles/{{ role.role_id }}/permissions" class="btn btn-info" title="অনুমতি নির্ধারণ" data-bs-toggle="tooltip">
                                                <i class="bi bi-key"></i>
                                            </a>
                                            <a href="/roles/edit/{{ role.role_id }}" class="btn btn-warning" title="সম্পাদনা" data-bs-toggle="tooltip">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="/roles/delete/{{ role.role_id }}" class="btn btn-danger" title="মুছুন" data-bs-toggle="tooltip">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
            new bootstrap.Tooltip(el);
        });
    }
});
</script>
{% endblock %}

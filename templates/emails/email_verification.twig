{% extends "layout.twig" %}


{% block content %}
<div class="header">
    <h1>আপনার ইমেইল যাচাই করুন ✓</h1>
    <p>আপনার অ্যাকাউন্ট সক্রিয় করতে একটি সহজ পদক্ষেপ</p>
</div>

<div class="content">
    <p>প্রিয় {{ username | default('ব্যবহারকারী') }},</p>

    <p>আপনার অ্যাকাউন্ট সফলভাবে তৈরি করা হয়েছে। এখন আপনার ইমেইল যাচাই করুন এবং লগইন করুন।</p>

    <div class="button-container">
        <a href="{{ verification_link }}" class="button">ইমেইল যাচাই করুন</a>
    </div>

    <p style="text-align: center; color: #666; font-size: 13px;">
        উপরের বোতামটি কাজ না করলে, এই লিঙ্কটি আপনার ব্রাউজারে পেস্ট করুন:<br>
        <code style="word-break: break-all;">{{ verification_link }}</code>
    </p>

    <div class="alert alert-info">
        <strong>নোট:</strong> এই লিংকটি {{ expiry_hours | default(24) }} ঘন্টার জন্য বৈধ।
    </div>

    <p>আপনি এই অনুরোধ করেননি? তাহলে এই ইমেইল উপেক্ষা করুন।</p>

    <p>ধন্যবাদ,<br>
    {{ mail_from_name | default('লগ ধাকা') }} টিম</p>
</div>
{% endblock %}
